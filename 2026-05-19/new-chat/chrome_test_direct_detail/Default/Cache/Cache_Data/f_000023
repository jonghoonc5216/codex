/* swiper autoplay */
.swiper-container.autoplay {clear: both; margin: 0; padding: 3.6rem 0 0 0;}
.swiper-container.autoplay:before {content: ""; position: absolute; top: 3.6rem; left: 0; right: 0; bottom: 0; background-color: #ffffff; border: 0.1rem solid #e1e1e2;
    border-radius: 0.4rem;}
.swiper-container.autoplay .ctrl-box {position: absolute; top: 0rem; left: auto; right: 4.0rem; width: 14.8rem; height: 2.4rem;}
.swiper-container.autoplay .ctrl-box .swiper-pagination-fraction {width: auto; top: 0; left: 0;}
.swiper-container.autoplay .ctrl-box .swiper-button-prev,
.swiper-container.autoplay .ctrl-box .swiper-button-next {top: 0; left: auto; right: auto; width: 2.4rem; height: 2.4rem; margin-top: 0; background-size: 1.2rem;}
.swiper-container.autoplay .ctrl-box .swiper-button-prev {left: 4.2rem; background: url(/kn/com/images/portal/gnb/ic_arr_nav_left.svg) no-repeat center; background-size: 1.2rem;}
.swiper-container.autoplay .ctrl-box .swiper-button-next {left: 6.8rem;background: url(/kn/com/images/portal/gnb/ic_arr_nav_right.svg) no-repeat center; background-size: 1.2rem;}
.swiper-container.autoplay .ctrl-box .autoplay-control-wrap {position: absolute; right: 0; top: 0; cursor: pointer; z-index: 1;}
.swiper-container.autoplay .ctrl-box .autoplay-control-wrap .btn.stop {
    position: relative;
    width: 4.0rem;
    height: 2.3rem;
    color: transparent;
    font-size: 0;
    border-radius: 5.0rem;
    background-color: rgba(67, 100, 247, 0.2);
}
.swiper-container.autoplay .ctrl-box .autoplay-control-wrap .btn.stop:before,
.swiper-container.autoplay .ctrl-box .autoplay-control-wrap .btn.stop:after {content: ""; position: absolute; top: 0.5rem; transition: all 0.4s;}
.swiper-container.autoplay .ctrl-box .autoplay-control-wrap .btn.stop:before {
    left: 0.5rem;
    width: 1.3rem;
    height: 1.3rem;
    background-color: #4364f7;
    border-radius: 50%;
}

.swiper-container.autoplay .ctrl-box .autoplay-control-wrap .btn.stop:after {
    top: 0.7rem;
    left: auto;
    right: 0.9rem;
    width: 0.4rem;
    height: 0.9rem;
    background-color: transparent;
    border: 0.1rem solid rgba(0, 0, 0, 0.2);
    border-width: 0 0.1rem 0 0.1rem;
}

.swiper-container.autoplay .ctrl-box .autoplay-control-wrap .btn.stop.active:before {background-color: rgba(0, 0, 0, 0.16);}
.swiper-container.autoplay .ctrl-box .autoplay-control-wrap .btn.stop.active:after {border: 0.1rem solid #4364f7; border-width: 0 0.1rem 0 0.1rem;}
.swiper-container.autoplay .swiper-wrapper .swiper-slide {font-size: 1.6rem; padding:  2.2rem 2.6rem; box-sizing: border-box;}
.swiper-container.autoplay .swiper-wrapper .swiper-slide .banner-wrap {width: 100%; height: 100%;}

.swiper-container.autoplay .banner-wrap {background: url(/kn/com/images/portal/main/family.svg) no-repeat right 0rem bottom 0rem;padding-top: 1.2rem;}
.swiper-container.autoplay .banner-wrap.stock {background: url(/kn/com/images/portal/main/stock.svg) no-repeat right 0rem bottom 0rem;}
.swiper-container.autoplay .banner-wrap.estate_search {background: url(/kn/com/images/portal/main/estate_search.svg) no-repeat right 0rem bottom 0rem;}
.swiper-container.autoplay .banner-wrap.it-service {background: url(/kn/com/images/portal/main/office.svg) no-repeat right 0rem bottom 0rem;}

.swiper-container.autoplay .banner-wrap .title {display: inline-block; color: #4876ef; font-size: 2.0rem; font-weight: 500; padding-top: 3.2rem; border-bottom: 0.1rem solid #4876ef;}
.swiper-container.autoplay .banner-wrap .txt-content {width: auto; padding: 2.0rem 2.0rem 0; text-align: center;}

.swiper-container.autoplay.sub:before {border: 0;}
.swiper-container.autoplay.sub .swiper-wrapper .swiper-slide {padding: 0;}
.swiper-container.autoplay.sub .banner-wrap .title {float: left; font-size: 2.5rem; padding: 0; line-height: 1.2;}
.swiper-container.autoplay.sub .banner-wrap .title ~ .title {margin-top: 0.6rem;}
.swiper-container.autoplay.sub .banner-wrap .title.br {clear: both;}
.swiper-container.autoplay.sub .banner-wrap .txt-content {padding: 9.2rem 0 0 0; text-align: left;}
.swiper-container.autoplay.sub .banner-wrap .txt-content .br {display: inline-block; width: 100%;}
.swiper-container.autoplay.sub .banner-wrap .txt-content .font_lg {font-size: 2.0rem; font-weight: 700;}


