/* 메인디자인 D타입 - swiper 최상단 배너영역 */
.swiper-container.banner {position: absolute; top: 0; left: 0;width: 100%; color: #ffffff;}
.swiper-container.banner .swiper-wrapper li {height: 41.8rem;}
.swiper-container.banner .swiper-wrapper li:nth-of-type(1) {background: linear-gradient(to right, #4aa8f1 0%, #4876ef 100%);}
.swiper-container.banner .swiper-wrapper li:nth-of-type(2) {background: linear-gradient(to right, #3a5fed 0%, #08f59c 100%);}
.swiper-container.banner .swiper-wrapper li:nth-of-type(3) {background: linear-gradient(to right, #8cec85 0%, #0dabd2 100%);}
.swiper-container.banner .swiper-wrapper li:nth-of-type(4) {background: linear-gradient(to right, #0ba1c9 0%, #a096fe 100%);}
.swiper-container.banner .swiper-wrapper li:nth-of-type(5) {background: linear-gradient(to right, #fa6170 0%, #f9aa89 100%);}
.swiper-container.banner .swiper-wrapper li:nth-of-type(6) {background: linear-gradient(to right, #fc7a8a 0%, #9db9f1 100%);}
.swiper-container.banner .swiper-wrapper > li > div{padding:20px;}
.swiper-container.banner .swiper-wrapper > li .banner-wrap {width: 100%; height: 100%; box-sizing: border-box;}
.swiper-container.banner .swiper-wrapper > li:nth-of-type(1) .banner-wrap {
    background: url(/kn/com/images/portal/main/people_type1.svg) no-repeat 15% 7.6rem,
    url(/kn/com/images/portal/main/bg_left_btm.svg) no-repeat left 0 bottom 0, url(/kn/com/images/portal/main/bg_right_btm.svg) no-repeat right 0 top 0; /* url(/kn/com/images/portal/main/people_type1.svg) no-repeat 25.8rem 7.6rem,  */}

.swiper-container.banner .swiper-wrapper > li:nth-of-type(2) .banner-wrap {
    background: url(/kn/com/images/portal/main/people_type2.svg) no-repeat 15% 7.6rem,
    url(/kn/com/images/portal/main/bg_left_btm2.svg) no-repeat left 0 bottom 0, url(/kn/com/images/portal/main/bg_right_btm2.svg) no-repeat right 0 top 0;}

.swiper-container.banner .swiper-wrapper > li:nth-of-type(3) .banner-wrap {
    background: url(/kn/com/images/portal/main/people_type3.svg) no-repeat 15% 7.6rem,
    url(/kn/com/images/portal/main/bg_left_btm3.svg) no-repeat left 0 bottom 0, url(/kn/com/images/portal/main/bg_right_btm3.svg) no-repeat right 0 top 0;}

.swiper-container.banner .swiper-wrapper > li:nth-of-type(4) .banner-wrap {
    background: url(/kn/com/images/portal/main/people_type4.svg) no-repeat 15% 7.6rem,
    url(/kn/com/images/portal/main/bg_left_btm4.svg) no-repeat left 0 bottom 0, url(/kn/com/images/portal/main/bg_right_btm4.svg) no-repeat right 0 top 0;}

.swiper-container.banner .swiper-wrapper > li:nth-of-type(5) .banner-wrap {
    background: url(/kn/com/images/portal/main/people_type5.svg) no-repeat 15% 7.6rem,
    url(/kn/com/images/portal/main/bg_left_btm5.svg) no-repeat left 0 bottom 0, url(/kn/com/images/portal/main/bg_right_btm5.svg) no-repeat right 0 top 0;}

.swiper-container.banner .swiper-wrapper > li:nth-of-type(6) .banner-wrap {
    background: url(/kn/com/images/portal/main/people_type6.svg) no-repeat 15% 7.6rem,
    url(/kn/com/images/portal/main/bg_left_btm6.svg) no-repeat left 0 bottom 0, url(/kn/com/images/portal/main/bg_right_btm6.svg) no-repeat right 0 top 0;}

.swiper-container.banner .swiper-pagination-bullets {bottom: 13.6rem;}
.swiper-container.banner >.swiper-pagination-bullets .swiper-pagination-bullet {width: 1.5rem; height: 1.5rem; background-color: rgb(255, 255, 255); opacity:.3; margin: 0 0.5rem;}
.swiper-container.banner >.swiper-pagination-bullets .swiper-pagination-bullet-active{opacity:1}
.swiper-container.banner .swiper-pagination-bullets-dynamic{background:transparent;}

.main-top-wrap {position: relative; padding-top: 12.0rem;}
.main-top-wrap .inner-wrap.top {position: relative; margin-bottom: 2.4rem;}
.main-top-wrap .inner.top-srch {position: relative; z-index: 1;max-width: 90.0rem; margin: 0 auto; margin-bottom: 7.2rem;}
.main-top-wrap .inner.top-srch .ipt-srch {
    width: calc(100% - 25.0rem); height:5.8rem; color: #ffffff; font-size: 1.7rem; border: 0.2rem solid #ffffff;
    border-top-left-radius: 0.4rem; border-bottom-left-radius: 0.4rem; border-top-right-radius: 0; border-bottom-right-radius: 0;
    background-color: transparent; box-shadow: none; margin: 0; padding: 0 2.4rem 0.4rem 2.4rem;}
.main-top-wrap .inner.top-srch .ipt-srch::placeholder {color: #ffffff;}
.main-top-wrap .inner.top-srch .btn.srch {
    width: 5.8rem;
    height: 5.8rem;
    color: transparent;
    font-size: 0;
    background: #ffffff url(/kn/com/images/portal/gnb/ic_search_blue.svg) no-repeat center;
    background-size: 2.5rem;
    border: 0;
    border-top-left-radius: 0rem;
    border-bottom-left-radius: 0rem;
    border-top-right-radius: 0.4rem;
    border-bottom-right-radius: 0.4rem;
}
.main-top-wrap .inner.top-srch .btn.sitemap {
    width: 17.6rem;
    height: 5.8rem;
    color: #ffffff;
    font-size: 1.7rem;
    margin: 0 0 0 1.6rem;
    padding: 0 0 0 5.0rem;
    border: 0.2rem solid #ffffff;
    border-radius: 0.4rem;
    line-height: 52px;
    background: url(/kn/com/images/portal/gnb/ic_ham.svg) no-repeat 1.6rem center;
    background-size: 2.0rem;
}
.main-top-wrap .inner.top-srch .chipbox {color: #ffffff; font-size: 1.4rem; margin-top: 2.0rem; padding: 0 2.4rem;}
.main-top-wrap .inner.top-srch .chipbox span {display: inline-block; width: auto; height: auto; line-height: 3.2rem; margin: 0 1.0rem; background-color: transparent;}
.main-top-wrap .inner.top-srch .chipbox .title {
    font-weight: 500;
    background-color: rgba(255, 255, 255, 33%);
    margin: 0 1.0rem 0 0;
    padding: 0 2.0rem 0.2rem 2.0rem;
    border-radius: 1.8rem;
}
.main-top-wrap .inner-wrap.top .main-custom-service {display: flex; max-width: 146.0rem; margin: 0 auto; padding: 0rem 0.6rem 2.4rem;}
.main-custom-service ul {height: 20.8rem; align-items: center; margin: 0 auto;}
.main-custom-service ul li {
    width: 33.33333% !important;
    /* width: calc(33.33333% - 13.3333px) !important; */
    height: 13.2rem;
    background-color: transparent;
    border-radius: 0.4rem;
    transition: all 0.4s ease;
    box-sizing: border-box;
    padding: 0 1.0rem;
}
.main-custom-service ul li.swiper-slide-active {height: 16.0rem; transform: scale(1.25, 1.25); z-index: 100;}
.main-custom-service ul li.swiper-slide-active .title {height: calc(3.2rem*1.39); font-size: calc(1.2rem*1.32); line-height: 1.9;}
.main-custom-service ul li.swiper-slide-active .inner.content {height: 11.4rem;}
.main-custom-service ul li.swiper-slide-active .inner.content .btn {height: calc(4.8rem*1.32); padding: 4.8rem 1.2rem 0rem 1.2rem; background-color: transparent;}
.main-custom-service ul li.swiper-slide-active .inner.content .btn ~ .btn:before {top: 1.2rem; height: calc(2.6rem*1.16);}
.main-custom-service.swiper-container-horizontal > .swiper-pagination-bullets {bottom: 0;}
.main-custom-service .swiper-pagination-bullet {width: 1.0rem; height: 1.0rem;}
.main-custom-service .swiper-pagination-bullet.swiper-pagination-bullet-active {background-color: #4876ef;}
.main-custom-service .title {
    height: 3.2rem;
    color:#4876ef;
    font-size: 1.2rem;
    font-weight: 500;
    background-color: #f3f4f5;
    border: 0.1rem solid #dededf;
    padding: 0.6rem;
    text-align: center;
    border-top-left-radius: 0.4rem;
    border-top-right-radius: 0.4rem;
    box-shadow: 0 0.3rem 0.6rem rgba(0, 0, 0, 8%);
}
.main-custom-service .inner.content {
    display: flex;
    padding: 2.6rem 1.6rem 2.4rem;
    background-color: #ffffff;
    border: 0.1rem solid #dedfdf;
    border-width: 0 0.1rem 0.1rem 0.1rem;
    border-bottom-left-radius: 0.4rem;
    border-bottom-right-radius: 0.4rem;
    box-shadow: 0 0.3rem 0.6rem rgba(0, 0, 0, 8%);
}
.main-custom-service .inner.content .btn {
    position: relative;
    flex: 1 1 auto;
    height: 4.8rem;
    color: #191919;
    font-size: 1.0rem;
    font-weight: 500;
    padding: 3.2rem 1.2rem 0rem 1.2rem;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    background-repeat: no-repeat;
}
.main-custom-service .inner.content .btn ~ .btn:before {content: ""; position: absolute; top: 0.6rem; left: 0; height: 2.6rem; border-left: 0.1rem solid #cccccc;}
.main-content-wrap, .main-btm-wrap {max-width: 164.0rem; margin: 0 auto; transition: all 0.2s ease-in-out;}
