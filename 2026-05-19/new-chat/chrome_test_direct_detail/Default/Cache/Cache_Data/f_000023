.portal.has-main, .has-main {background-color: #ebecf1;}
.portal.has-main .section.container {padding-bottom: 0; transition: none;}

/* 메인컨테이너 영역 상하 중앙 정렬 flex 효과 적용 */
.has-main .portal {display: flex; flex-direction: column; height: 100%;}
.has-main .portal > div:not(.container-layout) {flex: none;}
.has-main .portal > .container-layout {/*height: calc(100% - 50rem); */ min-height: 62.0rem; display: flex; flex: 1 0 auto; align-items: flex-start;}
.has-main .portal > .container-layout .parent-container {width: 100%; flex: 1 1 100%;}
.has-main .portal .main-cnt-area.guide {padding: 0; min-height: 100%;}
.has-main .portal .w2tabcontrol.main-rtl .w2tabcontrol_container {min-height: 100%;}
.has-main .portal .w2tabcontrol.main-rtl.layout .main-cnt-wrap.cnts-info {padding-bottom: 0;}
.has-main .section.container {padding-bottom: 0;}

.main-area {padding-top: 0rem;}
/* 스크롤링 마우스 아이콘 임시삭제 */
.main-area.scrolling:before {content: none;}

.main-area .section.gnb {position: static; top: auto; left: auto; transform: none;}
.main-area .section.rnb {top: 19.6rem;}
.main-area .section.rnb .tab-item.popup {display: none;}

.main-area .inner.right .user-wrap.before-login {display: inline-block;}
.main-area .inner.right .user-wrap.after-login {display: none;}
.main-area .inner.right .srch-wrap,
