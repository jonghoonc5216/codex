 * @param certDp {string} 업무 구분자
 * @returns returns {string} 인증서
 */
pkiUtil.getKmCert = async function( certDp ) {
    let kmCert = pkiUtil.getEncryptCert(certDp);
    if (kmCert == false) {
        kmCert = await pkiUtil.getSvrKmCert(certDp);
        pkiUtil.setEncryptCert(certDp, kmCert);
    }
    return kmCert;
}

/**
 * 서버 암호화인증서 얻기(서버에서 직접가져오기)
 * @param certDp {string} 업무 구분자
 * @returns returns {string} 인증서
 */
pkiUtil.getSvrKmCert = async function( certDp ) {
    let jsonObject = new Object() ;
    jsonObject.certDp = certDp;

    return new Promise((resolve, reject)=>{
        $.ajax({
            type:"POST",
            url:"/co/coe/coeb/getSvrCertSv.do",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            data: JSON.stringify(jsonObject),
            success: function(resData){
                if(resData.result=="success"){
                    resolve( resData.kmCert );
                } else {
                    resolve( false );
                }
            },
            error : function ( msg ) {
                reject( false );
            }
        });
    });
};

