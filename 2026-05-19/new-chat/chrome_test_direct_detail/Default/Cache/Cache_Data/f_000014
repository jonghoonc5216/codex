/**
 * 입찰대리인 본인확인 처리
 * @returns true : 성공 , false : 실패
 */
pkiUtil.bidUserAuth = async function( ) {
    let rst = await  pkiUtil.isUserAuth();
    if( rst == false ){
        await com.gfnAlert("error.comm.userAuthReq");
        return false;
    }else if( rst.result == "success" ) {
        //본인확인이 되어 있음
        return true;
    } else 	if( rst.result == "notlogin" ) {
        //로그인이 되어 있지 않음
        await com.gfnAlert("msg.login.required");
        return false;
    }

    let txid = await pkiUtil.getAuthProviderPopUP();
    if( txid == false ) {
        //본인확인 실패 및 취소...
        //메시지 창은 본인확인창에서 처리함
        return false;
    }

    //화면이 닫히기를 기다린다.
    //await pkiUtil.sleep(500);

    rst = await pkiUtil.userAuthChk( txid );
    if( rst == false ){
        await com.gfnAlert("error.comm.userAuth");
        return false;
    } else if( rst.result == "success" ) {
        return true;
    } else if( rst.result == "notlogin" ) {
        await com.gfnAlert("msg.login.required");
    } else if( rst.result == "notAuth" ){
        await com.gfnAlert("error.comm.userNotAuth");
    } else if( rst.result == "missMatch" ){
        await com.gfnAlert("error.comm.userNotMatch");
    }else if( rst.result ==  "upFail" ){
        await com.gfnAlert("error.comm.userAuthUpdate");
    }
    return false;
};

