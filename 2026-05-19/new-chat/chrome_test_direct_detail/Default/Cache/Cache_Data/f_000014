/**
 * 간편인증 POP UP 화면 생성
 * @memberOf moSimAuthR
 * @date 2023.10.01
 * @param fn {String} 처리 요청 구분코드, 본인인증 : "simpleAuth",  전자서명 : "simpleSign", 비회원 본인인증 : "simpleAuthNonMember",  비회원 전자서명 : "simpleSignNonMember"
 * @param accKey {String}  접속인증키
 * @param accToken {String}  접속Token
 * @param signTarget {String} 전자서명 원문(전자서명시)
 * @return {String} JSON형식의 처리결과 : {"result": 성공: "sucess" / 실패 : "error", "msg" : 오류메시지(오류 발생시), "txId" : tx ID }
 * @example
moSimAuthR.sendData( "simpleAuth",  접속인증키, 접속Token, "")
 */

moSimAuthR.InitVal = false;
moSimAuthR.InitCount = 0;

/* 간편인증 팝업 페이지 호출 */
moSimAuthR.sendData  = function(fn, accKey, accToken, signTarget ){
    setTimeout(function(){
        if(moSimAuthR.InitVal){
            if(fn == "simpleAuth"){
                moSimAuthR.Popup.postMessage('{"simpleType":"simpleAuth", "accKey":"'+accKey+'", "accToken":"'+accToken+'"}',"*");
            } else if(fn == "simpleSign"){
                moSimAuthR.Popup.postMessage('{"simpleType":"simpleSign", "accKey":"'+accKey+'", "accToken":"'+accToken+'","signTarget":"'+signTarget+'"}',"*");
            } else if(fn == "simpleAuthNonMember"){
                moSimAuthR.Popup.postMessage('{"simpleType":"simpleAuthNonMember", "accKey":"'+accKey+'", "accToken":"'+accToken+'"}',"*");
            } else if(fn == "simpleSignNonMember"){
                moSimAuthR.Popup.postMessage('{"simpleType":"simpleSignNonMember", "accKey":"'+accKey+'", "accToken":"'+accToken+'","signTarget":"'+signTarget+'"}',"*");
            }
            moSimAuthR.InitVal = false;
            moSimAuthR.InitCount = 0;
        } else {
            if(moSimAuthR.InitCount > 20){
                moSimAuthR.InitCount = 0;
                return;
            }
            moSimAuthR.sendData(fn, accKey, accToken, signTarget);
            moSimAuthR.InitCount++;
        }
    },300);

}

/**
 * 간편인증 POP UP으로 부터 전송되어온 메시지 처리
 * @memberOf moSimAuthR
 * @date 2023.10.01
 * @param  event
 */
moSimAuthR.receiveMsg = async function(event) {
    var data = event.data;
    var jsonData = JSON.parse(data);
    //===========================================================================
    // window.open 으로 호출한 중계서비스 인증화면의 초기화 상태값을 받는 부분
    if(jsonData.initFlag == "true"){
        moSimAuthR.InitVal = true;
        console.log( "Init 성공");
        return;
    }
    //===========================================================================

    //===========================================================================
    // 인증창으로 postMessage 접속 데이터를 전송 후 트랜젝션 아이디가 생성 되고 응답 받는 부분
    if(jsonData.fn == "getToken"){
        if(jsonData.status == "success"){
            moSimAuthR.TxID = jsonData.res.txId;
            console.log( "getToken 성공, Txid :" + jsonData.res.txId);
            moSimAuthR.isComplate = 1;
        } else {
            moSimAuthR.ErrorMessage = "getToken fail =  "+JSON.stringify(jsonData.res);
            console.log(moSimAuthR.ErrorMessage );
        }
    //===========================================================================

        // 인증요청 버튼을 누르고 인증사업자에게 호출 후 응답데이터를 받는 부분
    } else if(jsonData.fn == "authRequest"){
        if(jsonData.status == "success"){
            console.log("request response success." );
            moSimAuthR.isComplate = 2;
        } else {
            try{
                moSimAuthR.ErrorMessage = "request response fail = "+ jsonData.res.clientMessage;
                console.log(moSimAuthR.ErrorMessage);
            }catch(e){
            }
        }
    //===========================================================================

    // 인증완료 버튼을 누르고 인증사업자에게 호출 후 응답데이터를 받는 부분
    } else {
        if(jsonData.status == "success"){
            console.log("인증 완료 success" );
            var jsonData = JSON.parse(data);
            //===========================================================================
            // txId (트랜젝션 아이디) 추출
            var txId = jsonData.res.reqTxId;
            //===========================================================================
            if(jsonData.fn == "signComplete" || jsonData.fn == "signNonMemberComplete"){
                jsonData.signTargetOri = moSimAuthR.SignData;
            }
            jsonData.reqBizCode = moSimAuthR.reqBizCode;
            jsonData.reqTaskId = moSimAuthR.reqTaskId;
            let reqJsonData = JSON.stringify(jsonData);

            moSimAuthR.isComplate = 3;
            let result =  await moSimAuthR.simAuthResult(reqJsonData );
            if( result == false ) {
                moSimAuthR.ErrorMessage = "simple auth fail = "+JSON.stringify(result.res);
                console.log(moSimAuthR.ErrorMessage );
                moSimAuthR.isComplate = 4;
            }else{
                moSimAuthR.isComplate = 5;
            }

            console.log("간편인증처리 완료 txid =  "+txId);
        } else {
            moSimAuthR.ErrorMessage = "simple auth fail = "+ jsonData.res.clientMessage;
            console.log(moSimAuthR.ErrorMessage );
        }
    }
    //===========================================================================
}

