 * @param  {string} sessionId 세션 ID
 */
pkiUtil.initCertWindowCompany= function( sessionId ) {
    let usrCert = pkiUtil.getCert( sessionId, CERT_TYPE.SIGN );

    if( usrCert != false && usrCert != undefined ) {
        let userCertPoid = pkiUtil.getPolicyOID( sessionId );
        let baseCertPoid = "not defined";
        if( sessionId.toLowerCase() == "www.g2b.go.kr/company" ) {
            baseCertPoid  = PKI_CERT_POID_COMPANY;
        }else if( sessionId.toLowerCase() == "www.g2b.go.kr/tax" ) {
            baseCertPoid  = PKI_CERT_POID_TAX;
        }else if( sessionId.toLowerCase() == "www.g2b.go.kr/person" ) {
            baseCertPoid  = PKI_CERT_POID_PERSON;
        }
        baseCertPoid  = JSON.stringify( baseCertPoid );
        if( baseCertPoid.indexOf( userCertPoid ) == -1) {
            pkiUtil.initSession( sessionId );
            usrCert = false;
        }
    }

    if( usrCert == false || usrCert == undefined )
    {
        if( sessionId.toLowerCase() == "www.g2b.go.kr/company" ) {
            MagicLineJSAPI.setCertWindow_oid(PKI_CERT_POID_COMPANY);
            MagicLineJSAPI.setCertWindow_storageList(PKI_CERT_MEDIA);
            MagicLineJSAPI.setCertWindow_certType(PKI_CERT_CA);
            MagicLineJSAPI.setCertWindow_storageTabList(PKI_CERT_TYPE_COMPANY);
            MagicLineJSAPI.setCertWindow_showExpireCert(PKI_CERT_SHOWEXPIRE);
        }else if( sessionId.toLowerCase() == "www.g2b.go.kr/tax" ) {
            MagicLineJSAPI.setCertWindow_oid(PKI_CERT_POID_TAX);
            MagicLineJSAPI.setCertWindow_storageList(PKI_CERT_MEDIA);
            MagicLineJSAPI.setCertWindow_certType(PKI_CERT_CA);
            MagicLineJSAPI.setCertWindow_storageTabList(PKI_CERT_TYPE_COMPANY);
            MagicLineJSAPI.setCertWindow_showExpireCert(PKI_CERT_SHOWEXPIRE);
        }else if( sessionId.toLowerCase() == "www.g2b.go.kr/person" ) {
            MagicLineJSAPI.setCertWindow_oid(PKI_CERT_POID_PERSON);
            MagicLineJSAPI.setCertWindow_storageList(PKI_CERT_MEDIA);
            MagicLineJSAPI.setCertWindow_certType(PKI_CERT_CA);
            MagicLineJSAPI.setCertWindow_storageTabList(PKI_CERT_TYPE_USER);
            MagicLineJSAPI.setCertWindow_showExpireCert(PKI_CERT_SHOWEXPIRE);
        }
    }
};


