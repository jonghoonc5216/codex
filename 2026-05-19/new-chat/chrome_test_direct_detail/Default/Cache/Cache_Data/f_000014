/**
 * 간편인증 화면에 기본값을 설정한다.
 * @memberOf moSimAuthI
 * @date 2023.10.01
 * @param reqType {string} 간편인증:"simpleAuth", 전자서명: "simpleSign"
 * @param inSignData {string} 전자서명 입력값
 * @param inUserInfo {json} 사용자 정보 json
 * {
        name:"",       //이름 (ex 홍길동)
        phone1:"",     //휴대폰번호 앞자리 3자리 (ex 010)
        phone2:"",     //휴대폰번호 뒷자리 7,8자리 (ex 12345678)
        telcoTycd: "", //S,K,L
        ssn1: "",      //주민등록번호 앞자리 (ex 900101)
        ssn2: "",      //주민등록번호 뒷자리 (ex 1999999)
        birthday:""    //생년월일 (ex 19900101)
    };
 * @return {string} tx id
 * @example
inUserInfo = {
        name:"고길동",       //이름 (ex 홍길동)
        phone1:"010",     //휴대폰번호 앞자리 3자리 (ex 010)
        phone2:"12341234",     //휴대폰번호 뒷자리 7,8자리 (ex 12345678)
        telcoTycd: "S", //S,K,L
        ssn1: "",      //주민등록번호 앞자리 (ex 900101)
        ssn2: "",      //주민등록번호 뒷자리 (ex 1999999)
        birthday:"20230101"    //생년월일 (ex 19900101)
    };
 let bRstTxId2 = await moSimAuthI.makeSimAuth( "simpleAuth", "", {} );
 alert( bRstTxId2 );
*/
moSimAuthI.makeSimAuth = async function( reqType /*간편인증:"simpleAuth", 전자서명: "simpleSign"*/, inSignData, inUserInfo ) {

    let reqTxId = false;
    try {
        //step1. 간편인증 백그라운드 열기
        await moSimAuthI.loadSimAuthDiv();

        //step2. 간편인증 백그라운드 보이기
        moSimAuthI.showSimAuth();

        //step3 간편인증 요청
        let insReqType = "GOV_SIMPLE_AUTH";
        if( "simpleSign" == reqType ) {
            insReqType = "GOV_SIMPLE_SIGN";
        }

        let simIframe = document.getElementById("moisSimAuth").contentWindow;

        if( inUserInfo != "" && inUserInfo != null && inUserInfo != {} ) {
            simIframe.setPreUserInfo( inUserInfo.name, inUserInfo.phone1,  inUserInfo.phone2,
                    inUserInfo.telcoTycd,  inUserInfo.inSsn1,  inUserInfo.inSsn2,  inUserInfo.birthday  ) ;
        }

        simIframe.reqSimpleAuth( insReqType, inSignData );

        //step4 사용자가 간편인증 창을 닫을 때까지 기다림
        while( 1 ) {
            await moSimAuthI.sleep(200);
            if( simIframe.isCloseMoisWindow == true ) {
                break;
            }
        }

        if( simIframe.moisStatus == 53 ){
            reqTxId = simIframe.moisInsTxId;
        }else if( simIframe.moisStatus == 99 ){
            pkiUtil.simAuthErrMsg = "사용자가 간편인증을 취소하였습니다.";
            reqTxId = "";
        }

        //step5 백그라운드 숨기기
        moSimAuthI.hideSimAuth();
        //step5 백그라운드 닫기
        moSimAuthI.unloadSimAuth();
    } finally {
    }

    return reqTxId;
}
