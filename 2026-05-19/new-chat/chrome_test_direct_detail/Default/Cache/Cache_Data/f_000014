/**
 * 인증서 유효성 및 등록여부 검사
 * @param sessionId {string} 세션 ID
 * @returns {boolean} 성공/실패
 */
pkiUtil.isSvrValidCert = async function( sessionId ) {
    let newCertDn = pkiUtil.getSubject( sessionId );
    let newCertSn = pkiUtil.getPolicyOID( sessionId );

    if( pkiUtil.selectCertInfo[sessionId]  != undefined ) {
        if( (pkiUtil.selectCertInfo[sessionId].preCertDn == newCertDn) && (pkiUtil.selectCertInfo[sessionId].preCertSN == newCertSn) && pkiUtil.selectCertInfo[sessionId].IsValid == true ) {
            return true;
        }
    }

    let signCert = pkiUtil.getCert(sessionId, "SIGN");

    let  resultJson = await pkiUtil.chkRegstCert( signCert )
    if( resultJson == false  ) {
        pkiUtil.IsValid   = false;
        alert( "인증서 등록여부 검사에 실패하였습니다.");
        return false;
    }else if(  resultJson.result == "fail" ) {
        pkiUtil.IsValid   = false;
        alert( resultJson.message );
        return false;
    }else if( resultJson.status == "notComplate" ) {
        alert( resultJson.message );
    }

    let newInfo = new Object();
    newInfo.preCertDn = newCertDn;
    newInfo.preCertSN = newCertSn;
    newInfo.IsValid   = true;
    pkiUtil.selectCertInfo[sessionId] = newInfo;

    return true;
}


