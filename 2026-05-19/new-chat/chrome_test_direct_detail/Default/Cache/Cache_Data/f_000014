/**
* pkcs7 기능 : 전자서명 추가 (callback funtion 방식)
* @param  sessionId {string} 세션 ID
* @param  signedText {string} 전자서명값, pkcs#7 signed Type
* @param  callbackfun {new function} 수행후 실행할 함수
* @return {boolean} 처리결과
*/
pkiUtil.pkcs7AddSigner_call = function( sessionId, signedText, callbackfun  ) {
    let userDN = MagicLineJSAPI.selectedCert_subjectDn(sessionId);
    if( userDN == false ) {
        callbackfun( false );
        return false;
    }

    let rst = MagicLineJSAPI.verifySignedData(signedText);
    if (rst == false) {
        callbackfun( false );
        return false;
    }

    for (var i=0; i < rst.signerInfos.length; i++) {
        if( userDN == rst.signerInfos[i].certInfo.subject ){
            return false;
        }
    }

    MagicLineJSAPI.addSigner(sessionId, signedText, null, function(result){
        callbackfun( result );
    });
};
