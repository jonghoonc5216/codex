/**
 * HASH값 생성 (알고리즘:SHA256)
 *
 * @param inValue
 *            {string} 입력값(utf8)
 * @return {string} hexa 인코딩된 hash값
 */
pkiUtil.genHash = function(inValue) {
    let md = magicjs.md.create(PKI_ALG.HASH);
    md.init();
    md.update(inValue, PKI_LANG_SET.UTF8 );
    let digestpw = md.digest();
    return digestpw.toHex();
};
/**
 * HASH값 생성 (알고리즘:SHA256)
 *
 * @param inValue {string}
 *            입력값
 * @param langSet {string}
 *            입력값의 언어셋
 * @return {string} hexa 인코딩된 hash값
 */
pkiUtil.genHash_langset = function(inValue, langSet) {
    let md = magicjs.md.create(PKI_ALG.HASH);
    md.init();
    md.update(inValue, langSet );
    let digestpw = md.digest();
    return digestpw.toHex();
};


/**
 * HASH값 검증 (알고리즘:SHA256)
 *
 * @param inValue {string} hash 생성에 사용한 데이터
 * @param hashValue {string} 검증하고자 하는 hash값
 * @return { boolean } 검증 결과
 *
 */
pkiUtil.verifyHash = function(inValue, hashValue) {
    let md = magicjs.md.create(PKI_ALG.HASH);
    md.init();
    md.update(inValue, PKI_LANG_SET.UTF8 );
    let digestpw = md.digest();
    let hexaMD = digestpw.toHex();

    if( hashValue.trim() === hexaMD ) {
        return true ;
    }else {
        return false;
    }
};


/**
 * hexa 인코딩
 *
 * @param inValue {string} 입력 데이터
 * @return {string} hexa 인코딩된 값
 */
pkiUtil.hexEncode = function(inValue) {
    return magicjs.hex.encode( unescape(encodeURIComponent(inValue) ) );
};
/**
 * hexa 디코딩
 *
 * @param inValue {string} hexa인코딩된 입력 데이터
 * @return {string} hexa 디코딩된 값
 */
pkiUtil.hexDecode = function(inValue) {
    let org =  magicjs.hex.decode( inValue );
    return decodeURIComponent(escape(org));
};
/**
 * base64 인코딩
 *
 * @param inValue {string} 입력 데이터
 * @return {string} base64 인코딩된 값
 */
pkiUtil.b64Encode = function(inValue) {
    let b64 = magicjs.base64.encode( unescape(encodeURIComponent(inValue) ) );
    return pkiUtil.insertNewLine( b64 );
};
/**
 * base64 디코딩
 *
 * @param inValue {string} base64 인코딩된 입력 데이터
 * @return {string} base64 디코딩된 값
 */
pkiUtil.b64Decode = function(inValue) {
    let delNewlineData = pkiUtil.deleteNewLine(inValue);
    let org =  magicjs.base64.decode( delNewlineData );
    return decodeURIComponent(escape(org));
};

/**
 * 개행문제 제거
 *
 * @param inValue {string} 입력 데이터
 * @return {string} 입력데이터에 대하여 개행문자(\r\n)값이 제거된 문자열
 */
pkiUtil.deleteNewLine = function(inData) {
    if( inData == null || inData == "" || inData.length <= 0 ) {
        return "";
    }
    return inData.replace(/\r|\n/g,  "" );
};
/**
 * 개행문제 추가 (75자 마다 개행문자(\n)을 입력)
 *
 * @param inValue {string} 입력 데이터
 * @return {string} 입력데이터에 대하여 75자마다 개행문자(\r\n)값이 추가된 문자열
 */
pkiUtil.insertNewLine = function(inData) {
    if( inData == null || inData == "" || inData.length <= 0 ) {
        return "";
    }
    if( inData.indexOf("\n") > -1 ) {
        return inData;
    }

    let sb = "";
    for( let i=0 ; inData.length > i ; i++ ) {
        if( i>0 && (i% 76) == 0 ) {
            sb += "\n";
        }
        sb += inData.charAt(i);
    }
    sb += "\n";
    return  sb;
};

