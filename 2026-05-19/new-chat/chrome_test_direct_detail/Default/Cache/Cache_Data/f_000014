/**
 * 행안부 중계형 간편인증
 * @date 2023. 10. 01.
 * @memberOf moSimAuthR
 * @param bizCode {String} 요청자의 업무구분코드 4자리(소스코드의 4자리)
 * @param reqTaskId {String} 업무처리 ID(예: 문서번호, 처리순번, 요청코드순번 등)
 * @param reqAuthType {String} 요청코드 : 본인확인 : "simpleAuth", 전자서명 : "simpleSign"
 * @param inSignData {String} 전자서명 원문
 * @return {String} TxID
 */
moSimAuthR.makeSimAuth = async function( bizCode, reqTaskId, reqAuthType, inSignData ) {

    moSimAuthR.reqBizCode = bizCode;
    moSimAuthR.reqTaskId = reqTaskId;
    let authType = reqAuthType ; //"simpleAuth"
    moSimAuthR.TxID = "";

    //step 1 이벤트 listener 생성
    window.addEventListener("message", moSimAuthR.receiveMsg, false);

    try {

        //step 2 접속정보 수신
        let jsonAccessInfo = await moSimAuthR.getAccessInfo( );
        if( jsonAccessInfo == false ) {
            console.log(moSimAuthR.ErrorMessage);
            return false;
        }

      //step 3 전자서명처리시 원문을 암호화
        if( authType == "simpleSign" ) {
//      if( inSignData != null && inSignData != ""  && inSignData != "undefined" ) {
//            authType = "simpleSign";

            moSimAuthR.SignData = inSignData;

            let jsonObject = new Object() ;
            jsonObject.sign = inSignData;

            let encSignRst = await moSimAuthR.getEncryptSignData(JSON.stringify(jsonObject ));
            if( encSignRst == false ) {
                console.log(moSimAuthR.ErrorMessage );
                return false;
            }

            moSimAuthR.EncSignData = encSignRst.sign;
            console.log(moSimAuthR.sign );
        }

        if(jsonAccessInfo.accKey == "" || jsonAccessInfo.accToken == ""){
            moSimAuthR.ErrorMessage = "행안부 간편인증 접속 정보가 없습니다.";
            console.log(moSimAuthR.ErrorMessage);
            return false;
        }

        //step 4 간편인증창이 닫혀있지 않으면 간편인증창을 강제로 닫음
        if( moSimAuthR.Popup != null && moSimAuthR.Popup.closed == false ) {
            moSimAuthR.Popup.close();
        }

        //step 5 간편인증창을 신규로 열고 간편인증을 요청함
        if(moSimAuthR.Popup == null || moSimAuthR.Popup.closed == true){
            moSimAuthR.Popup = window.open(jsonAccessInfo.connUrl, authType, moSimAuthR.Status);	//팝업 호출
            moSimAuthR.sendData(authType, jsonAccessInfo.accKey, jsonAccessInfo.accToken, moSimAuthR.EncSignData );
        }

       //step 6 간편인증창이 닫힐때까지 waiting(사용자가 완료 버튼을 누를때임)
        while(1){
            if(  moSimAuthR.Popup.closed == true && moSimAuthR.isComplate != 3){
                break;
            }
            await moSimAuthR.sleep(500);
        }

        if( moSimAuthR.TxID === "" || moSimAuthR.isComplate <= 2 ){
           moSimAuthR.ErrorMessage = "사용자의 요청에 의하여 간편인증을 취소하였습니다.  ";
           return false;
        }
    } finally {
        //step 7 이벤트를 삭제
        window.removeEventListener("message", moSimAuthR.receiveMsg );
    }
    return moSimAuthR.TxID;
}


