/**
* pkcs7 기능 : 전자서명 검사
* @param  signedText {string} 전자서명값, pkcs#7 signed Type
* @return {array} 전자서명 결과 :
*  0 : 원문 데이터
*  1 : 전자서명 갯수
*  2 : arrary 전자서명에 사용된 인증서
*  3 : arrary 전자서명에 사용된 인증서 DN
*
*/
pkiUtil.pkcs7VerifySignedData = function( signedText ) {
    let result = MagicLineJSAPI.verifySignedData(signedText);
    if( result == false ) {
        return false;
    }

    let plainText = result.content; // 서명원문
    let signCerts = [];
    let signerDNs = [];
    let signerNo = 0;
    for (var i=0; i<result.signerInfos.length; i++) {
        signCerts.push( result.signerInfos[i].certPEM );
        signerDNs.push( result.signerInfos[i].certInfo.subject );
        signerNo++;
    }
    return[ plainText, signerNo, signCerts, signerDNs ];
};

