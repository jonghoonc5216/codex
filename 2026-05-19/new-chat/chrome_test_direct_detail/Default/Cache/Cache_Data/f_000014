/**
 * 금융인증서를 이용하여 전자서명을 한다.
 * @date 2023. 12. 6.
 * @memberOf pkiUtil 내부함수
 * @param jsonObject pkiUtil.getNonceVal()함수의 결과값 JSON Object
 *         {  orgId : 조직 ID,
 *           orgName : 조직 명,
 *           clientId : 클라이언트 ID,
 *           orgUrl : 접속 가능 주소,
 *           txId : tx id,
 *           data : nonce 값
 *         }
 * @param agreeTerm 이용 약관
 * @param useAgreeJson 정보제공 동의 항목 JSON Object
 *       {
 *          useRealName : 이름 제공 동의(true/false),
 *          useGender   : 성별 제공 동의(true/false),
 *          useNationalInfo : 국적 제공 동의(true/false),
 *          useBirthDate : 생년월일 제공동의(true/false),
 *          useCi : CI 제공동의(true/false)
 *       }
 * @returns 전자서명값
 */
pkiUtil.finaceSign = async function( jsonObject, agreeTerm, useAgreeJson ) {

    return new Promise((resolve, reject)=>{
        FinCert.Sdk.sign({
            "content": {
                "ucpidInfo": {
                    "userAgreement": agreeTerm, // 약관 내용
                    "userAgreeInfo": {
                        "realName": useAgreeJson.useRealName,
                        "gender": useAgreeJson.useGender,
                        "nationalInfo": useAgreeJson.useNationalInfo,
                        "birthDate": useAgreeJson.useBirthDate,
                        "ci": useAgreeJson.useCi
                    },
                    "ispUrlInfo": jsonObject.orgUrl, // 이용기관 URL
                    "ucpidNonce": jsonObject.data    // Nonce
                }
            },
            "info": {
                "signType": "12"
            },
            "success": async function (result) {
                //console.log("UCPID 전자서명문 : " + result.signedVals[0]);
                resolve( result.signedVals[0]  );
            },
            "fail": function (error) {
                // console.log( "에러메시지 : " + error.message + ", 에러코드 : " + error.code);
                pkiUtil.finaceErrMsg =  error.message  ;
                resolve( false );
            }
        });
    });
};

