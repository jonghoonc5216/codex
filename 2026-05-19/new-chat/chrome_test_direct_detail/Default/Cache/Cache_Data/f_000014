/**
 * 금융결제원 금융인증서 API를 로드한다.
 * @date 2023. 12. 6.
 * @memberOf pkiUtil
 * @returns void
 */
pkiUtil.loadFinanceModule = async function ( ) {
    let isComplate = true;
    let today = new Date();
    let year = today.getFullYear();
    let month = ("0" + (1 + today.getMonth())).slice(-2);
    let day = ("0" + today.getDate()).slice(-2);

    var scriptElem = document.createElement('script');
    scriptElem.src = FINACE_CONNECT_URL + "/v1/fincert.js?dt=" + year + month + day;
    scriptElem.id = "finaceAuthScript";

    isHaveScript =  document.getElementById("finaceAuthScript");
    if( isHaveScript == null ) {
        document.querySelector('body').appendChild(scriptElem);
        isComplate = await pkiUtil.waitLoadFinanceModuleComplate();
    }
    return isComplate;
};

/**
 * 금융결제원 금융인증서 API가 정상적으로 로드될때까지 15초가 대기한다.
 *  - 내부에서 15초 동안 0.5초 간격으로 모듈이 로드되었는지 체크
 *  - 15초가 지나도 API가 로드되지 않으면 오류처리한다.
 * @date 2023. 12. 6.
 * @memberOf pkiUtil 내부함수
 */
pkiUtil.waitLoadFinanceModuleComplate = async function ( ) {
    let cnt = 0;
    let complate = false;
    while( cnt < 30 ){
        let rst = await pkiUtil.loadFinanceModuleTest();
        if( rst == false ){
            await pkiUtil.sleep(500);
        }else{
            complate = true;
            break;
        }
    }
    return complate;
};

/**
 * 금융결제원 금융인증서 API가 동작하는지 체크한다.
 *  - base64함수를 동작 테스트 해보는 것
 *  - try catch에 잡히면 아직 모듈이 로드되지 않은것
 *  - base64함수가 success, fail 중 하나의 결과가 나오면 API가 로드된 것임
 * @date 2023. 12. 6.
 */
pkiUtil.loadFinanceModuleTest = async function ( ) {

    return new Promise((resolve, reject)=>{
        try{
//            console.log( "check start");
            FinCert.Sdk.convertBase64UrlToBase64({
                "base64Url": "MIIHxAYJ",
                "success": function(result) {
//                    console.log( "check ok");
                    resolve(true);
                },
                "fail": function(error) {
//                    console.log( "check ok");
                    resolve(true);
                }
            });
        }catch(e) {
//            console.log( "check fail");
            resolve(false);
        }
    });
};


/**
 * 사용자 PC 브라우저용) 금융인증서를 이용하여 본인확인한다.
 * @date 2023. 12. 6.
 * @memberOf pkiUtil
 * @param agreeTerm 이용약관
 * @param useAgreeJson 정보제공 동의 JSON Object
 *       {
 *          useRealName : 이름 제공 동의(true/false),
 *          useGender   : 성별 제공 동의(true/false),
 *          useNationalInfo : 국적 제공 동의(true/false),
 *          useBirthDate : 생년월일 제공동의(true/false),
 *          useCi : CI 제공동의(true/false)
 *       }
 * @returns  txid
 */
pkiUtil.finaceAuth = async function( agreeTerm, useAgreeJson ) {
    let jsonObject = await pkiUtil.getNonceVal();
    if( jsonObject == false ) {
        return false;
    }

    let rstInit  = await pkiUtil.finaceInit( jsonObject );
    if( rstInit == false ) {
        return false;
    }

    let finSignValue = await pkiUtil.finaceSign( jsonObject, agreeTerm, useAgreeJson );
    if( finSignValue == false ) {
        return false;
    }

    let finUserInfo = await pkiUtil.finaceUserInfo();
    if( finUserInfo == false ) {
        return false;
