 *    kabankAuthReq() -> 카카오뱅크 인증UI -> callback URL ->   kabankAuthRes()
 * @returns
 */
pkiUtil.kabankAuthReq = async function ( clientCallbackUrl ) {
    //팝업차단 방지, 새창을 먼저 띠운다.
    let kakaobankPopup = window.open( "",  "kakaobank 본인확인",   "toolbar=no,scrollbars=no,location=no,resizable=no,status=no,menubar=no,width=500,height=600"  );
    res  = await pkiUtil.kabankUcpidReq( clientCallbackUrl ) ;
    if( res.result != "success" ) {
        kakaobankPopup.close();
        await pkiUtil.sleep(500);
        alert( res.message );
        return false;
    }
    //팝업차단 방지, 새창에 URL을 추가한다.
    kakaobankPopup.location.href = res.url;

    //창이 닫힐때까지 waiting(사용자가 완료 버튼을 누를때임)
    while(1){
        if(  kakaobankPopup.closed == true ){
            break;
        }
        await pkiUtil.sleep(500);
    }

    return res.txId;
};

