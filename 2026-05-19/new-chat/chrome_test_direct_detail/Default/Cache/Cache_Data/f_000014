/**
 * soap/xml 기능 : 입찰서 암호화
* @param  sessionId {string} 세션 ID
* @param  bidXMLDocument {string} 입찰서 xml
* @param  bidCert {string} 입찰서 암호화에 사용될 암호화 인증서
* @return {array} 암호화된 입찰서 정보 :
*  0: 암호화된 입찰서
*  1: 입찰서 원문에 대한 HASH값
*  2: 암호화된 입찰서에 대한 HASH값
*/
pkiUtil.genEncryptBidXML = function(sessionId, bidXMLDocument, bidCert ) {

    let envelopeValue;             // 암호화된 XML
    let bidXmlHashValue;           // 원문 입찰서 hash값
    let bidXmlEncHashValue;        // 암호화된 입찰서 hash값

    let kmCerts = [];             // 암호화인증서

    kmCerts.push(bidCert);
    let userKmCert = pkiUtil.getCert(sessionId, CERT_TYPE.KM);
    if (userKmCert != false) {
        kmCerts.push(userKmCert);
    }

    bidXmlHashValue = pkiUtil.genHash( bidXMLDocument );
    if (bidXmlHashValue == false) {
        return;
    }

    envelopeValue = MagicLineJSAPI.makeEnvelopedData(kmCerts, bidXMLDocument);
    if (envelopeValue == false) {
       return;
    }

    bidXmlEncHashValue = pkiUtil.genHash( envelopeValue );
    if (bidXmlEncHashValue == false) {
        return;
    }

    return [envelopeValue, bidXmlHashValue, bidXmlEncHashValue ];
};

/**
 * soap/xml 기능 : 암호화된 입찰서 검증 (async 방식)
 *
* @param  sessionId {string} 세션 ID
* @param  envelopeValue {string} 암호화된 입찰서
* @param  orgHashVal {string} 입찰서 원문 HASH값
* @param  encHashVal {string} 암호화된 입찰서 HASH값
* @return {array} 검사 결과
*/
pkiUtil.checkEncryptBidXML = async function(sessionId, envelopeValue, orgHashVal, encHashVal ) {
    let rst = pkiUtil.verifyHash(envelopeValue, encHashVal );
    if(rst == false ) {
        return false;
    }

//  if( pkiUtil.getCertType(sessionId) == "NPKI" && pkiUtil.getCertMedia (sessionId) != "fincert" ) {
    let kmCert = pkiUtil.getCert( sessionId, CERT_TYPE.KM );
    if( kmCert == false || kmCert == undefined || pkiUtil.getCertMedia (sessionId) == 'token' ) {
        return true;
    }

    let decBidXML = await pkiUtil.pkcs7DecryptData( sessionId, envelopeValue );
    if( decBidXML == false ) {
        return false;
    }

    rst = pkiUtil.verifyHash(decBidXML, orgHashVal );
    if(rst == false ) {
        return false;
    }

    return true;
};

