/*콘텐츠 안에서 지시 텍스트 기존 당구장 표시 점으로 변경 고객 수정내용임 */
.con_text{margin:.5rem 0 0;}
.con_text p{position: relative;color: #555;font-size: 1.3rem;margin-bottom: 0.1rem;padding-left: 1.2rem;}
.con_text p:before{content: 'ㆍ';position: absolute;top: 0;left: -0.4rem;}
.con_text span{position:relative;margin-bottom:.1rem;color:#555;font-size:1.3rem;}
.con_text .name {font-size: 1.6rem;font-weight: 500;}
.con_text .eng {font-size: 1.5rem;}

.bul_dot > li {position: relative;color: #555;font-size: 1.3rem;margin-bottom: 0.1rem;padding-left: 1.2rem;}
.bul_dot > li:before {content:'ㆍ';position: absolute;top: 0;left: -0.4rem;}

/*테이블 안 지시 텍스트*/
.w2group.tbbox .w2tb.tb .w2tb_td .con_text,
.w2group.tbbox .w2tb.tb_list .w2tb_td .con_text{display: inline-block; margin-top:0;margin-left:.6rem;vertical-align: inherit;}
.w2group.tbbox .w2tb.tb .w2tb_td .con_text.non_bf p,
.w2group.tbbox .w2tb.tb_list .w2tb_td .con_text.non_bf p{padding-left: 0;line-height: 1.5rem;}
.w2group.tbbox .w2tb.tb .w2tb_td .con_text.non_bf p:before,
.w2group.tbbox .w2tb.tb_list .w2tb_td .con_text.non_bf p:before{display: none;}
.w2group.tbbox .w2tb.tb .w2tb_td .con_text.block,
.w2group.tbbox .w2tb.tb_list .w2tb_td .con_text.block{display: block;margin-left: 0;}
.w2group.tbbox .w2tb.tb .w2tb_td .con_text.num,
.w2group.tbbox .w2tb.tb_list .w2tb_td .con_text.num{display: block;margin-left: 1.9rem;}
.w2group.tbbox .w2tb.tb .w2tb_td .con_text.num span,
.w2group.tbbox .w2tb.tb_list .w2tb_td .con_text.num span{display: block; text-indent: -14px;}

/*테이블 안 텍스트*/
.input_text{margin:.5rem 0 0.4rem;}
.input_text p{position:relative;margin-bottom:.1rem;color:#191919;font-size:1.4rem;}
.input_text p.bar_list{padding-left: 1.2rem}
.input_text p.bar_list:before {content:'-';position: absolute;top: 0;left: 0rem;}

/*내부 도움말*/
.helpbox.help_in_con{padding:1rem .5rem;margin-bottom:.5rem;border:.1rem solid #e1e1e1;background-color:#fafafa;}
.helpbox.help_in_con ul{margin-top:0;}
.helpbox.help_in_con ul li{margin-bottom:0;font-size:1.35rem;}

/*약관 그룹*/
.w2group.terms{margin-bottom: 2rem;}
.w2group.terms .w2group.helpbox {margin-bottom: 1rem;}
.w2group.terms .w2group.helpbox .w2textbox {max-height: 18rem; overflow: auto;white-space: pre-wrap;}
.w2group.terms .w2group.helpbox .term_conts {max-height: 18rem; overflow: auto;}
.w2group.terms .w2group.helpbox .term_conts .w2textbox {max-height: none;overflow: initial;white-space: pre-wrap;}
.num.txt_index > span {font-size: 1.4rem; display:block; color:#191919;text-indent: -1.4rem; padding-left:1.4rem;}

/*서약서 그룹*/
.pledgebox {position: relative; border: 0; border-radius: 0.8rem; background-color: #f4f6f8; padding: 1.2rem 1.6rem; margin-bottom: 2rem;}
.pledgebox .pledge_conts{max-height: 45rem; overflow: auto;}
.pledgebox .pledge_conts .pledge_tit{font-size:2rem; text-align:center; padding:1rem 0 2rem}
.pledgebox .pledge_conts .text{ overflow: auto;white-space: pre-wrap;}
.pledgebox .pledge_conts .day{font-size:1.6rem; text-align:center;padding:4rem 0 3rem}

.green .pledgebox .pledge_conts,
.green .terms .helpbox{color:#555}

.w2group.terms .w2checkbox{float: right; margin: 0;}
.w2group.terms:after{content: ''; display: block; clear: both;}

/*서약서 그룹 블릿 텍스트*/
/* ol li numbering style */
.pledgebox ol {counter-reset: depth1;}
.pledgebox ol > li:before {float:left; counter-increment: depth1; content:counter(depth1) ". "; position: absolute; width: 10px; height: 10px; left: 0;}
.pledgebox ol > li{position: relative; padding-left: 16px; padding-bottom:0.5rem}
.pledgebox ol > li > ol {counter-reset: depth2; padding-left: 0;}
.pledgebox ol > li > ol > li:before {float:none;display: inline-block;counter-increment: depth2; content:counter(depth2);margin-right:0.2rem; position: absolute;top: 4px;width: 1.4rem; height: 1.4rem; border: 0.1rem solid #191919; border-radius:50%;line-height: 1;font-size: 1.1rem; text-align: center;}
.pledgebox ol > li > ol > li {padding-left:19px}

.pledgebox ul.star{}
.pledgebox ul.star > li:before {float:left; content:"★"; position: absolute; width: 10px; height: 10px; left: 0;}
.pledgebox ul.star > li{position: relative; padding-left: 16px; padding-bottom:0.5rem}

.pledgebox .comtext{margin:5px 0; border-bottom: 0.27rem solid #4876ef;border-top: 0.27rem solid #4876ef;padding: 10px}

/*테이블 안 지시 텍스트 span*/
.w2group.w2tb_td .w2span {margin-left:.5rem;font-size: 1.3rem;color:#555;}
.w2group.w2tb_td .w2span.block{display: block;}
.w2group.w2tb_td .phone_number span, .w2group.w2tb_td .card_number span, .w2group.w2tb_td .id_number span, .w2group.w2tb_td .business_number span {margin:0;}

/*테이블 안 블릿 텍스트*/
.w2group.w2tb_td ul.bullet{margin: 0.4rem 0}
.w2group.w2tb_td ul.bullet li {position: relative; padding: 0 0rem 0 1rem;}
.w2group.w2tb_td ul.bullet li:before {content: "ㆍ"; position: absolute; left: -0.5rem;}
.w2group.w2tb_td ul.bullet li span{font-size: 1.4rem; margin-left:0; color: #191919}
.w2group.w2tb_td ul li > * {vertical-align: middle;}


/* 고시 내용 */
.con_detail{
/* 	position: relative; */
    padding: 2rem;
  margin-top: 1rem;
    background-color: #f4f6f8;
    border-radius: 0.8rem;
    border: 0;
}
.con_detail .con_detail_inner{max-height: 30rem;overflow-y: auto;}
.con_detail .con_detail_inner.h_full{max-height:100%;}
.helpbox.list ul {padding-left: 1.5rem;}
.helpbox.list ul li{list-style: decimal;margin-bottom: 0.5rem;}
.helpbox.list ul :last-child{margin-bottom: 0;}

/* td 컴포넌트 복합형 input + btn, select + btn 등  */
.flexbox{position: relative; width: 100%}
.flexbox .fix{position: absolute; top: -0.2rem; right: 0;}

/* iframe 영역 box*/
.iframe_area{border:1px solid #ccc;padding:2rem;}

/* 이용자현황 추가 */
.user_count_box{background-color:#f4f6f8;border-radius:0.8rem;padding:1rem;display:flex;}
.user_count_box > .select{display:block;flex:1;}
.user_count_box > .select > dl{display:block;height:100px;border:0.1rem solid #cccccc;margin-right:1rem;text-align:center;background-color:#fff;border-radius:0.8rem;}
.user_count_box > .select:last-child > dl{margin-right:0;}
.user_count_box > .select > dl > dt{display:block;margin:1.5rem 0 1rem 0;font-weight:500;text-decoration:underline;}
.user_count_box > .select > dl > dd{display:block;border-radius:5rem;background-color:#4876ef;color:#fff;width:70%;margin:auto;padding:0.5rem 0 0.5rem 0;height:3rem; }
.user_count_box > .select > dl > dd.red{background-color:#e3e3e3; color: #ff0000; font-weight: 500;}
.user_count_box > .select > dl > dd.green{background-color:#e3e3e3; color: #007732; font-weight: 500;}
.user_count_box > .select > dl > dd.orange{background-color:#e3e3e3; color: #de714c; font-weight: 500;}

/*인포메이션 닷 하위 하이픈 추가*/
.bul_dot_ul > li {position: relative;color: #191919;font-size: 1.4rem;margin-bottom: 0.1rem;padding-left: 1.2rem;}
.bul_dot_ul > li:before{content:'ㆍ';position: absolute;top: 0;left: -0.4rem;}
.bul_dot_ul > li > .hyphen li{display:block; position: relative;color: #191919;font-size: 1.3rem;margin-bottom: 0.1rem; margin-left:.5rem; padding-left: .6rem;}
.bul_dot_ul > li > .hyphen > li:before {content:'-';position: absolute;top: 0;left: -0.4rem;}
.w2group.w2tb_td .bul_dot_ul .w2span {margin-left:0;color: #191919;font-size: 1.4rem;}
.bul_dot_ul > li > .red> a{color: #ff0000;}

/* 툴팁 넘버링 추가 */
.num_ol_count{counter-reset: number 0;}
.num_ol{margin-left: 0.5rem;}
.num_ol > li{position: relative;color: #191919;font-size: 1.4rem;margin-bottom: 0.1rem;padding-left: 1.2rem;}
.num_ol > li:before {content:counter(number) '.';position: absolute;top: 0;left: -0.4rem;counter-increment: number 1;}
/* 서브 넘버링(하위번호 괄호 1) 추가 */
.num_sub_ol{counter-reset: subnum 0;}
.num_sub_list{position: relative;list-style: none;}
.num_sub_list > span{margin-left: 1.6rem;}
.num_sub_list:before{position: absolute;top:0.1rem;left: 0;counter-increment: subnum 1;content:counter(subnum) ')';font-size: 1.3rem;}
/* .num_sub_list:after{content: '';position: absolute;top:0.4rem;left:-0.4rem;display:inline-block;border:0.1rem solid #191919;border-radius:50%;width:1.5rem;height:1.5rem;font-size: 1.3rem;} */

/* 툴팁 넘버링(하위번호서클) 추가 UI-PBECAA-002M */
.circle_num{counter-reset: circle 0;margin-left: 2.2rem;}
.circle_list{position: relative;list-style: none;}
.circle_list > span{margin-left: 1.6rem;}
.circle_list:before{position: absolute;top:0.1rem;left: 0;counter-increment: circle 1;content:counter(circle);font-size: 1.3rem;}
.circle_list:after{content: '';position: absolute;top:0.4rem;left:-0.4rem;display:inline-block;border:0.1rem solid #191919;border-radius:50%;width:1.5rem;height:1.5rem;font-size: 1.3rem;}
/*툴팁 넘버링 하위 하이픈 추가*/
.num_ol > li > ul.hyphen li{display:block; position: relative;color: #191919;font-size: 1.3rem;margin-bottom: 0.1rem; margin-left:.5rem; padding-left: .6rem;}
.num_ol > li > ul.hyphen > li:before {content:'-';position: absolute;top: 0;left: -0.4rem;}

/* QnA */
.w2group.qnabox{position: relative;border: 0;border-radius: 0.8rem;background-color: #f4f6f8;padding: 1.2rem 1.6rem; margin-bottom: 2rem;}
.w2group.qnabox ul{margin: 0.4rem 0}
.w2group.qnabox ul li {position: relative; padding: 1.5rem;}
.w2group.qnabox ul li + li{ border-top:0.1rem solid #cecece}
.w2group.qnabox ul li p{position: relative;padding-left: 2rem; }
.w2group.qnabox ul li p.qusetion{color:#4876ef;}
.w2group.qnabox ul li p.qusetion:before {content: "Q.";position: absolute; top: -3px;left: 0;width: 1.6rem;height: 1.6rem;color: #4876ef;font-weight: bold;font-size: 1.6rem;}
.w2group.qnabox ul li p.answer{margin-top:0.5rem;color:#555}
.w2group.qnabox ul li p.answer:before {content: "A.";position: absolute; top: -3px;left: 0;width: 1.6rem;height: 1.6rem;color: #4876ef;font-weight: bold;font-size: 1.6rem;}
.w2group.qnabox ul li p.item{margin-top:0.5rem;color:#555}
.w2group.qnabox ul li p.item:before {content: "■ ";position: absolute; top: -3px;left: 0;width: 1.6rem;height: 1.6rem;color: #4876ef;font-weight: bold;font-size: 1.6rem;}

/*도움말 하이픈 단독 사용*/
ul.hyphen li{display:block; position: relative;color: #191919;font-size: 1.3rem;margin-bottom: 0.1rem; margin-left:.5rem; padding-left: .6rem;}
ul.hyphen > li:before {content:'-';position: absolute;top: 0;left: -0.4rem;}

