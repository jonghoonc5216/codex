@charset "utf-8";
/* layout */
.lybox{display:flex; flex: 1 1 auto; width:100%;margin-top: 2rem;}
.ly_column{display: flex; flex: 1 1 auto; flex-direction: column; padding:0 1.0rem; margin:0; -moz-box-sizing:border-box; box-sizing:border-box;}
.ly_column .dfbox {flex: none;}
.ly_column .tvwbox, .ly_column .tbbox, .ly_column .gvwbox {flex: 1 1 auto;}
.lybox .ly_column .dfbox:first-of-type {margin-top:0;}

/* shuttle drag&drop 예외- 그리드 top 고정/ 그리드 높이 고정(10줄 40.2rem) */
.ly_column .gvwbox.fix_top{flex: 0;}
.fix_height40{height: 44.2rem !important;}

/* .lybox{display:table;width:100%;table-layout: fixed;} */
/* .ly_column{display:table-cell;padding:0 10px;margin:0;-moz-box-sizing:border-box;box-sizing:border-box;vertical-align:top;} */
.ly_column:first-child{padding-left:0 !important}
.ly_column:last-child{padding-right:0 !important}
.lybox.col2 .ly_column{width:50%;}
.lybox.col3 .ly_column{width:33.333%;}
.lybox.col4 .ly_column{width:25%;}
.lybox.col5 .ly_column {width:20%;}
.col_05{width:5%}
.col_1{width:10%}
.col_2{width:20%}
.col_3{width:30%}
.col_4{width:40%}
.col_5{width:50%}
.col_6{width:60%}
.col_7{width:70%}
.col_8{width:80%}
.col_half .w2selectbox_select,
.col_half .w2input,
.col_half .w2inputCalendar_div,
.col_half .title {display: inline-block; width: calc(50% - 0.3rem);}
.col_half .search_wrap{width: calc(50% - 0.3rem);}
.col_half .search_wrap .w2input{width: calc(100% - 5.7rem);}
.col_half .search_wrap .searchbox.del_none {width: calc(100% - 2.6rem);}
.col_half :last-child{margin-right: 0;}
.col_3rd .w2selectbox_select,.col_3rd .w2input,.col_3rd .w2inputCalendar_div{width: calc(100%/3 - 0.4rem);}
.col_2srch .w2input{width: calc(50% - 3.2rem);}
.col_2srch_c .w2input{width: calc(50% - 3.2rem);}



/* column fix */
.lybox.left_fix2 .ly_columnfix_left{position:relative;float:left;width:200px;padding:0;margin-right:-200px;min-height:14px}
.lybox.left_fix2 .ly_columnfix_right{position:relative;padding:0;margin-left:200px;overflow:hidden;min-height:14px}
.lybox.left_fix3 .ly_columnfix_left{position:relative;float:left;width:300px;padding:0;margin-right:-300px;min-height:14px}
.lybox.left_fix3 .ly_columnfix_right{position:relative;padding:0;margin-left:300px;overflow:hidden;min-height:14px}

/* resize split 레이아웃 */
.lybox.resize {display: flex;}
.lybox.resize .ly_column.col_2{width:20%}
.lybox.resize .ly_column.col_3{width:30%}
.lybox.resize .ly_column.col_4{width:40%}
.lybox.resize .ly_column.col_5{width:50%}
.lybox.resize .ly_column.col_6{width:60%}
.lybox.resize .ly_column.col_7{width:70%}
.lybox.resize .ly_column.col_8{width:80%}
.lybox.resize .ly_column {display: flex; flex-direction: column; flex: 1 1 auto; width: 50%; min-width: 32%; /*overflow: hidden;*/}
.lybox.resize .ly_column.min_a{min-width:auto}
.lybox.resize .ly_column.splitter {width: 4.0rem; min-width: 4.0rem; max-width: 4.0rem; align-self: center; vertical-align: middle;}
.lybox.resize .ly_column.splitter .btn.splitter {
    width: 2.0rem;
    height: 6.0rem;
    color: transparent;
    font-size: 0;
    background: url(/kn/com/images/components/ic_splitter.svg) no-repeat center;
    background-size: 2rem;
    border: 0;
    cursor: col-resize;
}

.lybox.resize .ly_column.popup .pop_hidden_title {display: none;}

/* mobile 해상도 hidden 영역 닫기버튼 스타일 */
.lybox.resize .ly_column.popup .btn.pop_close {
    display: none;
    width: 3.2rem;
    height: 3.2rem;
    color:transparent;
    font-size: 0;
    border: 0;
    background: url('/kn/com/images/portal/gnb/ic_close_white.svg') no-repeat center;
    background-size: 1.6rem;
}
.lybox.resize .ly_column .gvwbox {display: flex; flex-direction: column; flex: 1 1 auto;}
.lybox.resize .ly_column .gvwbox .w2grid {flex: 1 1 auto;}
/* .lybox.resize .ly_column .tbbox {margin: 0;} */

/*ly_column.popup 부분 버튼설정*/
.lybox.resize .ly_column.popup .popup_detail{margin-bottom: 0.6rem; display: none;}
/* .lybox.resize .ly_column.popup .btnbox_all{display: none;} */

.ly_column .tb{border-top:0.27rem solid #4876ef;}
.ly_column .w2grid th.gridHeaderTDDefault {border-top:0;}

/* 별점 star rating */
.reviewbox {border: 0.1rem solid #cecece;}
.reviewbox .inner {padding: 0.8rem;}
.reviewbox .inner.title {display:flow-root;border-top:0.1rem solid #cecece;border-bottom: 0.1rem solid #cecece; padding: 0.8rem;}
.reviewbox > .inner.title:first-of-type,
.reviewbox .review_con_wrap:first-of-type > .inner.title{border-top:0;}
.reviewbox > .review_con_wrap > .inner.title {display:flow-root;min-height:4.5rem;border-top:.1rem solid #cecece;}
.reviewbox > .review_con_wrap:first-of-type > .inner.title {border-top:0;}
.reviewbox .inner.title .btn_cm {margin-top: 0; margin-bottom: 0;}
.reviewbox .review_info,
.reviewbox .user_info {display: inline-block; vertical-align: middle;}
.reviewbox .user_info span {margin-left: 0.8rem;}
.reviewbox .user_info span.date,
.reviewbox .user_info span.time{color:#666;font-size: 1.3rem;}
.reviewbox .inner.content.bg{background: #f5f5f5;}

.rating {display: inline-block; vertical-align: middle;}
.rating .star {font-size: 0; width: 2.4rem; height: 2.4rem; background: url(/kn/com/images/portal/gnb/ic_fav.svg) no-repeat center; background-size: 1.8rem;cursor: auto;}
.rating .star.active{cursor: pointer;}
.rating .star.is-active {background: url(/kn/com/images/portal/gnb/ic_fav_on.svg) no-repeat center; background-size: 1.8rem;}

.txt_btn_wrap{display:flex;}
.txt_btn_wrap .w2textarea{margin-right:.6rem;}
.txt_btn_wrap .btn_cm{height:auto;margin-right:0;}

.reviewbox .inner + span.block{padding:.5rem;border-top:.1rem solid #e5e5e5;background:#f5f5f5;}

/* 응용개발 예외적용페이지 HpcmPM.xml */
.unit_box_wrap{
  display: flex;
  margin-bottom: 1rem;
}
.unit_box_wrap .unit1,
.unit_box_wrap .unit2,
.unit_box_wrap .unit3,
.unit_box_wrap .unit4{
  height: 8rem;
  background-color: #eef5ff;
  padding: 1rem;
  border-radius: 0.8rem;
  margin-right: 1rem;
  overflow: hidden;
}
.unit_box_wrap .unit1{width: 21rem;}
.unit_box_wrap .unit2{width: 16rem;}
.unit_box_wrap .unit3{width: 24rem;}
.unit_box_wrap .unit4{margin-right: 0;width: 21rem;}
.unit_box_wrap .w2radio,.unit_box_wrap  .w2checkbox{margin: 0;}
.unit_box_wrap .w2radio input[type=radio]+label{min-width: 5.8rem;}
.unit_box_wrap .w2checkbox{display: flex;}
.unit_box_wrap .w2checkbox.bgcheck li:last-child input[type=checkbox]+label,
.unit_box_wrap .w2checkbox.bgcheck_txt li:last-child input[type=checkbox]+label{margin:0;}
.unit_box_wrap .shbox{border: 0;}
.unit_box_wrap .shbox .tb .w2tb_th label{padding-left: 0;}
.unit_box_wrap .shbox table.w2tb.tb tr > .w2tb_td,
.unit_box_wrap .shbox table.w2tb.tb > tbody > tr > .w2tb_td {display:flex; padding: 0;margin: 0;}
.unit_box_wrap .shbox .tb .w2tb_td .w2radio,
.unit_box_wrap .shbox .tb .w2tb_td .w2checkbox{display: flex;}
.unit_box_wrap .btn_cm{min-width: 6rem;}
.unit_box_wrap .btn_cm.file_down {padding-left: 2.6rem;background-position: 0.4rem center;}

