/* 전자캐비닛 lybox 테두리 */
.lybox_border{padding: 1.6rem 2rem;border: 0.1rem solid #ccc;border-radius: 0.8rem;box-sizing: border-box;}

/*입찰 임시 이미지*/
.arr_box{height:5rem; border-bottom: .1rem dotted #ccc; margin-bottom: 2rem;}
.arr_box span{position:relative;line-height: 4rem;color: #ccc;}
.arr_box span:before{display: block; content: ''; clear: both; position:absolute;top:.75rem; right:-.3rem; width: 1rem; height: 1rem; border-right:.11rem solid #ccc; border-bottom:.11rem solid #ccc; transform:rotate(-45deg); }

.arr_box_btm{height:5rem; border-top: .1rem dotted #ccc; margin-top: 2rem; text-align: right;}
.arr_box_btm span{position:relative;line-height: 5rem;color: #ccc;}
.arr_box_btm span:before{display: block; content: ''; clear: both; position:absolute;top:.75rem; left:-.3rem; width: 1rem; height: 1rem; border-right:.11rem solid #ccc; border-bottom:.11rem solid #ccc; transform:rotate(-225deg); }

/* 보고서 화면 */
.report_wrap .dfbox .square:before {content:"□";padding-right:.5rem;}
.report_wrap ul {margin-left:1rem;}
.report_wrap ul li p {display:inline-block; }
.report_wrap ul li:before {content:"○";padding-right:.4rem;}
.report_wrap ul li ul {margin-left:1rem;}
.report_wrap ul li ul li {position: relative;color: #555;font-size: 1.3rem;margin-bottom: 0.1rem;padding-left: 1.2rem;}
.report_wrap ul li ul li:before{content: '-';position: absolute;top: 0;left: -0.4rem;}
.report_wrap ul li ul li ul li.bullet {position: relative;color: #555;font-size: 1.3rem;margin-bottom: 0.1rem;padding-left: 1.2rem;}
.report_wrap ul li ul li ul li.bullet:before {content:"※";position: absolute;top: 0;left: -0.4rem;font-size:1.2rem;}
.report_wrap ul li ul li * + ul {margin-top:.5rem;margin-left:0;}
.report_wrap ul + ul {margin-top:2rem;}
.report_wrap pre {font-family: 'Roboto', 'NotoSansCJKkr', 'Malgun Gothic', 'Dotum', sans-serif;font-size:1.4rem;width:100%;overflow-x:auto;}
.report_wrap ol.decimal,
.report_wrap ol.decimal li  {list-style-type:decimal;margin-left:1rem;}

/* 전자시담 채팅화면 */
