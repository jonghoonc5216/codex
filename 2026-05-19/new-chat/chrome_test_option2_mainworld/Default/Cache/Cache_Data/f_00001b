        RAONKUPLOAD.Transfer(scwin.kUploadId);
    }
    return dlUntyAtchFileM.get('untyAtchFileNo');
};

scwin.checkFileExtentionChanged = function(fileObject){
    return new Promise(async(resolve, reject)=>{
        if(fileObject){
            var files = [fileObject];
            RAONKUPLOAD.DetectFileExtension(files,{},function(result, error){
                if(error){
                    reject(error);
                    return;
                }

                resolve(result);
            }, scwin.kUploadId);
        }else{
            resolve(null);
        }
    });
}

