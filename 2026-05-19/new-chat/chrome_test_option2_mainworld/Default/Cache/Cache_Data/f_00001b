    await scwin.fnFileDel(true);
};
// 삭제 이벤트 별도 함수 지정후 구현 (로직상 호출되는 케이스 고려를 위함.)
scwin.fnFileDel = async function(isEvPreBtnDel = false) {
    // VIEW 모드에서는 삭제가 되지 않는다.
    if (objViewMode.viewMode.toUpperCase() === "VIEW") return;    
    if(isEvPreBtnDel) {
        // 부모가 지정한 함수 동기처리
        if(typeof scwin.options.evPreBtnDel === "function") {
            let isContinue = await scwin.options.evPreBtnDel(scwin.fileScope);
            if(isContinue === false) {
                return;
            }
        }
    }
    const dt = dlUntyAtchFileL.getRowJSON(0);

    if (!comUtil.gfnIsEmpty(dt.untyAtchFileNo)) {
        // web 파일은 dataList 상태를 D로 변경
        const result = await com.gfnConfirmPopup("confirm.common.delete");
        if (result) {
            //사용자의 의지로 confirm 제어시 이후에도 업무 체크로직 호출 후 한번더 검증.
            if(isEvPreBtnDel) {
                // 부모가 지정한 함수 동기처리
                if(typeof scwin.options.evPreBtnDel === "function") {
                    let isContinue = await scwin.options.evPreBtnDel(scwin.fileScope);
                    if(isContinue === false) {
                        return;
                    }
                }
            }
            // kupload에서 파일을 삭제한다.
            RAONKUPLOAD.DeleteAllFile(scwin.kUploadId);

            // 파일 삭제 진행 여부에 따라 분기
            if (scwin.continuedDeleteFile) {
                dlUntyAtchFileL.deleteRow(0);

                // 삭제를 위한 서브미션
                const sbmOption = {
                    id: "sbmInsertAtflGrp",
                    action: "/fs/fsc/fscb/UntyAtchFile/multiUntyAtchFileComp.do",
                    inData: "dlUntyAtchFileL=dlUntyAtchFileL dlUntyAtchFileM",
                    msgYn: { succ: false, err: true }
                };

                const getResult = await com.gfnExecute(sbmOption);

                dlUntyAtchFileL.removeAll();

                return getResult;
            } else {
                return null;
            }
        } else {
            return null;
        }
    } else {
        // local 파일은 삭제
        scwin.continuedDeleteFile = true;
        dlUntyAtchFileL.removeAll();
        RAONKUPLOAD.DeleteAllFile(scwin.kUploadId);
        return null;
    }
};

