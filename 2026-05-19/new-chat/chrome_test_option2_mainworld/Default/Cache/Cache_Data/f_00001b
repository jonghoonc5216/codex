 * @exception
 * @example
 */
scwin.load = async function () {
    scwin.fileLog('file > API > load');
    if ( !comUtil.gfnIsEmpty(dlUntyAtchFileM.get('untyAtchFileNoArray')) ) {
        const sbmOption = {
            id: "sbmInsertAtflGrp",
            action: "/fs/fsc/fscb/UntyAtchFile/selectMultiAtchFileList.do",
            inData: "dlUntyAtchFileM=dlUntyAtchFileM",
            outData: "dlUntyAtchFileL",
            isProcessMsg: ((scwin.options.loadingUse === 'Y') ? true : false),
            msgYn: { succ: false, err: true }
        };
        await com.gfnExecute(sbmOption);

        RAONKUPLOAD.ResetUpload(scwin.kUploadId); // 업로드 리스트 초기화
        const list = dlUntyAtchFileL.getAllJSON();
        for (idx in list) {
            const obj = list[idx];
            // 업로드 컴포넌트에 등록된 파일 추가
            RAONKUPLOAD.AddUploadedFile(idx, comUtil.gfnEscapeToChar(obj.orgnlAtchFileNm), '', obj.fileSz, obj.untyAtchFileNo + ',' + obj.atchFileSqno, scwin.kUploadId);
            scwin.fileCountChange(scwin.kUploadId, obj.orgnlAtchFileNm);
        }
        return dlUntyAtchFileM.get('untyAtchFileNo');
    } else {
        if (!comUtil.gfnIsEmpty(dlUntyAtchFileM.get('untyAtchFileNo')) && !comUtil.gfnIsEmpty(dlUntyAtchFileM.get('bsnePath'))) {
            const sbmOption = {
                id: "sbmInsertAtflGrp",
                action: "/fs/fsc/fscb/UntyAtchFile/selectUntyAtchFileList.do",
                inData: "dlUntyAtchFileM=dlUntyAtchFileM",
                outData: "dlUntyAtchFileL",
                isProcessMsg: ((scwin.options.loadingUse === 'Y') ? true : false),
                msgYn: { succ: false, err: true }
            };
            await com.gfnExecute(sbmOption);
            if(dlUntyAtchFileL.getTotalRow() > 0) {
                if(dlUntyAtchFileM.get("untyAtchFileNo") != dlUntyAtchFileL.getCellData(0, "untyAtchFileNo")) {
                    com.gfnInitDataList("dlUntyAtchFileL");
                    console.error("첨부파일번호가 변조되어 첨부파일목록 초기화.");
                }
            }

            RAONKUPLOAD.ResetUpload(scwin.kUploadId); // 업로드 리스트 초기화
            const list = dlUntyAtchFileL.getAllJSON();
            for (idx in list) {
                const obj = list[idx];
                // 업로드 컴포넌트에 등록된 파일 추가
                RAONKUPLOAD.AddUploadedFile(idx, comUtil.gfnEscapeToChar(obj.orgnlAtchFileNm), '', obj.fileSz, obj.untyAtchFileNo + ',' + obj.atchFileSqno, scwin.kUploadId);
                scwin.fileCountChange(scwin.kUploadId, obj.orgnlAtchFileNm);
            }
            return dlUntyAtchFileM.get('untyAtchFileNo');

        } else {
            return dlUntyAtchFileM.get('untyAtchFileNo');
        }

    }
};

