        dlUntyAtchFileM.set('bsneClsfCd', scwin.options.bsneClsfCd);
    }

    if (!comUtil.gfnIsEmpty(scwin.options.tblNm)) {
        dlUntyAtchFileM.set('tblNm', scwin.options.tblNm);
    }
    if (!comUtil.gfnIsEmpty(scwin.options.colNm)) {
        dlUntyAtchFileM.set('colNm', scwin.options.colNm);
    }

    if (!comUtil.gfnIsEmpty(scwin.options.atchFileKndCds)) {
        dlUntyAtchFileM.set('atchFileKndCds', scwin.options.atchFileKndCds);
    }

    if (!comUtil.gfnIsEmpty(scwin.options.ignoreAtchFileKndCds)) {
        dlUntyAtchFileM.set('ignoreAtchFileKndCds', scwin.options.ignoreAtchFileKndCds);
    }

    if (!comUtil.gfnIsEmpty(scwin.options.kbrdrIds)) {
        dlUntyAtchFileM.set('kbrdrIds', scwin.options.kbrdrIds);
    }

    dlUntyAtchFileM.set('webPathUse', scwin.options.webPathUse);
    dlUntyAtchFileM.set('isScanEnabled', scwin.options.isScanEnabled);

    // 업로드 아이디를 지정 한다. 웹스퀘어의 아이디 생성 방식으로 인해 id는 겹치지 않도록 생성 된다.
    scwin.kUploadId = kupload_holder.getID() + '_upload';
    scwin.kUploadHolder = kupload_holder.getID();
    scwin.fileLog('kupload id  : ' + scwin.kUploadId);

    // 드랍존 생성을 위해서 target_upload 어트리뷰트를 추가함
    const ele = document.getElementById(ibxFile.getID());
    WebSquare.xml.setAttribute(ele, "target_upload", scwin.kUploadId);

    // kupload 를 생성함
    const options = {
        Id: scwin.kUploadId || "kupload",
        MaxOneFileSize: scwin.options.maxOneFileSize,
        MaxTotalFileSize: scwin.options.maxTotalFileSize,
        UploadHolder: scwin.kUploadHolder,
        ExtensionAllowOrLimit: scwin.options.extensionAllowOrLimit || "0",
        ExtensionArr: scwin.options.extensionArr || "",
        DownloadMulti: scwin.options.downloadMulti,
        ZipFileName: scwin.options.zipFileName,
        UseZipDownload: scwin.options.useZipDownload,
        AllowedZeroFileSize: scwin.options.allowedZeroFileSize,
        IsScanEnabled: scwin.options.isScanEnabled,
        bsnePath: scwin.options.bsnePath,
        mode: scwin.options.mode,
        security: scwin.options.security,
    };

    objViewMode.viewMode = scwin.options.mode;

    await scwin.makeKupload(options);

    return scwin.kUploadId;
};

// 업로드 생성
scwin.makeKupload = async function (options) {
    scwin.destroy();
    // header 설정, commonScope 참고
    const pattern = 'XSRF-TOKEN=([^;]+)';
    const cookie = document.cookie.match(new RegExp(pattern));
    const csrfValue = (cookie != null && cookie.length > 1) ? cookie[1] : "";

    const uploadConfig = {
        Id: options.Id,
        InitXml: "raonkupload.config.txt",
        UseDropzone: '1',
        UploadHolder: options.UploadHolder,
        InitVisible: false, // 화면에 표시하지 않는다
        Width: "100%",
        HandlerUrl: "/fs/fsc/fsca/fileUpload.do",
        MaxOneFileSize: options.MaxOneFileSize,
        MaxTotalFileSize: options.MaxTotalFileSize,
        MaxTotalFileCount: '1', // 업로드 할 최대 파일 개수 0제한 없음
        AllowedZeroFileSize: options.AllowedZeroFileSize, // 0byte 파일의 업로드를 허용 할지 설정합니다. 기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.
        ExtensionAllowOrLimit: options.ExtensionAllowOrLimit,
        ExtensionArr: options.ExtensionArr,
        DownloadMulti: options.DownloadMulti,
        FolderNameRule: options.bsnePath,
        Mode: options.mode, // edit, view
        ButtonBarEdit: '0', // edit Mode 버튼 바 표시 여부 : 0 안함
        ButtonBarView: '0', // view Mode 버튼 바 표시 여부 : 0 안함
        ZipFileName: options.ZipFileName, // zip 다운로드 파일명
        UseZipDownload: options.UseZipDownload, // zip 다운로드 방식 (단일건도 zip으로 처리할경우 '2' 설정)
        IsScanEnabled: options.IsScanEnabled,  // 선택 | 악성코드 점검 여부 true, false(Default)
        UseExcuteDownloadInMobile: (WebSquare.util.isMobile()) ? '1' : '0', // 선택 | 모바일일 경우 '1', '0'(Default)
        SizeForChunkUpload : '1MB',
        DetectFileChanged : "1", // 파일전송 전 변경감지 여부 추가
        RequestConfigFileSync: true,    //환경설정 로드 방식을 동기로 추가 (2026.04.06)
        Security: {
            UseMagicJs: options.security.use == 'Y' ? '1' : '0',//  magicjs 연동 기능을 사용여부 화면개발자 설정 Y, N : 실제 1사용 0안함
        },
        // magicjs 추가 2022-05-16
        AddCSRFToken: {
            'X-CSRF-Token': csrfValue
        },
        Event: {
            CreationComplete: async function (uploadID) {
                scwin.fileLog('file > Event > CreationComplete');
                /* kupload 생성 후 실행 */

                scwin.setViewMode(scwin.options.mode); // 모드 edit/view

                dlUntyAtchFileM.set("kuploadId", scwin.kUploadId);
                dlUntyAtchFileM.set("viewMode", objViewMode.viewMode);

                await scwin.load(); // 데이터 로드
                await scwin.security(); // MagicLineJSAPI

                if (scwin.options?.downloadAfterInit?.use === 'Y') {
                    if (comUtil.gfnIsEmpty(scwin.options.downloadAfterInit.atchFileSqno)) {
                        scwin.getDnld();
                    } else {
                        scwin.getDnld(scwin.options.downloadAfterInit.atchFileSqno);
                    }
                }
                $p.emit("CreationCplt", uploadID, dlUntyAtchFileM.get('untyAtchFileNo'), dlUntyAtchFileL.getAllJSON());
            },
            BeforeAddFile: function (uploadID, paramObj) {
                // 파일명 길이 400byte 제한(확장자 포함)
                if (comUtil.gfnGetByteLength(paramObj.objFile.name) > 400) {
                    com.gfnAlert(["msg.fs.fsc.fileNmMaxbyte", "400", ""]);
                    return false;
                }

                scwin.fileLog('file > Event > BeforeAddFile');
            },
            AfterAddFile: async function (uploadID, paramObj) {
                scwin.fileLog('file > Event > AfterAddFile');

                if (paramObj.objFile.type.indexOf('image') > -1) {
                    scwin.objFile = paramObj.objFile;
                }

                // 이미지 사이즈 체크 여부
                if ((scwin.options.checkImageSize || scwin.options.checkImageRatio) && paramObj.objFile.type.indexOf('image') > -1) {
                    await checkImageFileSize();
                } else {
                    await insertFileAfter();
                }

                async function checkImageFileSize() {
                    let urlCreator = window.URL || window.webkitURL || window;
                    let img = new Image();

                    img.onerror = function () { // 이미지 로드 오류가 난 경우
                        // 메모리 해제
                        urlCreator.revokeObjectURL(this.src);

                        delete img;
                        console.log('image load error');
                    };

                    img.onload = async function () {
                        // 메모리 해제
                        urlCreator.revokeObjectURL(this.src);

                        let width = this.width; // 이미지의 width 값
                        let height = this.height; // 이미지의 height 값

                        delete img;

                        if (scwin.options.checkImageRatio && scwin.options.imgRatio != "") {
                            let ratioValue = scwin.options.imgRatio.trim().split(":");
                            let ratioX = width * Number(ratioValue[1]);
                            let ratioY = height * Number(ratioValue[0]);

                            if (ratioX !== ratioY) {
                                // '{0}' 이미지 파일 사이즈를 {1} x {2} 비율에 맞게 등록해주세요.
                                await com.gfnAlert(["msg.common.checkImageSizeRatio", paramObj.strName, ratioValue[0], ratioValue[1]]);

                                scwin.fnFileDel();
                            } else {
                                await insertFileAfter();
                            }
                        } else if ((scwin.options.exactImageSize && (Number(scwin.options.imageWidth) !== Number(width) || Number(scwin.options.imageHeight) !== Number(height)))
                            || (!scwin.options.exactImageSize && (Number(scwin.options.imageWidth) < Number(width) || Number(scwin.options.imageHeight) < Number(height)))) {
                            await com.gfnAlert(['msg.common.checkImageSize', paramObj.strName, scwin.options.imageWidth, scwin.options.imageHeight]);
                            scwin.fnFileDel();
                        } else {
                            await insertFileAfter();
                        }
                    };

                    let webkitURL = urlCreator.createObjectURL(paramObj.objFile);
                    img.src = webkitURL;
                }

                async function insertFileAfter() {
                    /* 파일 추가 후 실행
                        uploadID : 업로드 컴포넌트 아이디
                        paramObj : 추가된 파일 정보
                        console.log('AfterAddFile', uploadID, paramObj);

                        추가된 파일 정보를 dataList에 추가한다
                    */
                    const fileInfo = {
                        untyAtchFileNo: '',
                        atchFileSqno: '',
                        bsneClsfCd: dlUntyAtchFileM.get('bsneClsfCd'),
                        tblNm: dlUntyAtchFileM.get('tblNm'),
                        colNm: dlUntyAtchFileM.get('colNm'),
                        atchFileKndCd: (comUtil.gfnIsEmpty(scwin.options.addColumn.atchFileKndCd?.value)) ? "" : scwin.options.addColumn.atchFileKndCd?.value,
                        atchFileDscr: (comUtil.gfnIsEmpty(scwin.options.addColumn.atchFileDscr?.value)) ? scwin.options.addColumn.atchFileDscr?.title : scwin.options.addColumn.atchFileDscr?.value,
                        orgnlAtchFileNm: paramObj.strName,
                        fileExtnNm: '',
                        fileSz: paramObj.objFile.size,
                        atchFileNm: '',
                        atflPathNm: '',
                        atflRmrk: '',
                        rstrId: '',
                        rstrIpar: '',
                        rgstDttm: '',
                        chnrId: '',
                        chnrIpar: '',
                        chngDttm: '',
                        delYn: '',
                        sessUserNo: '',
                        nIndex: paramObj.nIndex // customValue 를 수정 할 때 사용
                    };

                    dlUntyAtchFileL.setJSON([fileInfo], true); // dataList에 데이터 추가
                    dlUntyAtchFileL.modifyRowStatus(dlUntyAtchFileL.getTotalRow() - 1, 'C'); // 상태를 등록 상태로 변경

                    scwin.fileCountChange(uploadID, paramObj.strName); // 파일 갯수 갱신
                    // 즉시전송
                    if (scwin.options.sendImmediately === 'Y') {
                        await scwin.send();
                    }

                    $p.emit("insertFileAftr", uploadID, paramObj);
                }
            },
            BeforeUpload: function (uploadID, paramObj) {
                scwin.fileLog('file > Event > BeforeUpload');
                /* 파일 전송 시작 전 발생합니다 */
                $p.emit("beforeUpld", uploadID, dlUntyAtchFileM.get('untyAtchFileNo'), dlUntyAtchFileL.getAllJSON());
                return scwin.continuedAddFile;
            },
            UploadComplete: async function (uploadID) {
                scwin.fileLog('file > Event > UploadComplete');

                /* 업로드 성공시 실행
                    scwin.load : 변경된 정보를 다시 로드
                    saveUpldCplt : 완료시 udc를 사용하는 화면에 saveUpldCplt 이벤트 발생
                 */

                // 전자서명
                const result = RAONKUPLOAD.GetListInfo('array', uploadID);
                const newFiles = result.newFile;
                scwin.completeFileListHash = [];

                if (!comUtil.gfnIsEmpty(newFiles) && !comUtil.gfnIsEmpty(newFiles.length)) {
                    for (let i = 0; i < newFiles.length; i++) {
                        if (!comUtil.gfnIsEmpty(newFiles[i].extraDataObject) && !comUtil.gfnIsEmpty(newFiles[i].originalFileHash)) {
                            // magicjs 추가 2022-05-16
                            // 원본파일 hash 값,
                            // hash 사용함 또는 전자서명 사용함 일 때 값이 들어있습니다.
                            scwin.completeFileListHash[i].originalFileHash = newFiles[i].extraDataObject.originalFileHash;
                            // 서버에 암호화된 채로 파일을 저장하겠다고 설정한 경우에 값이 들어있습니다.
                            scwin.completeFileListHash[i].encryptedFileHash = newFiles[i].extraDataObject.encryptedFileHash;
                            // 전자서명 사용함 일 때 값이 들어있습니다.
                            scwin.completeFileListHash[i].signedData = newFiles[i].extraDataObject.signedData;
                            // 파일 암호화 할 때 사용한 cipherKey 값이 들어있습니다.
                            // hex.encode(secretKey) + hex.encode(iv) 값이 암호화된 값입니다.
                            scwin.completeFileListHash[i].cipherKey = newFiles[i].extraDataObject.cipherKey;
                        }
                    }
                }

                // 즉시저장, 저장후 재조회
                if (scwin.options.sendImmediately === 'Y' || scwin.options.reloadAfterSend === 'Y') {
                    await scwin.load();
                }

                $p.emit("saveUpldCplt", uploadID, dlUntyAtchFileM.get('untyAtchFileNo'), dlUntyAtchFileL.getAllJSON());
            },
            BeforeOpenFile: function (uploadID, paramObj) {
                // uploadID  파일 열기 요청한 업로드의 id를 의미합니다.
                // paramObj  열기 실행될 파일에 대한 정보가 있는 object 입니다.
                // - paramObj.strIsWebFile  Web파일과 Local 파일의 구분 값을 의미합니다. (0:local, 1:web)
                // - paramObj.strKey  파일의 Unique Key를 의미합니다.
                // - paramObj.strName  원본 파일명을 의미합니다.
                // - paramObj.strPath  파일의 경로를 의미합니다.
                // - paramObj.strIsLargeFile  파일 대용량을 의미합니다. (0:일반, 1:대용량)
                scwin.fileLog('file > Event > beforeOpenFile');
                /* 파일 열기 전 발생합니다. */
                $p.emit("beforeOpenFile", uploadID, paramObj, dlUntyAtchFileM.get('untyAtchFileNo'), dlUntyAtchFileL.getAllJSON());
            },
            DownloadCompleteFile: function (uploadID, paramObj) {
                // uploadID  다운로드가 발생한 업로드의 id를 의미합니다.
                // paramObj  다운로드 완료된 파일에 대한 정보가 있는 object 입니다.
                // - paramObj.strPath  파일 경로를 의미합니다.
                // - paramObj.strDownloadedPath  로컬에 저장된 경로를 의미합니다.
                // - paramObj.strType  다운로드일 경우 "download"를 의미합니다.
                // - paramObj.customValue  다운로드된 파일의 customValue를 의미합니다.
                // - paramObj.size  다운로드된 파일의 사이즈를 의미합니다.
                // - paramObj.originalName  다운로드된 파일의 원본 파일명을 의미합니다.
                scwin.fileLog('file > Event > DownloadCompleteFile');
                /* 파일 다운로드 완료 후 발생합니다. */
                $p.emit("downloadCpltFile", uploadID, paramObj, dlUntyAtchFileM.get('untyAtchFileNo'), dlUntyAtchFileL.getAllJSON());
            },
            DownloadCompleteAllFile: function (uploadID, paramObj) {
                // uploadID  모든 파일 다운로드가 완료된 업로드의 id를 의미합니다.
                // paramObj  다운로드 완료된 파일에 대한 개수가 있는 object 입니다.
                // - paramObj.strCmd  다운로드일 경우 "download"를 의미합니다.
                // - paramObj.nCount  다운로드된 파일의 개수를 의미합니다.
                scwin.fileLog('file > Event > DownloadCompleteAllFile');
                /* 모든 파일 다운로드 완료 후 발생합니다. */
                $p.emit("downloadCpltAllFile", uploadID, paramObj, dlUntyAtchFileM.get('untyAtchFileNo'), dlUntyAtchFileL.getAllJSON());
            },
            OnError: function (uploadID, paramObj) {
                scwin.fileLog('file > Event > OnError');
                /* 오류 발생시 이벤트 processErr를 발생 */
                const errMsg = '' + paramObj.strMessage + '\n (Code : ' + paramObj.strCode + ')';

                if (paramObj.strCode == "024") {
                    com.gfnAlert(['msg.alert.notallowedextension']);
                } else if (paramObj.strCode == "C020") {
                    com.gfnServerAlert(errMsg);
                } else if (paramObj.strCode == "C021") {
                    // 업로드 전에 파일 변경 검사를 하여 오류가 발생한 경우
                    // 이 경우에는 오류 발생한 파일 정보를 추가로 얻으실 수 있습니다.
                    // paramObj.arrErrorFileList[0].originName : 파일명
                    console.log("kupload 오류 발생 파일 리스트 = ", paramObj.arrErrorFileList);
                    com.gfnServerAlert(errMsg);
                } else if (comUtil.gfnIsEmpty(paramObj.strCode)) {
                    // 에러코드가 넘어오지 않는 현상이 존재하여 일시적으로 경고창 제거(request for check download status error)
                    // 기능자체는 문제없이 작동
                } else if (paramObj.strCode === "910" || paramObj.strCode === "911") {
                    let uploadedFileLen = paramObj.arrUploadedFileList.length;

                    // 오류 발생한 파일 정보 가져오기
                    let errorFileInfo = paramObj.arrUploadedFileList[uploadedFileLen-1];
                    let hashErrorMsg = "";
                    hashErrorMsg += errorFileInfo.originName + " 파일에서 업로드중 오류(H)가 발생하였습니다. 다시 시도하여 주십시오";
                    com.gfnServerAlert(hashErrorMsg);
                } else if (paramObj.strCode === "920"){
                    let uploadedFileLen = paramObj.arrUploadedFileList.length;
                    // 오류 발생한 파일 정보 가져오기
                    let errorFileInfo = paramObj.arrUploadedFileList[uploadedFileLen-1];
                    let hashErrorMsg = "";
                    hashErrorMsg += errorFileInfo.originName + " 파일에서 업로드중 개인정보가 검출되었습니다.";
                    hashErrorMsg += "\n아래 검출 내역을 수정하시길 바랍니다.";
                    hashErrorMsg += "\n" + paramObj.strMessage;
                    com.gfnServerAlert(hashErrorMsg);
                } else {
                    com.gfnServerAlert(errMsg);
                }
                $p.emit("processErr", uploadID, paramObj);
            },
            BeforeDeleteFile: function (uploadID, paramObj) {
                scwin.fileLog('file > Event > BeforeDeleteFile');
                if(paramObj.strIsWebFile !== "0") {
                    /* 파일 삭제 전 발생 */
                    $p.emit("deleteFileBeoe", uploadID, paramObj);
                }

                return scwin.continuedDeleteFile;
            },
            AfterDeleteFile: function (uploadID, paramObj) {
                scwin.fileLog('file > Event > AfterDeleteFile');
                /* 파일 삭제 후 발생 */
                scwin.fileCountChange(uploadID); // 파일 갯수 갱신
                $p.emit("deleteFileAftr", uploadID, paramObj);
                return true;
            },
            Alert: function (uploadID, message) {
                const url = "/kn/com/MessageBox.xml";
                const msgSize = getMessageSize(comUtil.gfnEscapeToEnter(message));

                const options = {
                    cancelText : "아니요",
                    className : "messagebox",
                    confirmText : "확인",
                    height : msgSize.height,
                    id : "kupload_" + scwin.kUploadId,
                    msgInfo : [],
                    popupName : "경고 메시지",
                    width : msgSize.width,
                    yesText : "예",
                };

                const data = {
                    callbackFn: "",
                    callbackParam: {},
                    cancelText: "아니요",
                    confirmText: "확인",
                    id: "kupload_" + scwin.kUploadId,
                    message: comUtil.gfnEscapeToEnter(message),
                    messageFontStyle: undefined,
                    messageType: "alert",
                    yesText: "예",
                };

                _gcm.openPopup($p, url, options, data);

                function getMessageSize(errorMsg) {
                    let msgDiv = document.createElement("div");
                    msgDiv.style.display = "inline-block";
                    msgDiv.style.visibility = "hidden";
                    msgDiv.style.position = "absolute";
                    msgDiv.style.width = "auto";
                    msgDiv.style.top = "0px";
                    msgDiv.style.left = "0px";
                    msgDiv.innerHTML = errorMsg;

                    document.querySelector('body').appendChild(msgDiv);

                    let width = msgDiv.clientWidth;
                    let height = msgDiv.clientHeight;

                    width = (width + 120 < 380) ? 380 : width + 120;
                    height = (height + 180 < 223) ? 223 : height + 180;

                    msgDiv.remove();

                    return { width, height };
                };
            },
        }
    };
    new RAONKUpload(uploadConfig);
};

// 입력, 버튼 초기화
scwin.initUI = function () {
    ibxFile.setValue('');
    btnAtcm.hide();
    btnDel.hide();
    btnDel.setDisabled(true);
    //btnDnld.hide();
};

// 파일 갯수 변경시 처리
scwin.fileCountChange = function (uploadID, strName) {
    const totalCount = RAONKUPLOAD.GetTotalFileCount(uploadID)
    const fileList = RAONKUPLOAD.GetListInfo("array", uploadID);
    let hasWebFile = false; // 업로드 된 파일이 있는지 여부
    if (!comUtil.gfnIsEmpty(fileList.webFile) && fileList.webFile.length > 0) {
        hasWebFile = true;
    }
    if (totalCount >= 1) {
        ibxFile.setValue(comUtil.gfnEscapeToChar(strName));
        btnAtcm.hide();
        btnDel.show('inline');
        btnDel.setDisabled(false);

        if (hasWebFile && scwin.options.useExcuteDownload)
            btnDnld.removeClass("btn-hide");

        if (scwin.options.mode.toUpperCase() === 'VIEW') {//view일때 삭제버튼 hide 추가
            btnDel.hide();
            btnDel.setDisabled(true);
        }
    } else {
        ;
        ibxFile.setValue('');
        btnAtcm.show('inline');
        btnDel.hide();
        btnDel.setDisabled(true);

        btnDnld.addClass("btn-hide");
    }
};

