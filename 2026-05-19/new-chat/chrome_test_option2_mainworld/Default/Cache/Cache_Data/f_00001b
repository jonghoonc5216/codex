/**
 * @method
 * @name deleteWhol
 * @description 전체 삭제하고 성공여부를 리턴 한다.
 * @param {object} options 확인 창을 사용 할지 여부YN
 * @returns {boolean} result 성공여부
 * @hidden N
 * @exception
 * @example
 */
scwin.deleteWhol = async function (options) {
    scwin.fileLog('file > API > deleteWhol');
    const optionDefault = {
        confirmUse: 'N'
    };
    options = comUtil.gfnAssignDefined(optionDefault, options); // 지정 하지 않은 값은 기본 값으로 지정 한다.

    scwin.fileLog('전체 삭제하고 성공여부를 리턴 한다.');
    if (comUtil.gfnIsEmpty(options.confirmUse)) {
        com.gfnAlert(['warn.common.required', '확인 창을 사용 할지 여부']);
        return false;
    }

    if (options.confirmUse === 'Y') {
        // 확인 창 사용
        const result = await com.gfnConfirmPopup("confirm.common.delete");
        if (result) {
            return deleteFile();
        } else {
            return false;
        }
    } else {
        // 확인 창 사용 안함
        return deleteFile();
    }

    async function deleteFile() {
        const dt = dlUntyAtchFileL.getRowJSON(0);

        if (!comUtil.gfnIsEmpty(dt.untyAtchFileNo)) {
            scwin.fileLog('전체삭제 : 1 삭제를 시작 한다');
            const rowCount = dlUntyAtchFileL.getRowCount();
            if (rowCount > 0) {
                scwin.fileLog('전체삭제 : 2 rowCount' + rowCount);
                for (let idx = (rowCount - 1); idx >= 0; idx--) { // 혹시 몰라 뒤부터 삭제 한다.
                    scwin.fileLog('전체삭제 : 3 삭제idx : ' + idx);
                    dlUntyAtchFileL.getRowJSON(idx);
                }
            }

            scwin.fileLog('전체삭제 : 4 ~서브미션 ~' + rowCount);

            if (rowCount > 0) {
                // 삭제를 위한 서브미션
                const sbmOption = {
                    id: "sbmInsertAtflGrp",
                    action: "/fs/fsc/fscb/UntyAtchFile/multiUntyAtchFileComp.do",
                    inData: "dlUntyAtchFileL=dlUntyAtchFileL dlUntyAtchFileM",
                    msgYn: { succ: false, err: true }
                };

                const getResult = await com.gfnExecute(sbmOption);
                scwin.fileLog('전체삭제 : 5 then ');
                // 정상처리시 삭제 상태인 dataList를 제거한다.
                if (getResult.responseJSON.ErrorCode === 0) {
                    dlUntyAtchFileL.removeAll();
                    RAONKUPLOAD.DeleteAllFile(scwin.kUploadId);
                    return true;
                } else {
                    return false;
                }
            }
        } else {
            // local 파일은 삭제
            scwin.continuedDeleteFile = true;
            dlUntyAtchFileL.removeAll();
            RAONKUPLOAD.DeleteAllFile(scwin.kUploadId);
            return true;
        }
    }
};

