/**
 * @method
 * @name setDateRange
 * @description 날짜 범위 설정
 * @param {string} type 날짜 범위 타입(day, month, year)
 * @param {integer} range 날짜 범위
 * @returns
 * @hidden N
 * @exception
 * @example
 */
scwin.setDateRange = function(type, range) {
    // 기준일자
    let baseDate = "";
    if (scwin.baseDate === "start") {
        baseDate = (ibxStrDay.getValue() === "") ? calStart.getDate() : ibxStrDay.getValue();
    } else {
        baseDate = (ibxEndDay.getValue() === "") ? calEnd.getDate() : ibxEndDay.getValue();
    }

    // 유효하지 않은 날짜 보정
    if (!comUtil.gfnValidatDate(baseDate)) {
        baseDate = comUtil.gfnGetServerDateTime();
    }

    if (type === "year") {
        range *= 12;
    }

    // 선택한 개월에 따른 날짜 설정
    if (scwin.baseDate === "start") {
        if(scwin.dateRangeType === "custom") {
                switch(type) {
                    case "day" :
                        scwin.setInitDate(baseDate, comUtil.gfnAddDate(baseDate, range));
                        break;
                    default :
                        scwin.setInitDate(baseDate, comUtil.gfnAddMonthCal(baseDate, range));
                        break;

                }
        }else {
            scwin.setInitDate(baseDate, (scwin.dateRangeType === "day") ? comUtil.gfnAddDate(baseDate, range) : comUtil.gfnAddMonthCal(baseDate, range));
        }
    } else {
        if(scwin.dateRangeType === "custom") {
                switch(type) {
                    case "day" :
                        scwin.setInitDate(comUtil.gfnAddDate(baseDate, -range + 1), baseDate);
                        break;
                    default :
                        scwin.setInitDate(comUtil.gfnAddMonthCal(baseDate, -range), baseDate);
                        break;
                }
        }else {
            scwin.setInitDate((scwin.dateRangeType === "day") ? comUtil.gfnAddDate(baseDate, -range) : comUtil.gfnAddMonthCal(baseDate, -range));
        }
    }

    // 조회 버튼 선택
    if (type === "day") {
        range *= 0.01;
    }
    if(scwin.dateRangeType !== "custom") {
        btnMnth.setValue(range);
    }

    // From-To 달력 팝업 닫기
    scwin.showHide("hideAll");
};

