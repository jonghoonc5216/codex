/********************************************************************************
 * 설명 : 1주/2주/3주/1개월/3개월/6개월/1년/2년/3년 라디오버튼 onchange 이벤트 핸들러
 ********************************************************************************/
scwin.btnMnth_onchange = async function(info) {
    // 기준일자
    let baseDate = "";
    if (scwin.baseDate === "start") {
        if (!comUtil.gfnIsEmpty(scwin.rangeBaseDate)) {
            calStart.gotoCalendar(scwin.rangeBaseDate);
        } else if (!scwin.useRangeBaseDate) {
            calStart.gotoToday();
        }

        ibxStrDay.setValue(calStart.getDate());
        baseDate = (ibxStrDay.getValue() === "") ? calStart.getDate() : ibxStrDay.getValue();
    } else {
        if (!comUtil.gfnIsEmpty(scwin.rangeBaseDate)) {
            calEnd.gotoCalendar(scwin.rangeBaseDate);
        } else if (!scwin.useRangeBaseDate) {
            calEnd.gotoToday();
        }

        ibxEndDay.setValue(calEnd.getDate());
        baseDate = (ibxEndDay.getValue() === "") ? calEnd.getDate() : ibxEndDay.getValue();
    }

    // 유효하지 않은 날짜 보정
    if (!comUtil.gfnValidatDate(baseDate)) {
        baseDate = comUtil.gfnGetServerDateTime();
    }

    // 선택한 개월에 따른 날짜 설정
    if (scwin.baseDate === "start") {
        if(scwin.dateRangeType === "custom") {
            if(/\d일/.test(btnMnth.getText())
            || /\d주/.test(btnMnth.getText())) {
                scwin.setInitDate(baseDate, comUtil.gfnAddDate(baseDate, info.newValue * 100 - 1));
            }else {
                scwin.setInitDate(baseDate, comUtil.gfnAddMonthCal(baseDate, info.newValue));
            }
        }else {
            scwin.setInitDate(baseDate, (scwin.dateRangeType === "week") ? comUtil.gfnAddDate(baseDate, info.newValue * 100 - 1) : comUtil.gfnAddMonthCal(baseDate, info.newValue));
        }
    } else {
        if(scwin.dateRangeType === "custom") {
            if(/\d일/.test(btnMnth.getText())
            || /\d주/.test(btnMnth.getText())) {
                scwin.setInitDate(comUtil.gfnAddDate(baseDate, -info.newValue * 100 + 1));
            }else {
                scwin.setInitDate(comUtil.gfnAddMonthCal(baseDate, -info.newValue));
            }
        }else {
            scwin.setInitDate((scwin.dateRangeType === "week") ? comUtil.gfnAddDate(baseDate, -info.newValue * 100 + 1) : comUtil.gfnAddMonthCal(baseDate, -info.newValue));
        }

    }

    // From-To 달력 팝업 닫기
    scwin.showHide("hideAll");

    // 시작일 - 이전 날짜 입력 금지
    if (scwin.calStartDisableBeforeDate !== "") {
        if (ibxStrDay.getValue() < scwin.calStartDisableBeforeDate) {
            ibxStrDay.setValue("");
            await com.gfnAlert(["warn.validation.DisableDate"]);
            ibxStrDay.focus();
            return;
        }
    }

    // 시작일 - 이후 날짜 입력 금지
    if (scwin.calStartDisableAfterDate !== "") {
        if (ibxStrDay.getValue() > scwin.calStartDisableAfterDate) {
            ibxStrDay.setValue("");
            await com.gfnAlert(["warn.validation.DisableDate"]);
            ibxStrDay.focus();
            return;
        }
    }

    // 종료일 - 이전 날짜 입력 금지
    if (scwin.calEndDisableBeforeDate !== "") {
        if (ibxEndDay.getValue() < scwin.calEndDisableBeforeDate) {
            ibxEndDay.setValue("");
            await com.gfnAlert(["warn.validation.DisableDate"]);
            ibxEndDay.focus();
            return;
        }
    }

    // 종료일 - 이후 날짜 입력 금지
    if (scwin.calEndDisableAfterDate !== "") {
        if (ibxEndDay.getValue() > scwin.calEndDisableAfterDate) {
            ibxEndDay.setValue("");
            await com.gfnAlert(["warn.validation.DisableDate"]);
            ibxEndDay.focus();
            return;
        }
    }
};

/********************************************************************************
 * 설명 : 달력 팝업 Start ondateselect 이벤트 핸들러
 *
 * 시작 날짜 선택
 * 종료일이 없을 때
 *      정상 입력
 *
 * 종료일이 있을 때
 *      종료일보다 큰 경우
 *          비정상 리턴 - 선택값 지움
 *      종료일보다 작은 경우
 *          정상입력
 *
 * 정상입력 추가 동작
 *      input에 값 입력
 *      disableBeforeDate(dateStr)  입력 받은 날짜 이전의 날짜들은 달력에서 선택 불가능하도록 제한
 *
 * 전체 종료
 *      stard, end 값이 모두 입력 되어있다면 창 닫기
 *
 ********************************************************************************/
scwin.calStart_ondateselect = async function (dateStr, dateObj) {
    scwin.btnMnthReset();
    scwin.setStartDate(dateStr, 'N');

    if (scwin.rangeType !== "" && scwin.rangeValue > 0) {
        let startDay = ibxStrDay.getFormattedValue();
        if (startDay === "") return;
        let startDate = new Date(startDay);

        if (scwin.rangeType === "year") {
            startDay = comUtil.gfnAddYear(startDate.format("yyyyMMdd"), scwin.rangeValue);
        } else if (scwin.rangeType === "month") {
            startDay = comUtil.gfnAddMonthCal(startDate.format("yyyyMMdd"), scwin.rangeValue);
        } else if (scwin.rangeType === "day") {
            startDay = comUtil.gfnAddDate(startDate.format("yyyyMMdd"), scwin.rangeValue - 1);
        }

        startDate = new Date(`${startDay.substring(0, 4)}/${startDay.substring(4, 6)}/${startDay.substring(6, 8)}`);
        const rangeDate = startDate.format("yyyyMMdd");

        if (rangeDate < ibxEndDay.getValue()) {
            const rangeText = (scwin.rangeType === "year") ? "년" : (scwin.rangeType === "month") ? "개월" : "일";
            await com.gfnAlert(["msg.validation.DateFormat.RageDate.message", scwin.rangeValue, rangeText]);
            ibxEndDay.setValue(rangeDate);
            scwin.setEndDate(rangeDate, 'Y');
            scwin.showHide("show");
            return;
        }
    }
};

