/********************************************************************************
 * 설명 : End InputCalendar onblur 이벤트 핸들러
 ********************************************************************************/
scwin.ibxEndDay_onblur = async function (e) {
    if (ibxEndDay.getValue().length > 0) {
        const minYear = Number.parseInt(calStart.options.minYear);
        const maxYear = Number.parseInt(calStart.options.maxYear);
        const endYear = Number.parseInt(ibxEndDay.getValue().slice(0, 4));

        if (minYear > endYear || maxYear < endYear) {
            ibxEndDay.setValue("");
            await com.gfnAlert(["msg.fm.fma.formatDateBetween", "종료년도", minYear + " ~ " + maxYear + "년"]); // {0} (은)는 {1} 사이의 날짜여야 합니다
            ibxEndDay.focus();
            return;
        }

        if (!comUtil.gfnValidatDate(ibxEndDay.getValue())) {
            ibxEndDay.setValue("");
            await com.gfnAlert(["msg.alert.grd.formatDate", "yyyyMMdd"]);
            ibxEndDay.focus();
            return;
        }

        if (!comUtil.gfnIsEmpty(ibxStrDay.getValue()) && !comUtil.gfnIsEmpty(ibxEndDay.getValue())) {
            const dateDiff = WebSquare.date.dateDiffSilence(ibxStrDay.getValue(), ibxEndDay.getValue());
            if (dateDiff < 0) {
                ibxEndDay.setValue("");
                await com.gfnAlert(["warn.validation.StartDate"]);
                ibxEndDay.focus();
                return;
            }
        }

        const endDay = ibxEndDay.getFormattedValue();
        if (scwin.rangeType !== "" && scwin.rangeValue > 0 && endDay !== "") {
            const endDate = new Date(endDay);

            if (scwin.rangeType === "year") {
                endDate.setFullYear(endDate.getFullYear() - scwin.rangeValue);
            } else if (scwin.rangeType === "month") {
                endDate.setMonth(endDate.getMonth() - scwin.rangeValue);
            } else if (scwin.rangeType === "day") {
                endDate.setDate(endDate.getDate() - scwin.rangeValue + 1);
            }

            const rangeDate = endDate.format("yyyyMMdd");

            if (rangeDate > ibxStrDay.getValue()) {
                const rangeText = (scwin.rangeType === "year") ? "년" : (scwin.rangeType === "month") ? "개월" : "일";
                await com.gfnAlert(["msg.validation.DateFormat.RageDate.message", scwin.rangeValue, rangeText]);
                ibxStrDay.setValue(rangeDate);
                scwin.setStartDate(rangeDate, 'Y');
                return;
            }
        }

        // 종료일 - 이전 날짜 입력 금지
        if (scwin.calEndDisableBeforeDate !== "") {
            if (ibxEndDay.getValue() < scwin.calEndDisableBeforeDate) {
                ibxEndDay.setValue("");
                await com.gfnAlert(["warn.validation.DisableDate"]);
                ibxEndDay.focus();
                return;
            }
        }

        // 종료일 - 이후 날짜 입력 금지
        if (scwin.calEndDisableAfterDate !== "") {
            if (ibxEndDay.getValue() > scwin.calEndDisableAfterDate) {
                ibxEndDay.setValue("");
                await com.gfnAlert(["warn.validation.DisableDate"]);
                ibxEndDay.focus();
                return;
            }
        }
    }

    scwin.btnMnthReset();

    if (ibxEndDay.getValue() === "") {
        ibxEndDay.setValue("");
    } else {
        scwin.setEndDate(ibxEndDay.getValue(), "Y");
    }

    scwin.btnMnthColor();
};

