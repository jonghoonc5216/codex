/********************************************************************************
 * 설명 : 달력 팝업의 일자 중 선택 가능한 날짜에 색을 칠한다.
 ********************************************************************************/
scwin.setCalColor = function () {
    const sIn = ibxStrDay.getValue(); // 입력된 날짜
    const eIn = ibxEndDay.getValue();

    if (!comUtil.gfnIsEmpty(ibxStrDay.getValue()) && !comUtil.gfnIsEmpty(ibxEndDay.getValue())) {
        const sCal = calStart.getValue(); // 달력이 가르키는 월
        const eCal = calEnd.getValue().substr(0, 6) + '01'; // 처음 달력을 열 때 선택된 날 값이 오기 때문

        calStart.removeAllCellClass("selectRange1"); // 지우고 시작 한다.
        for (let i = 0; i <= comUtil.gfnGetLastDateOfMonth(sCal.substr(0, 6)) - 1; i++) {
            let colorDay = WebSquare.date.dateAdd(sCal, i); // 날짜를 더한다.
            if (WebSquare.date.dateDiffSilence(sIn, colorDay) >= 0 && WebSquare.date.dateDiffSilence(colorDay, eIn) >= 0) {
                calStart.setCellClass(colorDay, "selectRange1");
            }
        }

        calEnd.removeAllCellClass("selectRange1"); // 지우고 시작 한다.
        for (let i = 0; i <= comUtil.gfnGetLastDateOfMonth(eCal.substr(0, 6)) - 1; i++) {
            let colorDay = WebSquare.date.dateAdd(eCal, i); // 날짜를 더한다.
            if (WebSquare.date.dateDiffSilence(sIn, colorDay) >= 0 && WebSquare.date.dateDiffSilence(colorDay, eIn) >= 0) {
                calEnd.setCellClass(colorDay, "selectRange1");
            }
        }
    } else {
        if (comUtil.gfnIsEmpty(sIn)) {
            calStart.removeAllCellClass("selectRange1");
        }

        if (comUtil.gfnIsEmpty(eIn)) {
            calEnd.removeAllCellClass("selectRange1");
        }
    }
};

/********************************************************************************
 * 설명 : 선택된 기간에 맞게 1주/2주/3주/1개월/3개월/6개월/1년/2년/3년 라디오버튼 값을 설정한다.
 ********************************************************************************/
scwin.btnMnthColor = function () {
    const sIn = ibxStrDay.getValue(); // 입력된 날짜
    const eIn = ibxEndDay.getValue();

    if (comUtil.gfnIsEmpty(sIn) || comUtil.gfnIsEmpty(eIn)) {
        if (comUtil.gfnIsEmpty(sIn) && comUtil.gfnIsEmpty(eIn)) {
            scwin.btnMnthReset();
        }

        // 1주/2주/3주/1개월/3개월/6개월/1년/2년/3년 버튼 색 없으면 입혀준다.
        btnMnth.getItemArray().map(item => item.value).forEach(value => {
            let nowDate = new Date().format("yyyyMMdd");
            if (scwin.rangeType === "day" && scwin.rangeValue > 0) {
                let addDate = (Number(value) < 1) ? comUtil.gfnAddDate(nowDate, parseInt(value * 100)) : comUtil.gfnAddMonthCal(nowDate, parseInt(value));
                if (addDate > comUtil.gfnAddDate(nowDate, scwin.rangeValue)) {
                    btnMnth.deleteItem(btnMnth.itemArr.findIndex(item => item.value === String(value)));
                }
            } else if (scwin.rangeType === "month" && scwin.rangeValue > 0) {
                if (Number(value) > scwin.rangeValue) {
                    btnMnth.deleteItem(btnMnth.itemArr.findIndex(item => item.value === String(value)));
                }
            } else if (scwin.rangeType === "year" && scwin.rangeValue > 0) {
                if (Number(value) > scwin.rangeValue * 12) {
                    btnMnth.deleteItem(btnMnth.itemArr.findIndex(item => item.value === String(value)));
                }
            }
        });
    } else {
        // 1주/2주/3주/1개월/3개월/6개월/1년/2년/3년 버튼 색 없으면 입혀준다.
        btnMnth.getItemArray().map(item => item.value).forEach(value => {
            if (scwin.rangeType === "day" && scwin.rangeValue > 0) {
                let addDate = (Number(value) < 1) ? comUtil.gfnAddDate(sIn, parseInt(value * 100)) : comUtil.gfnAddMonthCal(sIn, parseInt(value));
                if (addDate > comUtil.gfnAddDate(sIn, scwin.rangeValue)) {
                    btnMnth.deleteItem(btnMnth.itemArr.findIndex(item => item.value === String(value)));
                }
            } else if (scwin.rangeType === "month" && scwin.rangeValue > 0) {
                if (Number(value) > scwin.rangeValue) {
                    btnMnth.deleteItem(btnMnth.itemArr.findIndex(item => item.value === String(value)));
                }
            } else if (scwin.rangeType === "year" && scwin.rangeValue > 0) {
                if (Number(value) > scwin.rangeValue * 12) {
                    btnMnth.deleteItem(btnMnth.itemArr.findIndex(item => item.value === String(value)));
                }
            }

