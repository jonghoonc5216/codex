/**
 * @method
 * @name initDate
 * @description 시작 종료 날짜 지정
 * @param {string} s 시작일
 * @param {string} e 종료일
 * @returns
 * @hidden N
 * @exception
 * @example
 */
scwin.initDate = async function (s, e) {
    if (!comUtil.gfnIsEmpty(s) && !comUtil.gfnValidatDate(s)) {
        await com.gfnAlert(["msg.alert.grd.formatDate", "yyyyMMdd"]);
        return false;
    }

    if (!comUtil.gfnIsEmpty(e) && !comUtil.gfnValidatDate(e)) {
        await com.gfnAlert(["msg.alert.grd.formatDate", "yyyyMMdd"]);
        return false;
    }

    const udcProp = $p.getOptions();
    const startArr = comUtil.gfnDataGetBindInfo(udcProp.refStartKey);
    const endArr = comUtil.gfnDataGetBindInfo(udcProp.refEndKey);

    scwin.rangeType = udcProp.rangeType || "";
    scwin.rangeValue = Number(udcProp.rangeValue) || 0;

    if (!comUtil.gfnIsEmpty(udcProp.baseDate)) {
        scwin.baseDate = udcProp.baseDate;
    }

    if (!comUtil.gfnIsEmpty(udcProp.rangeBaseDate)) {
        scwin.rangeBaseDate = udcProp.rangeBaseDate;
    }

    if (!comUtil.gfnIsEmpty(udcProp.useRangeBaseDate)) {
        scwin.useRangeBaseDate = (udcProp.useRangeBaseDate === "true") ? true : false;
    }

    if (!comUtil.gfnIsEmpty(startArr) && startArr.length > 0) {
        for (let idx in WebSquare.DataCollection.comp) {
            const obj = WebSquare.DataCollection.comp[idx];
            if (obj.initializeType == "dataMap") {
                if (obj.org_id == startArr.collectionId) {
                    const dataMap = $p.parent().$p.getComponentById(startArr.collectionId);
                    const dataPluginName = dataMap.options.pluginName;
                    const dataMapId = (dataPluginName === "aliasDataMap") ? dataMap.id : dataMap.getID();

                    if (!comUtil.gfnIsEmpty(s)) dataMap.set(startArr.refColumn, s);
                    ibxStrDay.setRef("data:" + dataMapId + "." + startArr.refColumn);
                    scwin.setInitDate(dataMap.get(startArr.refColumn), "");
                    if (!comUtil.gfnIsEmpty(endArr) && endArr.length > 0) {
                        if (!comUtil.gfnIsEmpty(e)) dataMap.set(endArr.refColumn, e);
                        ibxEndDay.setRef("data:" + dataMapId + "." + endArr.refColumn);
                        scwin.setInitDate("", dataMap.get(endArr.refColumn));
                    }
                }
            } else if (obj.initializeType == "dataList") {
                if (obj.org_id == startArr.collectionId) {
                    const dataList = $p.parent().$p.getComponentById(startArr.collectionId);
                    const dataPluginName = dataList.options.pluginName;
                    const dataListId = (dataPluginName === "aliasDataList") ? dataList.id : dataList.getID();

                    if (!comUtil.gfnIsEmpty(startArr) && startArr.length > 0) {
                        ibxStrDay.setRef("data:" + dataListId + "." + startArr.refColumn);
                    }

                    if (!comUtil.gfnIsEmpty(endArr) && endArr.length > 0) {
                        ibxEndDay.setRef("data:" + dataListId + "." + endArr.refColumn);
                    }
                }
            }
        }
    }

    if (comUtil.gfnIsEmpty(s) || comUtil.gfnIsEmpty(e)) {
        scwin.btnMnthColor();
        return false;
    }

    const dateDiff = WebSquare.date.dateDiffSilence(s, e);
    if (dateDiff >= 0) {
        scwin.btnMnthReset();
        scwin.setInitDate(s, e);
        scwin.btnMnthColor();
        return true;
    } else {
        return false;
    }
};

