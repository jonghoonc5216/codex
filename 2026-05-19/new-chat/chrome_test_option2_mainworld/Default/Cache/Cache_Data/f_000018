/********************************************************************************
 * 설명 : From-To 달력을 보여주거나 닫는다.
 ********************************************************************************/
scwin.showHide = function (type) {
    if (type === "show") {
        scwin.setCalColor();

        const frameHeight = (document.querySelector("#fs_content")) ? Number.parseInt(document.querySelector("#fs_content").getBoundingClientRect().height || 0) : Number.parseInt(grpCalRoot.scope_obj.getParentFrame().render?.getBoundingClientRect().height || 0);
        const parentRectHeight = Number.parseInt(grpCalRoot.scope_obj.getParentFrame().render?.getBoundingClientRect().top || 0) + frameHeight;
        grpCal.show();
        const calRectHeight = Number.parseInt(grpCal.render?.getBoundingClientRect().top || 0) + Number.parseInt(grpCal.render?.getBoundingClientRect().height || 0);

        if (calRectHeight > parentRectHeight) {
            grpCal.addClass("cal-inner-wrap-top");
        } else {
            grpCal.removeClass("cal-inner-wrap-top");
        }

        const myElement = document.querySelector(`#${grpCalRoot.getID()}>.cal-inner-wrap`);
        if (!comUtil.gfnIsEmpty(myElement) && myElement.style.display === "block") {
            const timeFunc = $p.setTimeout(function () {
                if (comUtil.gfnIsEmpty(timeFunc)) {
                    $p.clearTimeout("fromToCal");
                }

                const parentWidth = grpCalRoot.scope_obj.getParentFrame().render.getBoundingClientRect().width;
                const boundingRight = document.querySelector(`#${grpCalRoot.getID()}>.inputcal-fromto-wrap-inner`).getBoundingClientRect().left
                                      + document.querySelector(`#${grpCal.getID()}`).getBoundingClientRect().width
                                      - (($p.isWFramePopup(true)) ? grpCalRoot.scope_obj.getParentFrame().render.getBoundingClientRect().left : 0);

                if (boundingRight < parentWidth) {
                    myElement.style.right = "";
                    myElement.classList.remove("right-side");
                } else {
                    myElement.style.right = "0px";
                    myElement.classList.add("right-side");
                }
            }, { delay: 10, key: "fromToCal" });
        }

        document.addEventListener("mouseup", scwin.closeCal);
    } else if (type == "hideAll") {
        grpCal.hide();
        grpCal.removeClass("cal-inner-wrap-top");
        document.removeEventListener("mouseup", scwin.closeCal);
        scwin.btnMnthColor();
    }
};

/********************************************************************************
