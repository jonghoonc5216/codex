        btnMnth.deleteItem(9);
        btnMnth.deleteItem(8);
        btnMnth.deleteItem(7);
        btnMnth.deleteItem(6);
        btnMnth.deleteItem(5);
        btnMnth.deleteItem(4);
    } else if (dateRangeType === "month") {
        btnMnth.deleteItem(12);
        btnMnth.deleteItem(11);
        btnMnth.deleteItem(10);
        btnMnth.deleteItem(9);
        btnMnth.deleteItem(8);
        btnMnth.deleteItem(7);
        btnMnth.deleteItem(3);
        btnMnth.deleteItem(2);
        btnMnth.deleteItem(1);
        btnMnth.deleteItem(0);
    } else if (dateRangeType === "monthYear") {
        btnMnth.deleteItem(12);
        btnMnth.deleteItem(11);
        btnMnth.deleteItem(10);
        btnMnth.deleteItem(9);
        btnMnth.deleteItem(7);
        btnMnth.deleteItem(5);
        btnMnth.deleteItem(3);
        btnMnth.deleteItem(2);
        btnMnth.deleteItem(1);
        btnMnth.deleteItem(0);
    } else if (dateRangeType === "monthYear2") {
        btnMnth.deleteItem(12);
        btnMnth.deleteItem(11);
        btnMnth.deleteItem(10);
        btnMnth.deleteItem(9);
        btnMnth.deleteItem(7);
        btnMnth.deleteItem(3);
        btnMnth.deleteItem(2);
        btnMnth.deleteItem(1);
        btnMnth.deleteItem(0);
    } else if (dateRangeType === "year") {
        btnMnth.deleteItem(12);
        btnMnth.deleteItem(11);
        btnMnth.deleteItem(7);
        btnMnth.deleteItem(6);
        btnMnth.deleteItem(5);
        btnMnth.deleteItem(4);
        btnMnth.deleteItem(3);
        btnMnth.deleteItem(2);
        btnMnth.deleteItem(1);
        btnMnth.deleteItem(0);
    } else if (dateRangeType === "year2") {
        btnMnth.deleteItem(9);
        btnMnth.deleteItem(8);
        btnMnth.deleteItem(7);
        btnMnth.deleteItem(6);
        btnMnth.deleteItem(5);
        btnMnth.deleteItem(4);
        btnMnth.deleteItem(3);
        btnMnth.deleteItem(2);
        btnMnth.deleteItem(1);
        btnMnth.deleteItem(0);
    } else if (dateRangeType === "year3") {
        btnMnth.deleteItem(9);
        btnMnth.deleteItem(7);
        btnMnth.deleteItem(6);
        btnMnth.deleteItem(5);
        btnMnth.deleteItem(4);
        btnMnth.deleteItem(3);
        btnMnth.deleteItem(2);
        btnMnth.deleteItem(1);
        btnMnth.deleteItem(0);
    } else if (dateRangeType === "custom") {
        btnMnth.removeAll();
        let arrCustomRangeStr = scwin.customRangeStr.split("|");
        arrCustomRangeStr.forEach((str, idx) => {
            //*D(일), *M(개월), *Y(년), *W(주)
            if(/\dD/.test(str)) {
                btnMnth.addItem(Number(str.split("D")[0]) / 100, str.split("D")[0] + "일", idx);
            }
            else if(/\dM/.test(str)) {
                btnMnth.addItem(Number(str.split("M")[0]), str.split("M")[0] + "개월", idx);
            }
            else if(/\dY/.test(str)) {
                btnMnth.addItem(Number(str.split("Y")[0]) * 12, str.split("Y")[0] + "년", idx);
            }
            else if(/\dW/.test(str)) {
                btnMnth.addItem(Number(str.split("W")[0]) * 0.07, str.split("W")[0] + "주", idx);
            }
        });
    }

    const udcProp = $p.getOptions();
    scwin.prefixText = udcProp.prefixText || "";
    scwin.suffixText = udcProp.suffixText || "";

    btnMnth.getItemArray().forEach(item => {
        item.label = scwin.prefixText + item.label + scwin.suffixText;
    });
    btnMnth.redraw();
};

/********************************************************************************
 * 설명 : 최초 날짜 설정
 ********************************************************************************/
scwin.setInitDate = function (fromDate, toDate) {
    if (!comUtil.gfnIsEmpty(fromDate) && fromDate.length == 8 && !comUtil.gfnIsEmpty(toDate) && toDate.length == 8) {
        if (WebSquare.date.dateDiffSilence(fromDate, toDate) >= 0) {
            ibxStrDay.setValue(fromDate);
            ibxEndDay.setValue(toDate);

            calStart.gotoCalendar(fromDate);
            calEnd.gotoCalendar(toDate);

            scwin.calDisable("start", fromDate);
            scwin.calDisable("end", toDate);

            scwin.setCalColor();
        }
    } else if (!comUtil.gfnIsEmpty(fromDate) && fromDate.length == 8) {
        scwin.setStartDate(fromDate, "Y");
        scwin.setCalColor();
    } else if (!comUtil.gfnIsEmpty(toDate) && toDate.length == 8) {
        scwin.setEndDate(toDate, "Y");
        scwin.setCalColor();
    }
};

/********************************************************************************
 * 설명 : Start InputCalendar onblur 이벤트 핸들러
 ********************************************************************************/
scwin.ibxStrDay_onblur = async function (e) {
    if (ibxStrDay.getValue().length > 0) {
        const minYear = Number.parseInt(calStart.options.minYear);
        const maxYear = Number.parseInt(calStart.options.maxYear);
        const startYear = Number.parseInt(ibxStrDay.getValue().slice(0, 4));

        if (minYear > startYear || maxYear < startYear) {
            ibxStrDay.setValue("");
            await com.gfnAlert(["msg.fm.fma.formatDateBetween", "시작년도", minYear + " ~ " + maxYear + "년"]); // {0} (은)는 {1} 사이의 날짜여야 합니다
            ibxStrDay.focus();
            return;
        }

        if (!comUtil.gfnValidatDate(ibxStrDay.getValue())) {
            ibxStrDay.setValue("");
            await com.gfnAlert(["msg.alert.grd.formatDate", "yyyyMMdd"]);
            ibxStrDay.focus();
            return;
        }

        if (!comUtil.gfnIsEmpty(ibxStrDay.getValue()) && !comUtil.gfnIsEmpty(ibxEndDay.getValue())) {
            const dateDiff = WebSquare.date.dateDiffSilence(ibxStrDay.getValue(), ibxEndDay.getValue());
            if (dateDiff < 0) {
                ibxStrDay.setValue("");
                await com.gfnAlert(["warn.validation.EndDate"]);
                ibxStrDay.focus();
                return;
            }
        }

        const startDay = ibxStrDay.getFormattedValue();
        if (scwin.rangeType !== "" && scwin.rangeValue > 0 && startDay !== "") {
            const startDate = new Date(startDay);

            if (scwin.rangeType === "year") {
                startDate.setFullYear(startDate.getFullYear() + scwin.rangeValue);
            } else if (scwin.rangeType === "month") {
                startDate.setMonth(startDate.getMonth() + scwin.rangeValue);
            } else if (scwin.rangeType === "day") {
                startDate.setDate(startDate.getDate() + scwin.rangeValue - 1);
            }

            const rangeDate = startDate.format("yyyyMMdd");

            if (rangeDate < ibxEndDay.getValue()) {
                const rangeText = (scwin.rangeType === "year") ? "년" : (scwin.rangeType === "month") ? "개월" : "일";
                await com.gfnAlert(["msg.validation.DateFormat.RageDate.message", scwin.rangeValue, rangeText]);
                ibxEndDay.setValue(rangeDate);
                scwin.setEndDate(rangeDate, 'Y');
                return;
            }
        }

        // 시작일 - 이전 날짜 입력 금지
        if (scwin.calStartDisableBeforeDate !== "") {
            if (ibxStrDay.getValue() < scwin.calStartDisableBeforeDate) {
                ibxStrDay.setValue("");
                await com.gfnAlert(["warn.validation.DisableDate"]);
                ibxStrDay.focus();
                return;
            }
        }

        // 시작일 - 이후 날짜 입력 금지
        if (scwin.calStartDisableAfterDate !== "") {
            if (ibxStrDay.getValue() > scwin.calStartDisableAfterDate) {
                ibxStrDay.setValue("");
                await com.gfnAlert(["warn.validation.DisableDate"]);
                ibxStrDay.focus();
                return;
            }
        }
    }

    scwin.btnMnthReset();

    if (ibxStrDay.getValue() === "") {
        ibxStrDay.setValue("");
        //scwin.setStartDate(calStart.getDate(), "Y");
    } else {
        scwin.setStartDate(ibxStrDay.getValue(), "Y");
    }

    scwin.btnMnthColor();
};

