scwin.btnCalendar_onclick = function(e) {
    const frameHeight = (document.querySelector("#fs_content")) ? Number.parseInt(document.querySelector("#fs_content").getBoundingClientRect().height || 0) : Number.parseInt(grpCalRoot.scope_obj.getParentFrame().render?.getBoundingClientRect().height || 0);
    const parentRectHeight = Number.parseInt(grpCalRoot.scope_obj.getParentFrame().render?.getBoundingClientRect().top || 0) + frameHeight;

    scwin.initCalendar();

    const disp = boxYearMonth.getStyle('display');
    if (disp === 'none') {
        const calRectHeight = Number.parseInt(boxYearMonth.render?.getBoundingClientRect().top || 0) + Number.parseInt(boxYearMonth.render?.getBoundingClientRect().height || 0);

        if (calRectHeight > parentRectHeight) {
            boxYearMonth.addClass("cal-inner-wrap-year-month-top");
        } else {
            boxYearMonth.removeClass("cal-inner-wrap-year-month-top");
        }

        const myElement = boxYearMonth.render;
        const boundingRight = inputCalendar.render.getBoundingClientRect().left
                            + boxYearMonth.render.getBoundingClientRect().width;   
        let parentWidth = 0;
        if (com.gfnIsPopup(true)) {
            parentWidth = $p.parent().$p.getFrame().render.getBoundingClientRect().right;

            document.body.appendChild(boxYearMonth.render);
            boxYearMonth.render.style.top = grpCalRoot.render?.getBoundingClientRect().top + 33 + "px";
            boxYearMonth.render.style.left = grpCalRoot.render?.getBoundingClientRect().left + "px";
            boxYearMonth.render.style["z-index"] = "6011";
        } else {
            parentWidth = (window.innerWidth || document.documentElement.clientWidth);
        }
        
        if (boundingRight < parentWidth ) {
            myElement.style.right = "";
            myElement.classList.remove("right-side");
        } else {
            myElement.style.right = "0px";
            myElement.classList.add("right-side");
        }

        // 화면 외부 클릭시 닫히게 처리.
        document.addEventListener('mouseup', scwin.closeCal);

        if ($p.isWFramePopup(true)) {
            boxYearMonth.render.style.position = "fixed";
        }

        boxYearMonth.show();
    } else {
        if ($p.isWFramePopup(true)) {
            boxYearMonth.render.style.position = "absolute";
        }

        boxYearMonth.hide();
    }    

};

/********************************************************************************
 * 설명 : 화면 외부 클릭시 닫히게 처리.
 ********************************************************************************/
scwin.closeCal = function(e){
    let closeDiv = true;
	
    if (e.target == document.querySelector(`#${boxYearMonth.getID()}.cal-inner-wrap-year-month`)) {
        closeDiv = false;
    }

    if (document.querySelector(`#${boxYearMonth.getID()}.cal-inner-wrap-year-month`).contains(e.target)) {
        closeDiv = false;
        // 월 버튼을 선택했으면 닫을 것.
        document.querySelectorAll(`#${boxYearMonth.getID()} input.btn.year-month`).forEach(function(o, i) {
            if (o == e.target) {
                closeDiv = true;
            }
        });
    }
    
    if (closeDiv) {
        boxYearMonth.hide();
        document.removeEventListener('mouseup', scwin.closeCal);
    }
};

