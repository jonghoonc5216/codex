@charset "utf-8";
/* 웹접근성 관련 본문처리 */
.skip-nav {position: relative;z-index: 1000;display: block;overflow: hidden;height: 0;background: #000000;text-align: center;}
.skip-nav:focus {height: auto;padding:1rem;color:#ffffff;}
.portal {height: 100%; display: flex; flex-direction: column}
.portal > .section.gnb {flex: none;}
.portal > .section.navigation {flex: none;}
.portal > .container-layout {flex: 1 1 auto;}
.portal > .section.rnb {flex: none;}
.portal > .section.footer {flex: none;}

.scrollable .portal:before {content: ""; z-index: 100; position: fixed; bottom: 3.0rem; left: 50%; width: 3.0rem; height: 3.6rem; transform: translateX(-50%);
  animation: moveMouseBottom 2s infinite; background: url('/kn/com/images/portal/main/ic_mouse_footer.svg') no-repeat 0 center;}

.portal.has-scroll:before {content: ""; z-index: 100; position: fixed; bottom: 3.0rem; left: 50%; width: 3.0rem; height: 3.6rem; transform: translateX(-50%);
  animation: moveMouseBottom 2s infinite; background: url('/kn/com/images/portal/main/ic_mouse_footer.svg') no-repeat 0 center;}

.portal {padding-top: 15.8rem;}

.section.gnb {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: transparent;
    z-index: 100;
    transition: transform 0.2s ease-in-out;
}
.portal.gnb-fixed {}
.portal.gnb-fixed .section.gnb {transform: translateY(-11.4rem);}
.portal.scrolled-to-top .section.gnb,
.portal.gnb-fixed.sitemapAct .section.gnb {transform: translateY(0);}

.gnb-area {
    /* position: fixed;
    top: 0;
    width: 100%; */
    position: relative;
}

.gnb-area .gnb-top-wrapper {background-color: #f4f6f7;}

.mobile-top-wrap {display: none;}
.mobile-ctrl-wrap {display: none;}

.gnb-top-wrap {
  display: flex;
    align-items: center;
    max-width: 160rem;
    min-height: 5.0rem;
    margin: 0 auto;
    background-color: transparent;
}

.gnb-top-wrap .btn {height: 3.8rem; border: 0;}

.gnb-top-wrap .btn.menu-open {position: absolute; top: 0rem;}
.btn.menu-open.active:after {width: 0;}
.btn.menu-open.active span:before {width: 2.4rem; top: 0.7rem; transform: rotate(-45deg);}
.btn.menu-open.active span:after {width: 2.4rem; bottom: 0.7rem; transform: rotate(45deg);}

.btn.menu-open {
    display: none;
    position: relative;
    width: 3.8rem;
    height: 5.0rem;
    font-size: 0;
    color: transparent;
    padding: 1.8rem 0.8rem;
    transition: all 0.4s;
}
.btn.menu-open:after {
    content: "";
    position: absolute;
    top: 2.5rem;
    left: 0.8rem;
    width: 2.2rem;
    height: 0.2rem;
    margin: auto 0;
    background-color: #272626;
    transition: all 0.4s;
}
.btn.menu-open span {
    position: absolute;
    width: 2.2rem;
    height: 1.6rem;
    color: transparent;
    font-size: 0;
}
.btn.menu-open span:before,
.btn.menu-open span:after {
    content: "";
    position: absolute;
    left: 0;
    width: 2.2rem;
    height: 0.2rem;
    background-color: #272626;
    transition: all 0.4s;
}
.btn.menu-open span:before {top: 0;}
.btn.menu-open span:after {bottom: 0;}

.btn.menu-open.service-menu {width: auto; height: auto; font-size: 1.4rem; color: #333333; padding: 0rem 1.2rem;}
.btn.menu-open.service-menu:after {content: none;}
.btn.menu-open.service-menu span {position: static; width: auto; height: auto; color: inherit; font-size: inherit;}
.btn.menu-open.service-menu span:before, .btn.menu-open.service-menu span:after {content: none;}

.gnb-top-wrap .inner.service-site {display: inline-block; background-color: transparent; white-space: nowrap;}
.gnb-top-wrap .inner.service-site > li {display: inline-block;}

.gnb-top-wrap .inner.service-site .btn {display: inline-flex; position: relative; align-items: center;
    color: #333333; height: 5.0rem; font-size: 1.4rem; font-weight: 500;
    padding: 0 1.2rem; vertical-align: middle; line-height: 2.6;}

.gnb-top-wrap .inner.service-site .btn:before {
    content: "";
    position: absolute;
    top: auto;
    left: 50%;
    bottom: -0.1rem;
    bottom: 0rem;
    width: 0;
    background-color: transparent;
    opacity: 1;
    border-bottom: 0.2rem solid transparent; transform: translateX(-50%);
    transition: all 0.4s ease-in-out;
}

.gnb-top-wrap .inner.service-site .btn:hover:before {
    content: "";
    position: absolute;
    top: auto;
    left: 50%;
    bottom: -0.1rem;
    bottom: 0rem;
    width: 0;
    background-color: transparent;
    opacity: 1;
    border-bottom: 0.2rem solid transparent; transform: translateX(-50%);
    transition: all 0.4s ease-in-out;
    width: calc(100% - 3.2rem); border-bottom: 0.2rem solid #1f67c0;
}

.gnb-top-wrap .inner.service-site .btn.on {background-color: transparent;}

.gnb-top-wrap .inner.service-site .btn.on:before, .gnb-top-wrap .inner.service-site .btn.on:hover:before {transform: none;}

.gnb-top-wrap .inner.service-site .btn.on:before {left: 0; right: 0; width: 100%; border-bottom: 0.2rem solid #1755a1;}

/* 우측 서비스 버튼 영역 */
.gnb-top-wrap .inner.right {display: inline-flex; align-items: center; float: right; background-color: transparent; white-space: nowrap;}
.gnb-top-wrap .inner.right .btn {position: relative; color: transparent; width: 3.4rem; height: 3.4rem; font-size: 0; font-weight: 400;
    margin: 0; padding: 0; background-color: transparent; background-size: 1.8rem; background-repeat: no-repeat; background-position: center; border-radius: 50%;}
.gnb-top-wrap .inner.right .btn:before {content: ""; position: absolute;}
/* 우측 서비스 사용자 정보 영역 */
.user-info-wrap {
    display: inline-flex;
    align-items: center;
    font-size: 1.6rem;
    padding: 0 0.2rem;
}
.user-info-wrap .name {color: #4876ef; font-size: 1.8rem; font-weight: 500; margin-right: 0.4rem;}
.user-info-wrap .time {font-size: 1.4rem; margin-left: 2.0rem; min-width: 4.5rem;}


/* 로그인, 로그아웃, 인증센터, 나라장터서비스 툴팁 스타일 */
.login-wrap, .logout-wrap, .second-security-wrap, .security-center-wrap, .my-user-wrap, .ctrl-font-wrap {
    position: relative; /* margin: 0 0 0 1.4rem;  */z-index: 3;
}

.login-wrap .tooltip, .logout-wrap .tooltip, .second-security-wrap .tooltip, .security-center-wrap .tooltip,
.my-user-wrap .tooltip, .ctrl-font-wrap .tooltip {
    display: inline-block;
    visibility: hidden;
    opacity: 0;
    position: absolute;
   /*  top: 4.4rem; */
    top: 4.1rem;
    left: 55%;
    color: #000000;
    font-size: 1.4rem;
    padding: 0.9rem 1.8rem;
    transform: translateX(-50%);
    transition: all 0.2s ease-in-out;
    background-color: #ffffff;
    border: 1px solid #4876ef;
    border-radius: 0.4rem;
    box-shadow: 0 0.3rem 0.6rem rgba(0, 0, 0, 10%);
    transform: translateX(-50%);
}

.login-wrap .tooltip:before,
.logout-wrap .tooltip:before,
.second-security-wrap .tooltip:before,
.security-center-wrap .tooltip:before,
.my-user-wrap .tooltip:before,
.ctrl-font-wrap .tooltip:before {
    content: "";
    position: absolute;
    top: -0.7rem;
    left: 50%;
    right: auto;
    bottom: auto;
    width: 0;
    height: 0;
    border-left: 0.5rem solid transparent;
    border-right: 0.5rem solid transparent;
    border-bottom: 0.7rem solid #4876ef;
    transform: translateX(-50%);
}

.login-wrap .tooltip:after,
.logout-wrap .tooltip:after,
.second-security-wrap .tooltip:after,
.security-center-wrap .tooltip:after,
.my-user-wrap .tooltip:after,
.ctrl-font-wrap .tooltip:after {
    content: "";
    position: absolute;
    top: -0.5rem;
    left: 50%;
    right: auto;
    bottom: auto;
    width: 0;
    height: 0;
    border-left: 0.5rem solid transparent;
    border-right: 0.5rem solid transparent;
    border-bottom: 0.7rem solid #ffffff;
    transform: translateX(-50%);
}

.login-wrap .btn:hover ~ .tooltip,
.logout-wrap .btn:hover ~ .tooltip,
.second-security-wrap .btn:hover ~ .tooltip,
.security-center-wrap .btn:hover ~ .tooltip,
.my-user-wrap .btn:hover ~ .tooltip,
.ctrl-font-wrap .btn:hover ~ .tooltip {
    visibility: visible; opacity: 1; z-index: 3;
}

