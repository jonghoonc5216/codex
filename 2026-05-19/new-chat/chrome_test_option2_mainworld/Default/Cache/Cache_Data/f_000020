    font-size: 1.6rem;
    text-align: left;
    background-color: #ffffff;
    border: 0.1rem solid #4876ef;
    border-radius: 0.4rem;
    box-shadow: 0 0.3rem 0.6rem rgba(0, 0, 0, 10%);
}
.my-user-wrap .popup-content.my-user.appear {display: block;}

.my-user-wrap .popup-content.my-user:before {
    content: "";
    position: absolute;
    top: -0.9rem;
    left: auto;
    right: 6.35rem;
    bottom: auto;
    width: 0;
    height: 0;
    border-left: 0.7rem solid transparent;
    border-right: 0.7rem solid transparent;
    border-bottom: 0.9rem solid #4876ef;
}
.my-user-wrap .popup-content.my-user:after {
    content: "";
    position: absolute;
    top: -0.9rem;
    left: auto;
    right: 6.4rem;
    bottom: auto;
    width: 0;
    height: 0;
    border-left: 0.6rem solid transparent;
    border-right: 0.6rem solid transparent;
    border-bottom: 0.8rem solid #ebf1fa;
}

.my-user-wrap .popup-content.my-user .header-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #4876ef;
    font-weight: 500;
    padding: 0.9rem 1.4rem 0.9rem 1.4rem;
    border-bottom: 0.1rem solid #dededf;
    background-color: #f3f4f5;
    border-top-left-radius: 0.4rem;
    border-top-right-radius: 0.4rem;
    /* background: #ebf1fa url('/kn/com/images/portal/gnb/ic_basket.svg') no-repeat 1.2rem center;
    background-size: 2.0rem; */
}
.my-user-wrap .popup-content.my-user .header-wrap .title {float: left;}
.my-user-wrap .popup-content.my-user .btn.close {position: absolute;top: 1rem;right: 1rem;width: 2.0rem;height: 2.0rem;
    background: url(/kn/com/images/portal/gnb/ic_close.svg) no-repeat center;background-size: 1.6rem;}

.my-user-wrap .popup-content.my-user .content-wrap {
    font-size: 1.4rem;
    padding: 0rem;
    border-bottom-left-radius: 0.4rem;
