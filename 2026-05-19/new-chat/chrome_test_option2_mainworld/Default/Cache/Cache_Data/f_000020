/* 나의 나라장터 토글 레이어팝업 begin */
.appear {animation: fade-in 0.3s; animation-fill-mode: forwards;}
.disappear {animation: fade-out 0.3s; animation-fill-mode: forwards;}

@keyframes fade-in {
    from {opacity: 0;}
    to {opacity: 1;}
}

@keyframes fade-out {
    from {opacity: 1;}
    to {opacity: 0;}
}


/* 나라장터 서비스 */
.my-user-wrap .popup-content.my-user {
    display: none;
    position: absolute;
    top: 4.2rem;
    /* right: -5.4rem; */
    right:0;/*텍스트 추가로인한 위치 변경  */
