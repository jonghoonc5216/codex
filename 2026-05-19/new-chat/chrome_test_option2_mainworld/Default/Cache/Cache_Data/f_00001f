.log-in-wrap .tit-greeting {color: #191919;font-size: 2.6rem;}
.login-guide-cmt {font-size: 1.8rem; font-weight: 400; text-align: center; margin-top: 0rem;}
.login-guide-cmt em {color: #4876ef; font-weight: 500;}
.log-in-wrap .wq_tbc {margin-top: 2.0rem;}

.w2wframe.popupParent .log-in-wrap {padding-top: 7rem; padding-left: 2rem; padding-right: 2rem;}

/* 로그인 탭 중앙정렬  */
.log-in-wrap .wq_tbc .w2tabcontrol_tabhost {display: flex; justify-content: center; flex-direction: row;}
.log-in-wrap .w2tabcontrol .w2tabcontrol_tabhost li {min-width:167px;}

.w2wframe.popupParent .log-in-wrap .wq_tbc .w2tabcontrol_tabhost {width:100%;}
.w2wframe.popupParent .log-in-wrap .w2tabcontrol .w2tabcontrol_tabhost li {min-width:137px; width:100%;}

.log-in-wrap .w2tabcontrol .w2tabcontrol_tabhost li.w2tabcontrol_active {background-color: #ffffff;z-index: 1;}
.log-in-wrap .w2tabcontrol .w2tabcontrol_tabhost .w2tabcontrol_tab_center a {width: auto;min-width: auto;}
.log-in-wrap .w2tabcontrol .w2tabcontrol_container {top: 0rem; padding: 0rem;}
.log-in-wrap .w2tabcontrol .w2tabcontrol_contents_wrapper {padding: 0rem;}
/* .log-in-wrap .w2tabcontrol .login-content {display: flex; flex-direction: column; justify-content: center;} */
.log-in-wrap .login-content,
.login-content {min-height: 42.0rem; display: flex; flex-direction: column; /*justify-content: center;*/ padding: 8.0rem 0 0; border: 0;}
.login-content .inner-wrap,
.log-in-wrap .login-content .inner-wrap {min-width: 48rem;margin-left: auto; margin-right: auto; margin-bottom: 2.0rem; max-width: fit-content;}

.log-in-wrap .login-content .desc li ~ li {margin-top: 0.6rem;}
.log-in-wrap .desc li, .login-content .desc li {position: relative;padding-left: 1.2rem;}
.log-in-wrap .desc li:before, .login-content .desc li:before {content:'ㆍ';position: absolute;top: 0;left: -0.4rem;}
.log-in-wrap .desc li.set-radio, .login-content .desc li.set-radio li {padding-left:0}
.log-in-wrap .desc li.set-radio:before, .login-content .desc li.set-radio li:before {content: '';}

/* 변경 아이디비번찾기  */
.login-content .login_inner {display: flex !important; flex-flow: row wrap;align-items: flex-start;justify-content: center;}
.login-content .login_inner .btn.cellphone, .login-content .login_inner .btn.selfphone, .login-content .login_inner .btn.simple, .login-content .login_inner .btn.email {display: flex; align-items: center; padding-left:11.4rem;line-height: 1.3;}
.login-content .login_inner .btn span:not(.icon) {min-width:16.7rem;padding-right:0;}
.login-content .search-box {margin-top:-2.5rem}
.login-content .search-box .search-text {font-size: 2.8rem;text-align: center;margin-bottom: 3.0rem; color:#495057;}
.login-content .search-box .search-text > span {color:#4876ef; font-size: 3.3rem;}
.login-content .search-box .btn span:not(.icon) {background:none;}
.login-content .search-box .idpw-find {display: flex;justify-content: center; align-items: center;}


