/**
 * Slide 접기/펄치기 이벤트
 *
 * @memberOf chatbot
 * @date 2024.05.16
 * @param 해당 태그 이벤트
 * @return
 * @author 백지훈
 * @example
		chatbot.slideOpenHide(event)
 */
chatbot.slideOpenHide = function ( e ) {
	const parentaSlideCardGrp = $(e.target).parent().parent();
	const slideCardGrpClass = parentaSlideCardGrp.attr('class');
	const qTxt = $(e.target).parent().prev().find('div._qTxtGrup > div');
	const aTxt = $(e.target).parent().prev().find('div._aTxtGrup > span._aTxt');
	
	const CLASS_OPEN = "_open";
	
	if ( slideCardGrpClass.match(CLASS_OPEN) ) {
		parentaSlideCardGrp.removeClass(CLASS_OPEN);
		aTxt.scrollTop(0);
		aTxt.attr('style', chatbot.slideStyleLineClamp(qTxt.text()));
	} else {
		parentaSlideCardGrp.addClass(CLASS_OPEN);
		aTxt.attr('style', '');
	}
}


/**
 * 질문 byte 무시하고 길이에 따라 스타일 처리
 *
 * @memberOf chatbot
 * @date 2024.05.16
 * @param 질문내용
 * @return 스타일 설정
 * @author 백지훈
 * @example
		chatbot.slideStyleLineClamp(질문내용)
 */
chatbot.slideStyleLineClamp = function ( str ) {
	const lineClamp = 7 - Math.ceil(str.length / 24);
	
	let webkitLineClamp = "-webkit-line-clamp: " + lineClamp;
	let maxHeight = "max-height: " + (21 * lineClamp) + "px";
	
	let resultStyle = "".concat(webkitLineClamp, ";", maxHeight);
		
	return resultStyle;
}

