					const qTxtGrpSpan = chatbot.createEl("span", "_bullet", null, null);
					slideQTxtGrp.appendChild(qTxtGrpSpan);
					
					const qTxtGrpDiv = chatbot.createEl("span", "", comUtil.gfnIsNotEmpty(url) ? "" : question, null);
					if ( comUtil.gfnIsNotEmpty(url) ) {		// URL 값 있을시
						const qTxtA = chatbot.createEl("a", "_qLink", "", null);
						// 대화이력 링크 못하게 주석
