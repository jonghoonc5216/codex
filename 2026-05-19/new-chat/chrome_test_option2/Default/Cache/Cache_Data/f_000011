			let cpGrpUl = chatbot.createEl("ul", null, null, null);
			
			// 컴포넌트 그룹 DIV 생성
			let txtGrpDiv = null;			// 텍스트 목록일 경우 그룹 생성
			let menuGrpDiv = null;			// 1depth일 경우 그룹 생성
			let swiperContainerDiv = null;	// 슬라이더 부모 그룹 생성
			let swiperWrapperDiv = null;	// 슬라이더 부모의 자식 그룹 생성
