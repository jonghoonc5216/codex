/**
 * 최초시 챗봇 API
 *
 * @memberOf chatbot
 * @date 2024.04.22
 * @param 
 * @return 
 * @author 백지훈
 * @example
		chatbot.firstChatApi()
 */
chatbot.firstChatApi = async function () {
	// // fetch 방식
    const nowTime = new Date().getTime();
    
    const sbmOption = {
		method: "POST",
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({"timestamp": nowTime, "message": "hello", "chatArea": chatbot.chatArea}),
    };

    try {
    	const res = await fetch('/ku/kun/kuna/chatstart', sbmOption);
    	
    	const data = await res.json();
    	
    	if ( comUtil.gfnIsNotEmpty(data) ) {
    		if ( comUtil.gfnIsNotEmpty(data.status) ) {
    			if ( data.status !== 200 ) {
    				chatbot.serverErr = true;
    			}
    		} else {
    			// 데이터가 있을경우 세션 저장
    			chatbot.saveSession(data);
    			
    			// 홈페이지 타입 설정
    			chatbot.setChatArea();
    			
    			chatbot.oneDepth = false;
    		}
    	}
    } catch {
    	chatbot.errMsg();
    }
}


/**
 * 홈페이지 종류 설정
 *
 * @memberOf chatbot
 * @date 2024.04.22
 * @param 
 * @return 
 * @author 백지훈
 * @example
		chatbot.setChatArea()
 */
chatbot.setChatArea = function () {
	const chatArea = chatbot.chatArea;
	
	if ( chatArea === "나라장터" || chatArea === "nara" ) {
		chatbot.chatAreaJs = "nara";
	} else if ( chatArea === "데이터허브" || chatArea === "datahub" ) {
		chatbot.chatAreaJs = "datah";
	} else if ( chatArea === "벤쳐나라" || chatArea === "venture" ) {
		chatbot.chatAreaJs = "vent";
	} else if ( chatArea === "쇼핑몰" || chatArea === "shop" ) {
		chatbot.chatAreaJs = "shop";
	} else {
		chatbot.chatAreaJs = "nara";
	}
}


