						chatbot.updateEl(depthTag, depthTag.getAttribute("class") + " " + url);
					} else {
						const urlBasic = chatbot.chatTabType === "1" ? "Faq_basic" : "UsManl_basic"; 
						chatbot.updateEl(depthTag, depthTag.getAttribute("class") + " " + urlBasic);
					}
					
					// Active 처리
					chatbotMng.btnActive(depthTag, chatbotMng.userText, title);
					
					bbleTag.appendChild(depthTag);
				} else if ( cpType === "textlist" ) {	// 보고서 리스트
					const textSpan = chatbot.createEl("span", null, url, null);
					bbleTag.appendChild(textSpan);
				}
				
				// 슬라이더 아닐경우 input에 Ul로 담기
				if ( cpType !== "slidelist" ) {
					if ( cpType === "image" )  {
						//const img = chatbot.createEl("img", "", url, null);
						//cpGrpUl.appendChild(img);
						const aImgNewTab = chatbot.createEl("a", (chatbot.isApplyImgNewTab(url) ? "imgNewTab" : "imgNoTab"), url, null);
						const img = chatbot.createEl("img", "", url, null);
						aImgNewTab.appendChild(img);
						cpGrpUl.appendChild(aImgNewTab);
					} else {
						cpGrpUl.appendChild(bbleTag);
					}
						
				}
			}
			
			// chbtContAreaDiv Append Child 
			// 슬라이더 일 경우
			if ( cpType === "slidelist" ) {
				// swiper pagination div
				const swiperPaginationDiv = chatbot.createEl("div", "swiper-pagination _circle_pageNtn", null, null);
				
				// 이전, 다음 그룹 DIV
				const swiperControlBtnDiv = chatbot.createEl("div", "_contrlBtn", null, null);
				
				// 오른쪽 화살표
				const swiperBtnNextDiv = chatbot.createEl("input", "swiper-button-next btnNext chatbot-nav", null, null);
				// 왼쪽 화살표
				const swiperBtnPrevDiv = chatbot.createEl("input", "swiper-button-prev btnPrev chatbot-nav", null, null);
				
				swiperControlBtnDiv.appendChild(swiperBtnNextDiv);
				swiperControlBtnDiv.appendChild(swiperBtnPrevDiv);
				
				swiperContainerDiv.appendChild(swiperControlBtnDiv);
				
				swiperContainerDiv.appendChild(swiperWrapperDiv);
				swiperContainerDiv.appendChild(swiperPaginationDiv);
				
				chbtContAreaDiv.appendChild(swiperContainerDiv);
			} else if ( cpType === "text" ) {		// 텍스트 목록인 경우
				if ( txtGrpDiv !== null ) {
					txtGrpDiv.appendChild(cpGrpUl);
					chbtContAreaDiv.appendChild(txtGrpDiv);				
				}
			} else if ( cpType === "1depth" ) {		// 1depth 일경우
				if ( menuGrpDiv !== null ) {
					menuGrpDiv.appendChild(cpGrpUl);
					chbtContAreaDiv.appendChild(menuGrpDiv);				
				}
			} else if ( cpType === "textlist" ) {	// 데이터 허브 - 보고서 리스트
				reportGrpDiv.appendChild(cpGrpUl);
				chbtContAreaDiv.appendChild(reportGrpDiv);
			} else {								// 나머지 
				chbtContAreaDiv.appendChild(cpGrpUl);
			}
		}
	}
	
	return chbtContAreaDiv;
}


/**
 * 버튼 활성화 처리
 *
 * @memberOf chatbotMng
 * @date 2024.07.08
 * @param 
 * 			el			해당 태그
 * 			userText	다음 사용자 입력
 * 			title		해당 버튼
 * @return component Html
 * @author 백지훈
 * @example
		chatbotMng.btnActive()
 */
chatbotMng.btnActive = function(el, userText, title) {
	// Active 처리
	if ( comUtil.gfnIsNotEmpty(userText) ) {
		if ( userText.lastIndexOf(title) > -1 ) {
			chatbot.updateEl(el, el.getAttribute("class") + " _active");
		}
	}
}


/**
 * 사용자 입력 문자열 매칭시 문자열 변경 처리
 *
 * @memberOf chatbotMng
 * @date 2024.07.08
 * @param 	txt		사용자 입력 문자열			
 * @return 문자열 변경
 * @author 백지훈
 * @example
		chatbotMng.userTextReplace(txt)
 */
chatbotMng.userTextReplace = function (txt) {
	switch (txt) {
	case "/back_to_top":
		txt = "처음으로";
		break;
	case "/back_to_prev":
		txt = "이전으로";
		break;
	}
	
	return txt;
}


/**
 * Swiper 적용
 *
 * @memberOf chatbot
 * @date 2024.04.22
 * @param 
 * @return new Swiper 초기 셋팅
 * @author 백지훈
 * @example
		chatbot.swiperSetting()
 */
chatbotMng.swiperSetting = function () {
	if ( $(".swiper-container._cardListGrup.chatbothistSwiper").length > 0 ) {
		new Swiper('.swiper-container._cardListGrup.chatbothistSwiper', {
			slidesPerView: "auto",
			spaceBetween: 20,
			centeredSlides: false,
			observer: true,
			observeParents: true,
			threshold: 20,		// 마우스 민감도 숫자 올리면 민감도 떨어짐
			navigation: {
				nextEl: '.swiper-button-next.btnNext.chatbot-nav',
				prevEl: '.swiper-button-prev.btnPrev.chatbot-nav',
			},
			pagination: {
				el: '.swiper-pagination._circle_pageNtn',
				dynamicBullets: true
			},
		});
	}
}


/**
 * 날짜 포맷 처리(하이픈)
 *
 * @memberOf chatbot
 * @date 2024.05.03
 * @param 
 * @return 포맷된 데이터 값
 * @author 백지훈
 * @example
		chatbot.getDateFormat()
 */
chatbot.getDateFormatHyphen = function ( sDate ) {
	let output = "";
	if ( sDate.length === 8 ) {
		output = sDate.substring(0, 4) + "-" + sDate.substring(4, 6) + "-" + sDate.substring(6, 8);
	} else {
		output = sDate;
	}
	
	return output;
}
