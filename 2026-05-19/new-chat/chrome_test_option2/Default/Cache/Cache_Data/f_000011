chatbotMng.assisantComponent = function ( resObj ) {
	const chbtContAreaDiv = chatbot.createEl("div", "chbtContArea", null, null);
	
	// Reponse 값 있는지 체크
	if ( comUtil.gfnIsNotEmpty(resObj) ) {
		const contents = resObj.contents;
