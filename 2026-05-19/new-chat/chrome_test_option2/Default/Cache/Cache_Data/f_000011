				// 왼쪽 화살표
				const swiperBtnPrevDiv = chatbot.createEl("input", "swiper-button-prev btnPrev chatbot-nav", null, null);
				
				swiperControlBtnDiv.appendChild(swiperBtnNextDiv);
				swiperControlBtnDiv.appendChild(swiperBtnPrevDiv);
				
				swiperContainerDiv.appendChild(swiperControlBtnDiv);
				
				swiperContainerDiv.appendChild(swiperWrapperDiv);
				swiperContainerDiv.appendChild(swiperPaginationDiv);
				
				chbtContAreaDiv.appendChild(swiperContainerDiv);
			} else if ( cpType === "text" ) {		// 텍스트 목록인 경우
				if ( txtGrpDiv !== null ) {
					txtGrpDiv.appendChild(cpGrpUl);
					chbtContAreaDiv.appendChild(txtGrpDiv);
