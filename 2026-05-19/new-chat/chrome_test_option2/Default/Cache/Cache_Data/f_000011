	// response
	chatbotMng.responsesArr = datas.responses;
	
	// data
	chatbotMng.responseDataObj = datas.data;
	
	// 다음 데이터
	chatbotMng.nextRequestUserObj = comUtil.gfnIsNotEmpty(nextDatas) ? nextDatas : null;
	
	$(el).append(chatbotMng.chatbotHistsGroup('question'));		// 사용자 입력
	$(el).append(chatbotMng.chatbotHistsGroup('answer'));		// 응답
	
	return el;
}


/**
 * 챗봇 대화이력_사용자 입력 컴포넌트 question
 * 챗봇 대화이력_응답 컴포넌트		answer
 *
 * @memberOf chatbotMng
 * @date 2024.07.08
 * @param gubun 구분
 * 		question	사용자입력
 * 		answer		응답
 * @return html
 * @author 백지훈
 * @example
		chatbot.chatbotHistsGroupQ()
*/
chatbotMng.chatbotHistsGroup = function ( gubun ) {
	/**
	 * 1 사용자 타입에 따라 FAQ, 사용자매뉴얼 선택
	 */
	chatbotMng.setChatTypeTxt(chatbotMng.requestUserObj);
	
	
	/**
	 * 2. 사용지 입력, 응답 구분에 따라 컴포넌트 생성 처리
	 */
	let msgGrpDiv = null;
	if ( gubun === "question" ) {				// 사용자 입력 컴포넌트
		// 메시지 그룹 묶어서 DIV 생성
		msgGrpDiv = chatbot.createEl("div", "usr_chat", null, null);
		
		const requestUserObj = chatbotMng.requestUserObj;
		
		// 사용자 입력
		msgGrpDiv.appendChild(chatbotMng.userComponent(requestUserObj));
		
	} else if ( gubun === "answer") {			// 응답 컴포넌트
		msgGrpDiv = chatbot.createEl("div", "g2b_chat", null, null);
		
		if ( comUtil.gfnIsNotEmpty(chatbotMng.responsesArr) ) {
			// 메시지 그룹 묶어서 DIV 생성
			
			const responsesArr = chatbotMng.responsesArr;
			const responseDatasArr = chatbotMng.responseDatasArr;
			
			// 응답
			// TEXT, Contents 배열담기
			let resTexts = [];
			let resContents = [];
			
			if ( responsesArr.length > 0 ) {
				const len = responsesArr.length;
				// 먼저 TEXT 일경우 배열 저장
				for ( let i = 0; i < len; i++ ) {
					const resObj = responsesArr[i];
					
					if ( chatbotMng.chatAreaJs === "데이터허브" && chatbotMng.chatTabType === "1" ) {			// 데이터허브 일경우
						if ( comUtil.gfnIsNotEmpty(resObj.contents ) ) {
							for ( let c in resObj.contents ) {
								const resObjContentObj = resObj.contents[c];
								if ( resObjContentObj.type === "pretext" ) {
									resTexts.push(resObjContentObj);
								}
							} 
						} else {
							if ( comUtil.gfnIsNotEmpty(resObj.text) ) {
								resTexts.push(resObj);
							}	
						}
					} else {					// 나머지 기존 대로
						// Text 일경우
						if ( comUtil.gfnIsNotEmpty(resObj.text) ) {
							resTexts.push(resObj);
						}
						
					}
					
					// Contents 일경우
					if ( comUtil.gfnIsNotEmpty(resObj.contents) ) {
						resContents.push(resObj);
					}
					
					/* OLD
					// Text 일경우
					if ( comUtil.gfnIsNotEmpty(resObj.text) ) {
						resTexts.push(resObj);
					}
					*/
				}
				
				// TEXT 시작
				msgGrpDiv.appendChild(chatbotMng.assisantTexts( resTexts ));
				
				// Contents 시작
				for ( let i = 0; i < resContents.length; i++ ) {
					const resObj = resContents[i];
					
					let contentsType = null;
					if ( comUtil.gfnIsNotEmpty(resObj.contents) ) {
						if ( comUtil.gfnIsNotEmpty(resObj.contents[0].type) ) {
							contentsType = resObj.contents[0].type;
						}
						
						// 컴포넌트 Contents 출력
						msgGrpDiv.appendChild(chatbotMng.assisantComponent(resObj));
					}
				}
			}
		}
	}
	
	return msgGrpDiv;
}


