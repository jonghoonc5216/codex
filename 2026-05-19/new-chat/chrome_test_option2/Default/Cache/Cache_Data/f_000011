/**
 * 엘리먼트 생성
 *
 * @memberOf chatbot
 * @date 2024.04.29
 * @param  sEl		Tag
 * 		   sClass	클래스명
 * 		   sVal		텍스트
 * 		   sId		ID
 * @return 엘리먼트
 * @author 백지훈
 * @example
		chatbot.createEl()
 */
chatbot.createEl = function ( sEl, sClass, sVal, sId, sPayload ) {
	const el = document.createElement(sEl);
	if ( comUtil.gfnIsNotEmpty(sId) ) el.setAttribute("id", sId);					// id 값 있을경우 ID 속성추가
	if ( comUtil.gfnIsNotEmpty(sClass) ) el.setAttribute("class", sClass);		// 클래스 값 있을경우 ClassName 속성추가
	
	// 텍스트 값 있을경우 태그에 따라 innerHTML or value 속성 추가
	if ( comUtil.gfnIsNotEmpty(sVal) ) {
		if ( sEl === "div" || sEl === "span" || sEl === "dt" || sEl === "a") {
			if ( sEl === "a" ) {				// A 태그일경우 href 속성 처리
				if ( sClass === "imgNewTab") {		// 이미지 클래스가 새창(imgNewTab)
					el.setAttribute("href", sVal);
					el.setAttribute("target", "_blank");
				} else {
					if ( sPayload ) el.setAttribute("data-role", sPayload);
					el.setAttribute("href", "javascript:void(0);");
					
				}
			}
			if ( sClass !== "imgNewTab"
                 && sClass !== "imgNoTab") {
                el.innerHTML = sVal;
            }
		} else if ( sEl === "input" ) {			// input 태그일경우 button 관련 속성 처리
			el.setAttribute("type", "button");
			el.setAttribute("value", sVal);
			if ( sPayload ) el.setAttribute("data-role", sPayload);
		} else if ( sEl === "img" ) {			// img 태그일경우 src 속성 처리
			el.setAttribute("src", sVal);
		} 
	} else {
		if ( sEl === "input" ) {
			el.setAttribute("type", "button");
		} else if ( sEl === "a" ) {
			el.setAttribute("href", "javascript:void(0);");
		}
	}
	
	return el;
}

