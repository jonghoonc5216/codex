			} else if ( cpType === "1depth" ) {		// 1depth 일경우
				if ( menuGrpDiv !== null ) {
					menuGrpDiv.appendChild(cpGrpUl);
					chbtContAreaDiv.appendChild(menuGrpDiv);				
				}
			} else if ( cpType === "textlist" ) {	// 데이터 허브 - 보고서 리스트
				reportGrpDiv.appendChild(cpGrpUl);
				chbtContAreaDiv.appendChild(reportGrpDiv);
			} else {								// 나머지 
