/**
 * 맨 마지막 스크롤 이동 처리
 *
 * @memberOf chatbot
 * @date 2024.05.03
 * @param tabContentBody 해당 Body ID
 * @return 
 * @author 백지훈
 * @example
		chatbot.moveLastContentBody( 해당 body Id )
 */
chatbot.moveLastContentBody = function ( tabContentBody ) {
//	if ( comUtil.gfnIsNotEmpty(tabContentBody)  ) {
//		setTimeout(function() {
//			tabContentBody[0].scrollIntoView({behavior: "smooth", block: "end"});
//		}, 300);		
//	}
	if ( comUtil.gfnIsNotEmpty(tabContentBody)  ) {

	    //가장 가까운 사용가능 스크롤 찾기
	    function findScrollableParent(element){
	        while(element && element !== document.body){
	            const hasScrollableContent = element.scrollHeight > element.clientHeight; 
	            const overfY = WebSquare.style.getComputedStyle(element).overflowY;
	            const isScrollable = overfY === 'auto' || overfY==='scroll';
	            if(hasScrollableContent && isScrollable){
	                return element;
	            } 
	            element = element.parentElement;
	        } 
	        return null;
	    }
	        
	    //해당 스크롤만 가능하게 변경
	    setTimeout(function() {
	        //tabContentBody[0].scrollIntoView({behavior: "smooth", block: "end"});
	        const issScrolleblePart = findScrollableParent(tabContentBody[0]);
			if(issScrolleblePart){
				issScrolleblePart.scrollTo({top:issScrolleblePart.scrollHeight, behavior:'smooth'});	
			}
	        
	    }, 300);		
	}
}


