/**
 * 챗봇 대화이력_사용자 입력
 *
 * @memberOf chatbotMng
 * @date 2024.07.08
 * @param usrDataObj
 * @return html
 * @author 백지훈
 * @example
		chatbotMng.userComponent( datas )
 */
chatbotMng.userComponent = function ( usrDataObj ) {
	const grpUsrDataDiv = chatbot.createEl("div", "usr_data", null, null);
	
	if ( comUtil.gfnIsNotEmpty(usrDataObj) ) {
		const message = usrDataObj.message;
		let txt = "";
		const bbleTxtDiv = chatbot.createEl("div", "_bbleTxt", null, null);
		
		// 사용자입력
		txt = chatbotMng.txtMessageReplace(txt, chatbotMng.userTextReplace(message));
		
		if ( txt.match("config_welcome") ) txt = txt + " 첫인사";
		
		const txtSpan = chatbot.createEl("span", "", txt, null);
		bbleTxtDiv.appendChild(txtSpan);
		grpUsrDataDiv.appendChild(bbleTxtDiv);
		
		const usrInptInfoGrupDiv = chatbot.createEl("div", "usrInpt_infoGrup", null, null);
		
		// Response 중에 Data 값 있을경우
		if ( comUtil.gfnIsNotEmpty(chatbotMng.nextRequestUserObj) ) {
			const dataIEObj = chatbotMng.nextRequestUserObj.data;
			
			// Intent
			const intentAreaDiv = chatbot.createEl("div", "_intentArea", null, null);
			
			if ( comUtil.gfnIsNotEmpty(dataIEObj.intent) ) {
				// Intent > info > txt
				let infoDiv = chatbot.createEl("div", "_info", null, null);
				let infoTxtSpan = chatbot.createEl("span", "", dataIEObj.intent.intent, null);
				infoDiv.appendChild(infoTxtSpan);
				
				let etcDiv = chatbot.createEl("div", "_etc", null, null);
				let etcTxtSpan = chatbot.createEl("span", "", "Confidence : " + parseFloat(dataIEObj.intent.confidence), null);
				etcDiv.appendChild(etcTxtSpan);
				
				intentAreaDiv.appendChild(infoDiv);
				intentAreaDiv.appendChild(etcDiv);
			}
			
			// Entity
			const entityAreaDiv = chatbot.createEl("div", "_entityArea", null, null);
			
			if ( comUtil.gfnIsNotEmpty(dataIEObj.entities) ) {
				infoDiv = chatbot.createEl("div", "_info", null, null);
				for ( let i = 0; i < dataIEObj.entities.length; i++ ) {
					// Entity > info > txt
					infoTxtSpan = chatbot.createEl("span", "", dataIEObj.entities[i].entity + " : " + dataIEObj.entities[i].entity, null);
					infoDiv.appendChild(infoTxtSpan);
					
				}
				entityAreaDiv.appendChild(infoDiv);
			}
			
			usrInptInfoGrupDiv.appendChild(intentAreaDiv);
			usrInptInfoGrupDiv.appendChild(entityAreaDiv);
		}
		
		grpUsrDataDiv.appendChild(usrInptInfoGrupDiv);
	}
	
	
	// 다음 사용자가 입력한 텍스트 넣기
	if ( comUtil.gfnIsNotEmpty(chatbotMng.nextRequestUserObj) ) {
		const nextMessage = chatbotMng.nextRequestUserObj.message;
		let nextTxt = chatbotMng.txtMessageReplace("", chatbotMng.userTextReplace(nextMessage));
		
		chatbotMng.userText = nextTxt;
	}
	
	return grpUsrDataDiv;
}

/**
 * 사용자 입력한 문자열 잘라서 출력 처리
 *
 * @memberOf chatbotMng
 * @date 2024.07.09
 * @param
 * 			txt			리턴 Text 값
 * 			message		사용자 입력한 내용
 * @return txt
 * @author 백지훈
 * @example
		chatbotMng.txtMessageReplace()
 */
chatbotMng.txtMessageReplace = function(txt, message) {
	if ( comUtil.gfnIsNotEmpty(message) ) {
		// 최초시 이용자유형일경우
		if ( message.indexOf("action") > -1 ) {
			if (message.indexOf(":") > -1 && message.lastIndexOf("}") > -1 ) {
				txt = message.substring(message.indexOf(":") + 1, message.lastIndexOf("}"));
				txt = txt.trim().replace(/"/g, '');
			}
		} else if ( message.search(/\/D[0-9]_/g) > -1) {		// 1depth, nomal0, nomal1 버튼일경우
			txt = message.substring(0, message.indexOf("{"));
			txt = txt.trim().replace(/\//g, '').replace(/D[0-9]_/g, '');
		} else {
			txt = message;
		}		
	}
	
	return txt;
} 


