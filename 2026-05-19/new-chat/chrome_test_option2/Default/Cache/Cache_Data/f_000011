/**
 * AI 응답 Text + Component 포함 호출
 *
 * @memberOf chatbot
 * @date 2024.04.22
 * @param 그룹DIV
 * @return html
 * @author 백지훈
 * @example
		chatbot.assisantGroup( 그룹DIV )
 */
chatbot.assisantGroup = function () {
	// 메시지 그룹 ID 랜덤 만들기
	chatbot.g2pGrpId = "grp_" + new Date().getTime();
	
	// 메시지 그룹 묶어서 DIV 생성
	const msgGrpDiv = chatbot.createEl("div", "g2b_chat", null, chatbot.g2pGrpId);
	
	const responsesArr = chatbot.responsesArr;
	
	// TEXT, Contents 배열담기
	let resTexts = [];
	let resContents = [];
	
	// 로그인 체크
	const usr = com.gfnGetUsrInfo();
	
	if ( responsesArr.length > 0 ) {
		const len = responsesArr.length;
		// 먼저 TEXT 일경우 배열 저장
		for ( let i = 0; i < len; i++ ) {
			const resObj = responsesArr[i];
			
			if ( chatbot.chatAreaJs === "datah" && chatbot.chatTabType === "1" ) {			// 데이터허브 일경우
				if ( comUtil.gfnIsNotEmpty(resObj.contents ) ) {
					for ( let c in resObj.contents ) {
						const resObjContentObj = resObj.contents[c];
						if ( resObjContentObj.type === "pretext" ) {
							resTexts.push(resObjContentObj);
						}
					} 
				} else {
					if ( comUtil.gfnIsNotEmpty(resObj.text) ) {
						resTexts.push(resObj);
					}	
				}
			} else {					// 나머지 기존 대로
				// Text 일경우
				if ( comUtil.gfnIsNotEmpty(resObj.text) ) {
					resTexts.push(resObj);
				}
				
			}
			
			// Contents 일경우
			if ( comUtil.gfnIsNotEmpty(resObj.contents) ) {
				resContents.push(resObj);
			}
		}
		
		// TEXT 시작
		msgGrpDiv.appendChild(chatbot.assisantTexts( resTexts ));
		
		// Contents 시작
		for ( let i = 0; i < resContents.length; i++ ) {
			const resObj = resContents[i];
			
			let contentsType = null;
			if ( comUtil.gfnIsNotEmpty(resObj.contents) ) {
				if ( comUtil.gfnIsNotEmpty(resObj.contents[0].type) ) {
					contentsType = resObj.contents[0].type;
				}
				
				if ( contentsType !== "1depth" || ( comUtil.gfnIsEmpty(usr) && contentsType === "1depth" ) && !chatbot.oneDepth ) {
					if ( comUtil.gfnIsEmpty(usr) && contentsType === "1depth" ) {
						chatbot.oneDepth = true;
					}
				}
				
				// 컴포넌트 Contents 출력
				msgGrpDiv.appendChild(chatbot.assisantComponent(resObj));
			}
		}
	}
	
	// 피드백 처리 출력 함수
	if ( comUtil.gfnIsNotEmpty(chatbot.fdbkObj) ) {
		const fdbkObj = chatbot.fdbkObj;
		
		// 최종답변여부가 1 이면 피드백 컴포넌트 출력
		if ( fdbkObj.cmpyn === 1 ) {
			msgGrpDiv.appendChild(chatbot.assisantFeedbackComponent());
		}
	}
	
	return msgGrpDiv;
}

/**
 * 응답 내용 생성_개선
 *
 * @memberOf chatbot
 * @date 2024.06.04
 * @param text 배열
 * @return html
 * @author 백지훈
 * @example
		chatbot.assisantTexts()
 */
chatbot.assisantTexts = function ( resTextArr ) {
	const grpAreaDiv = chatbot.createEl("div", "narmiArea", null, null);
	
	if ( resTextArr.length > 0 ) {
		const resTextArrLen = resTextArr.length;
		const chatBbleGrupDiv = chatbot.createEl("div", "_chatBbleGrup", null, null);
		
		for ( let i = 0; i < resTextArrLen; i++ ) {
			
			const resTextObj = resTextArr[i];
			if ( i === 0 ) {
				const thumbDiv = chatbot.createEl("div", "_thumb", null, null);
				grpAreaDiv.appendChild(thumbDiv);				
			}
			
//			let text = comUtil.gfnIsNotEmpty(resTextObj.text) ? resTextObj.text : "";
			let text = comUtil.gfnIsNotEmpty(resTextObj.text) ? resTextObj.text : (comUtil.gfnIsNotEmpty(resTextObj.url) ? resTextObj.url : "");
			
			if ( text !== "" ) {
				const txtGrpDiv = chatbot.createEl("div", "_chatBble", null, null);
				
				const txtSpan = chatbot.createEl("span", "", text.replace(/\\n/g, "<br />"), null );
				txtGrpDiv.appendChild(txtSpan);
				
				chatBbleGrupDiv.appendChild(txtGrpDiv);
			}
		}
		grpAreaDiv.appendChild(chatBbleGrupDiv);
	}
	
	return grpAreaDiv;
}


/**
 * 컴포넌트 타입 생성
 *
 * @memberOf chatbot
 * @date 2024.04.22
 * @param 
 * @return component Html
 * @author 백지훈
 * @example
		chatbot.assisantComponent()
 */
chatbot.assisantComponent = function ( resObj ) {
	const chbtContAreaDiv = chatbot.createEl("div", "chbtContArea", null, null);
	
	// Reponse 값 있는지 체크
	if ( comUtil.gfnIsNotEmpty(resObj) ) {
		const contents = resObj.contents;
		let cpType = "text";
		
		// 버튼 Arr 값 체크
		if ( comUtil.gfnIsNotEmpty(contents) ) {
			
			let cpGrpUl = chatbot.createEl("ul", null, null, null);
			
			// 컴포넌트 그룹 DIV 생성
			let txtGrpDiv = null;			// 텍스트 목록일 경우 그룹 생성
			let menuGrpDiv = null;			// 1depth일 경우 그룹 생성
			let swiperContainerDiv = null;	// 슬라이더 부모 그룹 생성
			let swiperWrapperDiv = null;	// 슬라이더 부모의 자식 그룹 생성
			let reportGrpDiv = null;		// 보고서리스트 그룹 생성
			
			for ( let i = 0; i < contents.length; i++ ) {
				const contentObj = contents[i];
				
				// Type
				// text: 텍스트, normal0: 화면에 따라 자동 줄바꿈, normal1: 한줄씩, 
				// download: 다운로드, link: 링크, slidelist: 가로슬라이드 목록, 1depth: 1depth 버튼
				cpType = comUtil.gfnIsNotEmpty(contentObj.type) ? contentObj.type : "text";
				
				const title = comUtil.gfnIsNotEmpty(contentObj.title) ? contentObj.title : "";
				const payload = comUtil.gfnIsNotEmpty(contentObj.payload) ? contentObj.payload : "";
				const url = comUtil.gfnIsNotEmpty(contentObj.url) ? contentObj.url : "";
				const question = comUtil.gfnIsNotEmpty(contentObj.question) ? contentObj.question : "";
				const answer = comUtil.gfnIsNotEmpty(contentObj.answer) ?  contentObj.answer : "";
				
				// 해당 타입에 따라 상위(ul) 컴포넌트 생성 처리
				if ( i === 0 ) {					
					if (cpType === "text" ) {						// 텍스트
						txtGrpDiv = chatbot.createEl("div", "_txtInfoList", null, null);
						chatbot.updateEl(cpGrpUl, "_infoList");
					} else if ( cpType === "normal0" ) {			// 일반버튼
						chatbot.updateEl(cpGrpUl, "_bbleBtnGrup");
					} else if ( cpType === "normal1" ) {			// 일반버튼
						chatbot.updateEl(cpGrpUl, "_listBtnGrup _newBtn");
					} else if ( cpType === "download" || cpType === "link" ) {			// 다운로드 or 링크
						chatbot.updateEl(cpGrpUl, "_listBtnGrup");
					} else if ( cpType === "slidelist" ) {			// 슬라이드
						// contArea 그룹에 클래스 변경
						chatbot.updateEl(chbtContAreaDiv, "chbtContArea posL_zero");
						
						// Swiper Container
						const randomSwiper = Math.random().toString(16).substr(2,10);
						const swiperId = chatbot.chatAreaJs + "_" + randomSwiper;
						swiperContainerDiv = chatbot.createEl("div", "swiper-container _cardListGrup " + swiperId, null, null);
						
						chatbot.swiperId = swiperId;
						
						// Swiper Wrapper
						swiperWrapperDiv = chatbot.createEl("ul", "swiper-wrapper _cardArea", null, null);
					} else if ( cpType === "1depth" ) {				// 1depth 버튼
						menuGrpDiv = chatbot.createEl("div", "_menuGrup", null, null);
						chatbot.updateEl(cpGrpUl, "_menu" + (chatbot.chatTabType === "2" ? " usrManual" : ""));
					} else if ( cpType === "image" ) {
						cpGrpUl = chatbot.createEl("div", "_txtInfoGrup chat_img", null, null);
					} else if ( cpType === "textlist" ) {			// 보고서 리스트
						reportGrpDiv = chatbot.createEl("div", "_txtInfoGrup", null, null);
						chatbot.updateEl(cpGrpUl, "_reprtList");
					}
				}
				
				// 해당 타입에 따라 상위 컴포넌트 안에 하위 컴포넌트 생성 처리
				let bbleTag = chatbot.createEl("li", null, null, null);
				
				if (cpType === "text" ) {						// 텍스트
					
					const dlTxt = chatbot.createEl("dl", null, null, null);
					const dtTxt = chatbot.createEl("dt", "w2textbox", title, null);

					dlTxt.appendChild(dtTxt);
					
					// url 있다면 dd 처리(dd > a > span)
					if ( comUtil.gfnIsNotEmpty(url) ) {
						const ddTxt = chatbot.createEl("dd", null, null, null);
						const ddATxt = chatbot.createEl("a", "w2trigger_anchor", null, null);
						// url이 '/link' 이면 새로운탭 링크로 처리
						if ( url.indexOf("/link") > -1) {
							chatbot.linkEventEl(ddATxt, url);
						} else {
							ddATxt.addEventListener("click",  function() { com.gfnOpenMenu(url, { targetMain : true }) });
						}
						
						const chkKoTxt = /[ㄱ-ㅎ|ㅏ-ㅣ|가-힣]/;
						
						// url이 한글인경우.?
						
						if ( chkKoTxt.test(url)){
							const chkParam = {
									reptNm : url
							};
							ddATxt.addEventListener("click", function() {com.gfnOpenMenu('AISC001_01', { isHistory: true, param: chkParam })});
						}	
						const ddASpanTxt = chatbot.createEl("span", "w2textbox", payload, null);
						ddATxt.appendChild(ddASpanTxt);
						ddTxt.appendChild(ddATxt);
						
						dlTxt.appendChild(ddTxt);
					}
					
					bbleTag.appendChild(dlTxt);
				} else if ( cpType === "normal0" ) {			// 일반버튼(화면에 따라 자동 줄바꿈)
					bbleTag.appendChild(chatbot.createEl("input", "_bbleBtn", title, null, payload));
					
				} else if ( cpType === "normal1" ) {			// 일반버튼(한줄씩)
					const listBtn = chatbot.createEl("input", "_listBtn", title, null, payload);
					
					bbleTag.appendChild(listBtn);
				} else if ( cpType === "download" ) {			// 다운로드
					chatbot.updateEl(bbleTag, "_ico");		// half > _ico 변경
					const a_tag = chatbot.createEl("a", "_listBtn down", title, null);
					if ( comUtil.gfnIsNotEmpty(url) ) {
						if ( url.indexOf('untyAtchFileNo') > -1 ) {
							a_tag.addEventListener("click", function() { chatbot.getDownload(url) });
						}
					}
					bbleTag.appendChild(a_tag);
					
				} else if ( cpType === "link" ) {				// 링크
					chatbot.updateEl(bbleTag, "_ico");		// half > _ico 변경
					const a_tag = chatbot.createEl("a", "_listBtn link", title, null);
					if ( url.indexOf("/link") > -1) {
						chatbot.linkEventEl(a_tag, url);
					} else {
						if ( chatbot.chatAreaJs === "datah" && chatbot.chatTabType === "1" ) {		// 데이터허브 챗봇이고, 보고서찾기 일경우 메뉴번호로 이동 
							a_tag.addEventListener("click",  function() { com.gfnOpenMenu(url, { targetMain : true }) });
						} else {
							a_tag.setAttribute("target", "_blank");
							a_tag.setAttribute("href", url);
						}
					}
					bbleTag.appendChild(a_tag);
					
				} else if ( cpType === "slidelist" ) {			// 슬라이드
					chatbot.updateEl(bbleTag, "swiper-slide slideCard");
					
					// txtDataArea 그룹
					const slideTxtDataArea = chatbot.createEl("div", "txtDataArea", null, null);
					
					// _qTxtGrup 질문 그룹
					const slideQTxtGrp = chatbot.createEl("span", "_qTxtGrup", null, null);
//					const qTxtGrpSpan = chatbot.createEl("span", "_bullet", (i+1), null);
					const qTxtGrpSpan = chatbot.createEl("span", "_bullet", null, null);
					slideQTxtGrp.appendChild(qTxtGrpSpan);
					
					const qTxtGrpDiv = chatbot.createEl("span", "", comUtil.gfnIsNotEmpty(url) ? "" : question, null);
					if ( comUtil.gfnIsNotEmpty(url) ) {		// URL 값 있을시
						const qTxtA = chatbot.createEl("a", "_qLink", "", null);
						if ( url.indexOf("/link") > -1) {
							chatbot.linkEventEl(qTxtA, url);
						} else {
							qTxtA.setAttribute("target", "_blank");
							qTxtA.setAttribute("href", url);
						}
						const qTxtASpan = chatbot.createEl("span", "", question, null);
						qTxtA.appendChild(qTxtASpan);
						qTxtGrpDiv.appendChild(qTxtA);
					}
					slideQTxtGrp.appendChild(qTxtGrpDiv);
					
					slideTxtDataArea.appendChild(slideQTxtGrp);
					
					// _aTxtGrup 답변 그룹
					const slideATxtGrp = chatbot.createEl("div", "_aTxtGrup", null, null);
					const answerTxt = answer.replace(chatbot.urlPattern, chatbot.replaceUrl);
					const aTxtGrpSpan = chatbot.createEl("span", "_aTxt", answerTxt.replace(/\\n|\n/g, "<br />"), null);
					
					// 질문 길이 구하기
					const qLen = comUtil.gfnGetByteLength(question);
					// 답변 길이 구하기
					const aLen = comUtil.gfnGetByteLength(answer);
					
					// -webkit-line-clamp
					// 질문 라인수에 따라 스타일 변경
					aTxtGrpSpan.setAttribute("style", chatbot.slideStyleLineClamp(question));
					slideATxtGrp.appendChild(aTxtGrpSpan);
					
					let answerOpen = false;
					if ( qLen > 250 && aLen > 368 ) {
						answerOpen = true;
					} else {
						if ( aLen > 368 ) {
							answerOpen = true;
						} else if ( chatbot.qsStrLenTot(question, answer) > 6 ) {
							answerOpen = true;
						} 
					}
					
					// 접기/평처보기
					const aTxtGrpIpt = chatbot.createEl("a", "_innerBtn" + (answerOpen ? "" : " disabled"), null, null);
