                const xhr = new XMLHttpRequest();
                xhr.open("GET",`${url}?${params}`);
                xhr.onload = () =>{
                    if ( xhr.status == 200 ){
                        resolve(xhr);
                    } else {
                        reject(xhr.statusText);
