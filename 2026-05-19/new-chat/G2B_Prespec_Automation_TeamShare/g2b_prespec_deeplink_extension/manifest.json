{
  "manifest_version": 3,
  "name": "G2B Prespec Detail Helper",
  "version": "1.0.1",
  "description": "Open G2B preliminary specification details from local Excel links.",
  "host_permissions": [
    "https://www.g2b.go.kr/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.g2b.go.kr/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.g2b.go.kr/*"
      ],
      "js": [
        "injected.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js"
      ],
      "matches": [
        "https://www.g2b.go.kr/*"
      ]
    }
  ]
}
