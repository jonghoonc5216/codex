/********************************************************************************
 * 설명 : Page Load 이벤트
 ********************************************************************************/
scwin.onpageload = function() {
    // Main Contents WFrame에서는 아이디 중복체크를 해제한다.
    wfm_container.options._idCollisionCheck = false;

    // 메인 페이지일 경우 Navigation + Header 정보를 노출하지 않는다.
    scwin.setNavitionVisible();

    // 퍼블리싱 작업
    // 웹접근성(스크린 리더기)-  a태그(class="skip-nav" 본문영역 바로가기)의 href="#fs_content"를 본문영역(class="container-layout")의 아이디에 연결
    const cntLayout = document.querySelector(".portal > .container-layout");
    cntLayout.setAttribute("id", "fs_content");

    dlMenuM.set('infoSysCd', com.gfnGetInfoSysCd());

    // 메인 페이지 로드 여부
    _gcm.Global.setMainLoaded(true);

    // 최초 페이지 호출 시 menuCangVal 값이 있을 경우 해당 페이지로 이동 후 레이아웃을 숨긴다
    let result = false;

    if (!comUtil.gfnIsEmpty(WebSquareExternal.menuCangVal)) {
        let option = null;

        if (!comUtil.gfnIsEmpty(WebSquareExternal.param)) {
            Object.keys(WebSquareExternal.param).forEach(key => {
                if (comUtil.gfnIsArray(WebSquareExternal.param[key])) {
                    WebSquareExternal.param[key] = WebSquareExternal.param[key][0];
                }
            });

            option = { param : WebSquareExternal.param };
        }

        result = com.gfnInitMovePage(WebSquareExternal.menuCangVal, WebSquareExternal.target, option);
        
        if (!comUtil.gfnIsEmpty(WebSquareExternal.param.externalYn) && WebSquareExternal.param.externalYn !== "Y") {
            if (document.referrer !== "" && $p.parent() !== WebSquare.util.getMainFrame()) {
                // 링크로 새창이 열린 경우 window.opener = null 처리한다.
                window.opener = null;
            }
        }

        if (WebSquareExternal.menuCangVal === _gcm.Global.getLoginMenuCangVal()) {
            history.replaceState({}, "", "/");
        }
    } else {
        if ($p.parent() !== WebSquare.util.getMainFrame()) {
            // 특정 페이지로 이동하지 않는 경우 window.opener = null 처리한다.
            window.opener = null;
        }
    }

    // 포탈기능 조회호출
    scwin.fnSrchPrtlFtreMainList().then(rtn => {
        if (!result) {
            // 메인 페이지 로드
            const dev_goto_menuId = WebSquare.localStorage.getItem("dev_goto_menuId");
            const menuInfo = _gcm.Global.getMenuDataList().getAllJSON().filter(f => f.menuCangVal === dev_goto_menuId);
            if (( comUtil.gfnIsNotEmpty(com.gfnGetUsrInfo())) &&  ( !comUtil.gfnIsEmpty(dev_goto_menuId) && comUtil.gfnGetThisMenuCangVal() != dev_goto_menuId)
            && !( menuInfo.length === 0 || comUtil.gfnIsEmpty(menuInfo[0].menuCangVal) || comUtil.gfnIsEmpty(menuInfo[0].scrnSrcePathNm))) {
                com.gfnOpenMenu(dev_goto_menuId);
            } else {
                com.gfnOpenMenu(_gcm.Global.getMainMenuCangVal());
            }
        }
    });
};

/********************************************************************************
 * 설명 : 메인 페이지일 경우 Navigation + Header 정보를 노출하지 않는다.
 ********************************************************************************/
scwin.setNavitionVisible = function(menuCangVal = com.gfnGetMenuCangVal()) {
    // 퍼블리싱 작업 - 퍼블리싱 작업 - 메인화면 노출되는 화면에서 최상위 그룹 .portal에 클래스 추가, 삭제하여 배경색상 디자인 변경
    const portalElement = window.document.querySelector(".portal");
    const callUrl = window.location.href;
    if( 
        (callUrl.indexOf("link") > -1 && callUrl.indexOf("PBPA021_01") > -1 && callUrl.indexOf("single") > -1 && callUrl.indexOf("encryptParam") > -1) // 투찰보기
        || (callUrl.indexOf("link") > -1 && callUrl.indexOf("FUUA017_01") > -1 && callUrl.indexOf("single") > -1 ) // 인증센터
        || (callUrl.indexOf("link") > -1 && callUrl.indexOf("PNPE027_01") > -1 && callUrl.indexOf("bidPbancNo") > -1 && callUrl.indexOf("bidPbancOrd") > -1 && callUrl.indexOf("pbancType") > -1 && callUrl.indexOf("single") > -1 ) // 입찰상세 
        || (
            callUrl.indexOf("link") > -1 && callUrl.indexOf("FIUA027_01") > -1 && callUrl.indexOf("oderPlanNo") > -1 && callUrl.indexOf("ctrtDmndRcptNo") > -1 && callUrl.indexOf("ctrtDmndRcptOrd") > -1
           && callUrl.indexOf("bidPbancNo") > -1 && callUrl.indexOf("bfSpecRegNo") > -1 && callUrl.indexOf("bidPbancOrd") > -1 && callUrl.indexOf("scsbdMthdCd") > -1 && callUrl.indexOf("bidPrgrsOrd") > -1
           && callUrl.indexOf("bidClsfNo") > -1 && callUrl.indexOf("bidPgst") > -1 && callUrl.indexOf("ctrtNo") > -1 && callUrl.indexOf("ctrtChgOrd") > -1 && callUrl.indexOf("untyInspIgiNo") > -1
           && callUrl.indexOf("untyPyprNo") > -1 && callUrl.indexOf("prcmBsneSeCd") > -1 && callUrl.indexOf("dlvdmRcptDt") > -1 && callUrl.indexOf("dlvdmRcptNo") > -1 && callUrl.indexOf("dlreqDt") > -1
           && callUrl.indexOf("dlreqNo") > -1 && callUrl.indexOf("dlvdmReqYn") > -1 && callUrl.indexOf("dlreqChgOrd") > -1 && callUrl.indexOf("srchName") > -1 && callUrl.indexOf("single") > -1
        ) // 모바일통합검색
    ){
        portalElement.classList.add("bid-gnb_head");
    }

    if (!comUtil.gfnIsEmpty(_gcm.Global.getMenuDataList())) {
        // 메인 페이지일 경우 Navigation + Header 정보를 노출하지 않는다.
        if (menuCangVal === _gcm.Global.getMainMenuCangVal() && com.gfnGetContxtSeCd() !== "콘010012") {
            (!wfm_navigation.hasClass("hide")) && wfm_navigation.addClass("hide");
            (!wfm_cntsHeader.hasClass("hide")) && wfm_cntsHeader.addClass("hide");
            //portalElement.parentElement.classList.add("has-main");
            //portalElement.parentElement.classList.remove("has-main");
        } else {
            (wfm_navigation.hasClass("hide")) && wfm_navigation.removeClass("hide");
            (wfm_cntsHeader.hasClass("hide")) && wfm_cntsHeader.removeClass("hide");
            portalElement.parentElement.classList.remove("has-main");
        }
    }
};

  

