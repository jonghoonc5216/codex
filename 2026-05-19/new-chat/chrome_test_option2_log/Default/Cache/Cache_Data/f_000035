// scroll top 버튼 이벤트
scwin.trackScroll = function() {
    const scrolled = window.pageYOffset;
    const coords = window.document.documentElement.clientHeight;
    const goTopBtn = window.document.querySelector('.btn.go-to-top');

    if (scrolled > coords) {
        goTopBtn.classList.add('back_to_top-show');
    }
    if (scrolled < coords) {
        goTopBtn.classList.remove('back_to_top-show');
    }
}

