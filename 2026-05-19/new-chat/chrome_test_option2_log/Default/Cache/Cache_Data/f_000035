scwin.showBkmkList = async function(){
    // 제너레이터 초기화
    genFavorite.removeAll();

    // 북마크 데이터콜렉션 사용
    let dataList = dlBkmkL.getAllJSON();
    if (comUtil.gfnIsEmpty(dataList) == true || dataList.length <= 0 ) {
        favNoCnts.show();
    } else {
        favNoCnts.hide();
    }

    //
    dataList.forEach((item) => {
        let nodeIdx = genFavorite.insertChild();
        let favAnchor = genFavorite.getChild(nodeIdx, 'favAnchor');
        let favTitle = genFavorite.getChild(nodeIdx, 'favTitle');
        let favDetail = genFavorite.getChild(nodeIdx, 'favDetail');

        favAnchor.setUserData('menuNo', item.menuNo);
        favTitle.setValue(comUtil.gfnEscapeToChar(item.menuNm));
        favDetail.setValue(comUtil.gfnEscapeToChar((comUtil.gfnIsEmpty(item.menuPos)) ? item.menuNm : item.menuPos));
    });
}

/********************************************************************************
* 설명 : 즐겨찾기 조회
* scwin.selectBkmkList(); // 즐겨찾기 조회
********************************************************************************/
scwin.selectBkmkList = async function(){
    let _infoSysCd = com.gfnGetInfoSysCd(); // 시스템 구분 코드
    let _usrId = '';

    // 자동 처리 가능한 값 : 회원
    const usrInfo = com.gfnGetUsrInfo();
    if (comUtil.gfnIsEmpty(usrInfo)) {
        return;
    } else {
        _untyGrpNo = usrInfo.untyGrpNo;
        _usrId = usrInfo.usrId;
    }

    // 저장용 데이터콜렉션 초기화
    com.gfnInitDataMap("dlBkmkM");
    // 저장용 데이터콜렉션 값 세팅
    dlBkmkM.set('infoSysCd', _infoSysCd);
    dlBkmkM.set('usrId', _usrId);
    dlBkmkM.set('bkmkKndCd', 'MENU');

    // 서브미션 호출
    const sbmOption = {
        id: "sbmSrch",
        action: "/co/coa/coaa/MainMenu/selectMenuBkmkList.do",
        inData: "dlBkmkM",
        outData: "dlBkmkL",
        msgYn: { succ: false, err: true },
    };

    try {
        const result = await com.gfnExecute(sbmOption);
        // 성공 처리
        if (result.responseJSON.ErrorCode == '0') {
            scwin.showBkmkList();
        }
    } catch (e) {
        console.error(e);
    }
}

// 즐겨찾기 클릭시 처리
