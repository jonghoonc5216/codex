scwin.groupRnbTab_onclick = function(e) {
    // tab 그룹 aria 속성 이벤트
    if ( e.target.classList.contains("tab-list") ) {
        const showYn = e.target.getAttribute("aria-selected");
        e.currentTarget.querySelectorAll(".tab-list").forEach(function(o,i){
            document.querySelector(".section.rnb").classList.remove("active");
            o.setAttribute("aria-selected","false");
            o.classList.remove("on");
        });
        e.currentTarget.querySelectorAll(".tab-panel").forEach(function(o,i){
            o.setAttribute("aria-hidden","true");
            o.style["display"] = "none";
        });
        if ( showYn === "false") {
            document.querySelector(".section.rnb").classList.add("active");
            e.target.classList.add("on");
            e.target.setAttribute("aria-selected","true");
            e.target.parentElement.lastElementChild.setAttribute("aria-hidden","false");
            e.target.parentElement.lastElementChild.style["display"] = "block";
            // 즐겨찾기 클릭하여 보일 경우 데이터를 가져와서 보여준다.
            if (e.target.id.split('_').pop() == 'favorite') {
                scwin.selectBkmkList();
            }
            if (e.target.classList.contains("info-use")){
                e.target.classList.remove("on");
                scwin.btnUtztnGuid_onclick();
            }
        }
    }

    this.blur();
};

