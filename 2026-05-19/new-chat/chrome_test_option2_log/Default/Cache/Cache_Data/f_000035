    const menuNo = this.getUserData('menuNo');
    const menuDataList = com.gfnGetMatchedJSON(_gcm.Global.getMenuDataList(), [{columnId : "menuNo", operator : "==", value : menuNo}]);
    if (menuDataList.length > 0) {
        com.gfnOpenMenu(menuDataList[0].menuCangVal, { isHistory : true });
