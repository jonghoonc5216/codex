/********************************************************************************
 * 설명 : 대용량파일첨부 팝업 호출 함수
 * TO-DO : 대용량 파일 업로드 후 unityAtchFileNo 리턴값 처리
 ********************************************************************************/
pcom.openBulkFileAtchPopup = function(unityAtchFileNo, width, height, callbackFunc) {

    let paramWidth = (width == "" || width == null) ? 810 : width;
    let paramHeight = (height == "" || height == null) ? 510 : height;

    comUtil.gfnCrossDomainPopup({
        popupName  : "대용량파일첨부",
        popupUrl   : "https://masstran.g2b.go.kr:8081/chaSSO.jsp",
        popupParam : {
            unityAtchFileNo : unityAtchFileNo, /* 통합첨부파일번호 (필수 항목) */
            jobSeCode       : ""             , /* 업무구분코드     (선택)     */
            fileRegistSj    : ""             , /* 파일등록제목     (선택)     */
            onslfBid        : ""               /* 자체공고여부     (선택)     */
        },
        popupSize  : {
            width  : paramWidth,
            height : paramHeight
        },
        popupCallBackFn : callbackFunc   /* 완료시 처리할 함수 */
    });

};

