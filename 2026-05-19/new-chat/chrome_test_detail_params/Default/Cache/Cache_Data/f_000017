    // CrossEditor 이벤트 삭제
    if ($p.isWFramePopup(true) !== undefined && !$p.isWFramePopup(true)) {
        (window.OnInitCompleted !== undefined) && (delete window.OnInitCompleted);
        (window.CE_OnKeyActive !== undefined) && (delete window.CE_OnKeyActive);
