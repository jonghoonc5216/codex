setDirty 실행 시 현재 작성 중인 문서가 초기문서로 설정이 되어 이후 문서의 변경 유무를 IsDirty 메소드를 통하여 확인할 수 있습니다.
 * @param
 * @returns
 * @hidden N
 * @exception
 * @example
 */
scwin.setDirty = function () {
    setTimeout(function run() {
        if (scwin.crossEditor?.ceEngine && scwin.crossEditor?.ceEngine?.getDocument()) {
            scwin.setUserData("initData", scwin.getBodyValue());
            scwin.crossEditor.SetDirty();
        } else {
            setTimeout(run, 500);
        }
    }, 500);
};

