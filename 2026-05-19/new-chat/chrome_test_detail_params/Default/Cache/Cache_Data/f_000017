    };

    // 참고사항
    /*
    크로스에디터 스크립트인증 버전에서 사용불가 기능
    - 관리자페이지
    - 다른이름저장
    - 리포트툴
    - 이미지/동영상/파일업로드
     */
    const udcProp = $p.getOptions();
    scwin.options = comUtil.gfnAssignDefined(editorDefault, udcProp); // 지정 하지 않은 값은 기본 값으로 지정 한다.

    // 크로스에디터 생성되기 전 이벤트(옵션 변경)
    $p.getFrame().scope.$p.emit("onComponentLoad", scwin.options);

    scwin.crossEditor = new NamoSE(scwin.options.editorId);
    scwin.crossEditor.params.AccessibilityOption = Number(scwin.options.accessibilityOption);  // 사용자가 콘텐츠를 입력할 때 적용할 웹 접근성 준수 정도를 설정합니다.
    scwin.crossEditor.params.Width = scwin.options.width;  // CrossEditor의 width 값 설정
    scwin.crossEditor.params.Height = scwin.options.height;  // CrossEditor의 height 값 설정
    // scwin.crossEditor.params.UserLang = scwin.options.userLang;  // 브라우저 언어와 상관없이 사용하는 다국어 리소스 중 특정 언어 리소스를 사용하고자 할 경우 사용 합니다.
    scwin.crossEditor.params.NewToolbar = String(scwin.options.newToolbar) === "true";  // 도구 막대의 구성요소를 설정
    scwin.crossEditor.params.FullScreen = String(scwin.options.fullScreen) === "true";  // 크로스에디터를 처음 실행할 때 전체화면으로 보이도록 설정합니다.
    scwin.crossEditor.params.ResizeBar = String(scwin.options.resizeBar) === "true";  // 에디터 높이 조절 표시 여부를 지정합니다.
    scwin.crossEditor.params.SetFocus = String(scwin.options.setFocus) === "true";  // 크로스에디터를 처음 실행할 때 에디터 영역에 대한 focus를 설정합니다.
    scwin.crossEditor.params.Menu = String(scwin.options.menu) === "true";  // 메뉴의 화면 표시 여부를 지정합니다.
    scwin.crossEditor.params.UploadFileNameType = scwin.options.uploadFileNameType;  // 파일 업로드 시 파일명 저장 형식을 설정합니다.
    scwin.crossEditor.params.UploadFileExecutePath = scwin.options.uploadFileExecutePath;  // 별도의 이미지 서버 구성 시 실제 이미지 업로드를 실행할 URL경로를 설정합니다.
    scwin.crossEditor.params.UploadEtcFileExecutePath = scwin.options.uploadEtcFileExecutePath;  // 별도의 파일 서버 구성 시 실제 파일 업로드를 실행할 URL경로를 설정합니다.
    scwin.crossEditor.params.ParentEditor = document.querySelector(`#${grpCrossEditor.id}`);  // 특정위치에 에디터를 로드 하려는 경우 에디터가 생성될 Element를 지정해 줍니다.
    scwin.crossEditor.params.DeleteCommand = ["flash", "saveas"];  // 사용하지 않을 메뉴를 설정합니다.
    scwin.crossEditor.params.Readonly = String(scwin.options.readOnly) === "true";  // CrossEditor의 Readonly 값 설정
    scwin.crossEditor.params.HtmlTabHighlight = true;
    scwin.crossEditor.params.Menu = false;
    scwin.crossEditor.params.AllowContentScript = false;
    scwin.crossEditor.params.AllowContentIframe = false;
    scwin.crossEditor.params.UserLang = "kor";
    scwin.crossEditor.params.Skin = "default";
    scwin.crossEditor.params.ReturnKeyActionBR = scwin.options.returnKeyActionBR; // 'Enter' 키 입력 시 p태그를 br태그로 설정합니다.
    scwin.crossEditor.params.TagBlockList = ["input","iframe","embed","button","form"];

    if (scwin.options.uploadFileSizeLimit !== "") scwin.crossEditor.params.UploadFileSizeLimit = scwin.options.uploadFileSizeLimit;  // 파일 업로드 시 업로드 파일의 용량을 제한합니다.
    if (scwin.options.uploadFileExtBlockList !== "") scwin.crossEditor.params.UploadFileExtBlockList = scwin.options.uploadFileExtBlockList; // 파일 링크 시의 파일 종류 제한을 설정합니다.
    if (scwin.options.uploadImageFileExtBlockList !== "") scwin.crossEditor.params.UploadImageFileExtBlockList = scwin.options.uploadImageFileExtBlockList; // 파일 링크 시의 이미지 파일 종류 제한을 설정합니다.

    // Placeholder 기능 추가
    scwin.crossEditor.params.Css = "/CrossEditor/css/placeholder.css";
    if (!comUtil.gfnIsEmpty(scwin.options.placeholder)) {
        scwin.crossEditor.params.Placeholder = comUtil.gfnEscapeToChar(scwin.options.placeholder).replace(comUtil.pattern.newline, " \\A ");
    }

    // Toolbar Type 지정
    if (scwin.options.toolbarType !== "default") {
        // Toolbar UserToolbar 속성 지정
        scwin.crossEditor.params.UserToolbar = scwin.options.userToolbar;  // 사용자가 직접 도구 막대의 구성요소를 지정할 수 있거나 혹은 할 수 없도록 설정합니다.
        scwin.crossEditor.params.CreateToolbar = (scwin.options.toolbarType === "custom") ? scwin.options.createToolbar : editorToolbar[scwin.options.toolbarType];  // 도구 막대의 구성요소를 설정합니다.
    }

    // 문단 들여쓰기 간격 설정 지정(2023.12.20)
    if (typeof scwin.options.indentPaddingValue != "undefined" && scwin.options.indentPaddingValue !== "") {
        scwin.crossEditor.params.IndentPaddingValue = Number(scwin.options.indentPaddingValue);
    }

    // config.xml 미사용 설정 (웹취약점 조치사항)
    let paramObj = {
        "Name" : "Namo Cross Editor", // 필수
        "WebLanguage" : "JSP", // 필수
        "HTMLTabContents" : "body", // 필수
        "Skin" : "default", // 필수
        "NoUseConfigXml" : true // 필수
    };

    scwin.crossEditor.EditorStart(paramObj);
};

