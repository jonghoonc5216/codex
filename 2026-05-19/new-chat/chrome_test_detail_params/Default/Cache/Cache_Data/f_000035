/********************************************************************************
 * 설명 : Header 유의 사항 설정
 ********************************************************************************/
scwin.setHelpBox = async function(menuInfo) {

    // 유의사항에서 사용하는 툴팁 관련 레이어 초기화
    scwin.closeHelpboxTooltip();

    // 유의사항 화면 초기화
    com.gfnInitDataCollection("dlMenuAtetMatrM");

    // 유의사항 submission 실행 결과 여부 체크 후 hide 여부 설정
    if (menuInfo.atetMatrYn === "Y" && menuInfo.menuCangSeCd !== "메020004") {
        dlMenuAtetMatrM.set("menuNo", menuInfo.menuNo);

        let sbmOption = {
            id: "sbmAtmt",
            action: "/co/coa/coaa/MainMenu/selectMenuAtetMatrWhenMenuOpen.do",
            inData: "dlParamM=dlMenuAtetMatrM",
            outData: "dlMenuAtetMatrM",
            msgYn: { succ: false, err: true },
        };

        try {
            // 유의사항 조회
            const result = await com.gfnExecute(sbmOption);
            const bulkAtetMatr = comUtil.gfnEscapeToChar(dlMenuAtetMatrM.get("bulkAtetMatr"));

            if (!comUtil.gfnIsEmpty(bulkAtetMatr)) {
                txbAtmtCntt.setValue(bulkAtetMatr);
                spnChangeDate.setValue(dlMenuAtetMatrM.get("chgDt"));

                // 유의사항열림설정
                if (dlMenuAtetMatrM.get("atetMatrAtmtUnfldYn") === 'Y') {
                    btnHelpToggle.openHelpToggle();
                } else {
                    // 유의사항 열람 여부 확인
                    const { menuNo, chgDt } = dlMenuAtetMatrM.getJSON();
                    let menuAtetMatr = JSON.parse(WebSquare.localStorage.getItem("menuAtetMatr") || "{}");

                    if (menuAtetMatr[menuNo] === undefined || menuAtetMatr[menuNo] !== chgDt) {
                        btnHelpToggle.openHelpToggle();
                    }
                }

                (grpHelpBox.hasClass("hide")) && grpHelpBox.removeClass("hide");
            } else {
                (!grpHelpBox.hasClass("hide")) && grpHelpBox.addClass("hide");
            }
        } catch (e) {
            console.error(e);
        }

    } else {
        txbAtmtCntt.setValue("");
        (!grpHelpBox.hasClass("hide")) && grpHelpBox.addClass("hide");
    }

    $p.setTimeout(function() {
        scwin.setHelpBoxEllipsis();
    }, { delay : 300, key : "setHelpBoxEllipsis" });
};

