scwin.btnFavorite_onclick = function(e) {
    menuNo = WebSquare.util.getMainFrame().wfm_container.getUserData("menuNo");
    if (menuNo.startsWith('SM') || menuNo.startsWith('TP') || menuNo.startsWith('PB')) {
        com.gfnAlert("warn.co.coa.notUseBkmkMenu");
        return false;
    }

    const bkmkMenuInfo = com.gfnGetMatchedJSON(_gcm.Global.getMenuDataList(), [{columnId : "menuNo", operator : "==", value : menuNo}, {columnId : "bkmkYn", operator : "==", value : 'Y'}]);
    if (comUtil.gfnIsEmpty(bkmkMenuInfo) == true || bkmkMenuInfo.length <= 0 ) {
        scwin.insertBkmk(); // 즐겨찾기 등록
    } else {
        scwin.deleteBkmk(); // 즐겨찾기 삭제
    }
};

