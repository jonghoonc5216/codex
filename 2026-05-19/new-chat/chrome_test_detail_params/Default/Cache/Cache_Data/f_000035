/********************************************************************************
 * 설명 : 유의사항 Ellipsis 설정
********************************************************************************/
scwin.setHelpBoxEllipsis = function() {
    const helpHeight = document.querySelector("#" + txbAtmtCntt.getID()).scrollHeight;
    const helpEllipsis = document.querySelector("#" + divHelpEllipsis.getID());

    // 유의사항열림설정
    if (dlMenuAtetMatrM.get("atetMatrAtmtUnfldYn") === 'Y') {
        helpEllipsis.classList.add("hide");

        if (helpHeight <= 84) {
            btnHelpToggle.hide();
        } else {
            btnHelpToggle.show();
        }
    } else {
        // 유의사항 열람 여부 확인
        const { menuNo, chgDt } = dlMenuAtetMatrM.getJSON();
        let menuAtetMatr = JSON.parse(WebSquare.localStorage.getItem("menuAtetMatr") || "{}");

        if (menuAtetMatr[menuNo] === undefined || menuAtetMatr[menuNo] !== chgDt) {
            helpEllipsis.classList.add("hide");
            if (helpHeight <= 84) {
                btnHelpToggle.hide();
            } else {
                btnHelpToggle.show();
            }
            menuAtetMatr[menuNo] = chgDt;
            WebSquare.localStorage.setItem("menuAtetMatr", JSON.stringify(menuAtetMatr));
        } else {
            if (helpHeight <= 84) {
                helpEllipsis.classList.add("hide");
                btnHelpToggle.hide();
            } else {
                helpEllipsis.classList.remove("hide");
                btnHelpToggle.show();
            }
        }
    }
};

