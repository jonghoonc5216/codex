/********************************************************************************
* 설명 : 즐겨찾기 데이터, 화면을 갱신한다.
메뉴 데이터콜렉션의 즐겨찾기 여부를 갱신한다. : MENU_DATA_LIST
화면을 갱신한다. : com.gfnSetFavoriteButton
scwin.setBkmkYn('KN00000004', 'Y'); // KN00000004 메뉴 즐겨찾기 등록
scwin.setBkmkYn('KN00000004', 'N'); // KN00000004 메뉴 즐겨찾기 삭제
********************************************************************************/
scwin.setBkmkYn = function(_menuNo, _yn) {
    // 필수 값 체크
    if (comUtil.gfnIsEmpty(_menuNo) || comUtil.gfnIsEmpty(_yn)) {
        return;
    }

    // 데이터 콜렉션 변경
    let dlMenuL = WebSquare.util.getMainFrame().dlt_gDlMenuL;
    dlMenuL.getAllJSON().forEach((item, index) => {
        if (item.menuNo == _menuNo) {
            dlMenuL.setCellData(index, 'bkmkYn', _yn);
        }
    });

    // 글로벌 데이터 갱신
    _gcm.Global.setMenuDataList(WebSquare.util.getMainFrame().dlt_gDlMenuL);
    _gcm.Global.setMenuDataJSON(WebSquare.util.getMainFrame().dlt_gDlMenuL.getAllJSON());

    // 화면 갱신
    com.gfnSetFavoriteButton(_menuNo);
}

/********************************************************************************
* 설명 : 즐겨찾기 등록
* scwin.insertBkmk(); // 즐겨찾기 등록
********************************************************************************/
scwin.insertBkmk = async function(){
    let _infoSysCd = com.gfnGetInfoSysCd(); // 시스템 구분 코드
    let _usrId = '';
    let _menuNo = '';

    // 자동 처리 가능한 값 : 회원
    const usrInfo = com.gfnGetUsrInfo();
    if (comUtil.gfnIsEmpty(usrInfo)) {
        return;
    } else {
        _untyGrpNo = usrInfo.untyGrpNo;
        _usrId = usrInfo.usrId;
    }

    // 자동 처리 가능한 값 : 메뉴
    _menuNo = WebSquare.util.getMainFrame().wfm_container.getUserData("menuNo");
    if (comUtil.gfnIsEmpty(_menuNo)) {
        return;
    }

    // 저장용 데이터콜렉션 초기화
    com.gfnInitDataMap("dlBkmkM");
    // 저장용 데이터콜렉션 값 세팅
    dlBkmkM.set('infoSysCd', _infoSysCd);
    dlBkmkM.set('menuNo', _menuNo);
    dlBkmkM.set('usrId', _usrId);
    dlBkmkM.set('bkmkKndCd', 'MENU');

    // 서브미션 호출
    const sbmOption = {
        id: "sbmSrch",
        action: "/fu/fuu/fuuz/Bkmk/insertMenuBkmk.do",
        inData: "dlBkmkM",
        outData: "",
        msgYn: { succ: false, err: true },
    };
    try {
        const result = await com.gfnExecute(sbmOption);
        // 성공 처리
        if (result.responseJSON.ErrorCode == '0') {
            scwin.setBkmkYn(_menuNo, 'Y'); // 즐겨찾기 데이터, 화면을 갱신한다.
        }
    } catch (e) {
        console.error(e);
    }
}

