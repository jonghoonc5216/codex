scwin.onpageload = function() {
    if ((WebSquareExternal.active === "local" || WebSquareExternal.active === "dev") && !comUtil.gfnIsMobileApp()) {
        btnInspect.removeClass("hide");
    } else if ((WebSquareExternal.active === "tst" || WebSquareExternal.active === "prod") && !comUtil.gfnIsMobileApp()) {
        // 화면점검요청 권한이 있을 경우 버튼 노출
        const menuInfo = _gcm.Global.getMenuDataJSON().filter(menu => menu.menuCangVal === "COEA007_01");
