/*floatlayer 추가 by SSM*/
.lybox.resize.flayer {display:block;position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:6000;max-width: 160rem;}
.lybox.resize.flayer .ly_column.popup {
    display:block;
    position: fixed;
    padding:0;
    width: 90%;
    min-width: 90%;
    max-width: 90%;
    max-height: 90%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    overflow: visible;
    z-index:6000;
    }
.lybox.resize.flayer:before {
    content: "";
    position: fixed;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 30%);
     margin-top:-2rem; z-index:5999;
}
.lybox.resize.flayer .ly_column.popup:before {display:none;}
.lybox.resize.flayer .ly_column.popup:after {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 5rem;
    border-radius: 0.8rem 0.8rem 0 0;
    background-color: #4876ef;
    z-index: 1000;
}
.lybox.resize.flayer .ly_column.popup .inner {
    position: relative;
    width: 100%;
    overflow: auto;
    padding: 7rem 2rem 2rem 2rem;
    border-radius: 0.8rem 0.8rem;
    background:#fff;
}
.lybox.resize.flayer .ly_column.popup .pop_hidden_title {
    display: inline-block;
    position: fixed;
    z-index: 1001;
    top: 1rem;
    left: 2rem;
    font-size: 2.0rem;
    color: #ffffff;
}
.lybox.resize.flayer .ly_column.popup .btn.pop_close {
    display: inline-block;
    z-index: 1001;
    position: fixed;
    top: 0.8rem;
    right: 1.6rem;
}

