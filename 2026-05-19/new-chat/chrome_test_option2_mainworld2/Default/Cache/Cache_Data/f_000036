scwin.onpageload = function() {
    // 현재 사이트의 CI 로고 변경
    scwin.setLogoImage();

    // 비축, 회계, 법무심사일 경우 검색 버튼 비노출, 결재 노출
    scwin.setTotalSearchButton();

    // 고객센터일 경우 고객센터 버튼 숨김
    scwin.setHelpDeskButton();

    scwin.fnCallGnbBtn();

    // 나의나라장터 메뉴 버튼 제어
    if (com.gfnIsLogin()) {
        grpBeforeLogin.addClass("hide");
        grpAfterLogin.removeClass("hide");
        btnMyPage.removeClass("hide");

        // 전자문서함 노출
        grpDocument.removeClass("hide");

        // 조달청인 경우에만 나라장터 캐비닛 버튼 노출
        if (_gcm.Global.getUsrInfo("usrTyCd") === "이030001") {
            grpEcabinet.removeClass("hide");
            grpApprove.removeClass("hide");
        } else {
            grpEcabinet.addClass("hide");
            grpApprove.addClass("hide");
        }

        grpDocument.removeClass("hide");

        let usrInfo = com.gfnGetUsrInfo();

        let prmsLgnLvelCnt = usrInfo.prmsLgnLvelCnt+"";
        let loginMthd = "";
        // 1:비로그인, 2:ID/PASS, 3:인증서, 4:FIDO, 5:간편인증, 6:모바일신분증
        if (prmsLgnLvelCnt === "1") {
            loginMthd = "비로그인";
        } else if (prmsLgnLvelCnt === "2") {
            loginMthd = "ID/PASS";
        } else if (prmsLgnLvelCnt === "3") {
            loginMthd = "인증서";
        } else if (prmsLgnLvelCnt === "4") {
            loginMthd = "FIDO";
        } else if (prmsLgnLvelCnt === "5") {
            loginMthd = "간편인증";
        } else if (prmsLgnLvelCnt === "6") {
            loginMthd = "모바일신분증";
        }
        loginMthd = loginMthd + "를 이용한<br/>로그인중입니다."
        spnUsrNm.setValue(usrInfo.usrNm);
        txaLogin.setValue(loginMthd);

        spnGrpNm.setValue((usrInfo.grpNm === null || usrInfo.grpNm === undefined) ? "" : usrInfo.grpNm);

    } else {
        grpBeforeLogin.addClass("hide");
        grpAfterLogin.addClass("hide");
        grpEcabinet.addClass("hide");
        grpApprove.addClass("hide");

        // 전자문서함 숨김
        grpDocument.addClass("hide");

        // 마이페이지 숨김
        btnMyPage.addClass("hide");
    }

    comUtil.gfnSetRecentSearchList(); // 최근 검색
};

/********************************************************************************
* 설명 : 현재 사이트의 CI 로고 변경
