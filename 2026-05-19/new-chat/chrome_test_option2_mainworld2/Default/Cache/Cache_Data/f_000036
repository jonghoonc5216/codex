scwin.setLogoImage = function() {
    const contxtSeCd = com.gfnGetContxtSeCd();

    // 평가의원일 경우 통합검색 버튼 안보이게
    if (contxtSeCd !== "콘010012") {
        btnTotalSrch.removeClass("hide");
    }

    btnLogo.removeClass("logo");
    btnLogo.removeClass("logo_accounting");
    btnLogo.removeClass("logo_reserve");
    btnLogo.removeClass("logo_legalScreening");

    switch (contxtSeCd) {
        case "콘010006" : // 나라장터
            btnLogo.addClass("logo");
            btnLogo.setTitle("나라장터");
            btnLogo.setValue("나라장터");
            break;
        case "콘010001" : // 비축
            btnLogo.addClass("logo_reserve");
            btnLogo.setTitle("나라장터 비축");
            btnLogo.setValue("나라장터 비축");
            break;
        case "콘010002" : // 회계
            btnLogo.addClass("logo_accounting");
            btnLogo.setTitle("나라장터 회계");
            btnLogo.setValue("나라장터 회계");
            break;
        case "콘010003" : // 법무심사
            btnLogo.addClass("logo_legalScreening");
            btnLogo.setTitle("나라장터 법무심사");
            btnLogo.setValue("나라장터 법무심사");
            break;
        case "콘010011" : // 조달청 기관운영
            btnLogo.addClass("logo");
            btnLogo.setTitle("나라장터 조달청 기관운영");
            btnLogo.setValue("나라장터 조달청 기관운영");
            break;
        case "콘010004" : // 운영자 : 변경 필요!!
            btnLogo.addClass("logo_customer");
            btnLogo.setTitle("나라장터 운영자");
            btnLogo.setValue("나라장터 운영자");
            break;
        case "콘010010" : // 고객센터 MOS730014 임시 변환
            btnLogo.addClass("logo_customer");
            btnLogo.setTitle("나라장터 고객센터");
            btnLogo.setValue("나라장터 고객센터");
            break;
        case "콘010009" : // 조달데이터 허브
            btnLogo.addClass("logo");
            btnLogo.setTitle("조달데이터 허브");
            btnLogo.setValue("조달데이터 허브");
            break;
        default:
            btnLogo.addClass("logo");
            btnLogo.setTitle("나라장터");
            btnLogo.setValue("나라장터");
            break;
    }
};

