 ********************************************************************************/
scwin.fnFooterMakeRemote = function() {
    genRemote.removeAll(); // 삭제
    let userData1 = genRemote.getUserData("userData1");

    let totCnt = adlPrtlFtreL.getTotalRow();
    let lvl = 0;
    let index = -1;

    for (let i = 0; i < totCnt; i++) {
        let prtlFtreNo = adlPrtlFtreL.getCellData(i, "prtlFtreNo");
        let prtlFtreNm = adlPrtlFtreL.getCellData(i, "prtlFtreNm");
        let upPrtlFtreNo = adlPrtlFtreL.getCellData(i, "upPrtlFtreNo");
        let scrnUrl = adlPrtlFtreL.getCellData(i, "scrnUrl");
        let indtYn = adlPrtlFtreL.getCellData(i, "indtYn");
        let isleafYn = adlPrtlFtreL.getCellData(i, "isleafYn");
        let pathPrtlFtreNo = adlPrtlFtreL.getCellData(i, "pathPrtlFtreNo");

        if (prtlFtreNo === userData1) {
            index = 0;
            continue;
        }

        if (scwin.fnMatchedPathPrtlFtreNo(userData1, pathPrtlFtreNo)) {
            //if (comUtil.gfnIsEmpty(scrnUrl)) continue;
            if (isleafYn !== "Y") continue;

            genRemote.insertChild(index);
            let compObj = genRemote.getChild(index , "genRowRemote"); // Generator 하위 컴포넌트 id genRowRemote
            compObj.setUserData("userData1", prtlFtreNo);
            compObj.render.innerHTML = prtlFtreNm;
            compObj.bind("onclick", scwin.fnOpenPortal);
            index++;
        }
    }
};

