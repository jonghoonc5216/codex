/********************************************************************************
 * 설명 : 연관 검색어 RED 처리
 ********************************************************************************/
scwin.makeRed = function(srchKy,str) {
    // 특수문자 처리
    srchKy = srchKy.replace(/[!@#$%^&*()+=\-[\]\\';,./{}|":<>?~_]/g,"\\$&");

    // 동적 검색어 처리를 위한 RegExp(정규표현식) 사용
    let regexAll = new RegExp(srchKy,"g");

    if (str.indexOf(srchKy.replace(/\\/g,"")) !== -1) { // Matched
        str = str.replace(regexAll,'<span class="blue">' + srchKy.replace(/\\/g,"") + '</span>'); // replace 정규식 사용
    } else { // Not Matched
        str = null;
    }
    return str;
};

