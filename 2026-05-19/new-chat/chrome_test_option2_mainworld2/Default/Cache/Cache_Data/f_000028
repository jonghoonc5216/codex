/* lybox Button Type */
.lybox.horizontal{width:100%;}
.lybox.horizontal .ly_column{}
.lybox.horizontal .ly_column.btn{width:3.4rem;padding-left:.4rem;padding-right:0;vertical-align:middle;align-self: center;flex: 0 0 auto;}
