/* 도움말 버튼 layer popup */
.help-pop-wrap {position: relative;	display: inline-block;}
.help-pop-wrap .popup-box {display: none;transition: 0.5s all ease;position: absolute;top: -2.6rem;left: 3.6rem;min-width: 30.0rem;z-index: -1;
  padding: 1.4rem 1.6rem 1.6rem;border: 0.1rem solid #4876ef;background-color: #ffffff;border-radius: 0.4rem;}
.help-pop-wrap .popup-box.on {display: block;	z-index: 11;}
.help-pop-wrap .popup-box:before{content:"";position:absolute;top: 2.8rem;;left:-1.0rem;width: 1rem;height: 1.6rem;
  background: url(/kn/com/images/components/ic_arr_left_tooltip.svg) no-repeat center;z-index:1;}
