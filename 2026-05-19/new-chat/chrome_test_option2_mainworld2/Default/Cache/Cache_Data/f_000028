/*작은버튼설정*/
.btn_sm{height:2.6rem;min-width: 2.6rem;margin: 0.2rem 0.6rem 0.2rem 0; padding: 0; background-color:#fff; border:0.1rem solid #ccc; border-radius:0.4rem; text-align:center; font-size:1.4rem; font-weight:normal; color: #ccc; box-sizing:border-box;}
.btn_sm:hover{border-color: #4876ef ;background-color: #eef5ff;color: #4876ef;}
.btn_sm:focus{-webkit-box-shadow: 0 0 .4rem .2rem #d9d9d9;box-shadow: 0 0 .4rem .2rem #d9d9d9;border-color: #4876ef ;background-color: #eef5ff;color: #4876ef;}
/*shuttle 페이지 그리드 부분 옆으로 전송*/
.btn_sm.mv_top,
.btn_sm.mv_left,
.btn_sm.mv_right,
.btn_sm.mv_bottom{width:2.6rem;height:2.6rem;text-indent:-9999px;border: 0.1rem solid #ccc; border-radius: 0.4rem;}
.btn_sm.mv_top,
.btn_sm.mv_left,
.btn_sm.mv_bottom{background-size: 2.8rem;background-image: url('/kn/com/images/components/ic_arr_left.svg');background-repeat: no-repeat;background-position: center center;}
.btn_sm.mv_left:hover,
.btn_sm.mv_left:focus,
.btn_sm.mv_top:hover,
.btn_sm.mv_top:focus,
.btn_sm.mv_bottom:hover,
.btn_sm.mv_bottom:focus{background-image: url('/kn/com/images/components/ic_arr_left_blue.svg');}
.btn_sm.mv_top{transform:rotate(90deg)}
.btn_sm.mv_bottom{transform:rotate(-90deg)}
.btn_sm.mv_right{background-size: 2.8rem;background-image: url('/kn/com/images/components/ic_arr_right.svg');background-repeat: no-repeat;background-position: center center;}
.btn_sm.mv_right:hover,.btn_sm.mv_right:focus{background-image: url('/kn/com/images/components/ic_arr_right_blue.svg');}


/* 접기 펼치기 */
.btn_sm.toggle_sm{display:inline-block;width: 2.6rem ;height: 2.6rem;color: transparent;font-size: 0;border-radius: 0.4rem;background-size: 1.6rem;background-image: url('/kn/com/images/components/ic_arr_up.svg');background-repeat: no-repeat;background-position: center center;}
.btn_sm.toggle_sm:hover,.btn_sm.toggle_sm:focus{background-image: url('/kn/com/images/components/ic_arr_up_blue.svg');}
.btn_sm.toggle_sm.active{background-image: url('/kn/com/images/components/ic_arr_down.svg');}
.btn_sm.toggle_sm.active:hover,.btn_sm.toggle_sm.active:focus{background-image: url('/kn/com/images/components/ic_arr_down_blue.svg');}


