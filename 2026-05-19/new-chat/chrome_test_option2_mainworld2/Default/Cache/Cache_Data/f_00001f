    box-sizing: border-box;
    }

@media only screen and (max-width:1400px) {
    .popup-content.srch{padding-left:17rem; padding-right:17rem}
    .popup-content.srch .pop-cnt-wrap{width:95%}

}

@media only screen and (max-width:1023px) {
    .popup-content.srch .pop-cnt-wrap .inner.content{display:block}
    .popup-content.srch .pop-cnt-wrap .inner.content .inner-wrap{width:100%}

}
