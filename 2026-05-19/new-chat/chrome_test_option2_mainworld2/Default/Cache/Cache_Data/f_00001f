/* 검색영역(우측 사용자 영역) */
.inner.right .srch-wrap {display: inline-block; position: relative;}
.inner.right .srch-wrap .btn.srch:before {top: 0; left: 0; width: 4.7rem; height: 4.7rem; border-radius: 50%;
    background-image: url('/kn/com/images/portal/gnb/ic_search.svg'); background-color: #4876ef; background-size: 2rem;}
.inner.right .srch-wrap .btn.srch.close {
    background-image: url('/kn/com/images/portal/gnb/ic_close_white.svg');
    background-size: 1.7rem;
}

/* 검색버튼 클릭시 노출 레이어 배경 dimmed */
/* .inner.right .srch-wrap .popup-srch.bg,  */
.popup-srch.bg {
    display: none;
    position: fixed;
    top: 12.4rem;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.3);
    z-index: 1;
}
/* .inner.right .srch-wrap .popup-srch.bg.appear,  */
.popup-srch.bg.appear {display: block;height:100vh;}

/* 검색버튼 클릭시 노출 레이어 팝업 */
/* .inner.right .srch-wrap .popup-content.srch, */
.popup-content.srch {
    display: none;
    position: fixed;
    /* top: 0; */
    top: 11.3rem;
    left: 0;
    right: 0;
    /* margin-top: 12.4rem; */
    margin: 0;
  /*   padding: 2.4rem 22.0rem 4.8rem; */
      padding:2.4rem 0;
    background-color: #f4f6f8;
    border-top: .0625rem solid #cdcece;
    border-bottom-right-radius: 10rem;
    box-shadow: 0 0.3rem 0.6rem rgba(0, 0, 0, 60%);
    z-index: 4;
}

.popup-content.srch .pop-cnt-wrap{width:72%; margin:0 auto}
.popup-content.srch .pop-cnt-wrap .shbox.srch_keyword .srch_step{width:calc(6.4%);}


.popup-content.srch .pop-cnt-wrap .inner.ipt-srch {
    display: flex; align-items: center; border-bottom: 0.1rem solid #dbdbdb;
}

.popup-content.srch .pop-cnt-wrap .inner.ipt-srch .w2input {width: calc(100% - 6.0rem); height: 6.0rem; font-size: 2.4rem; border: 0; padding:0 2rem; box-shadow: none; background-color:#f4f6f8;}

.popup-content.srch .pop-cnt-wrap .inner.ipt-srch .w2input_focus {
    border: 0; background-color: transparent;
}

.popup-content.srch .pop-cnt-wrap .inner.ipt-srch input::placeholder {
    color: #707070; font-size: 2.4rem; font-weight: 500;
}

.popup-content.srch .pop-cnt-wrap .inner.ipt-srch .btn.search {
    background: url(/kn/com/images/portal/gnb/ic_srch.svg) no-repeat center;
    background-size: 3.0rem;
}


.popup-content.srch .pop-cnt-wrap .inner.content {display: flex;margin-top: 1.6rem;justify-content: space-between;}
.popup-content.srch .pop-cnt-wrap .inner.content .inner-wrap {width: 50%;padding: 0 2rem;}
.pop-cnt-wrap .inner.content .inner-wrap.left {/* margin-right: 4.0rem; */}
.pop-cnt-wrap .inner.content .inner-wrap.right {/* margin-left: 4.0rem; */}
.pop-cnt-wrap .inner.content .title.srch {display: flex; height: 4rem;align-items: center; color: #343434;font-size: 1.8rem;font-weight: 500;/* margin-bottom: 1.2rem; */}
.pop-cnt-wrap .inner.content .btn.chip {
    width: auto;
    height: 3.2rem;
    color: #707070;
    font-size: 1.4rem;
    border-radius: 3.0rem;
    border: 0.1rem solid #dbdbdb;
    margin: 0 .5rem 1rem 0;
    padding: 0 2.4rem;
    display: inline-flex;
    align-items: center;
    min-width: 9rem;
    /* flex-direction: row; */
}

.popup-content.srch .pop-cnt-wrap .btn.close {
    position: absolute; top: 2.8rem; right: 8.0rem;
    background: url(/kn/com/images/portal/gnb/ic_close.svg) no-repeat center;
    background-size: 2.2rem;
}

.inner.right .btn.e-customer,
.inner.right .btn.remote {
    width: auto;
    min-width: 11rem;
    text-align: center;
    height: 3.6rem;
    color: #4876ef;
    font-size: 1.6rem;
    border-radius: 2.5rem;
    background-color: #eef5ff;
    padding: 0 1.6rem;
    line-height: 3.3rem;
    border:0.1rem solid #a7bffe;
}

.inner.right .btn.e-customer {margin-left: 1.6rem;}
.remote-wrap { z-index:100; position: absolute; top: 4.5rem; right: 0; background-color:#ecebeb; border-radius:1.0rem; padding:1.0rem 1.5rem;box-shadow: 0 0.7rem 1.2rem rgba(0, 0, 0, 0.15);}
.remote-wrap .list {padding-bottom: 0.5rem;}
.remote-wrap .list:last-child {padding-bottom: 0.2rem;}
.remote-wrap .list a {display:inline-block; font-size: 1.4rem; text-align: left; white-space: nowrap; color:#222;}
.remote-wrap .list a:hover {color:#4876ef}


/* 연관공고 연관검색어 추가 keh1016 */
.pop-cnt-wrap .tSerword,
.pop-cnt-wrap .tNoti_list{overflow:hidden;max-height: 22rem;overflow-y:auto;padding: 1rem 0;width: 100%;/* border: solid 1px #ddd; */display: block;margin: 0;}
.pop-cnt-wrap .inner-wrap.left .btn.chip{text-align:center}
