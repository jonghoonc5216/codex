@charset "utf-8";

.gnb-btm-wrapper {padding: 0.8rem 0 0.8rem 0; background-color: #fff;}

.gnb-btm-wrap {position: relative; max-width: 160rem; margin: 0 auto;}
.gnb-btm-wrap:after {content: ""; display: block; clear: both;}
.hide-title {color: transparent; font-size: 0; width: 0; height: 0;}

h1.logo {display: inline-block; background-image: none;}
.logo,
.logo_nuri,
.logo_reserve,
.logo_customer,
.logo_accounting,
.logo_legalScreening{display: inline-block; width: 20.8rem; height: 4rem; padding-top:.5rem; color: transparent; font-size: 0;  border: 0;}

.logo {background: url('/kn/com/images/portal/gnb/ci.svg') no-repeat 0 center; background-size: 20.4rem;}
.logo_accounting {background: url('/kn/com/images/portal/gnb/CI_01_accounting.svg') no-repeat 0 center; background-size: 20.4rem; }
.logo_reserve {background: url('/kn/com/images/portal/gnb/CI_02_reserve.svg') no-repeat 0 center; background-size: 20.4rem;}
.logo_legalScreening {background: url('/kn/com/images/portal/gnb/CI_03_legalScreening.svg') no-repeat 0 center; background-size: 20.4rem; }
.logo_nuri {background: url('/kn/com/images/portal/gnb/CI_04_nuri.svg') no-repeat 0 center; background-size: 20.4rem;}
.logo_customer{background: url('/kn/com/images/portal/gnb/CI_customer.svg') no-repeat 0 center; background-size: 20.4rem; }

.gnb-btm-wrap .img-move {width: auto; height: 4.7rem; padding-left: 2rem;}


/* 운영자페이지 상단 */
.gnb-btm-wrap.oper .site-title {font-size: 0rem;vertical-align: bottom;white-space: nowrap;}
.gnb-btm-wrap.oper h1.logo {display: inline-block; background-image: none;}
.gnb-btm-wrap.oper .logo {width: 26.0rem;height: 4.1rem; background: url('/kn/com/images/portal/gnb/ci-oper.png') no-repeat 0 center; background-size: 26.0rem;}

/* 우측 사용자 영역 */
.gnb-btm-wrap .inner.right {float: right; display: inline-flex; align-items: center;position: relative;}
.gnb-btm-wrap .inner.right .btn {position: relative; color: transparent; width: 4.7rem; height: 4.7rem; font-size: 0; border: 0; border-radius: 50%; background-color: transparent; background-size: 2.0rem; background-repeat: no-repeat;  background-position: center; margin: 0 0rem 0 1.6rem;}
.gnb-btm-wrap .inner.right .btn:before {content: ""; position: absolute; background-repeat: no-repeat; background-position: center;}
.gnb-btm-wrap .btn.menu-open.mobile {width: 3.8rem; height: 4.6rem; padding: 1.4rem 0.8rem;}
.gnb-btm-wrap .btn.menu-open.mobile:after {top: 2.1rem;}

/* 나의 나라장터(우측 사용자 영역) */
.inner.right .user-wrap {display: inline-block; position: relative; z-index: 2;}
.inner.right .user-wrap .btn.user:before {width: 4.7rem; height: 4.7rem; background-image: url('/kn/com/images/portal/gnb/ic_user.svg'); background-position: center 0.8rem; background-color: #6263f7; background-size: 2.8rem; border-radius: 50%;}

/* 전자캐비넷 */
.gnb-btm-wrapper.cabinet .gnb-btm-wrap .btn.menu-open.mobile {width: 3.8rem; height: 4.6rem; padding: 1.4rem 0.8rem; position: absolute; top: -5rem; right: 1rem;}
.inner.right .btn.e-cabinet:before {width: 4.7rem; height: 4.7rem; background-image: url('/kn/com/images/portal/gnb/ic_cabinet.svg'); background-position: center; background-color: #1da4e1; background-size: 2.2rem; border-radius: 50%;}
.inner.right .btn.e-approve:before {width: 4.7rem; height: 4.7rem; background-image: url('/kn/com/images/portal/gnb/ic_approve.svg'); background-position: center; background-color: #1da4e1;  background-size: 2.2rem; border-radius: 50%;}
.inner.right .btn.e-document:before {width: 4.7rem; height: 4.7rem; background-image: url('/kn/com/images/portal/gnb/ic_document.svg'); background-position: center; background-color: #1da4e1;  background-size: 2.3rem; border-radius: 50%;}
/* 전자캐비넷 툴팁, 통합검색 툴팁 */
.inner.right .btn.e-cabinet .tooltip.e-cabinet,
.inner.right .btn.e-approve .tooltip.e-approve,
.inner.right .btn.e-document .tooltip.e-document,
.inner.right .srch-wrap .tooltip.total-srch,
.inner.right .user-wrap .tooltip.user, .inner.right .user-wrap .tooltip.user-guide {
    display: inline-block;
    /* display: none; */
    visibility: hidden;
    opacity: 0;
    position: absolute;
    top: 5.9rem;
    left: 50%;
    color: #000000;
    font-size: 1.4rem;
    margin-left: 0.8rem;
    padding: 0.9rem 1.8rem;
    transform: translateX(-50%);
    transition: all 0.2s ease-in-out;
    background-color: #ffffff;
    border: 1px solid #4876ef;
    border-radius: 0.4rem;
    box-shadow: 0 0.3rem 0.6rem rgba(0, 0, 0, 10%);
    white-space: nowrap;
}
.inner.right .btn.e-approve .tooltip.e-approve, .inner.right .btn.e-document .tooltip.e-document { margin-left: 0rem; }

.inner.right .btn.e-cabinet .tooltip.e-cabinet {margin: 0;}

.inner.right .btn.e-cabinet .tooltip.e-cabinet:before,
.inner.right .btn.e-approve .tooltip.e-approve:before,
.inner.right .btn.e-document .tooltip.e-document:before,
.inner.right .srch-wrap .tooltip.total-srch:before,
.inner.right .user-wrap .tooltip.user:before,
.inner.right .user-wrap .tooltip.user-guide:before {
    content: "";
    position: absolute;
    top: -1.0rem;
    left: 50%;
    right: auto;
    bottom: auto;
    width: 0;
    height: 0;
    border-left: 0.7rem solid transparent;
    border-right: 0.7rem solid transparent;
    border-bottom: 1.0rem solid #4876ef;
    transform: translateX(-50%);
}

.inner.right .btn.e-cabinet .tooltip.e-cabinet:after,
.inner.right .btn.e-approve .tooltip.e-approve:after,
.inner.right .btn.e-document .tooltip.e-document:after,
.inner.right .srch-wrap .tooltip.total-srch:after,
.inner.right .user-wrap .tooltip.user:after,
.inner.right .user-wrap .tooltip.user-guide:after {
    content: "";
    position: absolute;
    top: -0.8rem;
    left: 50%;
    right: auto;
    bottom: auto;
    width: 0;
    height: 0;
    border-left: 0.7rem solid transparent;
    border-right: 0.7rem solid transparent;
    border-bottom: 1.0rem solid #ffffff;
    transform: translateX(-50%);
}

.inner.right .btn.e-cabinet:hover .tooltip.e-cabinet,
.inner.right .btn.e-approve:hover .tooltip.e-approve,
.inner.right .btn.e-document:hover .tooltip.e-document,
.inner.right .srch-wrap .btn.srch:hover ~ .tooltip.total-srch,
.inner.right .user-wrap .tooltip.user-guide.on,
.inner.right .user-wrap .btn.user:hover ~ .tooltip.user:not(.guide) {
    visibility: visible; opacity: 1; z-index: 3;
}

.inner.right .user-wrap .popup-content.user {
    display: none;
    position: absolute;
    top: 4.7rem;
    left: 50%;
   /*  min-width: 40rem; */
    min-width: 30rem;
    width: auto;
    background-color: transparent;
    transform: translateX(-50%);
    padding-top: 1.2rem;
}
.inner.right .user-wrap:hover .popup-content.user {display: block;}

.inner.right .user-wrap .popup-content.user:before {
    content: "";
    position: absolute;
    top: 0.3rem;
    left: 50%;
    right: auto;
    bottom: auto;
    width: 0;
    height: 0;
    margin-left: 0.1rem;
    border-left: 0.6rem solid transparent;
    border-right: 0.6rem solid transparent;
    border-bottom: 0.9rem solid #4876ef;
}

.inner.right .user-wrap .popup-content.user:after {
    content: "";
    position: absolute;
    top: 0.5rem;
    left: 50%;
    right: auto;
    bottom: auto;
    width: 0;
    height: 0;
    margin-left: 0.1rem;
    border-left: 0.6rem solid transparent;
    border-right: 0.6rem solid transparent;
    border-bottom: 0.9rem solid #ffffff;
}

.user-wrap .popup-content.user ul {
    display: flex;
    background-color: #fff;
    border: 0.1rem solid #4876ef;
    border-radius: 0.4rem;
}
