/* progressbar */
.progressbar {margin-top: 20px; text-align: center}
.progressbar li {display: inline-block; position: relative; width: 125px; font-weight: 600; color: #A2B5D3; text-align: center; cursor: pointer;}
.progressbar .num {display: block; position: relative; margin: 0 auto; width: 28px; height: 28px; line-height: 28px; background: #E6EBF4; border: 3px solid #fff; border-radius: 50px; z-index: 1}
.progressbar li + li:before {content: ""; position: absolute; left: -60px; top: 17px; width: 100%; border-top: 1px solid #ddd; z-index: 0}
.progressbar .finish,
.progressbar .on {color: #00A6C9}
.progressbar .finish .num,
.progressbar .on .num {background: #00A6C9}
.progressbar .num:after {content: ""; display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%;}
.progressbar .on .dot_wrap {visibility: visible;}
.progressbar .dot_wrap {display: flex; justify-content: center; margin-bottom: 5px; visibility: hidden;}
.progressbar .dot {display: inline-block; margin: 0 1px; width: 6px; height: 6px; background: #EBEBEB; border-radius: 10px}
.progressbar .dot.on {background: #00A6C9}
@media screen and (max-width: 1500px) {
  h2 + .progressbar{margin-top: 0}
}
@media screen and (max-width: 768px) {
  .progressbar li{display: block; margin-bottom: 10px; width: 100%;}
  .progressbar .num{width: 100%; border-radius: 5px}
  .progressbar li + li:before{display: none;}
}

