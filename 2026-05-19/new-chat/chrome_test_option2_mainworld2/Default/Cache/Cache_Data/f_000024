    border-width: 0.5rem 0.7rem 0.5rem 0; border-style: solid; border-color: transparent #ff0000 transparent transparent;}
.step-list-wrap .nav.depth2 > li .btn-link.depth2.active span:after {content: ""; position: absolute; top: 0.8rem; left: -0.6rem;
    border-width: 0.4rem 0.6rem 0.4rem 0; border-style: solid; border-color: transparent #ffffff transparent transparent;} */


.step-list-wrap .btn-link.depth1 ~ .nav.depth2 {top: 0.4rem; bottom: 1.3rem;}
.step-list-wrap .btn-link.depth1.active ~ .nav.depth2 {margin-top: 1.6rem; margin-bottom: -1.2rem; background-color: #eef5ff; z-index: 0;}

.step-list-wrap .nav.depth2 > li.prev.active {color: #4876ef; font-weight: 500;}
.step-list-wrap .nav.depth2 > li.prev:before {top: -0.8rem; border-left: 0.2rem solid #4876ef;}
/* .step-list-wrap .nav.depth2 > li.present:before {background-color: #ff0000;} */
.step-list-wrap .nav.depth2 > li.present:after {background-color: #ff0000;}


.btn-nav {width: 3.0rem; min-width: 3.0rem; height: 3.0rem; min-height: 3.0rem; border: 0.1rem solid #cccccc; border-radius: 50%; box-shadow: 0 0.3rem 0.6rem rgba(0, 0, 0, 0.2);
    margin: 0 0 0 3.4rem; background-color: #ffffff; background-repeat: no-repeat; background-position: center; background-size: 1.1rem; cursor: pointer;}
.btn-nav:hover {border: 0.1rem solid #4876ef;}
.btn-nav.top {background-image: url('/kn/com/images/portal/gnb/ic_arr_top_gray.svg');}
.btn-nav.top:hover {background-image: url('/kn/com/images/portal/gnb/ic_arr_top_blue.svg'); border: 0.1rem solid #4876ef;}
.btn-nav.bottom {background-image: url('/kn/com/images/portal/gnb/ic_arr_btm_gray.svg');}
.btn-nav.bottom:hover {background-image: url('/kn/com/images/portal/gnb/ic_arr_btm_blue.svg'); border: 0.1rem solid #4876ef;}

.btn-nav.left {background-image: url('/kn/com/images/portal/gnb/ic_arr_left_gray.svg'); background-size: 0.7rem;}
.btn-nav.left:hover {background-image: url('/kn/com/images/portal/gnb/ic_arr_left_blue.svg'); border: 0.1rem solid #4876ef;}
.btn-nav.right {background-image: url('/kn/com/images/portal/gnb/ic_arr_right_gray.svg'); background-size: 0.7rem;}
.btn-nav.right:hover {background-image: url('/kn/com/images/portal/gnb/ic_arr_right_blue.svg'); border: 0.1rem solid #4876ef;}



.btn-nav:disabled:hover {border: 0.1rem solid #cccccc;}
