/* step bar navigation */
.portal.stepbar .section.cnts-header .helpbox {width: calc(100% - 22.0rem); margin-left: 22.0rem; display: none;}
.section.container .sub_contents.stepbar-element,
.section.container .sub_contents.stepbar-element ~ .btnbox_all,
.stepbar-wrap ~ .sub_contents,
.section.container .stepbar-wrap ~ .btnbox_all {padding: 0 0 0 20.5rem;}


.portal.gnb-fixed .container-layout .stepbar-wrap {position: fixed; top: 6rem; left: auto; right: auto; height: calc(100vh - 7.4rem);}

/* 스텝바 떨림 현상 vertical  */
 .portal.gnb-fixed.has-scroll.scrolledto-bottom .container-layout .stepbar-wrap.vertical {height: calc(100vh - 44.2rem);}
.portal.scrolled-to-top.scrolledto-bottom .container-layout .stepbar-wrap.vertical {height: calc(100vh - 44.2rem);}
.portal.has-scroll.scrolledto-bottom .container-layout .stepbar-wrap.vertical {height: calc(100vh - 44.2rem);}
.portal.gnb-fixed.has-scroll.scrolled-to-top .container-layout .stepbar-wrap.vertical {top: 18rem;height: calc(100vh - 44.2rem);}


.stepbar-wrap {position: absolute; color: #191919; top: 7.0rem; width: 20.0rem; /* float: left; */ height: calc(100vh - 28.8rem); padding-right: 2.0rem; background-color: #ffffff; transition: top, height 0.1s ease-in-out;}
.step-nav {position: relative; width: 100%; height: 100%; /*overflow: hidden;*/}
.step-nav:before {content: ""; position: absolute; top: 3.0rem; left: 4.8rem; bottom: 3.4rem; border-left: 0.2rem solid #dededf;}
.step-nav:after {content: ""; position: absolute; top: 50%; left: 0; transform: translateY(-50%); width: 2.4rem; height: 6.5rem;
    animation: moveMouse 2s infinite; background: url('/kn/com/images/portal/main/ic_mouse_stepbar.svg') no-repeat 0 center;}

.step-nav .step-list-wrap {position: relative; height: calc(100% - 6.4rem); padding-top:2.4rem;overflow: auto; scrollbar-width: thin; scrollbar-color: #ffffff #ffffff !important;}
.step-nav .step-list-wrap::-webkit-scrollbar {display: none;}

.step-nav.vertical .btn-nav.left, .step-nav.vertical .btn-nav.right {display: none;}

.step-list-wrap .top {padding-top:0;}
.step-list-wrap .top .btn-link.depth-top {position:relative;z-index:1;color:#ffffff;font-weight:500;margin-left:1.8rem;padding:0.2rem 2rem 0.4rem 1.8rem;
    background-color:#4876ef;border-radius:2rem;cursor:auto;}

.step-list-wrap .nav li {padding: 2.0rem 0 2.0rem 0;}
.step-list-wrap .nav li .btn-link {position: relative;}
.step-list-wrap .nav li > .btn-link.depth1:before {content: ""; z-index:1;position: absolute; top: 0.6rem; left: 1.2rem; width: 1.0rem; height: 1.0rem; background-color: #dededf; border-radius: 50%;}
.step-list-wrap .nav li.prev .btn-link:before {background-color: #4876ef;}
.step-list-wrap .nav li.present:before {content: "";}

.step-list-wrap .nav li.prev:hover .btn-link:before,
.step-list-wrap .nav li.present:hover .btn-link:before,
.step-list-wrap .nav li.prev.active > .btn-link:before {top: 1.4rem;}
.step-list-wrap .nav li.present > .btn-link:before {background-color: #ff0000;}
.step-list-wrap .nav li.present.active > .btn-link:before {top: 1.4rem;}
.step-list-wrap .nav li .btn-link.disabled {color: #707070; pointer-events: none;}
.step-list-wrap .nav.depth1 {padding:0;}
.step-list-wrap .nav.depth1 > li {position: relative; padding-left: 3.2rem;}
.step-list-wrap .nav.depth1 > li.prev:after {content: ""; position: absolute; top: -2.6rem; left: 4.8rem; bottom: -2.6rem; border-left: 0.2rem solid #4876ef;}
.step-list-wrap .nav.depth1 > li.prev:hover {font-size: 1.6rem; padding-top: 1.2rem; padding-bottom: 1.2rem;}

.step-list-wrap .nav.depth1 > li.prev .nav.depth2 > li:after {background-color: #4876ef;}
.step-list-wrap .nav.depth1 > li.prev .nav.depth2 > li.active {color: #4876ef;}
.step-list-wrap .nav.depth1 > li.prev .nav.depth2 > li.active:after {background-color: #ffffff; border: 0.1rem solid #4876ef;}

.step-list-wrap .nav.depth1 > li.present:hover {font-size: 1.6rem; padding-top: 1.2rem; padding-bottom: 1.2rem;}
.step-list-wrap .nav.depth1 > li.prev:hover:before {background-color: rgba(72, 118, 239, 0.1);}
.step-list-wrap .nav.depth1 > li.active.prev:before {background-color: rgba(72, 118, 239, 0.1);}
.step-list-wrap .nav.depth1 > li.present:hover:before {background-color: rgba(254, 81, 28, 0.1);}
.step-list-wrap .nav.depth1 li.present > .btn-link {color: #ff0000; font-weight: 500;}
.step-list-wrap .nav.depth1 > li .btn-link.depth1 {position: relative; display: block; padding-left: 5.2rem;}
.step-list-wrap .nav.depth1 > li .btn-link.depth1 span {display: inline-block; width: auto;}
.step-list-wrap .nav.depth1 > li.active {padding-top: 1.2rem; margin-bottom: 0rem; padding-bottom: 1.2rem;}
.step-list-wrap .nav.depth1 > li:hover:before,
.step-list-wrap .nav.depth1 > li.active:before {content: ""; position: absolute; top: 0.6rem; left: 2.5rem; width: 4.8rem; height: 4.8rem; border-left: 0; border-radius: 50%;}
.step-list-wrap .nav.depth1 > li.active:before {background-color: rgba(254, 81, 28, 0.1);}
.step-list-wrap .nav.depth1 > li.prev:hover .btn-link.depth1 span {background-color: rgba(72, 118, 239, 0.1);}
.step-list-wrap .nav.depth1 > li.prev:hover .btn-link.depth1 span,
.step-list-wrap .nav.depth1 > li.active.prev .btn-link.depth1 span {position: relative; color: #4876ef; min-height: 3.6rem; border: 0.1rem solid #4876ef;
    padding: 0.4rem 1.2rem; border-radius: 0.4rem; font-size: 1.6rem; font-weight: 500;}
.step-list-wrap .nav.depth1 > li.prev:hover > .btn-link.depth1 span:before,
.step-list-wrap .nav.depth1 > li.active.prev > .btn-link.depth1 span:before {content: ""; position: absolute; top: 1.0rem; left: -0.9rem; border-width: 0.7rem 0.9rem 0.7rem 0;
    border-style: solid; border-color: transparent #4876ef transparent transparent;}
    .step-list-wrap .nav.depth1 > li.prev:hover > .btn-link.depth1 span:after,
    .step-list-wrap .nav.depth1 > li.active.prev:hover > .btn-link.depth1 span:after {content: ""; position: absolute; top: 1.1rem; left: -0.8rem;
    border-width: 0.6rem 0.8rem 0.6rem 0; border-style: solid; border-color: transparent #ecf1fd transparent transparent;}
.step-list-wrap .nav.depth1 > li.active.prev .btn-link.depth1 span:after {content: ""; position: absolute; top: 1.1rem; left: -0.8rem;
    border-width: 0.6rem 0.8rem 0.6rem 0; border-style: solid; border-color: transparent #ffffff transparent transparent;}
.step-list-wrap .nav.depth1 > li.present:hover .btn-link.depth1 span {background-color: rgba(254, 81, 28, 0.1);}
.step-list-wrap .nav.depth1 > li.present:hover .btn-link.depth1 span,
.step-list-wrap .nav.depth1 > li.active .btn-link.depth1 span {position: relative; color: #ff0000; min-height: 3.6rem; border: 0.1rem solid #ff0000;
    padding: 0.4rem 1.2rem; border-radius: 0.4rem; font-size: 1.6rem; font-weight: 500;}
.step-list-wrap .nav.depth1 > li.present:hover .btn-link.depth1 span:before {content: ""; position: absolute; top: 1.0rem; left: -0.9rem; border-width: 0.7rem 0.9rem 0.7rem 0;
    border-style: solid; border-color: transparent #ff0000 transparent transparent;}
.step-list-wrap .nav.depth1 > li.present.active .btn-link.depth1 span:before {content: ""; position: absolute; top: 1.0rem; left: -0.9rem; border-width: 0.7rem 0.9rem 0.7rem 0;
    border-style: solid; border-color: transparent #ff0000 transparent transparent;}
.step-list-wrap .nav.depth1 > li.present:hover .btn-link.depth1 span:after {content: ""; position: absolute; top: 1.1rem; left: -0.8rem;
    border-width: 0.6rem 0.8rem 0.6rem 0; border-style: solid; border-color: transparent #ffede8 transparent transparent;}
.step-list-wrap .nav.depth1 > li.active .btn-link.depth1 span:after {content: ""; position: absolute; top: 1.1rem; left: -0.8rem;
    border-width: 0.6rem 0.8rem 0.6rem 0; border-style: solid; border-color: transparent #ffffff transparent transparent;}
.step-list-wrap .nav.depth1 > li.active .btn-link.depth1.has-depth.active:after {content: ""; position: absolute; top: 2.4rem; left: 1.6rem; bottom: -2.0rem; border-left: 0.2rem solid #4876ef;}


.step-list-wrap .nav.depth2 {position: relative; max-height: 0; font-size: 1.3rem; overflow: hidden; margin-top: -1.6rem; margin-left: 0rem; padding: 0.8rem 0rem; letter-spacing: -0.05rem;
    z-index: -1; background-color: transparent; border-radius: 0.8rem; transition: max-height 0.3s ease-in-out;}
/* .step-list-wrap .nav.depth2:before {content: ""; position: absolute; top: 1.2rem; left: 0.5rem; bottom: 1.2rem; border-left: 0.1rem solid #dededf;} */
.step-list-wrap .nav.depth2 > li {position: relative; padding: 0.8rem 0rem 0.8rem 3.2rem;}
.step-list-wrap .nav.depth2 > li:before {content: ""; position: absolute; top: 2.0rem; left: 1.6rem; bottom: -1.3rem; border-left: 0.2rem solid #dededf;}
.step-list-wrap .nav.depth2 > li:last-of-type:before {border-left: 0;}

.step-list-wrap .nav.depth2 > li.present:before {}

.step-list-wrap .nav.depth2 > li:after {content: ""; position: absolute; top: 1.3rem; left: 1.2rem; width: 1.0rem; height: 1.0rem; background-color: #dededf; border-radius: 50%;}
.step-list-wrap .nav.depth2 > li.prev:after {left: 1.2rem; background-color: #4876ef;}
.step-list-wrap .nav.depth2 > li.prev.active:after {background-color: #ffffff; border: 0.1rem solid #4876ef;}
.step-list-wrap .nav.depth2 > li .btn-link.depth2 {position: relative; width: 100%; vertical-align: top;}
.step-list-wrap .nav.depth2 > li .btn-link.depth2.active {}
.step-list-wrap .nav.depth2 > li .btn-link.depth2.active:before {content: ""; position: absolute; top: 0.8rem; left: -1.7rem; width: 0.4rem; height: 0.4rem;
    z-index: 1; background-color: #4876ef; border-radius: 50%;}

.step-list-wrap .nav.depth2 > li .btn-link.depth2.active.present:before {background-color: #ff0000;}
.step-list-wrap .nav.depth2 > li.active.present:after {background-color: #ffffff; border: 0.1rem solid #ff0000;}

.step-list-wrap .nav.depth2 > li .btn-link.depth2 span {display: inline-block; width: 100%;}
.step-list-wrap .nav.depth2 > li .btn-link.depth2.active span {position: relative;}

