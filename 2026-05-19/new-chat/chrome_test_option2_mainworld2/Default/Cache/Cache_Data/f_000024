.btn-link:disabled {cursor: auto;}

/* 스텝바유형(좌측배치)에 마이페이지 컨트롤 위젯(우측배치) 레이아웃을 적용하여 스크롤 될때 position fixed 설정할 때 위치 적용 */
.section.container.stepbar-right {display: flex; flex-wrap: wrap; justify-content: flex-end;}
.section.container.stepbar-right .sub_contents {margin: 0; padding-right: 20rem;}
.section.container.stepbar-right .stepbar-wrap {left: auto; right: 0;}
.portal.gnb-fixed .section.container.stepbar-right .stepbar-wrap {/*left: auto;*/ right: auto;}

/* step bar navigation 가로방향 popup에 적용 */
.step-nav.row {height: auto; white-space: nowrap;}
.step-nav.row:before {content: ""; position: absolute; top: auto; left: 3.0rem; right: 3.0rem; bottom: 2.5rem; border-top: 0.1rem solid #dededf;}
.step-nav.row:after {width: 0; height: 0;}
.step-nav.row .btn-nav {min-width: 3.0rem; min-height: 3.0rem; margin: 0 0 1.1rem 0;}
.step-nav.row .step-list-wrap {display: inline-block; width: calc(100% - 6.0rem); height: auto; vertical-align: bottom;}
.step-nav.row .step-list-wrap > ul {overflow: auto; padding: 0rem 0 2.5rem; scrollbar-width: thin; scrollbar-color: #ffffff #ffffff !important;}
.step-nav.row .step-list-wrap > ul::-webkit-scrollbar {display: none;}
.step-nav.row .step-list-wrap .nav.depth1 li {display: inline-block; padding: 0rem; vertical-align: bottom;}
.step-nav.row .step-list-wrap .nav.depth1 > li .btn-link.depth1 {padding: 3.8rem 0rem 0rem;transition: padding 0.2s ease-in-out;}
.step-nav.row .step-list-wrap .nav.depth1 li .btn-link span {padding: 0 1.6rem 1.6rem;}
.step-nav.row .step-list-wrap .nav.depth1 li:not(.disabled) {cursor: pointer;}
.step-nav.row .step-list-wrap .nav.depth1 li:not(.disabled):hover,
.step-nav.row .step-list-wrap .nav.depth1 li.active {padding: 0;}
.step-nav.row .step-list-wrap .nav li .btn-link:before {top: auto; left: 50%; bottom: -0.5rem; transform: translateX(-50%);}
.step-nav.row .step-list-wrap .nav.depth1 li.prev:after {top: auto; left: 0; right: 0; bottom: 0rem; border-left: 0; border-bottom: 0.1rem solid #4876ef;}
.step-nav.row .step-list-wrap .nav.depth1 li.present:after {content: ""; position: absolute; top: auto; left: 0; right: calc(50% + 0.5rem); bottom: 0rem; border-left: 0;
    border-bottom: 0.1rem solid #4876ef;}

.step-nav.row .step-list-wrap .nav.depth1 li:before {content: "";width: 0rem; height: 0rem;top: auto; bottom: 0rem; left: 50%; border-radius: 50%;
    transform: translateX(-50%);transition: all 0.3s ease-in-out;}
.step-nav.row .step-list-wrap .nav.depth1 li:hover:before,
.step-nav.row .step-list-wrap .nav.depth1 li.active:before {width: 4.8rem;height: 4.8rem;bottom: -2.4rem;}

.step-nav.row .step-list-wrap .nav li:not(.disabled):hover .btn-link:before,
.step-nav.row .step-list-wrap .nav li.active .btn-link:before {bottom: -0.5rem;}

.step-nav.row .step-list-wrap .nav.depth1 li:hover .btn-link {padding-top: 3.8rem;}
.step-nav.row .step-list-wrap .nav.depth1 li.prev:hover .btn-link,
.step-nav.row .step-list-wrap .nav.depth1 li.present:hover .btn-link,
.step-nav.row .step-list-wrap .nav.depth1 li.active .btn-link {padding-top: 0rem; padding-bottom: 3.8rem;}

.step-nav.row .step-list-wrap .nav.depth1 li.prev:hover .btn-link.depth1 span,
.step-nav.row .step-list-wrap .nav.depth1 li.present:hover .btn-link.depth1 span,
.step-nav.row .step-list-wrap .nav.depth1 li.active .btn-link.depth1 span {padding: 0.4rem 1.2rem;}

.step-nav.row .step-list-wrap .nav.depth1 li.prev:hover .btn-link.depth1 span:before,
.step-nav.row .step-list-wrap .nav.depth1 li.active.prev .btn-link.depth1 span:before {border-width: 0.9rem 0.7rem 0rem 0.7rem; border-color: #4876ef transparent transparent transparent;
    top: auto; bottom: -1.0rem; left: 50%; transform: translateX(-50%);}

