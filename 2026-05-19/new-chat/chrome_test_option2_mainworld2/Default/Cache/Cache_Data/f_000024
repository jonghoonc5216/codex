@charset "utf-8";

@keyframes moveMouse {
    0% {margin-top: -1.0rem;}
    50% {margin-top: 1.0rem}
    100% {margin-top: -1.0rem;}
}

.section.navigation {position: relative; border-bottom: 0.1rem solid #cdcece; background-color: #ffffff;}
.section.navigation:before {
    content: ""; position: absolute; top: -0.1rem; left: 0;right: 0; bottom: auto; border-top: 0.1rem solid #cdcece;
}

.section.navigation .navi-wrap {max-width: 160rem; margin: 0 auto;}

.navi-wrap .btn.home {
    width: 4.8rem;
    height: 3.6rem;
    font-size: 0;
    color: transparent;
    border: 0.1rem solid #cdcece;
    border-width: 0 0.1rem;
    background: url('/kn/com/images/portal/gnb/ic_home.svg') no-repeat center;
    background-size: 1.9rem;
}

.section.gnb.menu-dpt2-show ~ .section.navigation .navi-wrap select,
.section.gnb.menu-dpt2-show ~ .section.navigation .navi-wrap select option {display: none; visibility: hidden; opacity: 0; position: relative; z-index: -1;}

.navi-wrap .w2selectbox_select {
    height: 3.6rem;
    border: 1px solid #cdcece;
    border-width: 0 0.1rem 0 0;
    margin: 0;
    padding: 0 3.6rem 0 1.6rem;
    outline: none;
    background: url('/kn/com/images/portal/gnb/ic_select_arrow.svg') no-repeat right 1.4rem center;
    background-size: 1.2rem;
    border-radius: 0;
}
.navi-wrap .w2selectbox_select:focus {background: url('/kn/com/images/portal/gnb/ic_select_arrow.svg') no-repeat right 1.4rem center; background-size: 1.2rem;}
.navi-wrap .w2selectbox_select option {padding: 2.0rem;}

.navi-wrap .w2selectbox_native {height: 3.6rem;border: 1px solid #cdcece;border-width: 0 0.1rem 0 0;padding: 0;outline: none;border-radius: 0;}

.navi-wrap .w2selectbox_native.fixedWidth .w2selectbox_native_innerDiv {border: 0; padding: 0.3rem 0 0 0;}
.navi-wrap .w2selectbox_native.fixedWidth .w2selectbox_native_select{min-height: 100%;-webkit-appearance: none;padding: 0 3.0rem 0 1.6rem;outline: none;
    background: url('/kn/com/images/portal/gnb/ic_select_arrow.svg') no-repeat right 1.4rem center;background-size: 1.2rem;border: 0;border-radius: 0;}

.navi-wrap .w2selectbox_native.fixedWidth .w2selectbox_native_select:focus {
    outline:none;
    border:0 !important;
    background: url('/kn/com/images/portal/gnb/ic_select_arrow.svg') no-repeat right 1.4rem center !important;
    background-size: 1.2rem !important;
}

/* popup navigation */
