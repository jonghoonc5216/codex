     * 			1. udc_tooltip을 생성하고자 하는 group (th, td 등)의 userData1 속성에 tooltip contents의 key를 설정한다.
     *          2. 페이지 내 init 함수 등에서 호출한다.
     *             e.g. await pnBidPbancUtil.gfnSetUdcTooltip(reqGrpChk);
     * @param grpObj: 페이지 내 최상위 group object
    ********************************************************************************/
    ,gfnSetUdcTooltip: async function(grpObj) {
        grpObj = (typeof grpObj == "string") ? $p.getComponentById(grpObj) : grpObj;

        let tooltipContents;
        await $.getScript("bsnejs/pn/udcTooltipContents.js", function(data, textStatus, jqxhr) {
            tooltipContents = udcTooltipContents.json;
        });

        const groups = com.gfnGetChildren(grpObj, {recursive: true, includePlugin: "group"});

        let userData;
        let compObj;
        for (let group of groups) {
            userData = group.getUserData("userData1");

            if (userData && userData.startsWith("udcTooltip")) {
                await $p.dynamicCreate(userData, "udc_tooltip",
                        {
                            class: "udc_help_tooltip tooltip",
                        },
                        group);
                compObj = $p.getComponentById(userData);
                compObj.setTooltipTitle(tooltipContents[userData].tooltipTitle);
                compObj.setTooltipContent(tooltipContents[userData].tooltipContent, true);
                compObj.setVisibleCloseButton(true);
                if (tooltipContents[userData].tooltipWidth) {
                    compObj.setTooltipWidth(tooltipContents[userData].tooltipWidth);
                }
            }
        }

    }
