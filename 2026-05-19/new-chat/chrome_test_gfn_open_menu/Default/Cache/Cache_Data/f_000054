             for (let i in objArr) {
                 if (flag) {
                     objArr[i].show("");
                     (objArr[i].hasClass("hide")) && (objArr[i].removeClass("hide"));
                     (!objArr[i].hasClass("inline_block")) && (objArr[i].addClass("inline_block"));
