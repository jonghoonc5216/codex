    }, setAllReadOnly :  function(grpObj,typeCheck){

        grpObj = (typeof grpObj === "string") ? $p.getComponentById(grpObj) : grpObj;


        if (comUtil.gfnIsEmpty(grpObj)) return false;

        let objArr = com.gfnGetChildren(grpObj, {
            includePlugin: "checkbox checkcombobox datePicker editor input inputCalendar multiselect radio selectbox searchbox secret textarea gridView trigger",
            recursive: true
        });

        try {
            for(let objIdx in objArr){
                let obj = objArr[objIdx];

                if(obj.options.pluginName == "selectbox"){
                    //console.log("selectbox",obj);
                    if( typeCheck == "false" ){
                        obj.setDisabled(false);
                    } else {
                        obj.setDisabled(true);
                    }
                }else if(obj.options.pluginName == "checkbox"){
                    if( typeCheck == "false" ){
                        obj.setDisabled(false);
                    } else {
                        obj.setDisabled(true);
                    }
                }else if(obj.options.pluginName == "radio"){
                    if( typeCheck == "false" ){
                        obj.setDisabled(false);
                    } else {
                        obj.setDisabled(true);
                    }
                }else if(obj.options.pluginName == "gridView"){

                    if( typeCheck == "false" ){
                        obj.setDisabled(false);
                    } else {
                        if(obj.org_id!="grdFile"){
                           //그리드의 선택에 따른 세부화면이 바뀌는 그리드의 경우에는 선택이 가능하도록 Readonly처리
                           if(obj.options.className=="wq_gvw item" || obj.options.className=="wq_gvw except_btn"){
                               obj.setReadOnly(true);
                           }else{
                               obj.setDisabled(true);
                           }
                        }
                    }

                    //Column쪽 처리
                    let colInfo = obj.bodyXml._element.E[0].E

                    for(let i=0; i<colInfo.length; i++){


                        if(colInfo[i].A.class == 'btn_grid_def'){
                            if( typeCheck == "false" ){
                                obj.setColumnVisible(colInfo[i].A.id, true);
                            } else{
                                obj.setColumnVisible(colInfo[i].A.id, false);
                            }
                        }

                        //그리드의 체크박스 컬럼 부분을 가리는 로직
                        if(colInfo[i].A.inputType=='checkbox'){
                            if( typeCheck == "false" ){
                                obj.setColumnVisible(colInfo[i].A.id, true);
                            } else{
                                //첨부파일 그리드의 경우 체크박스 컬럼을 가리지 않음
                                if(obj.org_id!="grdFile"){
                                    if(colInfo[i].A.id == "CHK"){
                                        obj.setColumnVisible(colInfo[i].A.id, false);
                                    }
                                }
                            }
                        }

                        //그리드의 선택에 따른 세부화면이 바뀌는 그리드의 경우에는 버튼들 disabled 처리
                        if( colInfo[i].A.inputType=="textImage" || colInfo[i].A.inputType=="button"){
                            if(obj.options.className=="wq_gvw item"){
                                obj.setColumnDisabled(colInfo[i].A.id, true);
                            }
                        }

                    }

                }else if(obj.options.pluginName == "trigger"){
                     if( typeCheck == "false" ){
                         (obj.hasClass("hide")) && (obj.removeClass("hide"));
                         obj.show("");
                     } else {
                         //토글 버튼, 첨부파일 다운로드 버튼은 숨기지 않음
                         const classArr = obj.options.className.split(" ");
                         if ((classArr.includes("btn_sm") && classArr.includes("toggle_sm")) ||
                             (classArr.includes("btn_cm") && classArr.includes("grid_file_down")) ||
                             (classArr.includes("btn_q")) ||
                             (classArr.includes("btn") && classArr.includes("close"))) {
                             // do nothing.
                         }else if(obj.id.includes("btnDmndPopUp") || obj.id.includes("btnDmndRcptPopUp") ||
                                 obj.id.includes("btnMassTranFileSave") || obj.id.includes("btnMassTranFileView") ||
                                 obj.id.includes("btnBsneCnsltnShct") ||
                                 obj.id.includes("bidPrgsInfo1") ||
                                 obj.id.includes("bidPrgsInfo2") ||
                                 obj.id.includes("bidPrgsInfo3") ||
                                 obj.id.includes("pqscCrtrInfo")
                                 ){
                            // do nothing.
                         }else {
                             obj.hide();
                             (!obj.hasClass("hide")) && (obj.addClass("hide"));
                             (obj.hasClass("inline_block")) && (obj.removeClass("inline_block"));
                         }
                         /*
                         if(obj.options.className!="btn_sm toggle_sm"&&obj.options.className!="btn_cm grid_file_down"&&obj.options.className != "btn_q"&&obj.options.className != "btn close"){
                            obj.hide();
                         }
                         */
                     }

                }else if(obj.options.pluginName == "input"){
                    if( typeCheck == "false" ){
                        obj.setReadOnly(false);
                    } else {
                        obj.setDisabled(false);
                        obj.setReadOnly(true);
                    }
                }else{
                    if( typeCheck == "false" ){
                        obj.setReadOnly(false);
                    } else {
                        obj.setReadOnly(true);
                    }
                }

            }
        } catch (ex) {
             console.error("erorr meseage!",ex);
        } finally {
            objArr = null;
        }


    }, gfnCodeNm: function(codeOptions) {

        codeOptions.forEach((codeObj) => {
            if (codeObj.compID) {
