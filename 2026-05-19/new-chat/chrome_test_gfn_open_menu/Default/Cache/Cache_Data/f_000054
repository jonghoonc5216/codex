  ,gfnAlert: function(msgId, opts={}, closeCallbackFncName) {
      let options = opts;
      if (!options.popupName) {
          let msgIdPrefix;
          let msgIdSplitArray;
          if (comUtil.gfnIsArray(msgId)) {
              msgIdSplitArray = msgId[0].split(".");
          } else {
              msgIdSplitArray = msgId.split(".");
          }
          msgIdPrefix = msgIdSplitArray[0];
          if (["warn", "error", "fail"].includes(msgIdPrefix)) {
              options.popupName = "경고 메시지";
          } else {
              options.popupName = "안내 메시지";
          }
      }

      return com.gfnAlert(msgId, options, closeCallbackFncName);
  }
