     * @param textarea event
    ********************************************************************************/
    ,gfnTextAreaAutoHeight: function(e, defaultHeight=null) {
       const objTextarea = document.getElementById(e.target.id);
       const offset = objTextarea.offsetHeight - objTextarea.clientHeight;
       if(defaultHeight==null){
           objTextarea.style.height = "auto";
           objTextarea.style.height = objTextarea.scrollHeight + offset + "px";
       }else{
           if(Number(defaultHeight)< Number(objTextarea.scrollHeight) + Number(offset)){
               objTextarea.style.height = "auto";
               objTextarea.style.height = objTextarea.scrollHeight + offset + "px";
           }else{
               objTextarea.style.height =defaultHeight + "px";
           }
       }
    }
