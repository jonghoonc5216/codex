                compArr.forEach((compId, compIndex) => {
                    let tmpIdArr = compId.split(":");
                    let comp = $p.getComponentById(tmpIdArr[0]);
                    if (comUtil.gfnIsEmpty(comp)) return;
                    const dataType = comp.initializeType || "comp";
                    let dltId = "";

                    if (".dataList.dataMap.".includes(dataType)) {
                        dltId = compId;
                    } else {
                        dltId = _gcm.Global.getDataPrefix() + codeObj.commClsfCd + "_" + codeObj.bsneClsfNo + "___" + compId.replace(/\:/g, "__");
                    }

                    let dataListOption = com.getCodeDataListOptions(_gcm.Global.getCommonCodeInfo("FILED_ARR"));
                    dataListOption.id = dltId;

                    // 동일한 id의 DataCollection이 존재할 경우, 삭제 후 재생성
                    $p.data.create(dataListOption);

                    let dataListObj = $p.getComponentById(dltId);
                    const jsonData = JSON.parse(JSON.stringify(codeData[codeObj.commClsfCd + "_" + codeObj.bsneClsfNo ]));

                    let obj =  codeData[codeObj.commClsfCd + "_" + codeObj.bsneClsfNo];

                    for(i=0;i<obj.length;i++){
                        if( obj[i].commCd) {
                            if(aliasDmInitComm.getJSON()[codeObj.compID] == obj[i].commCd){
                                comp.setValue(obj[i].cdNm);
                            }
                        }
                    }

                });
            }
        });

