********************************************************************************/
scwin.setResizeFontText = function(multiplier) {
    let fontSize = spnFontSize.getValue();
    fontSize = (multiplier === 100) ? 100 : Number(fontSize) + Number(multiplier * 10);

    spnFontSize.setValue(fontSize);
};

