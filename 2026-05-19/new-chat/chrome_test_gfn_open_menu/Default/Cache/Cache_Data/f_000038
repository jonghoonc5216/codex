scwin.fnOpenPortal = function(e){
    let id = this.id;
    let org_id = this.org_id;

    if( comUtil.gfnIsEmpty(org_id) ) {
        return false;
    }
    const obj = $p.getComponentById(org_id);
    if( comUtil.gfnIsEmpty(obj) ) {
        return false;
    }

    let prtlFtreNo = obj.getUserData("userData1");
    if(prtlFtreNo == "00122"){
        WebSquare.util.getMainFrame().scwin.fnOpenPortal(prtlFtreNo, {width : 1380, height : 770}); // 화면이동 함수 호출
    }else{
        WebSquare.util.getMainFrame().scwin.fnOpenPortal(prtlFtreNo); // 화면이동 함수 호출
    }

};

