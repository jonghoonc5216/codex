/********************************************************************************
 * 설명 : 나라장터 서비스 생성
 ********************************************************************************/
scwin.fnKonepsSrvcMake = function(){

    let userData1 = genContent.getUserData("userData1");

    genContent.removeAll(); // 삭제

    let totCnt = adlPrtlFtreL.getTotalRow();

    let lvl = 0;
    let index = -1;

    let genContentRowIndex = -1;
    let genBtnIndex = 0;
    let etcCnt = -1;

    for(let i=0; i<totCnt; i++){
        let prtlFtreNo = adlPrtlFtreL.getCellData(i, "prtlFtreNo");
        let prtlFtreNm = adlPrtlFtreL.getCellData(i, "prtlFtreNm");
        let upPrtlFtreNo = adlPrtlFtreL.getCellData(i, "upPrtlFtreNo");
        let scrnUrl = adlPrtlFtreL.getCellData(i, "scrnUrl");
        let indtYn = adlPrtlFtreL.getCellData(i, "indtYn");
        let isleafYn = adlPrtlFtreL.getCellData(i, "isleafYn");
        let pathPrtlFtreNo = adlPrtlFtreL.getCellData(i, "pathPrtlFtreNo");
        let untyAtchFileNo = adlPrtlFtreL.getCellData(i, "untyAtchFileNo");
        let poupYn = adlPrtlFtreL.getCellData(i, "poupYn"); //팝업여부


        if( prtlFtreNo === userData1 ){
            continue;
        }

        if( scwin.fnMatchedPathPrtlFtreNo(userData1, pathPrtlFtreNo ) ){
            //if( comUtil.gfnIsEmpty(scrnUrl) ) continue;
            //if( isleafYn !== "Y" ) continue;

            if( isleafYn === "N" ){

                if( prtlFtreNo === "00119" )  continue;//기타 New Line

                genContentRowIndex++;
                genContent.insertChild(genContentRowIndex); // genContentLi 생성

                let spnTit = genContent.getChild(genContentRowIndex , "spnTit"); // Generator 하위 컴포넌트 id
                spnTit.setValue(prtlFtreNm);
                continue;
            }

            else{
                let genBtnIndex = -1;
                if( scwin.fnMatchedPathPrtlFtreNo("00119", pathPrtlFtreNo )  ){
                    etcCnt++;
                    if(etcCnt === 0){
                        genContentRowIndex++;
                        genContent.insertChild(genContentRowIndex); // genContentLi 생성

                        let spnTit = genContent.getChild(genContentRowIndex , "spnTit"); // Generator 하위 컴포넌트 id
                        spnTit.removeClass("title");
                    }
                }

                let genLink = genContent.getChild(genContentRowIndex, "genLink");
                genBtnIndex = genLink.getLength();

                if( genBtnIndex >= 4){
                    genContentRowIndex++;
                    genContent.insertChild(genContentRowIndex); // genContentLi 생성
                    let spnTit = genContent.getChild(genContentRowIndex , "spnTit"); // Generator 하위 컴포넌트 id

                    spnTit.removeClass("title");
                    //continue;
                    //genLink = genContent.getChild(genContentRowIndex, "genLink");
                    genBtnIndex = genLink.getLength();
                }

                genLink.insertChild(genBtnIndex);
                let genAnchor = genLink.getChild(genBtnIndex, "genAnchor");

                genAnchor.setValue(prtlFtreNm);

                genAnchor.setUserData("userData1", prtlFtreNo);
                genAnchor.bind("onclick", scwin.fnOpenPortal);

                if( poupYn === "N" ){
                    genAnchor.addClass("new-window");
                }
            }
        }

        if( genContentRowIndex > -1  && scwin.fnMatchedPathPrtlFtreNo(userData1, pathPrtlFtreNo ) === false ) break;
    }

};

