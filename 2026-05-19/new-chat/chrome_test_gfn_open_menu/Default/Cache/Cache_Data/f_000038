        // document.documentElement.style.fontSize = "1.0rem";
        document.documentElement.style.fontSize = "0.625rem";
    }
    document.documentElement.style.fontSize = parseFloat(document.documentElement.style.fontSize) + (multiplier * 0.0625) + "rem";

    scwin.setResizeFontText(multiplier);
};

