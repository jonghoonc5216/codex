/********************************************************************************
* 설명 : 현재 사이트의 버튼에 underLine 생성
********************************************************************************/
scwin.setSiteUnderLine = function() {
    const contxtSeCd = com.gfnGetContxtSeCd();

    btnReserve.removeClass("on");
    btnAccounting.removeClass("on");
    btnLegalScreening.removeClass("on");

    btnCtrlScreen.hide();

    switch (contxtSeCd) {
        case "콘010006" : // 나라장터
            btnNara.addClass("on");
            break;
        case "콘010001" : // 비축
            btnReserve.addClass("on");
            btnReserve.setHref("javascript:void(0);");
            btnReserve.render.target = "";
            break;
        case "콘010002" : // 회계
            btnAccounting.addClass("on");
            btnAccounting.setHref("javascript:void(0);");
            btnAccounting.render.target = "";
            break;
        case "콘010003" : // 법무심사
            btnLegalScreening.addClass("on");
            btnLegalScreening.setHref("javascript:void(0);");
            btnLegalScreening.render.target = "";
            break;
        case "콘010011" : // 조달청 기관운영
            btnPpsOperation.addClass("on");
            btnPpsOperation.setHref("javascript:void(0);");
            btnPpsOperation.render.target = "";
            break;
        case "콘010004" : // 운영자 : 변경 필요!!
        case "콘010010" : // 고객센터 MOS730014 임시 변환
        case "콘010009" : // 조달데이터 허브
        default:
            btnNara.addClass("on");
            break;
    }

    // 로그인 버튼 제어
    if (com.gfnIsLogin()) {
        let usrInfo = com.gfnGetUsrInfo();
        if (!comUtil.gfnIsEmpty(usrInfo)) {
            grpUserInfo.removeClass("hide");
            trgLoginExtension.setTitle(usrInfo.authrtNm || "");

            if (usrInfo.chcNcsrYn === "Y") {
                btnChangeUsrTyCd.setValue((usrInfo.usrTyCd === "이030001") ? "조달청" : "조달청(수요기관)");
                sbxChangeUsrTyCd.removeClass("hide");
                spnGroupName.addClass("hide");
            } else {
                btnChangeUsrTyCd.setValue("선택하세요.");
                sbxChangeUsrTyCd.addClass("hide");
                spnGroupName.setValue(usrInfo.grpNm || "");
                spnGroupName.removeClass("hide");
            }

            spnUserName.setValue(usrInfo.usrNm || "");
            spnUsrIp.setValue(`[${WebSquareExternal.usrIp}]`);

            grpUserInfoM.removeClass("hide");

            if (usrInfo.chcNcsrYn === "Y") {
                btnChangeUsrTyCd.setValue((usrInfo.usrTyCd === "이030001") ? "조달청" : "조달청(수요기관)");
                sbxChangeUsrTyCd.removeClass("hide");
                spnGroupNameM.addClass("hide");
            } else {
                btnChangeUsrTyCd.setValue("선택하세요.");
                sbxChangeUsrTyCd.addClass("hide");
                spnGroupNameM.setValue(usrInfo.grpNm || "");
                spnGroupNameM.removeClass("hide");
            }

            spnUserNameM.setValue(usrInfo.usrNm || "");
            spnUsrIpM.setValue(`[${WebSquareExternal.usrIp}]`);
        }

        grpLogin.addClass("hide");
        grpLogout.removeClass("hide");

        grpLoginMobile.addClass("hide");
        grpLogoutMobile.removeClass("hide");

        // 로그인 시 조달업체, 민간수요기관일 경우 누리장터 메뉴 노출
        if (usrInfo?.grpSeCd === "단030004" || usrInfo?.grpSeCd === "단030006") {
            btnNuri.removeClass("hide");
        } else {
            btnNuri.addClass("hide");
        }

        // 조달청 직원일 경우 회계, 법무심사 버튼 노출
        if (usrInfo.ppsEmpYn === "Y") {
            btnAccounting.removeClass("hide");
            btnLegalScreening.removeClass("hide");
        }

        // 조달청 기관운영 버튼 노출
        // const contxtSeCd = com.gfnGetContxtSeCd();
        // if (contxtSeCd === "콘010011") {
        //  btnPpsOperation.removeClass("hide");
        // }

        // 조달청기관운영, ITSM, 서비스데스크 버튼 노출
        if (WebSquareExternal.isInternalIp && com.gfnGetUsrInfo("ppsEmpYn") === "Y") {
            // btnITSM.removeClass("hide");
            btnServicedesk.removeClass("hide");
            btnPpsOperation.removeClass("hide");
        }

    } else {
        grpUserInfoM.addClass("hide");
        grpUserInfo.addClass("hide");

        sbxChangeUsrTyCd.addClass("hide");

        spnGroupName.setValue("");
        spnUserName.setValue("");
        spnUsrIp.setValue("");

        spnGroupNameM.setValue("");
        spnUserNameM.setValue("");
        spnUsrIpM.setValue("");

        grpLogin.removeClass("hide");
        grpLogout.addClass("hide");

        grpLoginMobile.removeClass("hide");
        grpLogoutMobile.addClass("hide");

        // 비로그인 시 누리장터 메뉴 노출
        btnNuri.removeClass("hide");

        btnAccounting.addClass("hide");
        btnLegalScreening.addClass("hide");
        btnPpsOperation.addClass("hide");

        // 회계 버튼 노출
        if (contxtSeCd === "콘010002") {
            btnAccounting.removeClass("hide");
        }

        // 법무심사 버튼 노출
        if (contxtSeCd === "콘010003") {
            btnLegalScreening.removeClass("hide");
        }

        // 조달청 기관운영 버튼 노출
        if (contxtSeCd === "콘010011") {
            btnPpsOperation.removeClass("hide");
        }

        // 조달청기관운영, ITSM, 서비스데스크 버튼 비노출
        // btnITSM.addClass("hide");
        btnServicedesk.addClass("hide");

    }
};

