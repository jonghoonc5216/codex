scwin.onpageload = function () {
    scwin.FuCommonFn = new FuCommonFn($p);  // 이용자관리 공통 JS 생성

    // 현재 사이트의 버튼에 underLine 생성
    scwin.setSiteUnderLine();

    // 평가의원일 경우 인증센터 버튼 안보이게
    if (com.gfnGetContxtSeCd() !== "콘010012") {
        btnSecurity.removeClass("hide");
    }

    // 퍼블리싱 작업 - 메뉴 버튼 클릭 시 스크롤 있을 시 html에 클래스 적용 이벤트
    if (document.documentElement.scrollHeight > window.innerHeight) {
        document.documentElement.classList.add('scrollable');
    } else {
        document.documentElement.classList.remove('scrollable');
    }

    // scroll 아래에서 위로 올릴 시 gnb 메뉴 클래스 제어 이벤트
    let lastScrollTop = 113;
    // element should be replaced with the actual target element on which you have applied scroll, use window in case of no target element.
    window.addEventListener("scroll", function() {
        let st = window.pageYOffset || document.documentElement.scrollTop;
        if (st > lastScrollTop){
            // downscroll code
            // alert('down');
            portalWrap.classList.remove("scrolled-to-top");
        } else {
            // upscroll code
            // alert('up');
            portalWrap.classList.add("scrolled-to-top");
        }
        lastScrollTop = st;
        }, false);

    // scroll 시 gnb 메뉴 고정 이벤트
    let portalWrap = document.querySelector(".portal");
    let rnb = document.querySelector(".section.rnb");

    window.onscroll = function () {
        let windowTop = window.scrollY;
        if (windowTop > 113) {
            portalWrap.classList.add("gnb-fixed");
            rnb.classList.add("fixed");
        } else {
            portalWrap.classList.remove("gnb-fixed");
            rnb.classList.remove("fixed");
        }

        if (windowTop <= 0) {
            portalWrap.classList.remove("has-scroll");
        } else {
            portalWrap.classList.add("has-scroll");
        }

        // 스크롤 아래까지 갔을 때 포털 최상위 그룹 portal에 클래스 추가 삭제 이벤트
        // let target = document.querySelector(".footer .link-list-wrap");
        let target = document.querySelector(".section.footer");
        let portalElement = document.querySelector(".portal");

        function callback(entries, observer) {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                // Show button
                portalElement.classList.add("scrolledto-bottom");
                } else {
                // Hide button
                portalElement.classList.remove("scrolledto-bottom");
                }
            });
        }
        let observer = new IntersectionObserver(callback);
        // Finally start observing the target element
        observer.observe(target);
    };

    // GNB 버튼 클릭 시 최상위 그룹 portal에 있는 stepbar 클래스 삭제 이벤트
    const btnRemoveSteppBar = document.querySelectorAll('.gnb-top-wrap .btn');
    const portalBody = document.querySelector('.portal');
    for (let i = 0; i < btnRemoveSteppBar.length; i++) {
        btnRemoveSteppBar[i].addEventListener('click', function (e) {
            portalBody.classList.remove('stepbar');
        });
    }

 // scroll 시 gnb 메뉴 고정 이벤트 : 사이트맵 예외 조건  0206 추가
    let sitemapOpen = document.querySelector('.sitemap-wrap .btn.sitemap');
    let sitemapClose = document.querySelector('.sitemap-wrap .btn.close');
    sitemapOpen.addEventListener('click', function (e) {
        portalBody.classList.add('sitemapAct');
    });
    sitemapClose.addEventListener('click', function (e) {
        portalBody.classList.remove('sitemapAct');
    });

    // // GNB 1depth 버튼 클릭 이벤트 (테블릿 세로모드 1023px 이하)
    // const dptFirstBtn = document.querySelectorAll('.gnb-menu-wrap.total .menu-generator .depth1-wrap');
    // if (window.innerWidth < 1024) {
        // for (let i = 0; i < dptFirstBtn.length; i++) {
            // dptFirstBtn[i].addEventListener('click', function (e) {
                // // e.preventDefault();
                // for (let j = 0; j < dptFirstBtn.length; j++) {
                    // dptFirstBtn[j].classList.remove('on');
                // }
                // this.classList.add('on');
            // });
        // }
    // }

    // 최상위 서비스 버튼 클릭 이벤트
    const btnList = document.querySelectorAll('.inner.service-site .btn');
    const siteBtnBox = document.querySelector('.gnb-top-wrap .inner.service-site');
    const siteBtn = document.querySelector('.gnb-top-wrap .btn.menu-open');
    for (let i = 0; i < btnList.length; i++) {
        btnList[i].addEventListener('click', function (e) {
            //e.preventDefault();
            for (let j = 0; j < btnList.length; j++) {
                btnList[j].classList.remove('on');
            }
            this.classList.add('on');
            // 최대해상도 1023px(저해상도 모니터, 테블릿, 모바일)에서 버튼 클릭시 서비스메뉴 숨기기 이벤트
            siteBtnBox.classList.remove('show');
            // 최대해상도 1023px(저해상도 모니터, 테블릿, 모바일)에서 햄버거 버튼 클릭시 해당 버튼 클래스 삭제 이벤트
            siteBtn.classList.remove('active');
        });
    }

    // 퍼블리싱 작업 - 화면설정 테마색상 설정 버튼 클릭 이벤트
    const themeBtnList = document.querySelectorAll('.font-ctrl-menu .setting-wrap .btn.theme');
    for (let a = 0; a < themeBtnList.length; a++) {
        themeBtnList[a].addEventListener('click', function (e) {
            e.preventDefault();
            for (let b = 0; b < themeBtnList.length; b++) {
                themeBtnList[b].classList.remove('active');
            }
            this.classList.add('active');

            let classes = ['green', 'blue-green', 'purple', 'pink', 'brown', 'dark-brown'];
            classes.forEach(c => {
                if (portalBody.classList.contains(c)) {
                    portalBody.classList.remove(c);
                }
            })
        });

        let themeBtnGreen = document.querySelector('.font-ctrl-menu .setting-wrap .btn.theme.green');
        themeBtnGreen.addEventListener('click', function (e) {
            portalBody.classList.add('green');
        });

        let themeBtnLgtGreen = document.querySelector('.font-ctrl-menu .setting-wrap .btn.theme.blue-green');
        themeBtnLgtGreen.addEventListener('click', function (e) {
            portalBody.classList.add('blue-green');
        });

        let themeBtnPurple = document.querySelector('.font-ctrl-menu .setting-wrap .btn.theme.purple');
        themeBtnPurple.addEventListener('click', function (e) {
            portalBody.classList.add('purple');
        });

        let themeBtnPink = document.querySelector('.font-ctrl-menu .setting-wrap .btn.theme.pink');
        themeBtnPink.addEventListener('click', function (e) {
            portalBody.classList.add('pink');
        });

        let themeBtnBrown = document.querySelector('.font-ctrl-menu .setting-wrap .btn.theme.brown');
        themeBtnBrown.addEventListener('click', function (e) {
            portalBody.classList.add('brown');
        });

        let themeBtnDarkBrown = document.querySelector('.font-ctrl-menu .setting-wrap .btn.theme.dark-brown');
        themeBtnDarkBrown.addEventListener('click', function (e) {
            portalBody.classList.add('dark-brown');
        });
    }

    _gcm.setHtmlAttribute(btnLogin, "aria-describedby", spaLoginTip.getID());
    _gcm.setHtmlAttribute(btnLogout, "aria-describedby", spaLogoutTip.getID());
    _gcm.setHtmlAttribute(btnSecurity, "aria-describedby", spaSecurityTip.getID());
    //_gcm.setHtmlAttribute(btnMyUser, "aria-describedby", spaMyUserTip.getID());

    //2차인증여부 체크
    scwin.fnSecAuthYn();
};

