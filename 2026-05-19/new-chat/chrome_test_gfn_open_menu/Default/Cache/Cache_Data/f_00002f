    .show-scroll-icon:after {content: "";position: absolute;top: 50%;left: 50%;width: 5.2rem;height: 5.0rem;transform: translate(-50%, -50%); background: url(/kn/com/images/portal/main/ic_hand.svg) no-repeat center;background-size: 5.0rem;z-index: 10;opacity: 1;}

    .mb_scroll {overflow-x: auto;}
    .mb_scroll > .w2tb.tb_list {min-width: 102.3rem;}
    .mb_scroll > .w2tb.min_wid {min-width: 67.2rem !important;}

    /* tab control */
