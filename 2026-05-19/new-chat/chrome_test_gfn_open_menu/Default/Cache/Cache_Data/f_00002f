    .wq_tbc .w2tabcontrol_tabhost li {width: 50%; margin-top: -0.1rem;}
    .wq_tbc .w2tabcontrol_tabhost li.w2tabcontrol_active {box-shadow: 0 0.3rem 0.6rem 0.2rem rgba(0, 0, 0, 0.1);}
