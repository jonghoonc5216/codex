    .lybox .ly_column.btn .btn_sm.mv_right {transform: rotate(90deg);}
    .lybox .ly_column.btn .btn_sm.mv_left {transform: rotate(90deg);}
    .lybox.horizontal .ly_column.btn .btn_sm.mv_left {margin: 0 0 0 0.6rem;}

    .ly_column.col_05 {text-align:center; padding-top:1rem}
     /* 전자캐비닛 레이아웃 좌우분할 고정 */
