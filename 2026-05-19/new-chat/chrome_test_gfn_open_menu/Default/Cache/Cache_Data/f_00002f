@charset "utf-8";

@media only screen and (max-width: 1023px) {
      /* 테블릿 세로 & 모바일 모드 */
    .portal {padding-top: 7rem !important;}
    .section.rnb {display: none;}
    .section.gnb.fixed {transform: translateY(0);}
    .section.chatbot_wrap {display: none;}

    .portal.gnb-fixed .section.gnb {transform: translateY(0rem);}
    .portal.rnb-close .parent-container {padding-right:2rem;}
    .portal.rnb-close .section.cnts-header .cnts-header-wrap {padding-right:0;}
    .portal.rnb-close .section.container {padding-right:0;}
    .portal.rnb-close .swiper-container.main-nav > .swiper-wrapper > .swiper-slide {padding-right:0;}

    .cnts-header-wrap .inner.top .crud-inner {display: none;}

    .section.gnb.mobile-gnb-show {right: 0;	bottom: 0;}
    .section.gnb.mobile-gnb-show .gnb-area {height: 100%;}
    .section.gnb.mobile-gnb-show .mobile-top-wrap {display: block;}
    .section.gnb.mobile-gnb-show .gnb-top-wrap .inner-site-wrap {display: block;position: fixed;bottom: 2rem;}
    .section.gnb.mobile-gnb-show .gnb-btm-wrap .logo {display: none;}
    .section.gnb.mobile-gnb-show .gnb-btm-wrap .inner.right .srch-wrap {display: none;}
    .section.gnb.mobile-gnb-show .mobile-ctrl-wrap {display: block;}
    .section.navigation {display: none !important;}

    .gnb-area .gnb-top-wrapper {color: #ffffff;background-color: #b4c5f2;}
    .gnb-top-wrapper .gnb-top-wrap {/* display: none; */ position: relative;z-index: 2;min-height: 0;max-height: 0;padding-left: 2rem;padding-right: 2rem;}
    .gnb-top-wrap .inner-site-wrap {display: none;}
    .gnb-top-wrap .inner.service-site.show {top: auto;bottom: 3.3rem;left: 0;}
    .gnb-top-wrap .inner.right {display: none;}
    .gnb-top-wrap .btn.menu-open.service-menu {position: relative; top: 0;background: #ffffff url(/kn/com/images/portal/gnb/ic_select_arrow_top.svg) no-repeat right 1.2rem center; background-size: 1.3rem;}
    .gnb-top-wrap .btn.menu-open.service-menu.active {background: #ffffff url(/kn/com/images/portal/gnb/ic_select_arrow.svg) no-repeat right 1.2rem center; background-size: 1.3rem;}
    .gnb-menu-wrapper {display: none;}
    .gnb-btm-wrapper {height: 7rem;padding: 1.2rem 0 0 0;background-color: #4876ef;}

    .mobile-ctrl-wrap {position: fixed; top: 1.8rem; right: 2.0rem;}
    .mobile-ctrl-wrap .btn {width: 3.4rem; height: 3.4rem; font-size: 0; color: transparent;}
    .mobile-ctrl-wrap .btn.home {border: 0;background: url(/kn/com/images/portal/gnb/ic_home_white.svg) no-repeat center;background-size: 2.8rem;}
    .mobile-ctrl-wrap .btn.close {background: url(/kn/com/images/portal/gnb/ic_close_white.svg) no-repeat center;background-size: 2.0rem;margin: 0 0 0 1.2rem;}

    .gnb-btm-wrap {position: relative; text-align: center; padding-left: 1.6rem; padding-right: 1.6rem;}
    /* 나라장터 */
    .gnb-btm-wrap .logo .logo,
    .gnb-btm-wrap .logo .logo_reserve,
    .gnb-btm-wrap .logo .logo_customer,
    .gnb-btm-wrap .logo .logo_accounting,
    .gnb-btm-wrap .logo .logo_legalScreening{position: absolute; top: 0;left: 50%; height: 4.6rem; transform: translateX(-50%); }
    /* 나라장터 */
   .gnb-btm-wrap .logo .logo{background: url(/kn/com/images/portal/gnb/ci_white.svg) no-repeat 0 center;}
   /* 고객센터 */
   .gnb-btm-wrap .logo .logo_customer{background: url(/kn/com/images/portal/gnb/CI_customer_white.svg) no-repeat 0 center; background-size:contain}
   /* 회계 */
   .gnb-btm-wrap .logo .logo_accounting{background: url(/kn/com/images/portal/gnb/CI_01_accounting_white.svg) no-repeat 0 center;}
   /* 비축 */
   .gnb-btm-wrap .logo .logo_reserve{background: url('/kn/com/images/portal/gnb/CI_02_reserve_white.svg') no-repeat 0 center;}
   /*법무심사  */
   .gnb-btm-wrap .logo .logo_legalScreening{background: url(/kn/com/images/portal/gnb/CI_03_legalScreening_white.svg) no-repeat 0 center;}

    .gnb-btm-wrap .img-move {display: none;}

    /* 운영자페이지 상단 */
    .gnb-btm-wrap.oper .logo {background: url(/kn/com/images/portal/gnb/ci-operwh.png) no-repeat 0 center; top:0.1rem;}

    .gnb-btm-wrap .inner.right {position: static;}
    .gnb-btm-wrap .inner.right .user-wrap,
    .gnb-btm-wrap .inner.right .btn.e-cabinet,
    .gnb-btm-wrap .inner.right .btn.e-customer,
    .gnb-btm-wrap .inner.right .btn.remote,
    .gnb-btm-wrap .inner.right .btn.e-approve,
    .gnb-btm-wrap .inner.right .btn.e-document {display: none;}

    .gnb-btm-wrap .inner.right .srch-wrap {position: absolute; left: 0;}
    .gnb-btm-wrap .inner.right .srch-wrap .btn.srch {margin-left: 0.8rem;}
    .gnb-btm-wrap .inner.right .srch-wrap .tooltip.total-srch {transform: none;left: 1.2rem;top: 5rem;margin-left: 0;}
    .gnb-btm-wrap .inner.right .srch-wrap .tooltip.total-srch:before,
    .gnb-btm-wrap .inner.right .srch-wrap .tooltip.total-srch:after {left: 1.2rem;transform: none;}

    .gnb-btm-wrap .inner.right .srch-wrap .popup-content.srch {top: 7.0rem;padding: 2.4rem 2.4rem 2rem 2.4rem;text-align: left;}
    .gnb-btm-wrap .popup-content.srch .pop-cnt-wrap .inner.ipt-srch {width: calc(100% - 8.6rem);}
    .gnb-btm-wrap .popup-content.srch .pop-cnt-wrap .btn.close {right: 2.0rem;}
    .gnb-btm-wrap .btn.menu-open.mobile:after {background-color: #ffffff;}
    .gnb-btm-wrap .btn.menu-open.mobile span:before,
    .gnb-btm-wrap .btn.menu-open.mobile span:after {background-color: #ffffff;}
    .gnb-btm-wrap .btn.menu-open {display: inherit;}

    /* 전자캐비닛 */
    .gnb-btm-wrapper.cabinet .gnb-btm-wrap .btn.menu-open.mobile:after,
    .gnb-btm-wrapper.cabinet .gnb-btm-wrap .btn.menu-open.mobile span:before,
    .gnb-btm-wrapper.cabinet .gnb-btm-wrap .btn.menu-open.mobile span:after {background-color: #b4c5f2;}

    .mobile-gnb-show.section.gnb .gnb-top-wrapper .gnb-top-wrap {display: block;}
    .mobile-gnb-show.section.gnb .gnb-top-wrap .inner.right .user-info-wrap {display: none;}
    .mobile-gnb-show.section.gnb .gnb-top-wrap .inner.right .login-wrap,
    .mobile-gnb-show.section.gnb .gnb-top-wrap .inner.right .logout-wrap,
    .mobile-gnb-show.section.gnb .gnb-top-wrap .inner.right .ctrl-font-wrap {display: none;}
    .mobile-gnb-show.section.gnb .gnb-btm-wrap .inner.right .user-wrap {display: none;}
    .mobile-gnb-show.section.gnb .gnb-btm-wrap .btn.menu-open.mobile {display: none;}
    .mobile-gnb-show .gnb-btm-wrapper {height: 0;padding: 0;}
    .mobile-gnb-show .gnb-menu-wrapper {display: block; height: calc(100% - 11.4rem);}

    .mobile-top-wrap .inner-wrap.top {height: 7.2rem;	display: flex;	align-items: center;}
    .mobile-top-wrap .inner-wrap {padding: 1.6rem 6.4rem 1.6rem 2.8rem;}
    .mobile-top-wrap .inner-wrap .user-info-wrap .name {color: #ffffff;font-size: 2.0rem;}
    .mobile-top-wrap .inner-wrap.btm {padding: 0.6rem 2.8rem  2.0rem  2.8rem;}
    .mobile-top-wrap .login-box {display: inline-flex;align-items: center;}
    .mobile-top-wrap .login-box .user-info-wrap {padding: 0 1.2rem 0 0;}
    .mobile-top-wrap .btn.login,
    .mobile-top-wrap .btn.logout {color: transparent;width: 3.4rem;height: 3.4rem;font-size: 0;background-size: 1.5rem 1.8rem; background-position: 0.8rem center;background-color: #97afef;border-radius: 50%;}
    .mobile-top-wrap .btn.login {background-image: url(/kn/com/images/portal/gnb/ic_login.svg);}
    .mobile-top-wrap .btn.logout {background-image: url(/kn/com/images/portal/gnb/ic_logout.svg);}
    .mobile-top-wrap .btn.link {width: calc(25% - 1.0rem);height: 3.2rem;color: #ffffff;font-size: 1.4rem;font-weight: 500;border: 0;border-radius: 1.5rem;background-image: none; margin: 0 1.0rem 0 0;padding: 0 0.6rem;line-height: 3.0rem;text-align: center;}
    .mobile-top-wrap .btn.link.my-menu {background-color: #1da4e1; width: calc(30% - 1.0rem);}
    .mobile-top-wrap .btn.link.security-center {background-color: #57b7f6;}
    .mobile-top-wrap .btn.link.e-customer {background-color: #8d9bf8;}
    .mobile-top-wrap .chip {display: inline-block; width: auto; margin: 0 0 0 0.8rem; padding: 0 1.6rem;}

    .gnb-menu-wrapper:before {content: none;}
    .gnb-menu-wrap.total {height: 100%; max-height: fit-content; padding-left: 0rem; padding-right: 0rem; border-radius: 0;}
    .gnb-menu-wrap.total:before {border-bottom: 0; box-shadow: none;}
    .gnb-menu-wrap.total .inner-wrap {flex-direction: row; padding: 0;}
    .gnb-menu-wrap.total .inner-wrap .sitemap-wrap {position: fixed; top: 7.8rem; right:2.0rem; width: calc(25% - 5rem);}
    .gnb-menu-wrap.total .sitemap-wrap .btn.sitemap {width: 100%;height: 3.2rem;color: #ffffff;font-size: 1.4rem;font-weight: 500;border-radius: 1.5rem;background-color: #b48dfb; padding: 0 0.6rem;line-height: 3.0rem;background-image: none;}
    .gnb-menu-wrap.total .menu-generator .btn span {color: #000000; text-align: left;}
    .gnb-menu-wrap.total .menu-generator.dpt1 ~ .menu-generator {display: block; height: auto; max-height: 100%;}
    .gnb-menu-wrap.total > .inner-wrap > .menu-generator.dpt1 {max-width: none; height: auto; max-height: none; flex-direction: column; background-color: #f4f6f7; padding: 1.6rem 2rem 0 2.8rem;}
    .gnb-menu-wrap.total .menu-generator .depth1-wrap {max-width: none; width: auto; max-height: none;}
    .gnb-menu-wrap.total .menu-generator .depth1-wrap:nth-of-type(odd):before {content: none;}
    .gnb-menu-wrap.total .menu-generator .depth1-wrap .btn {width: 100%; padding: 0;}
    .gnb-menu-wrap.total .menu-generator .depth1-wrap .btn:focus {outline: none; outline: 0 !important;}
    .gnb-menu-wrap.total .menu-generator .depth1-wrap .btn:hover:before {content: none;}
    .gnb-menu-wrap.total .menu-generator .depth1-wrap .btn a.depth1 {padding: 1.6rem 0;}
    .gnb-menu-wrap.total .menu-generator .depth1-wrap .btn a.depth1 span {position: relative;display: inline-block; color: #000000;width: auto;}
    .gnb-menu-wrap.total .menu-generator .depth1-wrap .btn a.depth1 span:before {content: "";position: absolute;top: auto;left: 50%;bottom: -0.7rem; width: 0;background-color: transparent;	opacity: 1;	border-bottom: 0.2rem solid transparent; transform: translateX(-50%);transition: all 0.4s ease-in-out;}
    .gnb-menu-wrap.total .menu-generator .depth1-wrap .btn a.depth1:hover span:before {width: calc(100% - 0.6rem); border-bottom: 0.2rem solid #1f67c0;}
    .gnb-menu-wrap.total .menu-generator .depth1-wrap .btn a.depth1:focus span:before {width: calc(100% + 0.4rem); border-bottom: 0.2rem solid #4876ef;}
    .gnb-menu-wrap.total .menu-generator > .depth2-wrap {display: none; width: 100%; max-width: 100%; min-width: 100%;}
    .gnb-menu-wrap.total .menu-generator > .depth2-wrap.on {display: flex;}
    .gnb-menu-wrap.total .menu-generator > .depth2-wrap:nth-of-type(odd) {background-color: transparent; border-bottom: 0;}
    .gnb-menu-wrap.total .menu-generator .depth2-wrap .btn span {font-size: 1.6rem;}
    .gnb-menu-wrap.total.sub .menu-generator .depth1-wrap {align-items: flex-start; padding: 0;}
    .gnb-menu-wrap.total.sub > .inner-wrap > .menu-generator.dpt1 {width: 19.4rem;}
    .gnb-menu-wrap.total.sub .menu-generator.dpt1 ~ .menu-generator {width: 60%; align-items: flex-start;}
    .gnb-menu-wrap.total.sub .menu-generator > .depth2-wrap > .inner {padding: 2.8rem 0 0 0;}
    .gnb-menu-wrap.total.sub .menu-generator > .depth2-wrap > .inner > li {position: relative; max-width: 100%; min-width: 100%;padding: 0rem 2.4rem 1.2rem 2.4rem;}
    .gnb-menu-wrap.total.sub .menu-generator .depth2-wrap .btn.depth2 {display: inline-block; width: auto; border-bottom: 0; margin: 0; padding: 0 0 0 1.0rem;}
    .gnb-menu-wrap.total.sub .menu-generator .depth2-wrap .btn.depth2:before {width: 0.3rem;}
    .gnb-menu-wrap.total.sub .menu-generator .depth3-wrap {padding-left: 1.2rem;}
    .gnb-menu-wrap.total.sub .menu-generator .depth2-wrap .btn.depth3:before {top: 1rem; border-radius: 50%;}
    .gnb-menu-wrap.total.sub .menu-generator .depth3-wrap .btn.depth3 span {font-size: 1.6rem;}
    .gnb-menu-wrap.total > .inner-wrap > .menu-generator .depth3-wrap {max-height: 0; overflow: hidden; transition: max-height 0.3s ease-in-out;}
    .gnb-menu-wrap.total .popup-content.sitemap .menu-generator .depth1-wrap > .btn {position: relative; top: auto; left: 0rem; bottom: auto; transform: none;}

    /* mega-menu */
    .gnb-menu-wrap.total.sub .menu-generator.mega-menu {display: block;background-color: #ffffff;padding-top: 1.2rem;}
    .gnb-menu-wrap.total.sub .menu-generator.mega-menu:before {content:"";position: absolute;width: 30%;top: 0;left: 0;bottom: 0;background-color: #f4f6f7;}
    .gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth1-wrap {height: auto;}
    /* .gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth1-wrap.on > .inner-wrap {display: none;} */
    /* .gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth1-wrap.active > .inner-wrap {display: block;} */
    .gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth1-wrap > .btn {width: 30%;padding: 0rem 2rem 0 2.8rem;}
    .gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth1-wrap > .inner-wrap {position: fixed;width: 70%;max-height: 100%;top: 13rem;left: 30%;right: 0;bottom: 0; z-index: 1;padding-top: 0.6rem;padding-left: 0;padding-right: 0;flex-wrap: wrap;border-radius: 0;}
    .gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth1-wrap > .inner-wrap > .inner {flex-wrap: nowrap;flex-direction: column;height: 100%;max-height: 100%;}
    .gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth2-wrap {max-width: 100%;min-width: 100%;position: relative;}
    .gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth2-wrap > .inner {display: block;max-height: 0;overflow: hidden;transition: max-height 0.3s ease-in-out;}
    .gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth3-wrap {max-height:min-content;}

    .menu-generator .depth2-wrap .mobile-btn-toggle {display: block;top: 0.4rem;right:3.0rem;height: 2.0rem;}
    .menu-generator.mega-menu .depth2-wrap .mobile-btn-toggle {top: 1.8rem;}

    /* 나라장터 캐비닛 */
    .gnb-btm-wrapper.cabinet {padding: 0.3rem 0 0; background: #f5f6f8;}
    .gnb-menu-wrapper.cabinet .gnb-menu-wrap.total.sub {display: block !important;}
    .gnb-menu-wrapper.cabinet .gnb-menu-wrap.total.sub > .inner-wrap {overflow: hidden; height: calc(100% - 2rem);}

    /* 전체메뉴 레이어팝업 */
    .sitemap-wrap .btn.close {top: 2.0rem; right: 2.0rem;}
    .sitemap-wrap .popup-content.sitemap {bottom: 0; border-radius: 0; box-shadow: none;}
    .sitemap-wrap .popup-content.sitemap .inner.top {padding: 2.0rem 8.0rem 2.0rem 2.0rem;}

    .popup-content.sitemap .inner.top .title-sitemap {width: auto; padding: 0 1.6rem;}
    .popup-content.sitemap .inner.content.sitemap {height: calc(100% - 10.4rem); font-size: 1.6rem;}
    .popup-content.sitemap .inner.content.sitemap > .menu-generator {max-height: 100%; height: 100%;padding: 0 2rem;}
    .popup-content.sitemap .menu-generator .depth1-wrap .inner-wrap.menu-content {width: calc(100% - 14.0rem);}
    .popup-content.sitemap .menu-generator .depth1-wrap,
    .gnb-menu-wrap.total .popup-content.sitemap .menu-generator .depth1-wrap {flex-direction: row; justify-content: flex-start; padding: 2rem 0;}
    .popup-content.sitemap .menu-generator .depth1-wrap.active,
    .gnb-menu-wrap.total .popup-content.sitemap .menu-generator .depth1-wrap.active {position: static;width: 100%;}
    .popup-content.sitemap .menu-generator .depth1-wrap .depth1,
    .gnb-menu-wrap.total .popup-content.sitemap .menu-generator .depth1-wrap .depth1 {position: relative; top: auto; left: auto; bottom: auto;}
    .popup-content.sitemap .menu-generator .depth1-wrap.active > .inner-wrap > .inner,
    .gnb-menu-wrap.total .popup-content.sitemap .menu-generator .depth1-wrap.active > .inner-wrap > .inner {display: flex; flex-direction: row;width: 100%;padding: 0;}
    .popup-content.sitemap .menu-generator .depth1-wrap .inner,
    .gnb-menu-wrap.total .popup-content.sitemap .menu-generator .depth1-wrap .inner {display: none; flex-direction: column;}
    .popup-content.sitemap .menu-generator .depth2-wrap,
    .gnb-menu-wrap.total .popup-content.sitemap .menu-generator .depth2-wrap {width: 50%; max-width: 50%;min-width: 50%;padding-top: 0.4rem;}
    .gnb-menu-wrap.total .popup-content.sitemap .menu-generator .depth2-wrap.active {display: block;}
    .gnb-menu-wrap.total .popup-content.sitemap .menu-generator .depth2-wrap:nth-of-type(2n) ~ .depth2-wrap {padding-top: 2.0rem;}

    .parent-container {padding-left:2.0rem; padding-right: 2.0rem; margin-right: 0;}
    .cnts-header-wrap,
    .section.container {padding: 0rem;}
    .section.container {padding-bottom: 3.6rem;}
    .cnts-header-wrap .inner.top {display: flex;justify-content: space-evenly;}
    .cnts-header-wrap .inner.top h2 {width: 100%;margin: 0 auto;text-align: center;}
    .cnts-header-wrap .inner.top .btn.favorite {display: none;}

    .w2popup_window .cnts-header-wrap .inner.top {display: flex;justify-content: end;}

    .section.footer .footer-wrap .inner-wrap {padding-left:0rem; padding-right: 0rem; border: 0;}
    .footer-wrap .inner-wrap.top .inner {flex-direction: column; padding: 0;}
    .footer-wrap .inner-wrap.top .inner .shortcut-wrap {width: 100%;border: 0.1rem solid #cccccc;padding: 1rem 0;border-width: 0.01rem 0;}
    .footer-wrap .inner-wrap.top .inner .info-wrap {margin-top: 1.4rem;}

    .footer-wrap .inner-wrap.content {text-align: center;}
    .footer-wrap .inner-wrap.content .inner {position: relative;flex-direction: column;padding: 6.6rem 0 0 0;}
    .footer-wrap .inner-wrap.content .inner .link-list-wrap {display: flex;position: absolute;top: 0;left: 0;width: 100%;padding: 2rem 2rem;border-bottom: 0.1rem solid #cccccc;}

    .footer-wrap .link-list-wrap > li {width: calc(50% - 1.0rem);}
    .footer-wrap .link-list-wrap > li ~ li {margin: 0rem 0 0 2.0rem;}
    .footer-wrap .link-list-wrap > li:before {content: ""; position: absolute; top: 0; right: 2.6rem; height: 2.6rem; border-right: 0.1rem solid #cccccc;}
    .footer-wrap .link-list-wrap .link-toggle {width: 100%; height: 2.6rem;border: 0.1rem solid #cccccc;border-radius: 0.4rem;line-height: 1;font-weight: 400; text-align: left;padding: 0 2.6rem 0 0.8rem;background: #ffffff url(/kn/com/images/portal/gnb/ic_select_arrow_top.svg) no-repeat right 0.6rem top 0.8rem; background-size: 1.3rem;}
    .footer-wrap .link-list-wrap .link-toggle.active {border-radius: 0 0 0.4rem 0.4rem; background: #ffffff url(/kn/com/images/portal/gnb/ic_select_arrow.svg) no-repeat right 0.6rem center; background-size: 1.3rem;}
    .footer-wrap .link-list-wrap .link-inner-wrap {bottom: 2.5rem;}
    .footer-wrap .link-list-wrap .link {padding: 0 1.5rem;	text-align: left;}

    .footer-wrap .inner-wrap.content .address-wrap {display: inline-flex;flex-direction: column;justify-content: center;padding: 2rem 2rem 2rem 15rem; background: url(/kn/com/images/portal/rnb/ci.svg) no-repeat 2rem center;background-size: 10.8rem;}
    .footer-wrap .inner-wrap.content .info-wrap {padding-left: 16.0rem; text-align: left;}
    .footer-wrap .inner-wrap.content .info-wrap > * {display: inline-block;}
    .footer-wrap .inner-wrap .info-phone, .footer-wrap .inner-wrap .info-phone li {display: inline-block;}

    /* main */
     .has-main .portal > .container-layout {min-height: 105rem;}
    .has-main .portal .w2tabcontrol.main-rtl.layout .main-cnt-wrap.cnts-info {padding-bottom: 1rem;}

    .swiper-container.main-nav {padding-top: 2rem; margin-top: 0rem}
    .swiper-button-next.main-nav, .swiper-button-prev.main-nav {top: 3.6rem;}
    .swiper-button-next.main-nav{right:0.8rem }
    .swiper-button-prev.main-nav{left:calc(100% - 30rem) !important}
    .swiper-pagination.main-nav{top:0; right:6.8rem}

    /* .swiper-button-next.main-nav, .swiper-button-prev.main-nav {top: 45%;}
    .swiper-button-next.main-nav {right: -2rem;}
    .swiper-button-prev.main-nav {left: -2rem;} */

    .w2tabcontrol.main-rtl.layout {padding-top: 2rem;}
    .w2tabcontrol.main-rtl.layout .w2tabcontrol_tabhost {z-index: 2; top: 4.0rem; right: 2rem;}
    .w2tabcontrol.main-rtl.layout .w2tabcontrol_tabhost li ~ li {margin-left: 1.2rem;}
    .w2tabcontrol.main-rtl.layout .main-cnt-wrap {padding-bottom: 2rem;}
    .w2tabcontrol.main-rtl.layout .lybox {display: block;flex: none;}
    .w2tabcontrol.main-rtl.layout .tit-main-guide.type1 {display: none;}

    .main-cnt-wrap.cnts-info {padding-bottom: 2rem;}
    .tit-main-guide.type2 {display: flex;flex-wrap: wrap;align-items: center;justify-content: center;min-height: 7rem; margin-top: 6rem;margin-bottom: 0rem;padding-right: 0rem;padding-top: 0;height: auto;}
    .tit-main-guide.type2 span {display: inline-block;}
    .tit-main-guide.type2 .emp.lg {padding-bottom: 0.6rem;}

    .lybox .ly_column.main-banner {width: 100%;display: block;flex: none; margin-bottom: 1.6rem;}
    .lybox .ly_column.main-cnts {display: block;flex: none;width: 100%;padding-left: 0;}



