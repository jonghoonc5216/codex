scwin.fnMainBannerMake = function(){

    let userData1 = genBannerLst.getUserData("userData1"); //링크
    genBannerLst.removeAll(); // 삭제

    let totCnt = adlPrtlFtreL.getTotalRow();
    let index = 0;

    for(let i=0; i<totCnt; i++){
        let json = adlPrtlFtreL.getRowJSON(i);

        if( json.prtlFtreNo === userData1 ) continue;

        if( scwin.fnMatchedPathPrtlFtreNo(userData1, json.pathPrtlFtreNo ) ){
            if( json.isleafYn !== "Y" ) continue;
            genBannerLst.insertChild(index);

            let genRowBanner = genBannerLst.getChild(index, "genRowBanner");

            let imgBox = genBannerLst.getChild(index, "imgBox");

            genRowBanner.setUserData("userData1", json.prtlFtreNo);
            genRowBanner.bind("onclick", scwin.fnOpenPortal);

            comUtil.gfnIsNotEmpty(json.banrImgUrl) ? imgBox.setSrc(json.banrImgUrl) : imgBox.hide();
            index++;
        }
    }
}
