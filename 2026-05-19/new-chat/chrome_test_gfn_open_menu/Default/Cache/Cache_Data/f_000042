scwin.fnRefSiteMake = function(){

    let userData1 = "00008"; // 포탈기능번호 설정 나라장터 관련사이트

    let totCnt = adlPrtlFtreL.getTotalRow();
    let index = 0;

    
    for(let i=0; i<totCnt; i++){
        let json = adlPrtlFtreL.getRowJSON(i);

        if (json.upPrtlFtreNo !== userData1 ) continue;

        if( json.isleafYn !== "Y" ) continue;
        let banrImg = json.banrImgUrl;
        let prtTit = json.prtlFtreNm

        if (index == 2 )  {
            genGropImg1.setSrc(banrImg);
            genGropTit1.setLabel(prtTit)
            scwin.bindEvent(genGrop1, json.prtlFtreNo);
