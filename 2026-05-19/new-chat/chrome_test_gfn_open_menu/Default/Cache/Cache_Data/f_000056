scwin.stepBarDraw = function() {

    // progress bar 좌우 버튼 클릭시 이벤트
    const btnNaviLeft = document.querySelector('.prgrs_wrap .btn-nav.left');
    const btnNaviRight = document.querySelector('.prgrs_wrap .btn-nav.right');
    const scrollableNav = document.querySelector('.prgrs_ul');

    function btnNaviLeftFunction() {
        scrollableNav.scrollLeft -= 100;
    }
    btnNaviLeft.addEventListener('click', btnNaviLeftFunction);

    function btnNaviRightFunction() {
        scrollableNav.scrollLeft += 100;
    }
    btnNaviRight.addEventListener('click', btnNaviRightFunction);

    // 상단 스크롤되는 아이템에 스크롤 컨트롤 대신 drag 동작 이벤트
    const slider = document.querySelector('.prgrs_ul');
    let isDown = false;
    let startX;
    let scrollLeft;

    slider.addEventListener('mousedown', (e) => {
        isDown = true;
        slider.classList.add('active');
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
    });
    slider.addEventListener('mouseleave', () => {
        isDown = false;
        slider.classList.remove('active');
    });
    slider.addEventListener('mouseup', () => {
        isDown = false;
        slider.classList.remove('active');
    });
    slider.addEventListener('mousemove', (e) => {
        if(!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * .5; //scroll-fast
        slider.scrollLeft = scrollLeft - walk;
        // console.log(walk);
    });

    // 프로그레스 바 prgrs_wrap 스크롤 시 네비게이션 버튼 활성화 이벤트
    document.querySelector('.prgrs_wrap > ul').addEventListener('scroll', function() {
        let progressBox = document.querySelector('.prgrs_wrap > ul');
        let btnNavLeft = document.querySelector('.prgrs_wrap .btn-nav.left');
        let btnNavRight = document.querySelector('.prgrs_wrap .btn-nav.right');

        btnNavLeft.setAttribute('disabled', 'true');
        btnNavRight.setAttribute('disabled', 'true');

        // // 스크롤 생기지 않는 경우
        // if (progressBox.scrollWidth == progressBox.clientWidth) {
        //     btnNavLeft.setAttribute('disabled', 'true');
        //     btnNavRight.setAttribute('disabled', 'true');
        //     // console.log('scroll left');
        // } else {
        //     btnNavLeft.removeAttribute('disabled', 'true');
        //     btnNavRight.removeAttribute('disabled', 'true');
        //     // console.log('scrolling');
        // }

        // 스크롤 우측 끝까지 갔을 때
        if (Math.abs(progressBox.scrollLeft) === progressBox.scrollWidth - progressBox.clientWidth) {
            // console.log('scroll right');
            progressBox.classList.add('right');
            btnNavRight.setAttribute('disabled', 'true');
        } else {
            progressBox.classList.remove('right');
            btnNavRight.removeAttribute('disabled', 'true');
        }
        // 스크롤 좌측 끝에 갔을 때
        if (progressBox.scrollLeft <= 0) {
            btnNavLeft.setAttribute('disabled', 'true');
            // console.log('scroll left');
        } else {
            btnNavLeft.removeAttribute('disabled', 'true');
            // console.log('scrolling');
        }
    });

    //  프로그레스 바 li 클릭 시 active 클래스 적용 이벤트
    // let itemLink = document.querySelectorAll(".prgrs_wrap li");
    // let ii;
    // for (ii = 0; ii < itemLink.length; ii++) {
    //     // if (itemLink[i].classList.contains("present")) {
    //     //     itemLink[i].parentElement.classList.add('present');
    //     // }
    //     itemLink[ii].addEventListener("click", function() {
    //         for (let jj = 0; jj < itemLink.length; jj++) {
    //             itemLink[jj].classList.remove('cmplt_chk');
    //         }
    //         this.classList.add('cmplt_chk');
    //     });
    // };
    // previous selector 클래스 추가
    //$('.prgrs_wrap li.prgrs_ing').prevAll().addClass('prgrs_cmplt');
    // nextAll selector 클래스 추가
    //$('.prgrs_wrap li.prgrs_ing').nextAll('li').addClass('disabled');
    // $('.step-list-wrap .nav.depth1 > li.disabled > .btn-link.depth1').addClass('disabled');
    // disabled selector에 active 클래스 삭제
    // $('.prgrs_wrap li.disabled').click( function() {
    //     $(this).removeClass('cmplt_chk');
    // });

    // 스크롤 생기지 않는 경우
    let progressScrollBx = document.querySelector('.prgrs_wrap > ul');
    if (progressScrollBx.scrollWidth <= progressScrollBx.clientWidth) {
        document.querySelector('.prgrs_wrap .btn-nav.left').setAttribute('disabled', 'true');
        document.querySelector('.prgrs_wrap .btn-nav.right').setAttribute('disabled', 'true');
    } else {
        document.querySelector('.prgrs_wrap .btn-nav.left').removeAttribute('disabled', 'true');
        document.querySelector('.prgrs_wrap .btn-nav.right').removeAttribute('disabled', 'true');
    }

};


