        grpOpnnList.hide();
        if(dlBfSpecItemL.getRowCount() > 0){
            gvDmndItem.setColumnVisible(5, true);
        }
    }else{
        grpUrlInfo.hide();
        grpOpnnList.show("");
        if(dlBfSpecItemL.getRowCount() > 0){
            gvDmndItem.setColumnVisible(5, false);
        }
    }

};

