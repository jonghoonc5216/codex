/********************************************************************************
 * 설명 : 의견상세조회 팝업 콜백 => Y: 등록 팝업 수정모드로 호출, R: 답변등록
 ********************************************************************************/
scwin.fnCallbackFromView = function (data) {
    if(!comUtil.gfnIsEmpty(data)){  //수정하겠다는 flag
        if(data.gubun == "Y" && comUtil.gfnIsEmpty(data.ansSqno)){  //수정하겠다는 flag
            let param = {"bfSpecRegNo"      : dlBfSpecM.get("bfSpecRegNo")
                        ,"prcmBsneSeCd"     : scwin.prcmBsneSeCd
                        ,"opnnSqno"         : data.opnnSqno
                        ,"name"             : "사전규격 의견관리 수정"
                    };
            scwin.fn_openPopup(param);

        }else if(data.gubun == "R" || !comUtil.gfnIsEmpty(data.ansSqno)){    //답변등록 하겠다는 flag
            com.gfnOpenPopup({
                menuCangVal : "PRVA023_01",
                popupId : "BfSpecInstAnsPM",
                popupName : "사전규격의견 답변등록",
                param : {"bfSpecRegNo"      : dlBfSpecM.get("bfSpecRegNo")
                        ,"prcmBsneSeCd"     : scwin.prcmBsneSeCd
                        ,"opnnSqno"         : data.opnnSqno
                        ,"ansSqno"         : data.ansSqno
                        ,"upperOgdpNm"    : data.upperOgdpNm
                        },
                width : 1200,
                height: 700 ,
                callbackFn : "scwin.fnCallbackFromOpnnPopup"
            });
        }else if(data.gubun == "D"){ //삭제시
            //상세조회 호출
            scwin.sm_dtlSrch();
        }
    }
};





















