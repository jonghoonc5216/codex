    //전자문서번호가 있고 URL 정보가 있으면 사전규격 상세내역 노출 및 규격서 의견 제외 및 물품일때 물품분류명 표기  -> 연계기관에서 직접 사전규격을 낸 경우
    if(comUtil.gfnIsNotEmpty(dlBfSpecM.get("edocNo")) && comUtil.gfnIsNotEmpty(dlBfSpecM.get("pbancInstUrl"))){
