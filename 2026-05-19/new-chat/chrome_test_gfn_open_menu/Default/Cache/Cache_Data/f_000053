            com.gfnVisibleButton([btnM0002, btnM0001, btnD0001], false);
        }
    }

    //연계를 통해 입력된 사전규격일 경우 수량에 대한 값이 0으로 세팅되므로 수량에 대한 정보 숨김처리
    if(dlBfSpecItemL.getRowCount() > 0){
        let itemQtyHide = true;
        for(let i=0; i<dlBfSpecItemL.getRowCount(); i++){
