scwin.btnD0001_onclick = async function(e) {
    //삭제 confirm
    if (await com.gfnConfirmPopup("confirm.common.delete")) {
        // submission options
        let sbmOption = {
            id : "sbmDeleteBfSpec",
            action : "/pn/pnz/pnza/BfSpec/deleteBfSpec.do",
            inData : "dlBfSpecM",
            msgYn : {succ : false, err : true},
        };

        try {
            // step1. 조회
