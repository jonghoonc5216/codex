        else if (checkBsneSe.indexOf("조070002") > -1) infoOpt["index"] = "2";
        else infoOpt["index"] = "3";

        infoOpt["checked"] = true;
        scwin.sbxBsneSe_onviewchange(infoOpt);
    }
};

scwin.sbxBsneSe_onviewchange = function(info) {
    let sbxBsneSe = scwin.getComponect("sbxBsneSe");
    let frcpYn = scwin.getComponect("frcpYn"), laseYn = scwin.getComponect("laseYn"), rsrvYn = scwin.getComponect("rsrvYn");

    let prcmMaagSeCd = srchMap.get("prcmMaagSeCd"); //조달유형
    let index = info.index, checked = info.checked;

    if (prcmMaagSeCd == "조040001" || prcmMaagSeCd == "") {
        if (index == "0") {
            if (checked) {
                sbxBsneSe.checkAll(true);
                frcpYn.setDisabled(false); frcpYn.checkAll(false);
                laseYn.setDisabled(false); laseYn.checkAll(false);
                rsrvYn.setDisabled(false); rsrvYn.checkAll(false);
            } else {
                sbxBsneSe.checkAll(false);
                frcpYn.setDisabled(true); frcpYn.checkAll(false);
                laseYn.setDisabled(true); laseYn.checkAll(false);
                rsrvYn.setDisabled(true); rsrvYn.checkAll(false);
            }
        } else {
            const strChkIdx = sbxBsneSe.getSelectedIndex(",");
            const arrChkIdx = strChkIdx.split(",");
            // 전체체크 관련 처리
            if (strChkIdx.indexOf("전체") > -1 || (strChkIdx.indexOf("전체") == -1 && arrChkIdx.length == 5)) sbxBsneSe.setSelectedIndex(0);
            // 그외 업무구분에 따른 처리
            if (strChkIdx.indexOf("1") > -1 || strChkIdx.indexOf("2") > -1) {
                let prcmBsneSeCd = srchMap.get("prcmBsneSeCd"); //업무구분
                frcpYn.setDisabled(false);
                laseYn.setDisabled(false);
                rsrvYn.setDisabled(false);
                if (strChkIdx.indexOf("1") < 0 && strChkIdx.indexOf("2") > -1) {rsrvYn.setDisabled(true);  rsrvYn.checkAll(false);}

                if (srchMap.get("frcpYn") == "Y") scwin.changeFrcpYn({"checked":true});
                else if (srchMap.get("laseYn") == "Y") scwin.changeLaseYn({"checked":true});
            } else {
                frcpYn.setDisabled(true); frcpYn.checkAll(false);
                laseYn.setDisabled(true); laseYn.checkAll(false);
                rsrvYn.setDisabled(true); rsrvYn.checkAll(false);
            }
        }
    } else {
        frcpYn.setDisabled(true); frcpYn.checkAll(false);
        laseYn.setDisabled(true); laseYn.checkAll(false);
        rsrvYn.setDisabled(true); rsrvYn.checkAll(false);
    }
};

scwin.changeFrcpYn = function (info) {
    let frcpYn = scwin.getComponect("frcpYn"), laseYn = scwin.getComponect("laseYn"), rsrvYn = scwin.getComponect("rsrvYn");

    let prcmMaagSeCd = srchMap.get("prcmMaagSeCd"); //조달유형
    let prcmBsneSeCd = srchMap.get("prcmBsneAreaCd"); //업무구분

    if (prcmMaagSeCd == "조040001" || prcmMaagSeCd == "") {
        //조달유형 - 전체, 공공
        if (prcmBsneSeCd.indexOf("조070001") > -1) { // 물품
            if (srchMap.get("laseYn") == "Y") { // 리스
                if (info.checked) {rsrvYn.setDisabled(true); rsrvYn.checkAll(false);}
            } else if (srchMap.get("rsrvYn") == "Y") { //비축
                if (info.checked) {laseYn.setDisabled(true); laseYn.checkAll(false);}
            } else {
                rsrvYn.setDisabled(false);
                laseYn.setDisabled(false);
            }
        } else {
            if (prcmBsneSeCd.indexOf("조070002") > -1) {
                if (info.checked) {
                    rsrvYn.setDisabled(true); rsrvYn.checkAll(false);
                    laseYn.setDisabled(true); laseYn.checkAll(false);
                } else {
                    rsrvYn.setDisabled(true);
                    laseYn.setDisabled(false);
                }
            }
        }
    }
};

scwin.changeLaseYn = function(info) {
    let frcpYn = scwin.getComponect("frcpYn"), laseYn = scwin.getComponect("laseYn"), rsrvYn = scwin.getComponect("rsrvYn");
    let prcmMaagSeCd = srchMap.get("prcmMaagSeCd"); //조달유형
