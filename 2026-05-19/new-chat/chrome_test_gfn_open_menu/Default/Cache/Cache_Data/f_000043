    } else if(srchCd == "검030003") { // 계약요청
        componentCal = recpDt;
        componentSlctDt = null;
    } else if(srchCd == "검030004") { // 계약현황
        componentCal = ctrtDt;
        componentSlctDt = null;
    }

    if(info.newValue){
        componentCal.setDisabled(true);
        if(!comUtil.gfnIsEmpty(componentSlctDt)) {
            componentSlctDt.setDisabled(true);
        }
    } else {
        componentCal.setDisabled(false);
        if(!comUtil.gfnIsEmpty(componentSlctDt)) {
            componentSlctDt.setDisabled(false);
        }
    }
};

scwin.getMonthDiff = function(startDate, endDate) {
    const yearDiff = endDate.getFullYear() - startDate.getFullYear();

    const monthDiff = endDate.getMonth() - startDate.getMonth();

    return yearDiff * 12 + monthDiff;
};

