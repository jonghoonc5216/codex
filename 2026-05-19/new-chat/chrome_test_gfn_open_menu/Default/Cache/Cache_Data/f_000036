/********************************************************************************
 * 퍼블리셔가 작성한 이벤트
 * 동적으로 생성되는 메뉴로 순서상 메뉴를 생성한 후 동작해야 하기 때문에
 * onpageload()에서 scwin.createMenu() 이후에 동작하도록 이동함
********************************************************************************/
scwin.pubEvent = function(){
    // 모바일 모드 - 전체메뉴 레이어 팝업 버튼 클릭 이벤트
    const depth1List = document.querySelectorAll('.popup-content.sitemap .menu-generator .depth1-wrap');
    depth1List.forEach((depth1) => {
        depth1.addEventListener('click', function (e) {
            e.preventDefault();
            depth1.forEach((depth2) => {
                depth2.classList.remove('active');
            });
            this.classList.add('active');
        });
    });

    // gnb메뉴 1depth mouseover 시 클래스 제어 이벤트
    const gnbDpt1List = document.querySelectorAll('.gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth1-wrap');
    for (let i = 0; i < gnbDpt1List.length; i++) {
        gnbDpt1List[i].addEventListener('mouseenter', function (e) {
            //e.preventDefault();
            // 메뉴 선택 시 select, autocomplete 레이어 닫기
            document.querySelector('select:focus')?.blur();
            if (document.querySelector('.w2input_table_sb.w2input_table') !== null) {
                document.querySelector('.w2input_table_sb.w2input_table').style.display = "none";
                document.querySelector('.w2input_table_sb.w2input_table').style.visibility = "hidden";
            }
            
            for (let j = 0; j < gnbDpt1List.length; j++) {
                gnbDpt1List[j].classList.remove('on');
                gnbDpt1List[j].childNodes[1].style.display = 'none';
            }
            this.classList.add('on');
            this.childNodes[1].style.display = 'flex';
            document.querySelector('.section.gnb').classList.add('menu-dpt2-show');

            // gnb메뉴 하위 메뉴(2depth menu)가 없을 경우
            let gnbDpt2Container = document.querySelectorAll('.menu-generator.mega-menu .depth1-wrap > .inner-wrap > ul');
            gnbDpt2Container.forEach(function(el){
                let gnbDpt2List = el.querySelectorAll('.menu-generator.mega-menu .depth1-wrap > .inner-wrap > ul > li.depth2-wrap').length;
                if(gnbDpt2List < 1) {
                    document.querySelector('.section.gnb').classList.remove('menu-dpt2-show');
                    gnbDpt1List[i].classList.remove('on');
                }
            });

            document.querySelectorAll('ul[original_id="genDepth2"]').forEach(ul => {
                ul.scrollTop = 0;
            });

            // 메뉴 스크롤시 메인화면 스크롤 동작안하도록 처리 - 이벤트 추가
            window.addEventListener("wheel", scwin.preventDefaultScroll, { passive : false });
        });

        gnbDpt1List[i].addEventListener('mouseleave', function (e) {
            //e.preventDefault();
            for (let j = 0; j < gnbDpt1List.length; j++) {
                gnbDpt1List[j].classList.remove('on');
            }
            this.classList.remove('on');
            this.childNodes[1].style.display = 'none';
            document.querySelector('.section.gnb').classList.remove('menu-dpt2-show');

            // 메뉴 스크롤시 메인화면 스크롤 동작안하도록 처리 - 이벤트 제거
            window.removeEventListener("wheel", scwin.preventDefaultScroll, { passive : false });
        });
    }

    // gnb메뉴 1depth 메뉴버튼 focus 시 하위 메뉴 show hide 제어 이벤트(웹접근성 tab키로 제어)
    const gnbDpt1Btn = document.querySelectorAll('.gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth1-wrap .btn .depth1');
    for (let iii = 0; iii < gnbDpt1Btn.length; iii++) {
        gnbDpt1Btn[iii].addEventListener('focus', function (e) {
            for (let jj = 0; jj < gnbDpt1Btn.length; jj++) {
                if (!comUtil.gfnIsEmpty(gnbDpt1Btn[jj].parentElement?.nextElementSibling)) {
                    gnbDpt1Btn[jj].parentElement.nextElementSibling.style.display = 'none';
                }
            }
            this.parentElement.nextElementSibling.style.display = 'flex';
        });
    }

    // gnb메뉴 2depth 메뉴 하위 버튼 클릭 시 종속 메뉴 display: none; 처리 이벤트
    const gnbMnLinkBtn = document.querySelectorAll('.gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth2-wrap .btn.depth3');
    for (let i = 0; i < gnbMnLinkBtn.length; i++) {
        gnbMnLinkBtn[i].addEventListener('click', function (e) {
            for (let j = 0; j < gnbDpt1List.length; j++) {
                gnbDpt1List[j].classList.remove('on');
                gnbDpt1List[j].childNodes[1].style.display = 'none';
                document.querySelector('.section.gnb').classList.remove('menu-dpt2-show');
            }
        });
    }

    let mobileAcc = document.querySelectorAll("mobile-btn-toggle");
    let ii;
    for (ii = 0; ii < mobileAcc.length; ii++) {
        mobileAcc[ii].addEventListener("click", function() {

            this.classList.toggle("active");
            let panel = this.nextElementSibling;
            if (panel.style.maxHeight) {
                panel.style.maxHeight = null;
            } else {
                panel.style.maxHeight = panel.scrollHeight + "px";
            }
        });
    }

    // 웹접근성 관련 코드 - 탭 뒤로 갔을 경우 메뉴 닫힘
    const gnbRemoteBtn = document.querySelector('.gnb-btm-wrap .btn.remote');
    gnbRemoteBtn.addEventListener('focus', function (e) {
        if (!comUtil.gfnIsEmpty(gnbDpt1Btn[0]?.parentElement?.nextElementSibling)) {
            gnbDpt1Btn[0].parentElement.nextElementSibling.style.display = 'none';
        }
    });

    // 전체메뉴 포커스 시 gnb 하위 메뉴 hide 처리 제어 이벤트(웹접근성 tab키로 제어)
    const siteMapTrigger = document.querySelector('.sitemap-wrap .btn.sitemap');
    siteMapTrigger.addEventListener('focus', function (e) {
        if (!comUtil.gfnIsEmpty(gnbDpt1Btn[0]?.parentElement?.nextElementSibling)) {
            gnbDpt1Btn[0].parentElement.nextElementSibling.style.display = 'none';
        }
    });

    // 웹접근성 관련 대체텍스트 span 요소에 필수항목 적용하기
    let reqTarget = document.querySelectorAll("table.w2tb tr > .w2tb_th.req");
    for (let iii = 0; iii < reqTarget.length; iii++) {
        reqTarget[iii].insertAdjacentHTML('afterbegin', '<span class="req-hidden-txt">필수항목</span>');
    }

    let reqGridTarget = document.querySelectorAll(".w2grid th.gridHeaderTDDefault.req");
    for (let iiii = 0; iiii < reqGridTarget.length; iiii++) {
        reqGridTarget[iiii].insertAdjacentHTML('afterbegin', '<span class="req-hidden-txt">필수항목</span>');
    }
}

/********************************************************************************
* 설명 : GNB 메뉴의 버튼을 설정 버튼의 텍스트, UserData 를 설정 하는 부분 scwin.createMenu()의 반복부를 분리
********************************************************************************/
scwin.createMenuButton = function(btn, data){
    btn.setValue(data.menuNm);

    const contxtSeCd = com.gfnGetContxtSeCd();
    const secondLevel = (contxtSeCd === '' || contxtSeCd === '콘010006' || contxtSeCd === '콘010012') ? 2 : 3;

    if (data.menuLvl === secondLevel && !comUtil.gfnIsEmpty(data.menuCangVal.trim())) {
        btn.addClass("depth-last");
    }

    com.gfnSetUserData(btn, "menuNo", data.menuNo);
    com.gfnSetUserData(btn, "menuCangVal", data.menuCangVal);
    com.gfnSetUserData(btn, "upMenuNo", data.upMenuNo);
    com.gfnSetUserData(btn, "menuLvl", data.menuLvl);
    com.gfnSetUserData(btn, "scrnSrcePathNm", data.scrnSrcePathNm);
    com.gfnSetUserData(btn, "isDrawed", false);
}

/********************************************************************************
* 설명 : GNB 메뉴를 생성한다.
 *  String strContxtSeCd = "";
    if (contxtSe.equals("reserve")) { //비축
        strContxtSeCd = "콘010001";
    } else if (contxtSe.equals("accounting")) { //회계
        strContxtSeCd = "콘010002";
    } else if (contxtSe.equals("legalScreening")) { //법무심사
        strContxtSeCd = "콘010003";
    } else if (contxtSe.equals("operator")) { //운영자
        strContxtSeCd = "콘010004";
    } else if (contxtSe.equals("ehelpdesk")) { //고객센터
        strContxtSeCd = "콘010010";
    }
********************************************************************************/
scwin.createMenu = function(menuDataList) {
    // 컨택스트 구분코드 '콘010006' : 나라장터, '콘010001' : 비축, '콘010002' : 회계, '콘010003' : 법무심사, '콘010004' : 운영자, 'MOS730014' : 고객센터
    const contxtSeCd = com.gfnGetContxtSeCd();

    scwin.searchFilterSe = { "korOrEngMenuNm" : true,     // 기본 한글,영문 조회
                            "engToKorMenuNm" : true,     // 영문을 한글로 변경 또는 한글은 구분 초성 중성 종성 검색
                            "korFullLike"    : true,     // 한글도 '%like%' 검색여부
                            "menuNo"         : true,     // 메뉴No로 검색
                            "menuLvl"        : scwin.contxtSeMenuLvl[contxtSeCd] || scwin.contxtSeMenuLvl["etc"],        // 메뉴No로 검색일 때 사용되는 메뉴 LEVEL 배열 가능
                            "choKor"         : true,     // 한글 초성으로 검색
                            "choEngToKor"    : true,     // 영문을 한글로 변경하여 초성 검색
                            "filePath"       : true,     // 파일 경로 검색
                            "filePathSe"     : "f",      // { 'f': '파일명만' ,  'p' : '경로만' ,'pf' :  '경로+파일명' }
                            "searchLvl"      : scwin.contxtSeSearchLvl[contxtSeCd] || scwin.contxtSeSearchLvl['etc'],  // 검색에 적용하는 메뉴 LEVEL
                           };

    const firstLevel = (contxtSeCd === '' || contxtSeCd === '콘010006' || contxtSeCd === '콘010012') ? 1 : 2;
    const secondLevel = (contxtSeCd === '' || contxtSeCd === '콘010006' || contxtSeCd === '콘010012') ? 2 : 3;
    const thirdLevel = (contxtSeCd === '' || contxtSeCd === '콘010006' || contxtSeCd === '콘010012') ? 3 : 4;

    const allMenuList = (contxtSeCd === '' || contxtSeCd === '콘010006') ? menuDataList.getAllJSON().filter(menu => menu.contxtSeCd === '' || menu.contxtSeCd === '콘010006' ) : menuDataList.getAllJSON().filter(menu => menu.contxtSeCd === contxtSeCd);
    const showMenuList1Count = 9;
    const menuList1 = allMenuList.filter(f => f.menuLvl == firstLevel && f.indtYn == "Y" && f.poupYn != "Y").filter((f, i)=> i < showMenuList1Count);
    const menuNoList1 = menuList1.map(o => o.menuNo);

    const menuList2 = allMenuList.filter(f => f.menuLvl == secondLevel && f.indtYn == "Y" && f.poupYn != "Y").filter(f => menuNoList1.includes( f.upMenuNo ));
    const menuList2Info = menuList2.reduce((a, c) => {  if ( !Array.isArray(a[c["upMenuNo"]]) ) { a[c["upMenuNo"]] = []; } a[c["upMenuNo"]].push(c); return a; }, {});
    const menuNoList2 = menuList2.map(o => o.menuNo);

    const menuList3 = allMenuList.filter(f => f.menuLvl == thirdLevel && f.indtYn == "Y" && f.menuCangSeCd != "03" && f.poupYn != "Y" ).filter(f => menuNoList2.includes(f.upMenuNo));
    const menuList3Info = menuList3.reduce((a, c) => {  if ( !Array.isArray(a[c["upMenuNo"]]) ) { a[c["upMenuNo"]] = []; } a[c["upMenuNo"]].push(c); return a; }, {});

    genDepth1.removeAll();
    menuList1.forEach((data1, idx1) => {
        // lv1 start
        let nodeIdx1 = genDepth1.insertChild();
        let btnMenu1 = genDepth1.getChild(nodeIdx1, 'btn_menuLvl1');
        scwin.createMenuButton(btnMenu1, data1);

        // lv2 start
        const menuList2 = menuList2Info[data1.menuNo]||[];

        let dynamicGenDepth2 = genDepth1.getChild(nodeIdx1, 'genDepth2');
        menuList2.forEach((data2, idx2) => {
            let nodeIdx2 = dynamicGenDepth2.insertChild();
            let btnMenu2 = dynamicGenDepth2.getChild(nodeIdx2, 'btn_menuLvl2');
            scwin.createMenuButton(btnMenu2, data2);
            // lv3 start
            const menuList3 = menuList3Info[data2.menuNo]||[];

            let dynamicGenDepth3 = dynamicGenDepth2.getChild(nodeIdx2, 'genDepth3');
            menuList3.forEach((data3, idx3) => {
                let nodeIdx3 = dynamicGenDepth3.insertChild();
                let btnMenu3 = dynamicGenDepth3.getChild(nodeIdx3, 'btn_menuLvl3');
                scwin.createMenuButton(btnMenu3, data3);
            });
            // lv3 end
        });
        // lv2 end
    });
    // lv1 end

    scwin.pubEvent(); // 퍼블리셔의 화면 이벤트를 동작시킨다.
    scwin.searchMenuListInit(); // 초기화시 검색 메뉴 리스트를 초기화 한다.
};

