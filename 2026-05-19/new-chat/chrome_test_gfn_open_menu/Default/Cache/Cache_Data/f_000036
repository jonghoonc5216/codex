    const portalElement = window.document.querySelector(".portal");
    portalElement.classList.remove("stepbar");

    const menuCangVal = com.gfnGetUserData(com.gfnGetObject(this), "menuCangVal");
    const menuInfo = _gcm.Global.getMenuDataList().getAllJSON().filter(f => f.menuCangVal === menuCangVal);

    // menuCangSeCd : 메020006 (외부링크) 일경우 scrnSrcePathNm 에 있는 http 외부링크 open
    if (menuInfo.length > 0 && menuInfo[0].menuCangSeCd !== "메020006") {
        // 퍼블리싱 작업 - 메인화면 노출되는 화면에서 최상위 그룹 .portal에 클래스 추가, 삭제하여 배경색상 디자인 변경
