    scwin.openMenu(com.gfnGetObject(this));
    // 동적으로 생성되기 때문에 genDepth2는 직접 사용 불가 genDepth2.removeClass("on");
    // document.querySelector('div.gnb-menu-wrapper div.gnb-menu-wrap ul.mega-menu li.depth1-wrap').classList.remove('on');

    // 퍼블리싱 작업 - 테블릿 세로모드 해상도에서 메뉴 클릭 시 gnb에 추가한 class="mobile-gnb-show" 를 remove해서
