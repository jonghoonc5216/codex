        // 퍼블리싱 작업 - 메뉴 하단 홈버튼 영역 depth 네비게이션 영역
        const sectionNav = window.document.querySelector(".section.navigation");
        sectionNav.classList.remove("hide");
        // 퍼블리싱 작업 - 업무화면 타이틀, 상단 도움말 영역(공통)
        const sectionCntHeader = window.document.querySelector(".section.cnts-header");
        sectionCntHeader.classList.remove("hide");
        // 퍼블리싱 작업 - 메뉴 버튼 클릭 시 상단 도움말에 적용된 클래스 hide 삭제 이벤트(로그인 버튼 클릭시에는 도움말에 클래스 hide를 적용)
        //const helpCmtBox = document.querySelector('.section.cnts-header .cnts-header-wrap .inner.helpbox');
        //helpCmtBox.classList.remove("hide");
    }

};

