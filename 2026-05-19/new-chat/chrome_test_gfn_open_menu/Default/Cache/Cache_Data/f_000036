            } else {
                menu3Element.classList.remove(scwin.showClassText);
                menu3Element.classList.add   (scwin.hideClassText);
            }
        }
    }
    // menuLevel2 display class 설정
    const setMenu2BtnClass = function(menu2Element,searchText){
        const menu2AElement = menu2Element.querySelector("a.depth2");
