scwin.iptSearchText_onkeyup = function(e) {
    const searchText = e.target.value;
    if ( searchText.trim() == "" && e.key == "Enter") {
        iptSearchText.setValue("");
        setTimeout(()=>iptSearchText.focus(),10);
        return;
    }
    // btnObj USER-Data 를 가지고 온다.
    // 설정은 _gcm.setSiteMap().setButton() 처리
    const getUserData = function(menuBtnObj,keys) {
        let rtnValue, value;
        try {
            const keyList = ( Array.isArray(keys) ) ?  keys : [keys];
            rtnValue = {};
            keyList.forEach(k=>{
                value = com.gfnGetUserData(menuBtnObj,k);
                rtnValue[k] = typeof value == "string" ? value.toUpperCase().replaceAll(" ","") || "" : value;
            });
        } catch (e) {
            console.log(e);
        }
        return rtnValue;
    }
    // 초성 중성, 종성 검색 처리
    const searchFilterCJJ = function(menuNm,searchText) {
        const textCho  = korUtils.getChoArr (searchText).join("");
        const textJung = korUtils.getJungArr(searchText).map(m=>m=="" ? " ":m).join("").trimEnd();
        const textJong = korUtils.getJongArr(searchText).map(m=>m=="" ? " ":m).join("").trimEnd();
        return ( textCho  == "" || korUtils.getChoArr (menuNm).slice(0,textCho .length).join("") == textCho  ) &&
               ( textJung == "" || korUtils.getJungArr(menuNm).slice(0,textJung.length).join("") == textJung ) &&
               ( textJong == "" || korUtils.getJongArr(menuNm).map(m=>m=="" ? " ":m).slice(0,textJong.length).join("") == textJong );
    }
    // 검색 필터 설정
    const searchFilter = function(menuBtnObj,searchText){
        searchText = comUtil.gfnEscapeToChar(searchText.trim().replaceAll(" ",""));

        const { menuNm, menuNo, menuLvl, scrnSrcePathNm } = getUserData(menuBtnObj,["menuNm", "menuNo", "menuLvl", "scrnSrcePathNm"]);
        const searchLvl = scwin.searchFilterSe["searchLvl"];
        if ( !searchLvl.map(m=>String(m)).includes(String(menuLvl)) ) {
            return false;
        }

        // 기본 한글,영문 조회
        // - 영문+숫자+특수문자 : %like% , 한글+영어 : like%
        const searchKorOrEngMenuNmSe   = scwin.searchFilterSe["korOrEngMenuNm"] && ((menuNm,text)=>{
            if ( text.replace(comUtil.pattern.alphaNumSpecial,'') == '' || scwin.searchFilterSe["korFullLike"] ) {
                return menuNm.toUpperCase().includes(text.toUpperCase()) || comUtil.gfnEscapeToChar(menuNm).toUpperCase().includes(text.toUpperCase());
            } else {
                return menuNm.toUpperCase().startsWith(text.toUpperCase()) || comUtil.gfnEscapeToChar(menuNm).toUpperCase().startsWith(text.toUpperCase());
            }
        })(menuNm,searchText);

        // 영문을 한글로 변경 또는 한글은 구분 초성 중성 종성 검색
        // like%
        const searchEngToKorMenuNmSe   = scwin.searchFilterSe["engToKorMenuNm"] && ((menuNm,text)=>{
            const korText = korUtils.convertEngToKor(text);
            return searchFilterCJJ(menuNm,korText);
        })(menuNm,searchText);

        // 메뉴No로 검색
        // only number : "00112" => 112 값 비교  ,number값=0 : "00" => like%
        // number + char : "SM00" => like%
        const searchMenuNoSe           = scwin.searchFilterSe["menuNo"] && ((menuNo,menuLvl,text)=>{
            try {
                if ( Number.isNaN(Number(menuNo)) || Number.isNaN(Number(text)) ) {
                    return menuNo.toUpperCase().startsWith(text.toUpperCase());
                } else {
                    const menuLvlSe = scwin.searchFilterSe["menuLvl"];
                    const menuLvlSeArray = Array.isArray(menuLvlSe) ? menuLvlSe : [menuLvlSe];
                    const menuNoT = String(Number(menuNo));
                    const textT   = String(Number(text));
                    return ( Number(text) == 0 ) ? menuNo.startsWith(text) : menuNoT.startsWith(textT) && menuLvlSeArray.includes(menuLvl);
                }
            } catch (e) {
                return false;
            }
        })(menuNo,menuLvl,searchText);

        // 한글 초성으로 검색
        // "ㄱㄱ" : like% => "공고","가격","관급자재"
        const searchChoKorSe           = scwin.searchFilterSe["choKor"] && ((menuNm,text)=>{
            return korUtils.getChoArr (menuNm).slice(0,text.length).join("") == text;
        })(menuNm,searchText);

        // 영문을 한글로 변경하여 초성 검색
        // "rr" : "ㄱㄱ", like% => "공고","가격","관급자재"
        const searchChoEngToKorSe      = scwin.searchFilterSe["choEngToKor"] && ((menuNm,text)=>{
            const engText = text.split("").map(t=>{
                return korUtils.font_cho[korUtils.font_cho_eng.indexOf(t)];
            });
            return korUtils.getChoArr (menuNm).slice(0,engText.length).join("") == engText.join("");
        })(menuNm,searchText);

        // 파일 경로로 검색   현제 활성화 하지 않음.
        const searchFilePathSe         = scwin.searchFilterSe["filePath"] && ((filePath,text)=>{
            const filePathSe = scwin.searchFilterSe["filePathSe"]||"F";
            let rtnValue   = false;
            if ( filePathSe.toUpperCase() == "F" ) {
                rtnValue = filePath.toUpperCase().substring(filePath.lastIndexOf("/")+1).replaceAll(".XML","").startsWith(text.toUpperCase().replaceAll(".XML",""));
            } else if ( filePathSe.toUpperCase() == "P" ) {
                rtnValue = filePath.toUpperCase().substring(0,a.lastIndexOf("/")).startsWith(text.toUpperCase());
            } else if ( filePathSe.toUpperCase() == "PF" ||  filePathSe.toUpperCase() == "FP" ) {
                rtnValue = filePath.toUpperCase().startsWith(text.toUpperCase());
            }
            return rtnValue;
        })(scrnSrcePathNm,searchText);
        return searchKorOrEngMenuNmSe || searchEngToKorMenuNmSe || searchMenuNoSe || searchChoKorSe || searchChoEngToKorSe || searchFilePathSe;
    }
    // menuLevel3 display class 설정
    const setMenu3BtnClass = function(menu3Element,searchText){
        const menu2Element  = menu3Element.closest(scwin.menu2SelectorText)?.querySelector("a.depth2");
        const menu1Element  = menu3Element.closest(scwin.menu1SelectorText)?.querySelector("a.depth1");
        const menu3BtnId    = menu3Element.querySelector("a")?.id;
        const menu2BtnId    = menu2Element?.id || "";
