        const menu1BtnId    = menu1AElement.id || "";
        const menu2BtnObj   = com.gfnGetComponent(menu2BtnId);
        const menu1BtnObj   = com.gfnGetComponent(menu1BtnId);
        const menu2FilterSe = searchFilter(menu2BtnObj,searchText);
        const menu1FilterSe = searchFilter(menu1BtnObj,searchText);
        if ( menu2FilterSe || menu1FilterSe ) {
            menu2Element.classList.remove(scwin.hideClassText);
            menu2Element.classList.add   (scwin.showClassText);
        } else {
            menu2Element.classList.remove(scwin.showClassText);
            menu2Element.classList.add   (scwin.hideClassText);
        }
    }
    // menuLevel1 display class 설정
    const setMenu1BtnClass = function(menu1Element,searchText){
        const menu1AElement = menu1Element.querySelector("a.depth1");
        const menu1BtnId    = menu1AElement.id || "";
        const menu1BtnObj   = com.gfnGetComponent(menu1BtnId);
        const menu1FilterSe = searchFilter(menu1BtnObj,searchText);
        if ( menu1FilterSe ) {
            menu1Element.classList.remove(scwin.hideClassText);
            menu1Element.classList.add   (scwin.showClassText);
        } else {
            menu1Element.classList.remove(scwin.showClassText);
            menu1Element.classList.add   (scwin.hideClassText);
        }
    }
    // 검색 메뉴 list cache 처리
    scwin.sitemap   = scwin.sitemap   || document.querySelector(".sitemap.content");
    scwin.menu3List = scwin.menu3List || scwin.sitemap.querySelectorAll(scwin.menu3SelectorText);
    scwin.menu2List = scwin.menu2List || scwin.sitemap.querySelectorAll(scwin.menu2SelectorText);
    scwin.menu1List = scwin.menu1List || scwin.sitemap.querySelectorAll(scwin.menu1SelectorText);

    window.requestAnimationFrame(function(){
        scwin.menu3List.forEach(menu3Element=>{
            setMenu3BtnClass(menu3Element,searchText);
        });
        scwin.menu2List.forEach(menu2Element => {
        	const menu2E_menu3List = Array.from(menu2Element.querySelectorAll(scwin.menu3SelectorText));
        	if ( menu2E_menu3List.length > 0 ) {
        		const showSe = menu2E_menu3List.reduce((a,c)=> a || c.classList.contains(scwin.showClassText),false);
        		if ( showSe ) {
	                menu2Element.classList.remove(scwin.hideClassText);
	                menu2Element.classList.add   (scwin.showClassText);
        		} else {
	                menu2Element.classList.remove(scwin.showClassText);
	                menu2Element.classList.add   (scwin.hideClassText);
        		}
        	} else {
        		setMenu2BtnClass(menu2Element,searchText);
        	}
