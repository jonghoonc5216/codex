********************************************************************************/
scwin.preventDefaultScroll = function(e) {
    const divScroll = document.querySelector('.gnb-menu-wrap.total.sub .menu-generator.mega-menu .depth1-wrap.on > .inner-wrap')?.childNodes[0];
    if (divScroll === undefined) {
        console.log("divScroll === ");
        return;
    }

    if (e.target.parentElement.id === "mf_wfm_gnb_wfm_gnbMenu_genDepth1") {
        e.preventDefault();
        e.stopPropagation();
        return false;
    }

    const scrollY = divScroll?.scrollTop;
    const scrollGap = Math.abs(scrollY - scwin.prevScrollY) + 1;
    scwin.prevScrollY = scrollY;
    const offsetHeight = divScroll?.offsetHeight;
    const scrollHeight = divScroll?.scrollHeight;

    if (e.wheelDeltaY > 0) {
        if (scrollY === 0) {
            e.preventDefault();
            e.stopPropagation();
            return false;
        } else {
            return true;
        }
    } else {
        if (Number.parseInt(scrollY + offsetHeight) < Number.parseInt(scrollHeight) - scrollGap) {
            return true;
        } else {
            e.preventDefault();
            e.stopPropagation();
            return false;
        }
    }
