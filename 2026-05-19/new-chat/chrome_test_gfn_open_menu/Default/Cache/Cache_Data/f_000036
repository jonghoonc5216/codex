        scwin.menu1List.forEach(menu1Element=>{
        	const menu1E_menu2List = Array.from(menu1Element.querySelectorAll(scwin.menu2SelectorText));
        	if ( menu1E_menu2List.length > 0 ) {
        		const showSe = menu1E_menu2List.reduce((a,c)=> a || c.classList.contains(scwin.showClassText),false);
	            if ( showSe ) {
	                menu1Element.classList.remove(scwin.hideClassText);
	                menu1Element.classList.add   (scwin.showClassText);
	            } else {
	                menu1Element.classList.remove(scwin.showClassText);
	                menu1Element.classList.add   (scwin.hideClassText);
	            }
        	} else {
        		setMenu1BtnClass(menu1Element,searchText);
        	}
        });
        scwin.searchMenuListDisplay("set");
        const menu3show = Array.from(scwin.menu3List).filter(f=>f.classList.contains(scwin.showClassText));
        const menu2show = Array.from(scwin.menu2List).filter(f=>f.classList.contains(scwin.showClassText));
        const menu1show = Array.from(scwin.menu1List).filter(f=>f.classList.contains(scwin.showClassText));
        let   clickBtn = null;
