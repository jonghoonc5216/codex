            dlUntyAtchFileL_valid.setColumnName("inptDt", scwin.options.addColumn.inptDt.title);
            grdFile.setColumnVisible("inptDt", true); // show
            (scwin.options.addColumn.inptDt.width !== undefined) && (grdFile.setColumnWidth("inptDt", scwin.options.addColumn.inptDt.width)); // width

            // 필수입력 컬럼 CSS 설정
            let validateInfo = scwin.options.addColumn.validateData?.inptDt?.trim();
            if (!comUtil.gfnIsEmpty(validateInfo)) {
                if (validateInfo.includes("required:true")) {
                    grdFile.setHeaderClass('titleInptDt', 'req');
                }
            }
        } else {
            // 사용유무 옵션에의해 밸리데이션 체크 해제
            scwin.options.addColumn.validateData.inptDt = '';
        }
    }

    // 추가 버튼 설정
    if (!comUtil.gfnIsEmpty(scwin.options.addButtons) && Array.isArray(scwin.options.addButtons) && scwin.options.addButtons.length > 0) {
        grpDynButtons.removeClass("hide");
        scwin.options.addButtons.forEach((data, index) => {
            let button = $p.dynamicCreate("btnAddButton" + index, "trigger", {}, grpDynButtons);
            if (button === undefined) return;
            button.setValue(data.label);
            button.addClass("btn_cm");
            if (!comUtil.gfnIsEmpty(data["class"])) {
                button.addClass(data["class"]);
            }
            if (!comUtil.gfnIsEmpty(data.handler)) {
                button.setUserData("handler", data.handler);
                button.bind("onclick", function (e) {
                    const handler = this.getUserData("handler").replace(/^scwin\./, "");
                    $p.getParentWindow().scwin[handler](e);
                });
            }
        });
    }

    // 다운로드 기능 제거
    if (scwin.options.mode.toUpperCase() === "VIEW" && !scwin.options.useExcuteDownload) {
        grdFile.setColumnVisible("CHK", false);
    }

    //삭제자동플래그에 따라 화면 UI 설정
    btnChceDelRtrcn.addClass('hide');
    if(scwin.options.delAutoFlag === false) {
        btnChceDelRtrcn.removeClass('hide');    //삭제취소 버튼 hide
        grdFile.setRowStatusColumnWidth(60);    //데이터콜렉션 상태값 show
    }

    // 업로드 아이디를 지정 한다. 웹스퀘어의 아이디 생성 방식으로 인해 id는 겹치지 않도록 생성 된다.
    scwin.kUploadId = kupload_holder.getID() + '_upload';
    scwin.kUploadHolder = kupload_holder.getID();
    scwin.fileLog('kupload id  : ' + scwin.kUploadId);

    // 드랍존 생성을 위해서 target_upload 어트리뷰트를 추가함
    const ele = document.getElementById(dropzone.getID());
    WebSquare.xml.setAttribute(ele, "target_upload", scwin.kUploadId);

    // kupload 를 생성함
    const options = {
        Id: scwin.kUploadId || "kupload",
        MaxTotalFileCount: scwin.options.maxTotalFileCount,
        MaxOneFileSize: scwin.options.maxOneFileSize,
        MaxTotalFileSize: (scwin.options.maxTotalFileSize.startsWith("0")) ? "0" : scwin.options.maxTotalFileSize,
        MultiFileSelect : scwin.options.multiFileSelect,
        UploadHolder: scwin.kUploadHolder,
        ExtensionAllowOrLimit: scwin.options.extensionAllowOrLimit,
        ExtensionArr: scwin.options.extensionArr,
        DownloadMulti: scwin.options.downloadMulti,
        ZipFileName: scwin.options.zipFileName,
        AllowedZeroFileSize: scwin.options.allowedZeroFileSize,
        ListViewDragAndDrop: scwin.options.listViewDragAndDrop,
        IsScanEnabled: scwin.options.isScanEnabled,
        bsnePath: scwin.options.bsnePath,
        mode: scwin.options.mode.toLowerCase(),
        security: scwin.options.security,
    };

    objViewMode.viewMode = scwin.options.mode;
    await scwin.makeKupload(options);

    return scwin.kUploadId;
};

