/**
 * @method
 * @name validateDataCollect
 * @description dlUntyAtchFileL가 0건 이상 있을 때 체크하여 리턴
 * @param
 * @returns
 * @hidden N
 * @exception
 * @example
 */
scwin.validateDataCollect = async function () {
    let rtn = false;
    if (dlUntyAtchFileL.getDataLength() > 0) {
        // requiredList를 처리

        function remove(array, item) {
            const index = array.indexOf(item);
            if (index !== -1) array.splice(index, 1);
            return array;
        }

        const validateData = scwin.options.addColumn.validateData;
        if (!comUtil.gfnIsEmpty(validateData)) {
            // requiredList:01|02 확인
            const condition = validateData.atchFileKndCd; // required:true,requiredList:01|02
            if (condition.indexOf('requiredList') != -1) {
                let requiredList = condition.split(',').find((o) => o.startsWith('requiredList'));
                let strSplit2 = requiredList.split(':')[1];
                let valSplit = strSplit2.split('|');
                let chk = [...valSplit];

                for (let obj of dlUntyAtchFileL.getAllJSON()) {
                    if (obj.atchFileKndCd !== '') {
                        chk = remove(chk, obj.atchFileKndCd)
                    }
                }

                if (chk.length > 0) {
                    let alertObject = _gcm.Global.getCommonCodeList(`${scwin.options.addColumn.atchFileKndCd.selectCode.commClsfCd}_${scwin.options.addColumn.atchFileKndCd.selectCode.bsneClsfNo}`).filter((obj) => chk.includes(obj.commCd));
                    let alertName = [];
                    alertObject.forEach((obj) => { alertName.push(obj.cdNm); });
                    messageText = ["msg.alert.grd.mandatory", alertName.join(',')];
                    com.gfnMessagePopup({ msgInfo: messageText });
                    return false;
                }
            }
            // 종료 requiredList:01|02 확인

            // 공통함수 com.gfnValidateDataCollect를 수행
            let overwrite = false;
            (dlUntyAtchFileL_valid.getTotalRow() > 0) && (overwrite = true); // 아래에서 한개의 행만 입력 하기 위해,
            dlUntyAtchFileL_valid.setRowJSON(0, validateData, overwrite); // overwrite가 false인 경우에 행을 생성한다.
            return await com.gfnValidateDataCollect("grdFile");
        }
    } else {
        rtn = true;
    }

    return rtn;
};

