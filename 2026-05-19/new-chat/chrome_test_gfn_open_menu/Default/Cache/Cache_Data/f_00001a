        ButtonBarView: '0', // view Mode 버튼 바 표시 여부 : 0 안함
        ExtensionAllowOrLimit: options.ExtensionAllowOrLimit || '0',
        ExtensionArr: options.ExtensionArr,
        DownloadMulti: options.DownloadMulti,
        ZipFileName: options.ZipFileName, // zip 다운로드 파일명
        AllowedZeroFileSize: options.AllowedZeroFileSize, // 0byte 파일의 업로드를 허용 할지 설정합니다. 기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.
        ListViewDragAndDrop: options.ListViewDragAndDrop,  // 선택 | 업로드 영역에 드래그 앤 드랍해서 파일추가할 수 있도록 설정합니다.(편집 모드)
