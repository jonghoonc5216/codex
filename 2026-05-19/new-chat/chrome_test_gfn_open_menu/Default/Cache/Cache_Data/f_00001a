/********************************************************************************
 * 설명 : MagicLineJSAPI
 ********************************************************************************/
scwin.security = async function () {
    // magicjs 추가 2022-05-16
    if (scwin.options.security.use == 'Y') {
        // 인증서 키값 확인
        if (scwin.options.security.kmCert === "") {
            await com.gfnAlert("error.comm.notexistkmCert");
        } else {
            MagicLineJSAPI.setEncServerCertificate('FILE', scwin.options.security.kmCert);
        }

        const magicJsPlugin = RAONKUPLOAD.GetPlugin('magicjs', scwin.kUploadId);

        if (magicJsPlugin) {
            // MagicLineJSAPI 모듈 할당해 줌
            magicJsPlugin.options.MagicLineJSAPI = scwin.options.security.magicLineObj;
            // 암호화 전송을 하겠다는 설정
            magicJsPlugin.options.encrypt.use = scwin.options.security.encryptUse === 'Y' ? '1' : '0'; // 화면개발자 설정 Y, N : 실제 1사용 0안함
            // 암호화 전송 시 서버에서 암호화 된채로 저장할지, 복호화 하여 저장할 지 설정
            magicJsPlugin.options.encrypt.decryptInServer = scwin.options.security.decryptInServer === 'Y' ? '1' : '0'; // 화면개발자 설정 Y, N : 실제 1사용 0안함
            // 해시값 추출 할 지에 대한 설정
            magicJsPlugin.options.hash.use = scwin.options.security.hashUse === 'Y' ? '1' : '0'; // 화면개발자 설정 Y, N : 실제 1사용 0안함
            // 전자서명 사용할지에 대한 설정
            magicJsPlugin.options.signature.use = scwin.options.security.signatureUse === 'Y' ? '1' : '0'; // 화면개발자 설정 Y, N : 실제 1사용 0안함
            // 전자서명 사용 시 sessionId 값 할당
            magicJsPlugin.options.signature.sessionId = scwin.options.security.sessionId;
        }
    }
};

