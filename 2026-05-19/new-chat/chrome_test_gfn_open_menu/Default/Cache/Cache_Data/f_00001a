 최초등록 파일은 scwin.send에서 처리
*/
scwin.saveEdit = async function () {
    scwin.fileLog('file > API > saveEdit');
    if (dlUntyAtchFileL.getModifiedIndex().length > 0) {
        // 수정된 데이터가 있는 경우
        editList.setJSON(dlUntyAtchFileL.getModifiedJSON().filter(row => (row.rowStatus !== "E" && row.rowStatus !== "D")), false); // 수정 된 값만 edtList에 복사한다.
        editList.modifyAllStatus('U'); // 복사 한 데이터기 때문에 최초 상태 값이 R이다. U로 변경해서 보낸다.

        const sbmOption = {
            id: "sbmInsertAtflGrp",
            action: "/fs/fsc/fscb/UntyAtchFile/multiUntyAtchFileComp.do",
            inData: "dlUntyAtchFileL=editList dlUntyAtchFileM",
            msgYn: { succ: false, err: true }
        };
        await com.gfnExecute(sbmOption);
        return;
    } else {
        // 수정된 데이터가 없는 경우
        return;
    }
};
/*
 삭제 저장
 NAS 삭제 이후 첨부문서 삭제는 이곳에서 처리 된다.
*/
scwin.saveDel = async function () {
    scwin.fileLog('file > API > saveDel');
    let deleteArray = [];
    dlUntyAtchFileL.getRowIndexByStatus('D').forEach((idx) => { deleteArray.push(dlUntyAtchFileL.getRowJSON(idx));});
    if (deleteArray.length > 0) {
        deleteList.setJSON(deleteArray, false); // 삭제 데이터만 삭제 전용 dataList 에 담는다.
        deleteList.modifyAllStatus('D'); // 데이터를 옮겼기 때문에 처음 상태는 R 이다. 삭제 상태인 D로 변경
        const sbmOption = {
            id: "sbmInsertAtflGrp",
            action: "/fs/fsc/fscb/UntyAtchFile/multiUntyAtchFileComp.do",
            inData: "dlUntyAtchFileL=deleteList dlUntyAtchFileM",
            msgYn: { succ: false, err: true }
        };
        const resultGet = await com.gfnExecute(sbmOption);
        if (resultGet.responseJSON.ErrorCode == '0') {
            dlUntyAtchFileL.removeRows(dlUntyAtchFileL.getRowIndexByStatus('D'));
            scwin.resetFileIndex(false);
        }
        // 파일 삭제 후 scwin.options.gridVisibleRowNum 설정 값보다 작은 경우 visibleRowNum 재설정
        if (scwin.options.gridVisibleRowNum !== "all") {
            const gridVisibleRowNum = Number.parseInt(scwin.options.gridVisibleRowNum);
            grdFile.setVisibleRowNum((dlUntyAtchFileL.getRowCount() < gridVisibleRowNum) ? ((dlUntyAtchFileL.getRowCount() > 1) ? dlUntyAtchFileL.getRowCount() : 1) : gridVisibleRowNum);
        }
    } else {
        // 삭제 데이터가 없는 경우
        return;
    }
}

/**
 * @method
 * @name load
 * @description 데이터 로드
 *  untyAtchFileNo이 이미 세팅 되어있어야 한다. init시 자동실행
 * @param
 * @returns {string} untyAtchFileNo 파일그룹
 * @hidden N
 * @exception
 * @example
 */
scwin.load = async function () {
    scwin.fileLog('file > API > load');

    if (!comUtil.gfnIsEmpty(dlUntyAtchFileM.get('untyAtchFileNo')) && !comUtil.gfnIsEmpty(dlUntyAtchFileM.get('bsnePath'))) {
        // 키가 있는 경우 조회
        const sbmOption = {
            id: "sbmInsertAtflGrp",
            action: "/fs/fsc/fscb/UntyAtchFile/selectUntyAtchFileList.do",
            inData: "dlUntyAtchFileM=dlUntyAtchFileM",
            outData: "dlUntyAtchFileL",
            isProcessMsg: ((scwin.options.loadingUse == 'Y') ? true : false),
            msgYn: { succ: false, err: true }
        };
        await com.gfnExecute(sbmOption);
        if(dlUntyAtchFileL.getTotalRow() > 0) {
            if(dlUntyAtchFileM.get("untyAtchFileNo") != dlUntyAtchFileL.getCellData(0, "untyAtchFileNo")) {
                com.gfnInitDataList("dlUntyAtchFileL");
                console.error("첨부파일번호가 변조되어 첨부파일목록 초기화.");
            }
        }

        // gridVisibleRowNum이 지정되지 않았다면 기본 3행만 노출, 지정되었다면 지정된 row수 만큼 노출
        if (scwin.options.gridVisibleRowNum === "all") {
            grdFile.options.visibleRowNum = "all";
        } else {
            const gridVisibleRowNum = Number.parseInt(scwin.options.gridVisibleRowNum);
            grdFile.setVisibleRowNum((dlUntyAtchFileL.getRowCount() < gridVisibleRowNum) ? ((dlUntyAtchFileL.getRowCount() > 1) ? dlUntyAtchFileL.getRowCount() : 1) : gridVisibleRowNum);
        }

        RAONKUPLOAD.ResetUpload(scwin.kUploadId); // 업로드 리스트 초기화
        const dataList = dlUntyAtchFileL.getAllJSON();
        for (let idx in dataList) {
            // 업로드 컴포넌트에 등록된 파일 추가
            const obj = dataList[idx];
            RAONKUPLOAD.AddUploadedFile(idx, comUtil.gfnEscapeToChar(obj.orgnlAtchFileNm), '', obj.fileSz, obj.untyAtchFileNo + ',' + obj.atchFileSqno, scwin.kUploadId);
        }

        return dlUntyAtchFileM.get('untyAtchFileNo');
    } else {
        return dlUntyAtchFileM.get('untyAtchFileNo');
    }
};

