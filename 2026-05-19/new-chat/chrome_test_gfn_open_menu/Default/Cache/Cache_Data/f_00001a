    if ((grdFile.getCheckedIndex('CHK') || []).length == 0) {
        await com.gfnAlert(['msg.alert.choiceRow', '삭제 할 파일이 없습니다. \n삭제 가능한 파일을']);
        return false;
    }else {
        //자동삭제여부가 false인경우 데이터콜렉션 'D' 상태로 변경
        if(scwin.options.delAutoFlag === false) {
