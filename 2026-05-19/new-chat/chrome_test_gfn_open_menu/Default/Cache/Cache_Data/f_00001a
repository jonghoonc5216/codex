/********************************************************************************
 * 설명 : 다운로드 버튼 클릭
 ********************************************************************************/
scwin.btnFileDown_onclick = async function (e) {

    if (!scwin.options.useExcuteDownload) {
        return;
    }

    const listIndex = grdFile.getCheckedIndex('CHK'); // CHK 컬럼의 체크된 인덱스를 배열로 가져온다.
    if (listIndex.length === 0) {
        com.gfnAlert(['msg.alert.choiceRow', '다운로드 할 파일이 없습니다. \n다운로드 가능한 파일을']);
        return;
    }

    // 부모가 지정한 함수 동기처리
    if(typeof scwin.options.evPreBtnFileDown === "function") {
        let isContinue = await scwin.options.evPreBtnFileDown(scwin.fileScope);
        if(isContinue === false) {
            return;
        }
    }

    let cnt = 0;
    RAONKUPLOAD.SetSelectFile(-1, 0, scwin.kUploadId); // 전체 선택 해제

    for (let idx in listIndex) {
        const rowNumber = listIndex[idx];
        dt = grdFile.getRowJSON(rowNumber); // 한줄 데이터를 JSON으로 받아온다.
        if (dt.dwnldPrmsYn == 'N'){
            continue;
        }
        if (!comUtil.gfnIsEmpty(dt.untyAtchFileNo)) {
            // web 파일
            cnt++;
            RAONKUPLOAD.SetSelectFile(rowNumber, 1, scwin.kUploadId); // 체크상태 유지하며 index 선택
        }
    }

    if (cnt > 0) {
        RAONKUPLOAD.DownloadFile(scwin.kUploadId);
    } else {
        com.gfnAlert(['msg.alert.choiceRow', '첨부가 되지 않은 파일입니다. \n다운로드 가능한 파일을']);
    }
};

