/**
 * @method
 * @name getHash
 * @description 파일 해쉬값을 구한다.
 * @param {file}} file 객체
 * @returns {string} 파일 해쉬 값
 * @exception
 * @example
 */
scwin.getHash = async function (file) {
    if (comUtil.gfnIsEmpty(file)) {
        return null;
    }
    try{
        const buffer = await file.arrayBuffer();
        const hashBuffer = await crypto.subtle.digest('SHA-256', buffer);
        const hashArrary = Array.from(new Uint8Array(hashBuffer));
        return hashArrary.map(byte => byte.toString(16).padStart(2,'0')).join('');
    }catch(e){
        console.log(e);
    }

}
