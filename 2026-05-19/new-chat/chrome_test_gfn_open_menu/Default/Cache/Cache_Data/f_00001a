        dlDownAtflGrpDetlM.set("untyAtchFileNo", dlUntyAtchFileM.get("untyAtchFileNo"));
        dlDownAtflGrpDetlM.set("atchFileSqno", dlUntyAtchFileL.getCellData(row, "atchFileSqno"));

