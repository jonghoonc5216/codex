                    reloadAfterSend == Y
                        scwin.load : 변경된 정보를 다시 로드
                    saveUpldCplt : 완료시 udc를 사용하는 화면에 saveUpldCplt 이벤트 발생
                 */

                await scwin.saveEdit();
                // 전자서명
                const result = RAONKUPLOAD.GetListInfo('array', uploadID);
                const newFiles = result.newFile;
                scwin.completeFileListHash = [];
                if (!comUtil.gfnIsEmpty(newFiles) && !comUtil.gfnIsEmpty(newFiles.length)) {
                    for (let i = 0; i < newFiles.length; i++) {
                        if (!comUtil.gfnIsEmpty(newFiles[i].extraDataObject) && !comUtil.gfnIsEmpty(newFiles[i].originalFileHash)) {
                            // magicjs 추가 2022-05-16
                            // 원본파일 hash 값,
                            // hash 사용함 또는 전자서명 사용함 일 때 값이 들어있습니다.
                            scwin.completeFileListHash[i].originalFileHash = newFiles[i].extraDataObject.originalFileHash;
                            // 서버에 암호화된 채로 파일을 저장하겠다고 설정한 경우에 값이 들어있습니다.
                            scwin.completeFileListHash[i].encryptedFileHash = newFiles[i].extraDataObject.encryptedFileHash;
                            // 전자서명 사용함 일 때 값이 들어있습니다.
                            scwin.completeFileListHash[i].signedData = newFiles[i].extraDataObject.signedData;
                            // 파일 암호화 할 때 사용한 cipherKey 값이 들어있습니다.
                            // hex.encode(secretKey) + hex.encode(iv) 값이 암호화된 값입니다.
                            scwin.completeFileListHash[i].cipherKey = newFiles[i].extraDataObject.cipherKey;
                        }
                    }
                }
                /* 업로드 성공시 실행
                    scwin.saveDel : 삭제된 첨부문서를 DB Delete
                 */
                await scwin.saveDel();

