 ********************************************************************************/
scwin.dlUntyAtchFileL_oncelldatachange = async function(info) {
    // 부모가 지정한 함수 동기처리
    if(typeof scwin.options.evCellDataChange === "function") {
        let colID    = info.colID;
        let rowIndex = info.rowIndex;
        let newValue = info.newValue;
        let oldValue = info.oldValue;
        //그리드에 매핑되어 있는 컬럼인지 검증
        if(grdFile.getColumnIndex(colID) < 0) return;
        //그리드에 해당 컬럼이 표출되고 있는지 검증
        if(grdFile.getColumnVisible(colID) === false) return;
