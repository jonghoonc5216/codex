/**
 * @method
 * @name setSenseReader
 * @description init 웹접근성 관련 속성 초기화
 * @param
 * @hidden N
 * @exception
 * @example
 */
scwin.setSenseReader = function () {
    const hasClass = (grpToolTip.hasClass("on")) ? true : false;

    const objBtnToolTip = document.querySelector("#" + btnToolTip.getID());
    const objGrpToolTip = document.querySelector("#" + grpToolTip.getID());
    const objBtnClose = document.querySelector("#" + btnClose.getID());
    // 테이블 th에 있는 툴팁 스타일 적용
    const closestParent = objBtnToolTip.closest('.w2tb_th');
    (!comUtil.gfnIsEmpty(closestParent)) && (closestParent.style.paddingRight = "3.0rem");

    objBtnToolTip.setAttribute("aria-expanded", hasClass); // 도움말 버튼 활성화
    objBtnToolTip.setAttribute("aria-pressed", hasClass); // 도움말 버튼 활성화

    objGrpToolTip.setAttribute("aria-hidden", !hasClass);

    objBtnClose.setAttribute("aria-expanded", hasClass); // 닫기 버튼 활성화
    objBtnClose.setAttribute("aria-pressed", hasClass); // 닫기 버튼 활성화

    // 툴팁 최상위그룹 class="w2wframe udc_help_tooltip" 에 클래스 추가해서 z-index 우선순위 적용
    if (objGrpToolTip.classList.contains("on")) {
        objGrpToolTip.parentElement.parentElement.classList.add("on");
    } else {
        objGrpToolTip.parentElement.parentElement.classList.remove("on");
    }

    // 툴팁 우측에 위치할 때(화면 영역 벗어 났을 시) 스타일 추가하여 화면 영역 내에 위치하도록 변경 이벤트
    const boundRight = objBtnToolTip.getBoundingClientRect().right + objGrpToolTip.offsetWidth;
    if (boundRight < (window.innerWidth || document.documentElement.clientWidth)) {
        objGrpToolTip.style.right = "";
        objGrpToolTip.classList.remove("right-side");
    } else {
        objGrpToolTip.style.right = "0px";
        objGrpToolTip.classList.add("right-side");
    }
};

