        SizeForChunkUpload : '1MB',
        DetectFileChanged : "1", // 파일전송 전 변경감지 여부 추가
        RequestConfigFileSync: true,    //환경설정 로드 방식을 동기로 추가 (2026.04.06)
        Security: {
