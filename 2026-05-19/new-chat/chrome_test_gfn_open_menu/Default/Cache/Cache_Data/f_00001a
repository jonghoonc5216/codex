/********************************************************************************
 * 설명 : DataList Up/Down
 ********************************************************************************/
scwin.fnDataListRowMove = function(dataList, rowPosition, rowMoveCount) {
    const rowCount = Math.abs(rowMoveCount);
    for (i = 0; i < rowCount; i++) {
        if (rowMoveCount > 0) {
            dataList.rowMoveDown(rowPosition + i);
        } else if (rowMoveCount < 0) {
            dataList.rowMoveUp(rowPosition - i);
        }
    }
};

