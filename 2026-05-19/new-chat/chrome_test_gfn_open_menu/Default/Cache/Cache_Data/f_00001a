            inData: "dlDownAtflGrpDetlM",
            outData: "dlDownAtflGrpDetlResultM=result",
            msgYn: { succ: false, err: true },
        };

        const result = await com.gfnExecute(sbmOption);

        if (result.responseStatusCode === 200) {
            const previewWindow = window.open("about:blank");
            previewWindow.location.href = dlDownAtflGrpDetlResultM.get("viewUrlPath");
        }

        $p.emit("beforeOpenFile", scwin.kUploadId, RAONKUPLOAD.GetListInfo(scwin.kUploadId).mergeFile[row], dlUntyAtchFileM.get("untyAtchFileNo"), dlUntyAtchFileL.getAllJSON());
