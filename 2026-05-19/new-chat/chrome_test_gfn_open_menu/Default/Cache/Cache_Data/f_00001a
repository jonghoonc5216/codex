    else if (colId === "orgnlAtchFileNm") {
        RAONKUPLOAD.SetSelectFile(row, 0, scwin.kUploadId); // 파일 선택 row  체크

        if (scwin.options.preview && scwin.options.useExcuteDownload) {
            RAONKUPLOAD.DownloadFile(scwin.kUploadId); // 파일 다운로드
        } else if (scwin.options.useExcuteFileOpen) {
            RAONKUPLOAD.OpenSelectedFile(scwin.kUploadId); // 파일 미리보기
        }
    }
    else if (colId === "CHK") {
        if(dlUntyAtchFileL.getCellData(row, "CHK") == "0") {
            if(dlUntyAtchFileL.getRowStatus(row) == "D"
            && scwin.options.delAutoFlag === false) {
                await scwin.fnChceDelRtrcn(row);
            }
        }
    }
