                dlUntyAtchFileM.set("kuploadId", scwin.kUploadId);
                dlUntyAtchFileM.set("viewMode", objViewMode.viewMode);

                await scwin.load(); // 데이터 로드
                await scwin.security(); // MagicLineJSAPI
                kuploadLoadingArea.hide();

                if (scwin.options.groupTitleTooltip) {
                    btnToolTip.removeClass("hide");
                    if (grpTooltipTitle.render !== undefined) {
                        grpTooltipTitle.render.innerHTML = scwin.options.groupTitleTooltipTitle;
                    }
                    if (grpTooltipContent.render !== undefined) {
                        grpTooltipContent.render.innerHTML = scwin.options.groupTitleTooltipContent;
                    }
                }

                // 전체 파일 용량 표시 설정
                scwin.setTotalFileSizeInfo();

                // print 시 hidden 컬럼 처리 - hiddenPrint 클래스 추가
                $p.setTimeout(function() {
                    grdFile.hiddenList?.forEach((col, index) => {
                        const headerId = grdFile.getHeaderColID(index);
                        if(comUtil.gfnIsEmpty(headerId)) return;
                        const tdIndex = document.querySelector(`#${grdFile.getID()}_${headerId}`).attributes["colindex"].value;

                        if (col || col === "true") {
                            for (let i = 0; i < grdFile.getRowCount(); i++) {
                                document.querySelectorAll(`#${grdFile.getID()} tbody td[colindex="${tdIndex}"]`)[i]?.classList.add("hiddenPrint");
                                //document.querySelectorAll(`#${grdFile.getID()} tbody td[colindex="${tdIndex}"]`)[i]?.setAttribute("hiddenclass", "hiddenPrint");
                            }
                        } else {
                            for (let i = 0; i < grdFile.getRowCount(); i++) {
                                document.querySelectorAll(`#${grdFile.getID()} tbody td[colindex="${tdIndex}"]`)[i]?.classList.remove("hiddenPrint");
                                //document.querySelectorAll(`#${grdFile.getID()} tbody td[colindex="${tdIndex}"]`)[i]?.removeAttribute("hiddenclass");
                            }
                        }
                    });
                }, { delay : 1000 });

                $p.emit("CreationCplt", uploadID, dlUntyAtchFileM.get('untyAtchFileNo'), dlUntyAtchFileL.getAllJSON());
            },
            BeforeAddFile: function (uploadID, paramObj) {
                // 업로드된 파일과 파일명이 동일한지 확인
                const duplicateFile = dlUntyAtchFileL.getAllJSON().filter(row => row.orgnlAtchFileNm === paramObj.strName);
                if (duplicateFile.length > 0) {
                    com.gfnAlert(["msg.alert.dupNm", paramObj.strName, "파일"]);
                    return false;
                }

                // 파일명 길이 400byte 제한(확장자 포함)
                if (comUtil.gfnGetByteLength(paramObj.objFile.name) > 400) {
                    com.gfnAlert(["msg.fs.fsc.fileNmMaxbyte", "400", ""]);
                    return false;
                }

                scwin.fileLog('file > Event > BeforeAddFile');
            },
            AfterAddFile: async function (uploadID, paramObj) {
                scwin.fileLog('file > Event > AfterAddFile');

                // 이미지 사이즈 체크 여부
                if ((scwin.options.checkImageSize || scwin.options.checkImageRatio) && paramObj.objFile.type.indexOf('image') > -1) {
                    await checkImageFileSize();
                } else {
                    await insertFileAfter();
                }

                // gridVisibleRowNum이 지정되지 않았다면 기본 3행만 노출, 지정되었다면 지정된 row수 만큼 노출
                if (scwin.options.gridVisibleRowNum === "all") {
                    grdFile.options.visibleRowNum = "all";
                } else {
                    const gridVisibleRowNum = Number.parseInt(scwin.options.gridVisibleRowNum);
                    grdFile.setVisibleRowNum((dlUntyAtchFileL.getRowCount() < gridVisibleRowNum) ? ((dlUntyAtchFileL.getRowCount() > 1) ? dlUntyAtchFileL.getRowCount() : 1) : gridVisibleRowNum);
                }

                async function checkImageFileSize() {
                    let urlCreator = window.URL || window.webkitURL || window;
                    let img = new Image();

                    img.onerror = function () { // 이미지 로드 오류가 난 경우
                        // 메모리 해제
                        urlCreator.revokeObjectURL(this.src);

                        delete img;
                    };

                    img.onload = async function () {
                        // 메모리 해제
                        urlCreator.revokeObjectURL(this.src);

                        let width = this.width; // 이미지의 width 값
                        let height = this.height; // 이미지의 height 값

                        delete img;

                        if (scwin.options.checkImageRatio && scwin.options.imgRatio != "") {
                            let ratioValue = scwin.options.imgRatio.trim().split(":");
                            let ratioX = width * Number(ratioValue[1]);
                            let ratioY = height * Number(ratioValue[0]);

                            if (ratioX !== ratioY) {
                                // '{0}' 이미지 파일 사이즈를 {1} x {2} 비율에 맞게 등록해주세요.
                                await com.gfnAlert(["msg.common.checkImageSizeRatio", paramObj.strName, ratioValue[0], ratioValue[1]]);

                                RAONKUPLOAD.SetSelectFile(paramObj.nIndex, 1, scwin.kUploadId);
                                RAONKUPLOAD.DeleteSelectedFile(scwin.kUploadId);
                            } else {
                                await insertFileAfter();
                            }
                        } else if ((scwin.options.exactImageSize && (Number(scwin.options.imageWidth) !== Number(width) || Number(scwin.options.imageHeight) !== Number(height)))
                            || (!scwin.options.exactImageSize && (Number(scwin.options.imageWidth) < Number(width) || Number(scwin.options.imageHeight) < Number(height)))) {

                            await com.gfnAlert([(scwin.options.exactImageSize) ? 'msg.common.checkImageSize' : 'msg.common.lessImageSize', paramObj.strName, scwin.options.imageWidth, scwin.options.imageHeight]);

                            RAONKUPLOAD.SetSelectFile(paramObj.nIndex, 1, scwin.kUploadId);
                            RAONKUPLOAD.DeleteSelectedFile(scwin.kUploadId);
                        } else {
                            await insertFileAfter();
                        }
                    };

                    let webkitURL = urlCreator.createObjectURL(paramObj.objFile);
                    img.src = webkitURL;
                }

                // 전체 파일 용량 표시 설정
                scwin.setTotalFileSizeInfo();

                async function insertFileAfter() {
                    /* 파일 추가 후 실행
                        uploadID : 업로드 컴포넌트 아이디
                        paramObj : 추가된 파일 정보
                        console.log('AfterAddFile', uploadID, paramObj);

                        추가된 파일 정보를 dataList에 추가한다
                    */
                    const fileInfo = {
                        untyAtchFileNo: '',
                        atchFileSqno: '',
                        bsneClsfCd: dlUntyAtchFileM.get('bsneClsfCd'),
                        // tblNm : dlUntyAtchFileM.get('tblNm'),
                        // colNm : dlUntyAtchFileM.get('colNm'),
                        atchFileDscr: '',
                        atchFileKndCd: '',
                        orgnlAtchFileNm: paramObj.strName,
                        fileExtnNm: '',
                        fileSz: paramObj.objFile.size || 0,
                        atchFileNm: '',
                        atflPathNm: '',
                        atflRmrk: '',
                        rstrId: '',
                        rstrIpar: '',
                        rgstDttm: '',
                        chnrId: '',
                        chnrIpar: '',
                        chngDttm: '',
                        delYn: '',
                        sessUserNo: '',
                        nIndex: paramObj.nIndex // customValue 를 수정 할 때 사용
                    };

                    dlUntyAtchFileL.setJSON([fileInfo], true); // dataList에 데이터 추가
                    dlUntyAtchFileL.modifyRowStatus(dlUntyAtchFileL.getTotalRow() - 1, 'C'); // 상태를 등록 상태로 변경

                    /* 파일 확장자 체크 관련  */
                    // 확장자 체크 사용
                    let useFileExt = false;
                    if (scwin.options.zipExt.use === 'Y') {
                        useFileExt = true;

                        // 압축파일 확장자 체크 속성 Y/N을 true/false 로 변환한다.
                        if (scwin.options.zipExt?.deleteErrorList === 'Y') {
                            scwin.options.zipExt.deleteErrorList = true;
                        } else {
                            scwin.options.zipExt.deleteErrorList = false;
                        }

                        if (comUtil.gfnIsEmpty(scwin.options.zipExt?.inspectZipOptions?.findExt) == false && typeof scwin.options.zipExt?.inspectZipOptions?.findExt == 'string' && scwin.getType(scwin.options.zipExt?.inspectZipOptions?.findExt) == 'String') {
                            null;
                        } else if (comUtil.gfnIsEmpty(scwin.options.zipExt?.inspectZipOptions?.findExt) == false && typeof scwin.options.zipExt?.inspectZipOptions?.findExt == 'object' && scwin.getType(scwin.options.zipExt?.inspectZipOptions?.findExt) == 'Array') {
                            null;
                        } else {
                            console.error('findExt가 부적절합니다.');
                            useFileExt = false;
                        }
                    }

                    if (useFileExt) {
                        RAONKUPLOAD.DetectFileExtensionAndInspectZipFile(scwin.options.zipExt, function (err, result) {
                            if (err) {
                                console.log('파일 검사 중 오류 발생 >> 파일명 : ' + err.list.originalName + ' ' + err.message);
                                dlUntyAtchFileL.removeRow(paramObj.nIndex);
                                return false;
                            }

                            // 검사 통과
                            if (result.isSuccess) {
                                console.log('검사 이상 없음');
                                // 검사 이상이 없는 경우 이 부분에서 전송 시작을 하시면 됩니다.
                            } else {
                                console.log('이상 파일 존재');
                                // 확장자 변조된 파일 리스트 추출 예시
                                const errorDetectFileList = result.errorDetectFileList;
                                const errorDetectFileListLength = errorDetectFileList.length;
                                // 확장자 변조된 파일이 있는 경우
                                if (errorDetectFileListLength > 0) {
                                    console.log('<< 확장자 변조된 파일 리스트 >>');
                                    for (let i = 0; i < errorDetectFileListLength; i++) {
                                        const errorFileName = errorDetectFileList[i].originalName;
                                        console.log(errorFileName); // 확장자 변조 오류 파일명
                                    }
                                }

                                // zip 파일 검사 결과
                                const errorZipInspect = result.errorZipInspect;
                                const errorZipInspectLength = errorZipInspect.length;

                                // 허용하지 않는 zip 파일이 있는 경우
                                if (errorZipInspectLength > 0) {
                                    console.log('<< 허용되지 않는 zip 파일 리스트 >>');
                                    for (let i = 0; i < errorZipInspectLength; i++) {
                                        // const errorFileName = errorZipInspect[i].list.originalName; // zip 검사 오류 파일명
                                        const errorFilesInZip = errorZipInspect[i].errorFilesInZip; // 해당 zip 파일 안의 오류 파일들 리스트
                                        const errorFilesInZipLen = errorFilesInZip.length;
                                        for (let j = 0; j < errorFilesInZipLen; j++) {
                                            const errorFileName2 = errorFilesInZip[j].fileName;
                                            let errorReason = '';

                                            if (errorFilesInZip[j].isFolder) {
                                                // 폴더인 경우
                                                errorReason = '(폴더)';
                                            } else if (errorFilesInZip[j].isDetectedExt) {
                                                // 확장자가 변조된 파일인 경우
                                                errorReason = '(확장자 변조)';
                                            } else {
                                                errorReason = '(허용하지 않는 파일 확장자)'; // 허용하지 않는 확장자인 경우
                                            }
                                            console.log('-- ' + errorFileName2 + ' ' + errorReason);
                                        }
                                    }

                                    dlUntyAtchFileL.removeRow(paramObj.nIndex);
                                    return false;
                                }
                            }
                        }, uploadID);
                    }

                    // print 시 hidden 컬럼 처리 - hiddenPrint 클래스 추가
                    $p.setTimeout(function() {
                        grdFile.hiddenList?.forEach((col, index) => {
