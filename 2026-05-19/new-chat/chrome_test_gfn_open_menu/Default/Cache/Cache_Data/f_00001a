                }
            },
            CreationComplete: async function (uploadID) {
                scwin.fileLog('file > Event > CreationComplete');
                scwin.setViewMode(scwin.options.mode, scwin.options.untyAtchFileNo); // 모드 edit/view
                scwin.setUseMergePdfFile(scwin.options.useMergePdfFile); // 첨부파일인쇄버튼 삭제 유무
