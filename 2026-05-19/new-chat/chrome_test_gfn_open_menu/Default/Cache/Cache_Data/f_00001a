/********************************************************************************
 * 설명 : 전체 파일 용량 표시 설정
 ********************************************************************************/
scwin.setTotalFileSizeInfo = function() {
    if (scwin.options.maxTotalFileSize === undefined) return;
    let totalFileSize = RAONKUPLOAD.GetTotalFileSize(scwin.kUploadId);

    if (totalFileSize === 0) {
        spnTotalFileSize.setValue("0");
        return;
    } else if (Number.parseInt(totalFileSize) < 1024) {
        spnTotalFileSize.setValue(comUtil.gfnFormatNumber(totalFileSize) + " B");
        return;
    }

    if (scwin.options.maxTotalFileSize.includes("KB")) {
        totalFileSize = Number.parseFloat(totalFileSize / 1024).toFixed(2);
    } else if (scwin.options.maxTotalFileSize.includes("MB")) {
        totalFileSize = Number.parseFloat(totalFileSize / (1024 * 1024)).toFixed(3);
    } else if (scwin.options.maxTotalFileSize.includes("GB")) {
        totalFileSize = Number.parseFloat(totalFileSize / (1024 * 1024 * 1024)).toFixed(4);
    } else {
        totalFileSize = Number.parseFloat(totalFileSize);
    }

    spnTotalFileSize.setValue(comUtil.gfnFormatNumber(totalFileSize));

};

/********************************************************************************
 * 설명 : 전체 파일 제한 용량 표시 설정
 ********************************************************************************/
scwin.setMaxTotalFileSizeInfo = function() {
    // B(byte), KB(kilobyte), MB(megabyte), GB(gigabyte), 용량 제한이 없을 경우 용량 제한 표시 hide 처리
    if (scwin.options.maxTotalFileSize.startsWith("0")) {
        spnMaxTotalFileSize.setValue("0");
        spnFileSizeSplit.hide();
        spnMaxTotalFileSize.hide();
        spnFileSizeType.hide();
    } else if (scwin.options.maxTotalFileSize.includes("KB")) {
        spnMaxTotalFileSize.setValue(comUtil.gfnFormatNumber(Number.parseFloat(scwin.options.maxTotalFileSize.replaceAll("KB", ""))));
        spnFileSizeType.setValue("KB");
    } else if (scwin.options.maxTotalFileSize.includes("MB")) {
        spnMaxTotalFileSize.setValue(comUtil.gfnFormatNumber(Number.parseFloat(scwin.options.maxTotalFileSize.replaceAll("MB", ""))));
        spnFileSizeType.setValue("MB");
    } else if (scwin.options.maxTotalFileSize.includes("GB")) {
        spnMaxTotalFileSize.setValue(comUtil.gfnFormatNumber(Number.parseFloat(scwin.options.maxTotalFileSize.replaceAll("GB", ""))));
        spnFileSizeType.setValue("GB");
    } else {
        spnMaxTotalFileSize.setValue(comUtil.gfnFormatNumber(Number.parseFloat(scwin.options.maxTotalFileSize.replaceAll("B", ""))));
        spnFileSizeType.setValue("B");
    }
};

