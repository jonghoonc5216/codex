scwin.btnMergePdfFile_onclick = async function(e) {
    // 부모가 지정한 함수 동기처리
    if(typeof scwin.options.evPreBtnMergePdfFile === "function") {
        let isContinue = await scwin.options.evPreBtnMergePdfFile(scwin.fileScope);
        if(isContinue === false) {
            return;
        }
    }

    const sbmOption = {
        id : "sbmMergePdfFile",
        action : "/fs/fsc/fsca/mergePdfFileAndDocViewer.do",
        inData : "dlUntyAtchFileM",
        outData : "dlDownAtflGrpDetlResultM=result",
        msgYn : {succ : false, err : true},
    };

    // 선택된 첨부파일 순번 설정
    const arrAtchFileSqnos = dlUntyAtchFileL.getAllJSON().filter(row => row.CHK === '1').reduce((acc, cur) => {
        acc.push(cur.atchFileSqno);
        return acc;
    }, []);

    if (arrAtchFileSqnos.length === 0) {
        await com.gfnAlert("msg.pb.pbp.chekValidSlprAthmDocuSbmsn2");
        return;
    }

    dlUntyAtchFileM.set("atchFileSqnos", arrAtchFileSqnos.join(","));

    const result = await com.gfnExecute(sbmOption);

    if (result.responseStatusCode === 200) {
        const previewWindow = window.open("about:blank");
        previewWindow.location.href = dlDownAtflGrpDetlResultM.get("viewUrlPath");
    }
};

