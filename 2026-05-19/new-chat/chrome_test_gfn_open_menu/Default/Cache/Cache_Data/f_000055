            let pbancPstgYn = result.responseJSON.dmParamMap.pbancPstgYn;
            let atrzSttsCd = result.responseJSON.dmParamMap.atrzSttsCd;

            if (type == "btnAprvlReq") { //결재요청
                // 공고진행상태가 진010027 작성완료(최종저장), 결재상태코드가 null, 결020001 미결재, 공고게시 여부가 Y가 아닐때만 결재요청이 가능
