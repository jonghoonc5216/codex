    gfnSetFocus: async function(objTabContOrGroup, strKey) {
        bRet = true;

        if (objTabContOrGroup.getPluginName() == "group") {
            bRet = this.gfnSetFocusInGroup(objTabContOrGroup, strKey);
        } else if (objTabContOrGroup.getPluginName() == "tabControl") {
            for (idxTab = 0; idxTab < objTabContOrGroup.getTabCount(); idxTab++) {
                await objTabContOrGroup.setSelectedTabIndex(idxTab);

                bRet = this.gfnSetFocusInGroup(objTabContOrGroup.getWindow(idxTab).reqGrpChk, strKey);
                if (bRet === false) {
                    break;
                }
            }
        }

        return bRet;
    },
    gfnSetFocusInGroup: function(objGroup, strKey) {
        let objWfArr = com.gfnGetChildren(objGroup, {
            includePlugin: "wframe",
            recursive: false
        });

        if(!comUtil.gfnIsEmpty(objWfArr) && objWfArr.length != 0) {
            grpObj = [];
            for(let objWfIdx in objWfArr) {
                let obj = objWfArr[objWfIdx];
                if(obj.getStyle("visibility") == "hidden" || obj.getDisabled()) continue;
                grpObj.push(obj);
            }
        } else {
            grpObj = [objGroup];
        }

        let objArr = [];

        for(let grpObjIdx in grpObj) {
            let objSubArr = com.gfnGetChildren(grpObj[grpObjIdx], {
                includePlugin: "checkbox checkcombobox datePicker editor input inputCalendar multiselect radio selectbox searchbox secret textarea",
                recursive: true
            });
            objArr = objArr.concat(objSubArr);
        }

        try {
            for(let objIdx in objArr) {
                let obj = objArr[objIdx];

                if(obj.getStyle("visibility") == "hidden") continue;
                if(obj.getDisabled() && !obj.hasClass("searchbox")) continue;

                if (typeof obj.removeClass != "undefined") {
                    obj.removeClass("error");
                }

                let dataObjInfo = com.gfnGetDataCollection(obj);
                let dataCollection = null;
                let columnId = null;
                let value = null;

                if((dataObjInfo != undefined) && (dataObjInfo != null)) {
                    dataCollection = $p.getComponentById(dataObjInfo.runtimeDataCollectionId);
                    columnId = dataObjInfo.columnId;
                }

                if((dataCollection != null) && ((dataCollection.getObjectType() == "dataMap"))) {
                    value = dataCollection.get(dataObjInfo.columnId);
                    if (typeof value == "string") {
                        value = value.trim();
                    }
                } else {
                    if(obj.getPluginName() != "editor") {
                        if((typeof obj.getValue == "function")) {
                            value = obj.getValue();
                            if(typeof value == "string") {
                                value = value.trim();
                            }
                        } else {
                            continue;
                        }
                    } else {
                        value = obj.getHTML();
                        if(typeof value == "string") {
                            value = value.trim();
                        }
                    }
                }

                if(strKey == columnId ) {
                    obj.focus();
                    obj.removeClass("w2input_focus");
                    obj.addClass("error");
                    return false;
                }

            }

        } catch(ex) {
            console.error("erorr meseage!",ex);
        } finally {
            objArr = null;
        }
    },

