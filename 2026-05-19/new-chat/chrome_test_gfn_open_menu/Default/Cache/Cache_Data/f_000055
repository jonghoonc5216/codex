    /********************************************************************************
     * 이름   	: fnCheckHaveOrdDy
     * 설명   	: 특정 기간동안 평일 체크하는 로직
     * @param hldyYmd  입력한 년월일
     ********************************************************************************/
    fnCheckHaveOrdDy : async function(temPstgDt , slprRcptDdlnDay) {
        var result = [];
        var ordDy = 0;
        let sDate = WebSquare.date.dateAdd(temPstgDt , 1, 'day');
        let notK = "Y";

        while (WebSquare.date.dateDiff(sDate, slprRcptDdlnDay) > 0){
            result.push(sDate);
            sDate =  WebSquare.date.dateAdd(sDate, 1, 'day');
        }

        for(let i=0; i<result.length; i++ ){
            isHldy = await this.fnCheckHldyYn(result[i]);
            if (isHldy == false) {
                ordDy++;
            }
            if (ordDy > 2){
                break;
            }
        }

        if(ordDy < 3){
            notK = "N"
        }

        return notK;
    },
