    /********************************************************************************
     * 이름   	: gfnGetDataMapValueAmongTabs
     * 설명   	: 탭 구조 화면에서 각 탭 dmItemMap에서 특정 key에 대한 value 획득
     * @param tabCont tabControl Object
     * @param strKey datamap key
     * @return value
    ********************************************************************************/
    gfnGetDataMapValueAmongTabs: function(tabCont, strKey) {
        let strRtnVal = "";
        for(let i=0 ; i<tabCont.getTabCount() ; i++) {
            let keyInfo = tabCont.getWindow(i).dmItemMap.getKeyInfo(strKey);
            if(!comUtil.gfnIsEmpty(keyInfo)) {
                strRtnVal = tabCont.getWindow(i).dmItemMap.get(strKey);
                break;
            }
        }
        return strRtnVal;
    },
