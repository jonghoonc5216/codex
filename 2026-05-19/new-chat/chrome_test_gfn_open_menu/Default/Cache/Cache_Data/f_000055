    /********************************************************************************
     * 이름   	: gfnSetUdcTooltip
     * 설명   	: 화면 UI의 udc_tooltip에 udcTooltipContents.js로 부터 읽어온 툴팁 타이틀/내용을 세팅한다.
     * 사용방법    :
     *          1. 툴팁 내용을 설정하고자 하는 group의 userData1 속성에 tooltip contents의 key를 설정한다.
     *          2. 툴팁 내용을 설정하고자 하는 group에 Palette의 udc_tooltip을 삽입 위치 '기준객체의 마지막 자식 노드'로 추가한다.
     *          3. 페이지 내 init 함수 등에서 호출한다.
     *             e.g. await pnBidPbancUtil.gfnSetUdcTooltip(reqGrpChk);
     * @param grpObj: 페이지 내 최상위 group object
    ********************************************************************************/
    ,gfnSetUdcTooltip: async function(objGroup) {
        if (typeof udcTooltipContents == 'undefined' || !udcTooltipContents.json) {
            await $.getScript("/bsnejs/pn/udcTooltipContents.js", function(data, textStatus, jqxhr) {

            });
        }

        if (udcTooltipContents.json) {
            objGroup = (typeof objGroup == "string") ? $p.getComponentById(objGroup) : objGroup;

            const objWfArr = com.gfnGetChildren(objGroup, {
                includePlugin: "wframe",
                recursive: false
            });

            if(!comUtil.gfnIsEmpty(objWfArr) && objWfArr.length != 0) {
                grpObj = [];
                for(let objWfIdx in objWfArr) {
                    let obj = objWfArr[objWfIdx];
                    if(obj.getStyle("visibility") == "hidden" || obj.getDisabled()) continue;
                    grpObj.push(obj);
                }
            } else {
                grpObj = [objGroup];
            }

            let groups;
            let userData;
            let compId;
            let compObj;
            for (let objWframe of grpObj) {
                groups = com.gfnGetChildren(objWframe, {recursive: true, includePlugin: "group"});

                for (let group of groups) {
                    userData = group.getUserData("userData1");

                    if (userData && userData.startsWith("udcTooltip")) {
                        comps = com.gfnGetChildren(group);

                        if(comps.length > 0) {
                            compId = comps[comps.length-1].id;

                            compObj = $p.getComponentById(compId);

                            if (comUtil.gfnIsEmpty(compObj.setTooltipTitle)) { continue; }

                            compObj.setTooltipTitle(udcTooltipContents.json[userData].tooltipTitle);
                            compObj.setTooltipContent(udcTooltipContents.json[userData].tooltipContent, true);
                            compObj.setVisibleCloseButton(true);
                            if (udcTooltipContents.json[userData].tooltipWidth) {
                                compObj.setTooltipWidth(udcTooltipContents.json[userData].tooltipWidth);
                            }
                        }
                    }
                }
            }
        }
    }
    /********************************************************************************
     * 이름   	: gfnGetUntyPbancIsCnt
