                console.error(e);
            }
            console.log(objBidSysChckLis);
        }

        let objBidSysChck;
        let msg;
        if (objBidSysChckLis && strKey && strVal && strVal.length == 12) {
            for (let i = 0; i < objBidSysChckLis.length; i++) {
                objBidSysChck = objBidSysChckLis[i];
