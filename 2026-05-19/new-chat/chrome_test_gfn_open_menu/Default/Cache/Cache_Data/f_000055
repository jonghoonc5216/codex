        gfnAlert: function(msgId, opts={}, closeCallbackFncName) {
            let options = opts;
            if (!options.popupName) {
                let msgIdPrefix;
                let msgIdSplitArray;
                if (comUtil.gfnIsArray(msgId)) {
                    msgIdSplitArray = msgId[0].split(".");
                } else {
                    msgIdSplitArray = msgId.split(".");
                }
                msgIdPrefix = msgIdSplitArray[0];
                if (["warn", "error", "fail"].includes(msgIdPrefix)) {
                    options.popupName = "경고 메시지";
                } else {
                    options.popupName = "안내 메시지";
                }
            }

            return com.gfnAlert(msgId, options, closeCallbackFncName);
        },

        gfnMandatory : async function(grpObj, requireData){
            grpObj = (typeof grpObj == "string") ? $p.getComponentById(grpObj) : grpObj;
            if (comUtil.gfnIsEmpty(grpObj)) return false;

            let objWfArr = com.gfnGetChildren(grpObj, {
                includePlugin: "wframe",
                recursive: false
            });

            if(!comUtil.gfnIsEmpty(objWfArr) && objWfArr.length != 0) {
                grpObj = [];
                for(let objWfIdx in objWfArr) {
                    let obj = objWfArr[objWfIdx];
                    if(obj.getStyle("visibility") == "hidden" || obj.getDisabled()) continue;
                    grpObj.push(obj);
                }
            } else {
                grpObj = [grpObj];
            }

            let objArr = [];

            for(let grpObjIdx in grpObj) {
                let objSubArr = com.gfnGetChildren(grpObj[grpObjIdx], {
                    includePlugin: "checkbox checkcombobox datePicker editor input inputCalendar multiselect radio selectbox searchbox secret textarea",
                    recursive: true
                });
                objArr = objArr.concat(objSubArr);
            }

            try {
                for(let objIdx in objArr) {
                    let obj = objArr[objIdx];

                    if(obj.getStyle("visibility") == "hidden") continue;
                    if(obj.getDisabled() && !obj.hasClass("searchbox")) continue;

                    if (typeof obj.removeClass != "undefined") {
                        obj.removeClass("error");
                    }

                    let dataObjInfo = com.gfnGetDataCollection(obj);
                    let dataCollection = null;
                    let columnId = null;
                    let value = null;

                    if((dataObjInfo != undefined) && (dataObjInfo != null)) {
                        dataCollection = $p.getComponentById(dataObjInfo.runtimeDataCollectionId);
                        columnId = dataObjInfo.columnId;
                    }

                    if((dataCollection != null) && ((dataCollection.getObjectType() == "dataMap"))) {
                        value = dataCollection.get(dataObjInfo.columnId);
                        if (typeof value == "string") {
                            value = value.trim();
                        }
                    } else {
                        if(obj.getPluginName() != "editor") {
                            if((typeof obj.getValue == "function")) {
                                value = obj.getValue();
                                if(typeof value == "string") {
                                    value = value.trim();
                                }
                            } else {
                                continue;
                            }
                        } else {
                            value = obj.getHTML();
                            if(typeof value == "string") {
                                value = value.trim();
                            }
                        }
                    }

                    for(let objReqIdx in requireData) {
                        if(requireData[objReqIdx] == columnId ) {
                            if(comUtil.gfnIsEmpty(value) || value.length == 0) {
                                com.gfnAlert(['msg.ge.valCheck', obj.options.title], {}, () => {
                                        obj.focus();
                                        obj.removeClass("w2input_focus");
                                        obj.addClass("error");
                                    });

                                return false;
                            }
                        }
                    }
                }

            } catch(ex) {
                console.error("erorr meseage!",ex);
            } finally {
                objArr = null;
            }

            return true;
        },
        /********************************************************************************
         * 이름   	: gfnMandatoryAcrossTab
         * 설명   	: 각 탭의 dmItemMap을 돌며 특정 key의 value를 찾아 필수값 체크
         *
        ********************************************************************************/
        gfnMandatoryAcrossTab: async function(objTabCont, arrKeyInfo) {
            let strVal;

            for (let keyInfo of arrKeyInfo) {
                strVal = this.gfnGetDataMapValueAmongTabs(objTabCont, keyInfo.key);
                if (comUtil.gfnIsEmpty(strVal)) {
                    await com.gfnAlert(["msg.ge.valCheck", keyInfo.title]);
                    await this.gfnSetFocus(objTabCont, keyInfo.key);
                    return false;
                }
            }
            return true;
        },

