            // [자체조달-수의계약-수의시담] 예비가격작성프로그램 : "별도산출" 인경우, "시담수행방식" - "직접" 만 가능
            if (dmInitComm.get("prcmMthoSeCd") == "조020002" && strScsbdMthdCd == "낙030009" &&
                    keyValueMap.pnprPgmUseYn == "N" && (keyValueMap.pstmFlfmtPrcsTyCd == "시100002")) {
                await com.gfnAlert(["msg.alert.pn.isDoWant", "예비가격작성프로그램 '별도산출'인 경우, 시담수행방식은 '직접'을 선택"]);
                await this.gfnSetFocus(objTabContOrGroup, "pstmFlfmtPrcsTyCd");
                return false;
            }
            // [E] 예비가격방식에 따른 예비가격작성프로그램 이용, 예비가격재작성여부, 예비가격암호화 여부 체크
        }

        return true;
    },
    /********************************************************************************
     * 이름   	: gfnGetPnprDcsnMthoCd
     * 설명   	: 공고입력사항에 따른 예가방식 리턴
     * @param strPrcmBsneSeCd: 조달업무구분코드
     * @param strStdCtrtMthdCd: 계약방법코드
     * @param strScsbdMthdCd: 낙찰방법코드
     * @param nPrspPrce: 추정가격
     * @param keyValueMap: 기타 입력항목값을 담고 있는 object
     * @return { msgArgArr 메시지, rtnPnprDcsnMthoCd 예가방식코드 }
    ********************************************************************************/
    gfnGetPnprDcsnMthoCd: function(strPrcmBsneSeCd, strStdCtrtMthdCd, strScsbdMthdCd, nPrspPrce, keyValueMap) {
        let msgArgArr = [];
        let rtnPnprDcsnMthoCd = "";

        // 수의계약-수의시담 or 수의(예비계약) or 수의(우선시공분 공사계약)
        if (strStdCtrtMthdCd == "계030004" && ["낙030009", "낙030023", "낙030024"].includes(strScsbdMthdCd)) {
            if (nPrspPrce > 0 && nPrspPrce <= 20000000) { // 추정가격 2천만원 이하 -> 비예가 or 단일예가
//                rtnPnprDcsnMthoCd = "예050001,예050002";
                if(keyValueMap != undefined){
                    if(keyValueMap.pnprDcsnMthoCd == "예050003"){
                        msgArgArr = ["msg.alert.pn.isDoWant", "추정가격 2천만원 이하 수의계약(수의시담)인 경우, '비예가' 또는 '단일예가'를 선택"];
                        rtnPnprDcsnMthoCd = "예050002"; // 기본값 : 단일예가
                    }
                }else{
                    rtnPnprDcsnMthoCd = "예050002"; // 기본값 : 단일예가
                }
            } else if (nPrspPrce > 20000000) { //추정가격 2천만원 초과 -> 단일예가
                msgArgArr = ["msg.alert.pn.isDoWant", "추정가격 2천만원 초과 수의계약(수의시담)인 경우, '단일예가'를 선택"];
                rtnPnprDcsnMthoCd = "예050002";
            }
        }

        // 수의시담(2인 이상) -> 복수예가
        // 2024.08.05 jclee: 비예가 선택 시 낙찰하한율 관련 충돌이 생겨, 일단 '비예가' 막음
        if (["낙030010"].includes(strScsbdMthdCd)) {
            if(keyValueMap && keyValueMap.pnprDcsnMthoCd == "예050001"){
                msgArgArr = ["msg.alert.pn.isDoWant", "낙찰방법이 수의시담(2인 이상)인 경우, '단일예가' 또는 '복수예가'를 선택"];
            }
            rtnPnprDcsnMthoCd = "예050003";
        }

        // 소액수의견적 -> 복수예가
        // 2024.08.08 jclee: 단일예가도 허용
        if (["낙030029"].includes(strScsbdMthdCd)) {
            if(keyValueMap && keyValueMap.pnprDcsnMthoCd == "예050001"){
                msgArgArr = ["msg.alert.pn.isDoWant", "낙찰방법이 소액수의견적인 경우, '단일예가' 또는 '복수예가'를 선택"];
            }
            rtnPnprDcsnMthoCd = "예050003";
        }

        // 물품,일반용역
        if (strPrcmBsneSeCd == "01" || strPrcmBsneSeCd == "03") {
            // 경쟁적대화방식에의한계약 -> 비예가
            if (["낙030008"].includes(strScsbdMthdCd)) {
                msgArgArr = ["msg.alert.pn.isDoWant", "낙찰방법이 경쟁적대화방식에의한계약인 경우, '비예가'를 선택"];
                rtnPnprDcsnMthoCd = "예050001";
            }

            // 복수견적(역경매) -> 단일예가 (입찰팀 요청)
            if (["낙030030"].includes(strScsbdMthdCd)) {
                msgArgArr = ["msg.alert.pn.isDoWant", "낙찰방법이 복수견적(역경매)인 경우, '단일예가'를 선택"];
                rtnPnprDcsnMthoCd = "예050002";
            }

            // 협상에의한계약 기본값 '비예가' 셋팅.
            if (["낙030005"].includes(strScsbdMthdCd)) {
                if(keyValueMap == undefined){
                    rtnPnprDcsnMthoCd = "예050001";
                }
            }

            // 자체기준-최저가낙찰제 기본값 '비예가' 셋팅.(최저가낙찰제는 물품, 일반용역에서 자체기준만 존재)
            if (["낙030021"].includes(strScsbdMthdCd)) {
                if(keyValueMap == undefined){
                    rtnPnprDcsnMthoCd = "예050001";
                }
            }

            // 긴급수급조절물자 -> 복수예가
            if(strPrcmBsneSeCd == "01"){
                if(keyValueMap != undefined){
                    if (keyValueMap.esdacYn == "Y") {
                        msgArgArr = ["msg.alert.pn.isDoWant", "긴급수급조절물자인 경우, '복수예가'를 선택"];
                        rtnPnprDcsnMthoCd = "예050003";
                    }
                }
            }
        }

        // 공사
        if (strPrcmBsneSeCd == "07") {
            // 일괄입찰, 기본설계기술제안입찰 -> 비예가
            if (["낙030013", "낙030015"].includes(strScsbdMthdCd)) {
                msgArgArr = ["msg.alert.pn.isDoWant", "낙찰방법이 일괄입찰, 기본설계기술제안입찰인 경우, '비예가'를 선택"];
                rtnPnprDcsnMthoCd = "예050001";
            }

            // (국계법) 실시설계기술제안입찰 -> 비예가
            if (keyValueMap && keyValueMap.lcrtTyCd == "계040001" && strScsbdMthdCd == "낙030016") {
                msgArgArr = ["msg.alert.pn.isDoWant", "낙찰방법이 실시설계기술제안입찰인 경우 (국가계약법만 해당), '비예가'를 선택"];
                rtnPnprDcsnMthoCd = "예050001";
            }
        }

        // 기술용역
        if (strPrcmBsneSeCd == "05") {
            // 설계공모 -> 비예가
            if (["낙030017"].includes(strScsbdMthdCd)) {
                msgArgArr = ["msg.alert.pn.isDoWant", "낙찰방법이 설계공모인 경우, '비예가'를 선택"];
                rtnPnprDcsnMthoCd = "예050001";
            }

            // 협상에의한계약 기본값 '비예가' 셋팅.
            if (["낙030005"].includes(strScsbdMthdCd)) {
                if(keyValueMap == undefined){
                    rtnPnprDcsnMthoCd = "예050001";
                }
            }
        }

        // 외자 ( 물품/일반용역)
        if (strPrcmBsneSeCd == "02" || strPrcmBsneSeCd == "04") {
            // 협상에의한계약 -> 비예가
            if (["낙030005"].includes(strScsbdMthdCd)) {
                msgArgArr = ["msg.alert.pn.isDoWant", "낙찰방법이 협상에의한계약인 경우, '비예가'를 선택"];
                rtnPnprDcsnMthoCd = "예050001";
            }
        }

        // 리스: 내자/외자 -> 단일예가
        if (strPrcmBsneSeCd == "10" || strPrcmBsneSeCd == "11") {
            msgArgArr = ["msg.alert.pn.isDoWant", "'단일예가'를 선택"];
            rtnPnprDcsnMthoCd = "예050002";
        }

//        return { "msgArgArr": msgArgArr, "rtnPnprDcsnMthoCd": rtnPnprDcsnMthoCd.split(",")};
        return {msgArgArr, rtnPnprDcsnMthoCd};
    },
    /********************************************************************************
     * 이름   	: gfnGetRelaValsForPnpr
     * 설명   	: 예비가격방식에 따른 예비가격작성프로그램 이용, 예비가격재작성여부, 예비가격암호화 기본값 리턴
     * @param strPrcmMthoSeCd: 조달방식구분코드
     * @param strPnprDcsnMthoCd: 예비가격결정방식코드
     * @param strPnprPgmUseYn: 예비가격작성프로그램 이용
     * @return { pnprPgmUseYn (예비가격작성프로그램 이용): { val, disabled }
     *           pnprRwrtYn (예비가격재작성여부): { val, disabled }
     *           pnprEncrYn (예비가격암호화): { val }
     *         }
    ********************************************************************************/
    gfnGetRelaValsForPnpr: function(strPrcmMthoSeCd, strPnprDcsnMthoCd, strPnprPgmUseYn) {
        let rtnPnprPgmUseYn; // 예비가격작성프로그램 이용
        let rtnPnprRwrtYn;   // 예비가격재작성여부
        let rtnPnprEncrYn;   // 예비가격암호화
        if (strPnprDcsnMthoCd == "예050003") { // 복수예가
            rtnPnprPgmUseYn = { val: "Y", disabled: true };
            rtnPnprRwrtYn = { val: "Y", disabled: true };
            rtnPnprEncrYn = { val: "Y" };
        } else if (strPnprDcsnMthoCd == "예050001") { // 비예가
            rtnPnprPgmUseYn = { val: "", disabled: true };
            rtnPnprRwrtYn = { val: "", disabled: true };
            rtnPnprEncrYn = { val: "" };
        } else if (strPnprDcsnMthoCd == "예050002") { // 단일예가
            if (strPrcmMthoSeCd == "조020001") { // 중앙조달
                rtnPnprPgmUseYn = { val: "Y", disabled: true };
                rtnPnprRwrtYn = { val: "", disabled: true };
                rtnPnprEncrYn = { val: "Y" };
            } else { // 자체조달
                if (strPnprPgmUseYn == "Y") { // 이용
                    rtnPnprRwrtYn = { val: "", disabled: true };
                    rtnPnprEncrYn = { val: "Y" };
                } else if (strPnprPgmUseYn == "N") { // 별도산출
                    rtnPnprRwrtYn = { val: "", disabled: true };
                    rtnPnprEncrYn = { val: "N" };
                } else {
                    rtnPnprRwrtYn = { val: "", disabled: false };
                    rtnPnprEncrYn = { val: "" };
                }
                rtnPnprPgmUseYn = { val: strPnprPgmUseYn, disabled: false };
            }
        } else {
            return null;
        }
        return { pnprPgmUseYn: rtnPnprPgmUseYn, pnprRwrtYn: rtnPnprRwrtYn, pnprEncrYn:rtnPnprEncrYn };
    },

