    /********************************************************************************
     * 이름   	: fnCheckPrsmpPcArtclsbprg
     * 설명   	: 추정가격이 고시금액 미만일때 실적을 제한하는 경우 체크 - 중앙/자체 모두 체크
     * 			  (계약방법: 제한경쟁/수의계약, 물품/일반용역/기술용역만 체크 )
     * @param : strPrfmncLmtYn [ 실적제한여부 Y/N ]
     * @param : dmInitCommMap  [ 계약방법검토 Map ]
    ********************************************************************************/
    fnCheckPrsmpPcArtclsbprg: async function(strPrfmncLmtYn, dmInitCommMap, dmTabCommMap, prspPrce) {

        let strPrcmBsneSeCd;
        let strScsbdMthdCd;
        let strPrcmMthoSeCd;
        let strStdCtrtMthdCd;
        let strPrspPrce;
        let strAtcsCd;
        let strBidPbancNo;
        let strBidPbancOrd;
        let strLcrtTyCd;  // 계040001(국가) / 계040002(지방)
        let frstBidPstgYmd;

        if (dmInitCommMap) {
            strPrcmBsneSeCd  = dmInitCommMap.get("prcmBsneSeCd");  // 조달업무구분코드
            strScsbdMthdCd   = dmInitCommMap.get("scsbdMthdCd");   // 낙찰방법코드
            strPrcmMthoSeCd  = dmInitCommMap.get("prcmMthoSeCd");  // 조달방식구분코드
            strStdCtrtMthdCd = dmInitCommMap.get("stdCtrtMthdCd"); // 계약방법코드
            strPrspPrce	     = prspPrce;					 	   // 추정가격
            strAtcsCd     	 = dmInitCommMap.get("atcsCd"); 	   // 조항호코드
            strBidPbancNo    = dmTabCommMap.get("bidPbancNo");    // 입찰공고번호
            strBidPbancOrd   = dmTabCommMap.get("bidPbancOrd");   // 입찰공고번호차수
            strLcrtTyCd      = dmInitCommMap.get("lcrtTyCd");      // 계약법구분 - 계040001(국가) / 계040002(지방)
        }

        // 최초입찰공고게시일자 조회.Start =====================================================================================
        const sbmSelectFrstBidPstgYmd = {
                id : "selectFrstBidPbancPstgYmd",
                action : "/pn/pnp/pnpe/commBidPbac/selectFrstBidPbancPstgYmd.do",
                msgYn : {succ: false, err : false}
            };
        const resultFrstBidPstgYmd = await com.gfnExecute(sbmSelectFrstBidPstgYmd,
                                                          { "dlParamM" :
                                                                          {
                                                                            "bidPbancNo" : strBidPbancNo,
                                                                          "bidPbancOrd": strBidPbancOrd
                                                                        }
                                                          });
        frstBidPstgYmd = resultFrstBidPstgYmd.responseJSON.result.frstPbancPstgYmd;
        // 최초입찰공고게시일자 조회.End ========================================================================================

        // 고시금액 세팅. (최초공고게시일자에 따라 달라짐).Start ======================================================================
        let comepareNtfcMoney = 210000000; // 기준 고시금액
        if ( Number(frstBidPstgYmd) >= Number(20190101) && Number(frstBidPstgYmd) <= Number(20201231) ) {
            comepareNtfcMoney = 200000000;
        }
        if ( Number(frstBidPstgYmd) >= Number(20210101) ){
            comepareNtfcMoney = 210000000;
        }
        if ( Number(frstBidPstgYmd) >= Number(20230101) ){
            comepareNtfcMoney = 220000000;
        }
        // 25.01.01 부로 고시금액 기준이 2억2천에서 2억 3천으로 변경됨 ( 2025.01.02. 기준 변경내용 적용 )
        if ( Number(frstBidPstgYmd) >= Number(20250101) ){
            comepareNtfcMoney = 230000000;
        }
        // 고시금액 세팅. (최초공고게시일자에 따라 달라짐).End =========================================================================

        // 실적제한여부 'Y'일 경우
        if ( strPrfmncLmtYn == "Y" ) {
            if (strStdCtrtMthdCd == "계030003" && parseInt(strPrspPrce) < comepareNtfcMoney ) {  // 제한경쟁 && 추정가격이 고시금액보다 작을 경우
                // 물품/일반용역 실적제한 조항호 선택 시
                if( strAtcsCd.indexOf("02101030") > -1 || strAtcsCd.indexOf("02001030") > -1 ||
                        strAtcsCd.indexOf("02101050") > -1 || strAtcsCd.indexOf("02001050") > -1 ){
                    if ( strPrcmBsneSeCd == "05"  ) {  // 기술용역일 경우 ( 중앙/조달 )
                        await com.gfnAlert(["msg.pn.pnp.pnpe.prfmncLmtYn.comepareNtfcMoney01", "계약방법(실적) 및 조항호"]);
                        return false;
                    }else{  // 물품/일반용역일 경우
                        await com.gfnAlert(["msg.pn.pnp.pnpe.prfmncLmtYn.comepareNtfcMoney01", "실적제한여부 및 조항호"]);
                        return false;
                    }
                }else{
                    if ( strPrcmBsneSeCd == "05"  ) {  // 기술용역일 경우 ( 중앙/조달 )
                        await com.gfnAlert(["msg.pn.pnp.pnpe.prfmncLmtYn.comepareNtfcMoney01", "계약방법(실적)"]);
                        return false;
                    }else{  // 물품/일반용역일 경우
                        await com.gfnAlert(["msg.pn.pnp.pnpe.prfmncLmtYn.comepareNtfcMoney01", "실적제한여부"]);
                        return false;
                    }
                }
            }else if (strStdCtrtMthdCd == "계030004") {  // 수의계약
                if ( strLcrtTyCd == "계040001" ){ // 국가계약법일 경우
                    await com.gfnAlert(["msg.pn.pnp.pnpe.prfmncLmtYn.comepareNtfcMoney05"]);
                    return false;
                }

                // 추정가격이 5000만원을 초과할 경우
                if(parseInt(strPrspPrce) > 50000000){
                    if(strAtcsCd == "02503020-20200714" || strAtcsCd == "02503030-20200714" || strAtcsCd == "02503040-20200714" ){
                        if (parseInt(strPrspPrce) > 100000000){
                            await com.gfnAlert(["msg.pn.pnp.pnpe.prfmncLmtYn.comepareNtfcMoney06", "1억"]);
                            return false;
                        }
                    }else{
                        if(Number(frstBidPstgYmd) < Number("20230101") && parseInt(strPrspPrce) > 50000000){
                            await com.gfnAlert(["msg.pn.pnp.pnpe.prfmncLmtYn.comepareNtfcMoney06", "5천만원"]);
                            return false;
                        }else if(Number(frstBidPstgYmd) >= Number("20230101") && parseInt(strPrspPrce) > 100000000){
                            await com.gfnAlert(["msg.pn.pnp.pnpe.prfmncLmtYn.comepareNtfcMoney06", "1억"]);
                            return false;
                        }
                    }
                }
            }
        }
        return true;
    },

