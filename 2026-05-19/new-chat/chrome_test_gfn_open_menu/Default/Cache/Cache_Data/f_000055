     * 이름   	: gfnToggleTextAreaHeight
     * 설명   	: toggle 버튼 클릭 시 textarea 높이 펼침/접기 toggle 처리
     * @param objTextArea
     * @param objBtn
    ********************************************************************************/
    gfnToggleTextAreaHeight: function(objTextArea, objBtn) {
        const nInitHeight = objTextArea.getInitStyle("height") || objTextArea.getStyle("height");
        if (!objTextArea.getUserData("initHeight")) {
            objTextArea.setUserData("initHeight", nInitHeight);
        }

        if (objBtn?.hasClass("active") || objTextArea.getUserData("initHeight") == objTextArea.getStyle("height")) { // 펼침
            pnBidPbancUtil.gfnTextAreaAutoHeight({
                target: {
                    id: objTextArea.getID()
                }
            });
        } else { // 원래크기
            objTextArea.setStyle("height", objTextArea.getUserData("initHeight"));
        }

        objBtn?.toggleClass("active");
    },

