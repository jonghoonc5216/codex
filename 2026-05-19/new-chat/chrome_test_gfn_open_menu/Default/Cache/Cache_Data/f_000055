        }

        let keyValueMap = {};
        for (let dmItemMap of dmItemMapArray) {
            if (keyArray.length < 1) {
                break;
            }
            for (let key of keyArray) {
                if (dmItemMap.getKeyInfo(key) && dmItemMap.get(key)) {
                    keyValueMap[key] = dmItemMap.get(key);
                    keyArray = keyArray.filter((el) => {
                        return el != key;
