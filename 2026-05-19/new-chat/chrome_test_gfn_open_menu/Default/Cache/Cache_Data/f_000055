    /********************************************************************************
     * 이름   	: gfnDeleteRow
     * 설명   	: 공통 gfnDeleteRow 함수 사용 시 rowStatus: 'C' 가 아닌 행은 rowStatus = 'D' 로 변경되고 datalist에서 즉각 제거되지 않음.
     *            행삭제 시 datalist에서 무조건 제거 되도록 옵션 추가함.
     * 변경이력   : 2023.11.22 사용하지 않음. com.gfnRemoveRow 함수로 대체 사용.
     * @param gridViewObj
     * @param chk
     * @param defaultBehavior (기본값 false) : 기존 공통함수 대로 동작하길 원하는 경우 true로 설정
    ********************************************************************************/
    gfnDeleteRow: function(gridViewObj, chk = "CHK", defaultBehavior = false) {
        try {
            const dataListObj = com.gfnGetGridViewDataList(gridViewObj);

            let checkedIdx = dataListObj.getMatchedIndex(chk, "Y");

            if (checkedIdx.length === 0) {
                checkedIdx = dataListObj.getMatchedIndex(chk, "1");
            }

            if (checkedIdx.length > 0) {
                dataListObj.setBroadcast(false);

                for (let idx = checkedIdx.length - 1; idx >= 0; idx--) {
                    if(dataListObj.getRowStatus(checkedIdx[idx]) == "C" || !defaultBehavior) {
                        dataListObj.removeRow(checkedIdx[idx]);
                    } else {
                        dataListObj.deleteRow(checkedIdx[idx]);
                        dataListObj.setCellData(checkedIdx[idx], "CHK", "");
                    }
                }
                dataListObj.setBroadcast(true, true);
            } else {
                let rowIndex = gridViewObj.getFocusedRowIndex();

                if (rowIndex === -1) {
                    rowIndex = gridViewObj._dataList?.getRowPosition() || -1;
                }

                if (dataListObj.getRowStatus(rowIndex) == "C") {
                    dataListObj.removeRow(rowIndex);
                } else {
                    dataListObj.deleteRow(rowIndex);
                    dataListObj.setCellData(rowIndex, "CHK", "");
                }
            }

        } catch (ex) {
            console.error(ex);
        }
    },
    /********************************************************************************
     * 이름   	: gfnCheckDupCellDataByGroup
     * 설명   	: 그리드 데이터리스트 cell data 중복체크
     *
     * @param dataListObj: 대상 dataList object
     * @param curRowIdx: 중복체크 데이터의 row index
     * @param value: 중복체크 할 value
     * @param colId: 중복체크 대상 column id
     * @param groupColId: 특정 컬럼 기준으로 중복체크 할 경우, 해당 column id 명시
    ********************************************************************************/
    gfnCheckDupCellDataByGroup: function(dataListObj, curRowIdx, value, colId, groupColId) {
        let result = true;
        for (let i = 0; i < dataListObj.getTotalRow(); i++) {
            if (i != curRowIdx && !comUtil.gfnIsEmpty(dataListObj.getCellData(i, colId)) && value === dataListObj.getCellData(i, colId)) {
                if (groupColId) {
                    if (dataListObj.getCellData(curRowIdx, groupColId) == dataListObj.getCellData(i, groupColId)) {
                        result = false;
                        break;
                    } else {
                        result = true;
                    }
                } else {
                    result = false;
                    break;
                }
            }
        }
        return result;
