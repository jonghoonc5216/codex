     **************************************************************************/
    fnBidAtchFileChk : async function(allFileList, bidPbancNo, bidPbancOrd) {
        let chkMsg = "msg";
        let aplcnYn = 'Y';
        let chkType = "type"
        let chkObj = {};
        let requestData = {
                "dmParam" : {
                    "bidBsneCndtCrtrCd"       : "PNPE222",
                    "bsneCndtCrtrPritmVal"    : "0001",
                }
        };
        let sbmOption1 = {
                id: "selectBidAtchFileChk",
                action: "/pn/pnp/pnpg/bidBsneCndtCrtr/selectBidAtchFileChkList.do",
                msgYn: { succ: false, err: true },
        };
        try {
            const result = await com.gfnExecute(sbmOption1, requestData);
            const fileType1 = comUtil.gfnReplaceAll(result.responseJSON.selectBidAtchFileChkList[0].bsneCndt2Val, " ", "").split(","); //AI인식 가능 확장자
            let fileList1 = result.responseJSON.selectBidAtchFileChkList[0].bsneCndt2Val;
            const fileType2 = comUtil.gfnReplaceAll(result.responseJSON.selectBidAtchFileChkList[0].bsneCndt3Val, " ", "").split(","); //AI인식 불가능 확장자
            let fileList2 = result.responseJSON.selectBidAtchFileChkList[0].bsneCndt3Val;
            const aplcnYmd = result.responseJSON.selectBidAtchFileChkList[0].bsneCndt1Val; // AI인식 파일 체크 적용일시
            let toDate = WebSquare.date.getCurrentServerDate();
            chkObj.aplcnDt = aplcnYmd.substring(0, 8);
            let pbancPstgDt = await pnBidPbancUtil.fnGetPbancPstgDt(bidPbancNo, bidPbancOrd); //최초공고게시일
            if (pbancPstgDt == "") {
                pbancPstgDt = toDate;
            }
            if (toDate >= aplcnYmd.substring(0, 8) && allFileList != null) {
                chkType = "typeB";
                chkMsg = "공고서(원본)에 [확장자 : "+fileList2+"] 파일을 등록한 경우<br />AI가 직접 인식 가능한 파일을 공고서(변환본)[확장자 : "+fileList1+"]으로 병행 등록하셔야 합니다.";
                let oriBidDocCnt = 0; // 공고서(원본)
                let trsBidDocCnt = 0; // 공고서(원본)
                for (let file of allFileList) {
                    if (file.atchFileKndCd == "첨020297") { // 공고서(원본)
                        oriBidDocCnt++;
                        let fileExt = file.orgnlAtchFileNm.split(".");
                        fileExt = fileExt[fileExt.length - 1];
                        if (!fileType2.includes(fileExt.toLowerCase()) || fileType1.includes(fileExt.toLowerCase())) {
                            chkMsg = null;
                            chkType = "typeA";
                        }
                        if (oriBidDocCnt > 1) {
                            chkMsg = "공고서(원본) 파일은 1개만 첨부 가능합니다.";
                            chkType = "typeD";
                        }
                    }
                }
                //공고서(원본)에 AI불가능한 확장자 등록한 경우 공고서(변환본) 필수등록해야하고 변환본엔 AI인식 가능한 확장자만 등록가능
                if (chkType != "typeA" && chkType != "typeD") {
                    for (let file of allFileList) {
                        if (file.atchFileKndCd == "첨020417") { // 공고서(변환본) 예시로 첨020109(기타문서) 사용 코드 발급되면 수정필요
                            trsBidDocCnt++;
                            let fileExt = file.orgnlAtchFileNm.split(".");
                            fileExt = fileExt[fileExt.length - 1];
                            if (fileType1.includes(fileExt.toLowerCase())) {
                                chkMsg = null;
                            } else {
                                chkMsg = "공고서(변환본)에는 ["+fileList1+"] 확장자 파일만 첨부할 수 있습니다.";
                            }
                            if (trsBidDocCnt > 1) {
                                chkMsg = "공고서(변환본) 파일은 1개만 첨부 가능합니다.";
                            }
                        }
                    }
                }
            // 적용시점 이전 공고 재공고, 취소공고 등 저장 시
            } else if (pbancPstgDt < aplcnYmd.substring(0, 8) && allFileList != null) {
                aplcnYn = null;
                chkMsg = null;
            //공고 상세에서 해당 함수 조회 시 적용일시만 확인
            } else if (allFileList == null) {
                if (pbancPstgDt < aplcnYmd.substring(0, 8)){
                    aplcnYn = null;
                }
            }
        } catch (e) {
            console.error(e);
        }
        chkObj.chkMsg = chkMsg;
        chkObj.aplcnYn = aplcnYn;
        return chkObj;
    },

