                } else {
                    chkYn = 'N';
                }
            } else if (type == "btnAprvlInit") { //결재초기화
                // 결재상태코드 결020003 결재완료 및 공고게시전에만 결재초기화 가능
                if (atrzSttsCd == "결020003" && pbancPstgYn != "Y") {
                } else {
                    chkYn = 'N';
                }
            } else if (type == "btnNtice") { //게시
                // 공고진행상태 진010027 작성완료, 결재상태코드 결020003 결재완료, 공고게시 여부가 Y가 아닐때만 게시 가능
                if (atrzSttsCd == "결020003" && bidPbancPgstCd == "진010027" && pbancPstgYn != "Y") {
                } else {
                    chkYn = 'N';
                }
            }
        } catch (e) {
            console.error(e);
        }
            return chkYn;
