        // "예가방식이 비예가일 경우 낙찰하한율을 사용하실 수 없습니다.\r\n"+
        // "낙찰하한율이 적용되지 않는 낙찰자선정방식을 사용하시거나 또는 \r\n"+
        // "예가방식을 비예가에서 다른 예가방식으로 변경하시기 바랍니다."
        if (!["입180001", "입180006", "입180007", "입180009"].includes(keyValueMap.bidMthdCd)) {  // 2025.02.19 직찰 아닌 경우에만 체크
            if (keyValueMap.scsbdLwlmRat && keyValueMap.pnprDcsnMthoCd == "예050001") {
                await com.gfnAlert(["msg.alert.pn.isDoWant",
                    "비예가 예비가격방식을 선택한 경우 낙찰하한율을 사용할 수 없습니다.\n" +
                    "낙찰하한율이 적용되지 않는 낙찰자선정방식을 사용하거나,\n예비가격방식을 비예가 외 다른 예비가격방식으로 변경"]);
                await this.gfnSetFocus(objTabContOrGroup, "pnprDcsnMthoCd");
                return false;
            }
        }

        // 예비가격결정방식 관련 체크
        if ((dmInitComm != null && dmInitComm != "")) {
            const strScsbdMthdCd = dmInitComm.get("scsbdMthdCd");  // 낙찰방법

            // [S]공고업무-낙찰방법에 따른 예가방식 체크
            const strPrcmBsneSeCd = dmInitComm.get("prcmBsneSeCd");   // 조달업무구분코드
            const strStdCtrtMthdCd = dmInitComm.get("stdCtrtMthdCd"); // 계약방법코드
            const nPrspPrce = keyValueMap.prspPrce ? Number(keyValueMap.prspPrce) : 0; // 추정가격을 계약방법 검토에서 입력한 것과 비교하지 않도록
            const strPnprDcsnMthoCd = keyValueMap.pnprDcsnMthoCd;     // 예가방식: 예050001 비예가, 예050002 단일예가, 예050003 복수예가

            keyValueMap["lcrtTyCd"] = dmInitComm.get("lcrtTyCd"); // 계약법유형 (예가방식 체크시 사용)
            const rtnObj = this.gfnGetPnprDcsnMthoCd(strPrcmBsneSeCd, strStdCtrtMthdCd, strScsbdMthdCd, nPrspPrce, keyValueMap);
            if (rtnObj.rtnPnprDcsnMthoCd && strPnprDcsnMthoCd && !rtnObj.rtnPnprDcsnMthoCd.includes(strPnprDcsnMthoCd)) {
                if (!comUtil.gfnIsEmptyArray(rtnObj.msgArgArr)) { // msgArgArr 이 empty array가 아니면 alert 및 return false
                    await com.gfnAlert(rtnObj.msgArgArr);
                    await this.gfnSetFocus(objTabContOrGroup, "pnprDcsnMthoCd");
                    return false;
                }
            }
            // [E]공고업무-낙찰방법에 따른 예가방식 체크

            // [S] 예비가격방식에 따른 예비가격작성프로그램 이용, 예비가격재작성여부, 예비가격암호화 여부 체크
            const objRelaValsForPnpr = this.gfnGetRelaValsForPnpr(dmInitComm.get("prcmMthoSeCd"), strPnprDcsnMthoCd);
            // 전자입찰
            if (keyValueMap.bidMthdCd == "입180002") {
                const strPnprDcsnMthoCdNm = "";

                if (keyValueMap.pnprPgmUseYn && objRelaValsForPnpr.pnprPgmUseYn.val && objRelaValsForPnpr.pnprPgmUseYn.disabled === false &&
                        keyValueMap.pnprPgmUseYn != objRelaValsForPnpr.pnprPgmUseYn.val) {
                    await com.gfnAlert(["msg.alert.pn.isDoWant", "전자입찰이고 " + strPnprDcsnMthoCdNm + "일 경우, 예비가격작성프로그램은 '" +
                                        (objRelaValsForPnpr.pnprPgmUseYn == "Y" ? "이용" : "별도산출") + "'을 선택"]);
                    await this.gfnSetFocus(objTabContOrGroup, "pnprPgmUseYn");
                    return false;
                }

                if (keyValueMap.pnprRwrtYn && objRelaValsForPnpr.pnprRwrtYn.val && objRelaValsForPnpr.pnprRwrtYn.disabled === false &&
                        keyValueMap.pnprRwrtYn != objRelaValsForPnpr.pnprRwrtYn.val) {
                    await com.gfnAlert(["msg.alert.pn.isDoWant", "전자입찰이고 " + strPnprDcsnMthoCdNm + "일 경우, 예비가격재작성여부는 '" +
                                        (objRelaValsForPnpr.pnprRwrtYn == "Y" ? "신규작성" : "재사용") + "'을 선택"]);
                    await this.gfnSetFocus(objTabContOrGroup, "pnprPgmUseYn");
                    return false;
                }
